    // ════════════════════════════════════════════════════════════
    //  NOTIFICATION AUTOMATIQUE — SÉANCE PLANIFIÉE
    //  Envoie un message dans la boîte de messagerie des étudiants
    //  de la classe ET du formateur dès qu'une séance est créée.
    // ════════════════════════════════════════════════════════════
    window._notifySeanceCreated = async function(seance) {
      try {
        if (!seance?.id) return

        const base = window.location.origin + window.location.pathname
        const pointageLien = `${base}?pointage=${seance.id}`
        const dateObj = seance.date_seance ? new Date(seance.date_seance + 'T00:00:00') : new Date()
        const dateStr = dateObj.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long', year:'numeric'})
        const heureStr = seance.heure_debut ? `à ${seance.heure_debut}` : ''
        const classeStr = seance.programme || seance.classe_nom || '—'
        const enseignantStr = seance.enseignant || '—'
        const sujetStr = seance.sujet || '—'

        const msgSujet = `📅 Séance planifiée — ${dateStr} — ${classeStr}`
        const msgContenu =
          `📣 NOUVELLE SÉANCE PLANIFIÉE\n\n` +
          `📚 Programme / Cours : ${sujetStr}\n` +
          `📅 Date : ${dateStr} ${heureStr}\n` +
          `🏫 Classe / Groupe : ${classeStr}\n` +
          `👨‍🏫 Formateur : ${enseignantStr}\n` +
          (seance.lien_meet ? `🔗 Lien de cours : ${seance.lien_meet}\n` : '') +
          `\n✅ LIEN DE POINTAGE (cliquez pour signer votre présence) :\n${pointageLien}\n\n` +
          `Bonne séance ! — AGTM Digital Academy`

        const senderNom = [profile?.prenom, profile?.nom].filter(Boolean).join(' ') || 'Administration AGTM'
        const senderRole = profile?.role || 'admin'

        // 1. Notifier tous les étudiants de la classe
        if (seance.classe_id) {
          const { data: inscriptions } = await sb.from('inscriptions_classes')
            .select('etudiant_id')
            .eq('classe_id', seance.classe_id)

          const etudIds = (inscriptions || []).map(i => i.etudiant_id).filter(Boolean)

          if (etudIds.length > 0) {
            const msgs = etudIds.map(eid => ({
              etudiant_id: eid,
              expediteur_role: senderRole,
              expediteur_nom: senderNom,
              sujet: msgSujet,
              contenu: msgContenu,
              lu: false,
            }))
            await sb.from('messages_etudiants').insert(msgs)
          }
        }

        // 2. Notifier le formateur (si différent de l'utilisateur courant)
        if (seance.enseignant) {
          // Chercher l'utilisateur par le nom dans la table utilisateurs (rôle formateur)
          const parts = seance.enseignant.trim().split(/\s+/)
          const lastName = parts[parts.length - 1] || ''
          const { data: fmtUsers } = await sb.from('utilisateurs')
            .select('id,nom,prenom,email')
            .eq('role', 'formateur')

          // Trouver le formateur par correspondance nom/prénom
          const fmtUser = (fmtUsers || []).find(u => {
            const fullName = ((u.prenom||'') + ' ' + (u.nom||'')).toLowerCase()
            return fullName.includes(lastName.toLowerCase()) || seance.enseignant.toLowerCase().includes((u.nom||'').toLowerCase())
          })

          if (fmtUser && fmtUser.id !== currentUser?.id) {
            await sb.from('messages').insert({
              expediteur_user_id: currentUser?.id || null,
              expediteur_nom: senderNom,
              expediteur_role: senderRole,
              destinataire_user_id: fmtUser.id,
              destinataire_nom: [fmtUser.prenom, fmtUser.nom].filter(Boolean).join(' '),
              destinataire_role: 'formateur',
              sujet: msgSujet,
              contenu: msgContenu,
              lu: false,
            })
          }
        }

        toast('📬 Notifications envoyées aux étudiants et formateur')
      } catch (e) {
        console.warn('⚠️ Notification séance échouée :', e)
      }
    }

