    // ══════════════════════════════════════════════════════════════
    // ── HELPER COPIE PRESSE-PAPIER ───────────────────────────────
    // execCommand d'abord (synchrone, fiable depuis un clic)
    // navigator.clipboard en fallback (async, HTTPS uniquement)
    window._copyLink = function(text, label) {
      const msg = label || 'Lien copié !'
      // 1. Tentative synchrone via textarea (fonctionne partout depuis un geste utilisateur)
      const ta = document.createElement('textarea')
      ta.value = text
      ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0;pointer-events:none'
      document.body.appendChild(ta)
      ta.focus(); ta.select()
      let copied = false
      try { copied = document.execCommand('copy') } catch(e) {}
      document.body.removeChild(ta)
      if (copied) { toast('✅ ' + msg); return }
      // 2. Fallback : API Clipboard moderne (HTTPS)
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(
          () => toast('✅ ' + msg),
          () => toast('⚠️ Impossible de copier automatiquement. Lien : ' + text.substring(0,70), 'err')
        )
      } else {
        toast('⚠️ Copiez manuellement : ' + text.substring(0,70), 'err')
      }
    }

    //  HELPER PDF — Overlay interne (aucun popup, aucun blocage)
    // ══════════════════════════════════════════════════════════════
    function _openPrintWin(html) {
      // Supprimer overlay précédent si existant
      const old = document.getElementById('_pdfOverlay')
      if (old) old.remove()
      const overlay = document.createElement('div')
      overlay.id = '_pdfOverlay'
      overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);z-index:99999;display:flex;flex-direction:column'
      overlay.innerHTML = `
        <div style="background:#0A1520;padding:10px 18px;display:flex;align-items:center;gap:12px;border-bottom:2px solid #C8960C;flex-shrink:0">
          <div style="width:34px;height:34px;background:#C8960C;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:.8rem;color:#0A1520">AGTM</div>
          <span style="color:#C8960C;font-weight:800;font-size:.9rem">Aperçu du document — AGTM Academy</span>
          <button id="_pdfPrintBtn" onclick="window._triggerPdfPrint()"
            style="padding:8px 20px;background:#C8960C;border:none;border-radius:8px;font-weight:800;cursor:pointer;color:#0A1520;font-size:.85rem">🖨️ Imprimer / Exporter PDF</button>
          <button onclick="document.getElementById('_pdfOverlay').remove()"
            style="margin-left:auto;padding:8px 16px;background:transparent;border:1.5px solid #E04A4A;border-radius:8px;color:#E04A4A;font-weight:700;cursor:pointer;font-size:.82rem">✕ Fermer</button>
        </div>
        <iframe id="_pdfFrame" style="flex:1;border:none;background:#fff"></iframe>`
      document.body.appendChild(overlay)

      // Injecter un listener postMessage dans le HTML pour déclencher l'impression
      // depuis l'intérieur de l'iframe (contourne les restrictions cross-frame)
      const printScript = `<script>window.addEventListener('message',function(e){if(e.data==='agtm_print')window.print();})<\/script>`
      const htmlWithListener = html.replace('</body>', printScript + '</body>')

      window._triggerPdfPrint = function() {
        const f = document.getElementById('_pdfFrame')
        if (f && f.contentWindow) f.contentWindow.postMessage('agtm_print', '*')
      }

      document.getElementById('_pdfFrame').srcdoc = htmlWithListener
    }

