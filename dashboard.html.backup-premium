    // ── Génération PDF rapport par période ───────────────────────
    window._printRapports = function(filtre, raps, seancesData) {
      const now  = new Date()
      const dow  = now.getDay() || 7
      const sw   = new Date(now); sw.setDate(now.getDate()-dow+1)
      const ew   = new Date(sw);  ew.setDate(sw.getDate()+6)
      const sm   = new Date(now.getFullYear(), now.getMonth(), 1)
      const em   = new Date(now.getFullYear(), now.getMonth()+1, 0)
      const iso  = d => d.toISOString().substring(0,10)
      const fmtD = s => { try { return new Date(s+'T00:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'}) } catch(e){return s} }

      let filtered = raps, periodeLabel = 'Tous les rapports', sw2='', ew2=''
      let totalSeances=0, realises=0, planifies=0

      if (filtre==='semaine') {
        sw2=iso(sw); ew2=iso(ew)
        filtered = raps.filter(r=>r.date>=sw2&&r.date<=ew2)
        periodeLabel = `Semaine du ${fmtD(sw2)} au ${fmtD(ew2)}`
        const ws = (seancesData||[]).filter(s=>s.d>=sw2&&s.d<=ew2)
        totalSeances=ws.length; realises=ws.filter(s=>s.st==='Réalisée').length; planifies=ws.filter(s=>s.st==='Planifiée').length
      } else if (filtre==='mois') {
        sw2=iso(sm); ew2=iso(em)
        filtered = raps.filter(r=>r.date>=sw2&&r.date<=ew2)
        periodeLabel = now.toLocaleDateString('fr-FR',{month:'long',year:'numeric'})
        const ms = (seancesData||[]).filter(s=>s.d>=sw2&&s.d<=ew2)
        totalSeances=ms.length; realises=ms.filter(s=>s.st==='Réalisée').length; planifies=ms.filter(s=>s.st==='Planifiée').length
      } else {
        totalSeances=(seancesData||[]).length
        realises=(seancesData||[]).filter(s=>s.st==='Réalisée').length
        planifies=(seancesData||[]).filter(s=>s.st==='Planifiée').length
      }

      const printDate = now.toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})
      const byFmt = {}
