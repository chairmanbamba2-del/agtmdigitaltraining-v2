              .order('date_seance',{ascending:false}).limit(20),
            sb.from('presences')
              .select('present,seance_id')
              .gte('created_at', ws + 'T00:00:00').limit(500),
          ])

          // Séances semaine
          const seances = seancesRes.data || []
          if (seances.length) {
            const realises = seances.filter(s => s.statut === 'Réalisée').length
            const non = seances.length - realises
            lines.push(`SEANCES SEMAINE (${ws} au ${we}) : ${seances.length} total — ${realises} réalisées, ${non} non réalisées`)
            seances.forEach(s => {
              const cls = s.classes?.nom || `Classe #${s.classe_id}`
              const h = s.heure_debut ? ` ${s.heure_debut}` : ''
              const statut = s.statut === 'Réalisée' ? '✓' : '✗'
              lines.push(`  ${statut} ${s.date_seance}${h} | ${s.sujet||'Séance'} | ${cls} | ${s.enseignant||''} | Statut: ${s.statut||'Planifiée'}`)
            })
            lines.push('')
          } else {
            lines.push(`SEANCES SEMAINE (${ws} au ${we}) : Aucune séance planifiée\n`)
          }

          // Échéances en retard
          const echs = echsRes.data || []
          const retards = echs.filter(e => e.statut === 'En retard')
          const prochaines = echs.filter(e => e.statut === 'En attente')
          if (retards.length) {
            lines.push(`ECHEANCES EN RETARD : ${retards.length}`)
            retards.forEach(e => {
              const nom = e.etudiants ? `${e.etudiants.prenom} ${e.etudiants.nom}` : `Etudiant #${e.etudiant_id||'?'}`
              lines.push(`  ⚠ ${nom} : ${(e.montant||0).toLocaleString('fr-FR')} FCFA — était dû le ${e.date_echeance}`)
            })
            lines.push('')
          }
          if (prochaines.length) {
            lines.push(`ECHEANCES A VENIR (7 jours) : ${prochaines.length}`)
            prochaines.forEach(e => {
              const nom = e.etudiants ? `${e.etudiants.prenom} ${e.etudiants.nom}` : `Etudiant #${e.etudiant_id||'?'}`
              lines.push(`  → ${nom} : ${(e.montant||0).toLocaleString('fr-FR')} FCFA — dû le ${e.date_echeance}`)
            })
            lines.push('')
          }
          if (!retards.length && !prochaines.length) {
            lines.push('ECHEANCES : Aucune échéance en retard ni à venir dans les 7 jours\n')
          }

          // Devoirs à rendre prochainement (filter à partir d'aujourd'hui)
          const devoirsAVenir = (devoirsRes.data || []).filter(d => d.date_rendu >= todayStr)
          if (devoirsAVenir.length) {
            lines.push(`DEVOIRS A RENDRE PROCHAINEMENT : ${devoirsAVenir.length}`)
            devoirsAVenir.slice(0,10).forEach(d => {
              const cls = d.classes?.nom || `Classe #${d.classe_id}`
              lines.push(`  → ${cls} — à rendre le ${d.date_rendu} [${d.statut||'En attente'}]`)
            })
            lines.push('')
          }

          // Recettes du mois
          const paies = paiementsRes.data || []
          if (paies.length) {
            const totalMois = paies.reduce((s,p)=>s+(p.montant||0),0)
            lines.push(`RECETTES CE MOIS : ${totalMois.toLocaleString('fr-FR')} FCFA (${paies.length} paiements)\n`)
          }

          // Rapports de séances soumis cette semaine
          const rapports = rapportsRes.data || []
          if (rapports.length) {
            const totPres = rapports.reduce((s,r) => s+(r.nb_presents||0), 0)
            const totAbs  = rapports.reduce((s,r) => s+(r.nb_absents_non_justifies||0), 0)
            lines.push(`RAPPORTS SÉANCES SEMAINE : ${rapports.length} rapport(s) soumis — ${totPres} présents, ${totAbs} absents NJ`)
            rapports.slice(0,5).forEach(r => {
              lines.push(`  ${r.date_seance} | ${r.classe_nom||'—'} | ${r.formateur_nom||'—'} | Présents: ${r.nb_presents||0}`)
            })
            lines.push('')
          } else {
            lines.push(`RAPPORTS SÉANCES SEMAINE : Aucun rapport soumis cette semaine\n`)
          }

          // Devoirs — résumé statut
          const devs = devoirsRes.data || []
          if (devs.length) {
            const dSoumis = devs.filter(d=>d.statut==='Soumis').length
            const dCorr   = devs.filter(d=>d.statut==='Corrigé').length
            const dAtt    = devs.filter(d=>d.statut==='En attente').length
            lines.push(`DEVOIRS (30 derniers) : ${devs.length} total — ${dAtt} en attente, ${dSoumis} soumis (à corriger), ${dCorr} corrigés\n`)
          }

          // Présences semaine — taux global
          const pres = presencesRes.data || []
          if (pres.length) {
            const nbPres = pres.filter(p=>Number(p.present)===1).length
            const taux   = Math.round(nbPres/pres.length*100)
            lines.push(`PRESENCES SEMAINE : ${pres.length} enregistrements — Taux global : ${taux}% (${nbPres} présents, ${pres.length-nbPres} absents)\n`)
          }

          ctx.has_data = true

        } else if (role === 'formateur') {
          // Chercher les classes du formateur puis ses séances
          const {data:mes_classes} = await sb.from('classes').select('id,nom').eq('formateur_id', currentUser?.id)
          if (mes_classes?.length) {
            const ids = mes_classes.map(c=>c.id)
            const {data:seances} = await sb.from('seances')
              .select('date_seance,heure_debut,heure_fin,sujet,statut,classe_id,classes(nom)')
              .in('classe_id', ids).gte('date_seance', ws).lte('date_seance', we)
              .order('date_seance').order('heure_debut').limit(20)
            if (seances?.length) {
              const r = seances.filter(s=>s.statut==='Réalisée').length
              lines.push(`MES SEANCES SEMAINE (${ws} au ${we}) : ${seances.length} — ${r} réalisées, ${seances.length-r} non réalisées`)
              seances.forEach(s => {
                const cls = s.classes?.nom || `Classe #${s.classe_id}`
                const h = s.heure_debut ? ` ${s.heure_debut}` : ''
                const statut = s.statut === 'Réalisée' ? '✓' : '✗'
                lines.push(`  ${statut} ${s.date_seance}${h} | ${s.sujet||'Séance'} | ${cls} | ${s.statut||'Planifiée'}`)
              })
              lines.push('')
              ctx.has_data = true
            }
          }

        } else if (role === 'etudiant') {
          // Devoirs de l'étudiant
          const {data:devoirs} = await sb.from('devoirs')
            .select('date_rendu,classe_id,classes(nom)')
            .eq('etudiant_id', currentUser?.id).gte('date_rendu', todayStr)
            .order('date_rendu').limit(5)
          if (devoirs?.length) {
            lines.push(`MES DEVOIRS A RENDRE :`)
            devoirs.forEach(d => {
              const cls = d.classes?.nom || `Classe #${d.classe_id}`
              lines.push(`  → ${cls} — à rendre le ${d.date_rendu}`)
            })
            lines.push('')
            ctx.has_data = true
          }
        }

        if (ctx.has_data) ctx.text = lines.join('\n')
      } catch(e) {
        console.error('School context error:', e)
      }
      return ctx
    }

