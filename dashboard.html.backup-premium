                <div style="display:flex;gap:5px;align-items:center;flex-shrink:0">
                  <span style="padding:2px 8px;background:#1A3A1A;border:1px solid #4AE090;border-radius:10px;font-size:.6rem;color:#4AE090">Envoyé ✓</span>
                  ${accuse ? `<span title="Accusé le ${accuseAt}" style="padding:2px 8px;background:#1A2A1A;border:1px solid #4AE090;border-radius:10px;font-size:.6rem;color:#4AE090">👁 Accusé ✓</span>` : ''}
