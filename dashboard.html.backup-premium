                style="width:100%;padding:9px 12px;border-radius:8px;background:#0D1B2A;border:1.5px solid #2A3F58;color:#E2D8C0;font-size:.82rem;outline:none">
            </div>
            <div>
              <label style="display:block;font-size:.72rem;color:#8AAAC0;margin-bottom:5px;font-weight:600">📅 Au</label>
              <input type="date" id="rchDateMax" value="${st.dateMax}"
                style="width:100%;padding:9px 12px;border-radius:8px;background:#0D1B2A;border:1.5px solid #2A3F58;color:#E2D8C0;font-size:.82rem;outline:none">
