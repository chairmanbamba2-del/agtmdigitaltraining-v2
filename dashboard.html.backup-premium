      // Étape 2 : récupérer le reste en parallèle (on connaît maintenant le nom)
      const nomComplet = `${e.prenom||''} ${e.nom||''}`.trim()
      const [
        {data:plans},
        {data:echs},
        {data:allPais},
        {data:inscClasses},
        {data:evalLigne},
        {data:personnelFmt},
      ] = await Promise.all([
        sb.from('plans_paiement').select('*').eq('etudiant_id',etudiantId).order('created_at',{ascending:false}).limit(1),
        sb.from('echeances').select('*').eq('etudiant_id',etudiantId).order('date_echeance'),
        sb.from('paiements').select('montant,date_paiement,type_paiement,mode_paiement').eq('etudiant_id',etudiantId).order('date_paiement'),
        sb.from('inscriptions_classes').select('*,classes(id,nom,niveau,horaire,formateur_nom,programme)').eq('etudiant_id',etudiantId).order('id'),
        sb.from('soumissions_evaluations').select('score,score_max,niveau,created_at').eq('etudiant_nom',nomComplet).order('created_at',{ascending:false}).limit(1),
        sb.from('personnel').select('id,nom,prenom,cin,poste').or('poste.eq.Formateur,poste.eq.Enseignant').order('id'),
      ])

      const fmt = n => Number(n||0).toLocaleString('fr-FR')+' FCFA'
      const fmtD = d => d ? new Date(d).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'}) : '—'

      // Financial summary
      const plan = plans&&plans.length ? plans[0] : null
      const coutTotal = plan ? Number(plan.total_formation||0) : 0
      const totalPaye = (allPais||[]).reduce((s,p)=>s+(Number(p.montant)||0),0)
      const restePayer = Math.max(0, coutTotal - totalPaye)
      const pct = coutTotal>0 ? Math.min(100,Math.round(totalPaye/coutTotal*100)) : 0

      // Classes & formateurs
      const classes = (inscClasses||[]).map(ic=>ic.classes).filter(Boolean)
      const formateurNom = classes.length && classes[0].formateur_nom
