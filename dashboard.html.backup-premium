              </div>
              <div>
                <label style="display:block;font-size:.68rem;font-weight:700;color:#90A4AE;text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px">Confirmer le mot de passe</label>
                <input id="secConfPass" type="password" placeholder="Répéter le mot de passe" style="width:100%;padding:10px 13px;border-radius:8px;background:#0D1B2A;border:1.5px solid #2A3F58;color:#fff;font-size:.85rem;outline:none;box-sizing:border-box" onfocus="this.style.borderColor='#4A90D9'" onblur="this.style.borderColor='#2A3F58'"/>
              </div>
              <div>
                <button onclick="window._changePassword()" style="padding:10px 24px;border-radius:9px;background:#4A90D9;border:none;color:#fff;font-weight:800;font-size:.82rem;cursor:pointer">
