          <div style="font-size:1.8rem">🎓</div>
          <div style="flex:1;min-width:200px">
            <div style="font-size:.85rem;font-weight:800;color:#E8B84B">Test de Placement — Lien Public</div>
            <div style="font-size:.72rem;color:#7A9AB0;margin-top:3px;font-family:monospace;word-break:break-all">${_placUrl}</div>
