      const wrapper = document.getElementById('notifWrapper')
      if (wrapper && !wrapper.contains(e.target)) window._closeNotifPanel()
    })

    window._loadNotifications = async function() {
      const list = document.getElementById('notifList')
      if (!list) return
      const role = profile?.role
      const items = []
      const today = new Date().toISOString().substring(0,10)
      const tomorrow = new Date(Date.now()+86400000).toISOString().substring(0,10)

      try {
        // Messages non lus
        if (role === 'etudiant') {
          const etud = await _getEtudProfil('id,nom,prenom')
          if (etud?.id) {
            const {data:msgs} = await sb.from('messages_etudiants')
              .select('id,objet,expediteur,created_at,lu')
              .eq('etudiant_id', etud.id)
              .eq('lu', false)
              .order('created_at', {ascending:false})
              .limit(5)
            ;(msgs||[]).forEach(m => items.push({
              icon:'💬', col:'#4A90D9',
              title: m.objet || 'Nouveau message',
              sub: `De : ${m.expediteur||'Admin'} · ${m.created_at?.substring(0,10)||''}`,
              action: `navigateTo('mes_messages');window._closeNotifPanel()`
            }))

            // Séances à venir aujourd'hui ou demain
            const {data:inscs} = await sb.from('inscriptions_classes').select('classe_id').eq('etudiant_id', etud.id).order('id')
            const cids = (inscs||[]).map(i=>i.classe_id).filter(Boolean)
            if (cids.length) {
              const {data:seances} = await sb.from('seances')
                .select('id,sujet,date_seance,heure_debut,classe_id')
                .in('classe_id', cids)
                .gte('date_seance', today)
                .lte('date_seance', tomorrow)
                .order('date_seance')
              ;(seances||[]).slice(0,3).forEach(s => items.push({
                icon:'📅', col:'#C8960C',
                title: s.sujet || 'Séance à venir',
                sub: `${s.date_seance === today ? 'Aujourd\'hui' : 'Demain'}${s.heure_debut?' à '+s.heure_debut:''}`,
                action: `navigateTo('mes_seances');window._closeNotifPanel()`
              }))
            }

            // Devoirs en attente
            const {data:devoirs} = await sb.from('devoirs').select('id,titre,date_rendu').eq('email', currentUser.email).eq('statut','En attente').order('date_rendu').limit(3)
            ;(devoirs||[]).forEach(d => items.push({
              icon:'📤', col:'#9B59B6',
              title: d.titre || 'Devoir à rendre',
              sub: d.date_rendu ? `Date limite : ${d.date_rendu}` : 'Sans date limite',
              action: `navigateTo('devoir');window._closeNotifPanel()`
            }))
          }
        } else {
          // Admin/formateur/secrétaire : messages non lus
          const {data:msgs} = await sb.from('messages')
            .select('id,objet,expediteur_nom,created_at,lu')
            .eq('destinataire_user_id', currentUser.id)
            .eq('lu', false)
            .order('created_at', {ascending:false})
            .limit(6)
          ;(msgs||[]).forEach(m => items.push({
            icon:'💬', col:'#4A90D9',
            title: m.objet || 'Nouveau message',
            sub: `De : ${m.expediteur_nom||'Inconnu'} · ${m.created_at?.substring(0,10)||''}`,
            action: `navigateTo('messagerie');window._closeNotifPanel()`
          }))

          // Séances du jour pour admin/formateur
          const todaySeances = role === 'formateur'
            ? await sb.from('seances').select('id,sujet,heure_debut,enseignant').eq('date_seance', today).order('heure_debut').limit(5)
            : await sb.from('seances').select('id,sujet,heure_debut').eq('date_seance', today).order('heure_debut').limit(5)
          ;(todaySeances.data||[]).forEach(s => items.push({
            icon:'📅', col:'#4AE090',
            title: s.sujet || 'Séance aujourd\'hui',
            sub: s.heure_debut ? `Aujourd'hui à ${s.heure_debut}` : 'Aujourd\'hui',
            action: `navigateTo('planning');window._closeNotifPanel()`
          }))
        }
      } catch(e) { /* silently fail */ }

      // Update dot
      const dot = document.getElementById('notifDot')
      if (dot) dot.style.display = items.length ? 'block' : 'none'

      list.innerHTML = items.length
        ? items.map(it => `
          <div onclick="${it.action}" style="padding:11px 16px;cursor:pointer;border-bottom:1px solid #0D1B2A;display:flex;gap:10px;align-items:flex-start;transition:background .12s"
            onmouseover="this.style.background='rgba(74,144,217,0.06)'" onmouseout="this.style.background='none'">
            <div style="width:32px;height:32px;border-radius:50%;background:${it.col}18;border:1px solid ${it.col}35;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0">${it.icon}</div>
