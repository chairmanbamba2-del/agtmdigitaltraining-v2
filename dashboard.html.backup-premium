        toast('⚠️ Aucun code défini. Veuillez en définir un dans Paramètres → Sécurité.')
        await _finPerso()
        return
      }
      const hash = await _fpHash(entered)
      if (hash === stored) {
        window._fpUnlocked = true
        await _finPerso()
      } else {
        const errEl = document.getElementById('fpCodeErr')
        if (errEl) errEl.style.display = 'block'
        if (input) { input.value = ''; input.focus() }
      }
    }

