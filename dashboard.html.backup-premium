                  style="padding:5px 14px;border-radius:7px;background:rgba(37,211,102,0.12);border:1px solid rgba(37,211,102,0.4);color:#25D366;font-weight:700;font-size:.72rem;cursor:pointer">
                  ↩ Répondre
                </button>
              </div>
            </div>`
          }).join('')

