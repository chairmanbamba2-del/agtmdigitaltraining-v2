    //  VALIDATION DIRECTION + CALCUL HONORAIRES
    // ════════════════════════════════════════════════════════════
    // ── Helper : calculer et upsert honoraires pour une séance ──
    window._calcHonoraires = async function(seanceId, tarifOverride) {
      const [{data:seance},{data:presences}] = await Promise.all([
        sb.from('seances').select('*').eq('id',seanceId).single(),
        sb.from('presences').select('id,etudiant_id,present,justifie').eq('seance_id',seanceId),
      ])
      if (!seance) { toast('Séance introuvable','err'); return null }

      // Tarif : override > classe > défaut
      let tarif_type = tarifOverride || 'anglais_general'
      let classe_nom = seance.programme || ''
      if (!tarifOverride && seance.classe_id) {
        const {data:cl} = await sb.from('classes').select('nom,tarif_type').eq('id',seance.classe_id).maybeSingle()
        if (cl) { tarif_type = cl.tarif_type || 'anglais_general'; classe_nom = cl.nom || classe_nom }
      }
      const tarif_unitaire = tarif_type === 'anglais_pro' ? 1875 : 1500

      const pres        = presences||[]
      if (!pres.length) {
        toast('⚠️ Aucune présence enregistrée pour cette séance — faites d\'abord le pointage.', 'err')
        return null
      }
      const nbPresents  = pres.filter(p=>p.present===1||p.present===true).length
      const nbAbsNJ     = pres.filter(p=>!p.present&&!p.justifie).length
      const nbAbsJ      = pres.filter(p=>!p.present&&p.justifie).length
      const mPresents   = nbPresents * tarif_unitaire
      const mAbsNJ      = nbAbsNJ   * tarif_unitaire * 0.5
      const montantTotal = mPresents + mAbsNJ

      // Chercher formateur_id : personnel.email → utilisateurs.id (match exact sur prenom+nom)
      let formateur_id = null
      if (seance.enseignant) {
        const nomComplet = seance.enseignant.trim()
        // 1) Chercher dans personnel par nom complet (prenom nom ou nom prenom)
        const {data:persRows} = await sb.from('personnel').select('email,prenom,nom')
        const pers = (persRows||[]).find(p =>
          `${p.prenom} ${p.nom}`.toLowerCase() === nomComplet.toLowerCase() ||
          `${p.nom} ${p.prenom}`.toLowerCase() === nomComplet.toLowerCase()
        )
        if (pers?.email) {
          const {data:u} = await sb.from('utilisateurs').select('id').eq('email', pers.email).maybeSingle()
          formateur_id = u?.id || null
        }
        // 2) Fallback : utilisateurs par nom complet
        if (!formateur_id) {
          const {data:uRows} = await sb.from('utilisateurs').select('id,prenom,nom')
          const u2 = (uRows||[]).find(u =>
            `${u.prenom} ${u.nom}`.toLowerCase() === nomComplet.toLowerCase() ||
            `${u.nom} ${u.prenom}`.toLowerCase() === nomComplet.toLowerCase()
          )
          formateur_id = u2?.id || null
        }
      }

      const visaPar = `${profile?.prenom||''} ${profile?.nom||''}`.trim() || profile?.email
      const {error:he} = await sb.from('honoraires_formateurs').upsert({
        seance_id:            seanceId,
        formateur_id,
        formateur_nom:        seance.enseignant||'',
        classe_id:            seance.classe_id||null,
        classe_nom,
        date_seance:          seance.date_seance,
        tarif_type,
        tarif_unitaire,
        nb_presents:          nbPresents,
        nb_absents_nj:        nbAbsNJ,
        nb_absents_justifies: nbAbsJ,
        montant_presents:     mPresents,
        montant_absents_nj:   mAbsNJ,
        montant_total:        montantTotal,
        statut:               'valide',
        valide_par:           visaPar,
        valide_par_user_id:   currentUser?.id,
        valide_at:            new Date().toISOString(),
      }, {onConflict:'seance_id'})
      if (he) { toast('Erreur honoraires : '+he.message,'err'); return null }
      return { tarif_type, tarif_unitaire, nbPresents, nbAbsNJ, nbAbsJ, montantTotal }
    }

    window._validerSeanceDirection = async function(seanceId) {
      const isDirOrAdmin = profile?.role==='directeur_pedagogique'||profile?.role==='sous_directeur_pedagogique'||profile?.role==='admin'
      if (!isDirOrAdmin) { toast('⛔ Accès réservé à la Direction Pédagogique','err'); return }

      setContent(skeletonKpi(3) + skeletonTable(4,4))

      const result = await window._calcHonoraires(seanceId)
      if (!result) return

      const visaPar = `${profile?.prenom||''} ${profile?.nom||''}`.trim() || profile?.email
      const {error:se} = await sb.from('seances').update({
        statut:             'Réalisée',
        vise_par_direction: true,
        visa_par:           visaPar,
        visa_par_user_id:   currentUser?.id,
        visa_at:            new Date().toISOString(),
      }).eq('id', seanceId)
      if (se) { toast('Erreur séance : '+se.message,'err'); return }

      _cache.bust('rh_seances')
      const tarifLabel = result.tarif_type==='anglais_pro' ? 'Anglais Pro (1 875 FCFA)' : 'Anglais Général (1 500 FCFA)'
      toast(`✅ Séance validée ! ${result.montantTotal.toLocaleString('fr-FR')} FCFA — ${tarifLabel} · ${result.nbPresents} présent(s)`)
      // Revenir à la section courante (Séances ou Direction Pédagogique)
      const cur = window._navCurrentSectionId
      if (cur === 'seances') renderSeances()
      else renderDirectionPedagogique()
    }

