        </div>`}

        <!-- Séances à venir -->
        <div style="margin-bottom:24px">
          <div style="font-weight:800;color:#C8960C;font-size:.92rem;margin-bottom:12px;display:flex;align-items:center;gap:8px">
            📅 Prochaines séances
            <span style="font-size:.72rem;color:#5A7090;font-weight:400">(${seancesAvenirFinal.length} planifiée(s))</span>
          </div>
          ${seancesAvenirFinal.length
            ? seancesAvenirFinal.map(s=>seanceCard(s,true)).join('')
