        sb.from('seances').select('*').order('date_seance',{ascending:false}).limit(200),
        sb.from('etudiants').select('id,nom,prenom,niveau').order('id').order('nom'),
        sb.from('presences').select('*').limit(5000),
        sb.from('classes').select('*').order('nom'),
        sb.from('inscriptions_classes').select('*'),
      ])

      // ── KPIs globaux ─────────────────────────────────────────
      const totalPres=(pres||[]).filter(p=>Number(p.present)===1).length
      const totalAbs =(pres||[]).filter(p=>Number(p.present)===0).length
      const total=totalPres+totalAbs
      const tauxMoyen=total?Math.round(totalPres/total*100):0
      const seancesCouvertes=[...new Set((pres||[]).map(p=>p.seance_id))].length

      // ── Stats par étudiant ────────────────────────────────────
      const statsMap={}
      ;(pres||[]).forEach(p=>{
        if(!statsMap[p.etudiant_id])statsMap[p.etudiant_id]={total:0,presents:0}
