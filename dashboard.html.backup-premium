    window._savePersonnel = async function() {
      const prenom=document.getElementById('pPren').value.trim()
      const nom=document.getElementById('pNom').value.trim()
      const poste=document.getElementById('pPoste').value
      const type_contrat=document.getElementById('pContrat').value
      const date_embauche=document.getElementById('pEmb').value||null
      const date_fin_contrat=document.getElementById('pFin').value||null
      const salaire_base=parseFloat(document.getElementById('pSal').value)||0
      const taux_seance=parseFloat(document.getElementById('pTaux').value)||0
      const telephone=document.getElementById('pTel').value.trim()||null
      const email=document.getElementById('pEmail').value.trim()||null
      const cin=document.getElementById('pCin').value.trim()||null
      const adresse=document.getElementById('pAdr').value.trim()||null
      const notes=document.getElementById('pNotes').value.trim()||null
      if(!prenom||!nom){toast('Prénom et Nom obligatoires','err');return}
      if(!poste){toast('Poste obligatoire','err');return}
      // Matricule saisi ou auto-généré après insertion
      const matriculeSaisi=document.getElementById('pMatricule')?.value.trim()||null
      const {data:inserted,error}=await sb.from('personnel').insert({prenom,nom,poste,type_contrat,date_embauche,date_fin_contrat,salaire_base,taux_seance,telephone,email,cin,adresse,notes}).select('id').single()
      if(!error && inserted?.id && !matriculeSaisi){
        await sb.from('personnel').update({matricule:'MAT-'+inserted.id}).eq('id',inserted.id)
      } else if(!error && inserted?.id && matriculeSaisi){
        await sb.from('personnel').update({matricule:matriculeSaisi}).eq('id',inserted.id)
      }
      if(error){toast('Erreur : '+error.message,'err');return}
      _cache.bust('personnel_fmts','rh_seances')
      toast('✅ Employé enregistré')
      renderRH()
    }

    window._rhChangeStatut = async function(id, statut, sel) {
