    window._openPointageLink = function(seanceId) {
      renderPointageInline(seanceId)
    }

    window._copyPointageLink = function(seanceId, sujet) {
      const base = window.location.origin + window.location.pathname
      const lien = `${base}?pointage=${seanceId}`
      navigator.clipboard.writeText(lien).then(()=>{
        toast(`🔗 Lien pointage copié !\n${sujet}`)
      }).catch(()=>{
        // fallback
        const ta = document.createElement('textarea')
        ta.value = lien
        document.body.appendChild(ta)
        ta.select()
        document.execCommand('copy')
        document.body.removeChild(ta)
        toast(`🔗 Lien copié — partagez-le aux apprenants`)
      })
    }

    window._saveSéance = async function() {
      const date=document.getElementById('sD').value
      const sujet=document.getElementById('sS').value.trim()
      if(!date||!sujet){toast('Date et sujet sont obligatoires','err');return}
      const classeId=Number(document.getElementById('sClasse')?.value)||null
      const format=document.getElementById('sFmt')?.value||'Groupe en ligne'
      const programme=document.getElementById('sProg')?.value||'Général'
      const {data:newSeancePeda, error}=await sb.from('seances').insert({
        date_seance:date,
        heure_debut:document.getElementById('sH').value||null,
        sujet, titre:sujet,
        enseignant:document.getElementById('sEns').value.trim()||[profile.prenom,profile.nom].filter(Boolean).join(' ')||null,
        notes:document.getElementById('sNotes')?.value.trim()||null,
        statut:document.getElementById('sSt').value,
        classe_id:classeId, format, programme,
      }).select().single()
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('✅ Séance enregistrée')
      // ── Notification automatique aux étudiants et formateur ──
      if (newSeancePeda) await window._notifySeanceCreated(newSeancePeda)
      renderPedagogie()
    }

    window._markSeanceOk = async function(id) {
      const isDirP = profile?.role==='directeur_pedagogique'||profile?.role==='sous_directeur_pedagogique'||profile?.role==='admin'||profile?.role==='secretaire'
      if (!isDirP) {
        const {data:s} = await sb.from('seances').select('vise_par_direction,visa_par').eq('id',id).single()
        if (s?.vise_par_direction) {
          toast(`🔐 Modification bloquée — séance visée par ${s.visa_par||'la Direction'}`, 'err')
          return
        }
      }
      const {error}=await sb.from('seances').update({statut:'Réalisée'}).eq('id',id)
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('✅ Séance marquée Réalisée')
      renderPedagogie()
    }

    window._delSeance = async function(id) {
      // Vérifier si la séance est visée par la direction
      const {data:s} = await sb.from('seances').select('vise_par_direction,visa_par').eq('id',id).single()
      if (s?.vise_par_direction) {
        toast(`🔐 Suppression bloquée — séance visée par ${s.visa_par||'la Direction Pédagogique'}`, 'err')
        return
      }
      if(!confirm('Supprimer cette séance ?')) return
      // Supprimer les honoraires associés avant la séance
      await sb.from('honoraires_formateurs').delete().eq('seance_id', id)
      const {error}=await sb.from('seances').delete().eq('id',id)
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('Séance supprimée')
      renderPedagogie()
    }

    window._annulerSeance = async function(id) {
      const {data:s} = await sb.from('seances').select('vise_par_direction,visa_par,statut').eq('id',id).single()
      if (s?.vise_par_direction) {
        toast(`🔐 Action bloquée — séance visée par ${s.visa_par||'la Direction Pédagogique'}`, 'err')
        return
      }
      if (s?.statut === 'Annulée') { toast('⚠️ Séance déjà annulée', 'warn'); return }
      if(!confirm('Annuler cette séance ? Les honoraires associés seront supprimés.')) return
      await sb.from('honoraires_formateurs').delete().eq('seance_id', id)
      const {error}=await sb.from('seances').update({statut:'Annulée'}).eq('id',id)
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('❌ Séance annulée — honoraires supprimés')
      renderPedagogie()
    }

    // ── Onglet 2 : PRÉSENCES & ABSENCES ─────────────────────────
    async function _pedaPresences() {
