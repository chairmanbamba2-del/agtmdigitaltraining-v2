              <div style="font-size:.78rem;color:#B0C4D8;line-height:1.55;white-space:pre-wrap">${m.contenu||''}</div>
              ${m.reponse_contenu ? `<div style="margin-top:10px;padding:10px 14px;background:rgba(74,224,144,.06);border:1px solid rgba(74,224,144,.2);border-radius:8px;font-size:.74rem;color:#4AE090">
                <span style="font-weight:700">Votre réponse :</span> ${m.reponse_contenu}
              </div>` : ''}
            </div>`
          }).join('')

          // Nouveaux messages (table `messages`)
          const newCards = recusNew.map(m => _msgCard(m, false)).join('')

          recusHTML = `
            <div style="font-weight:700;color:#4A90D9;font-size:.82rem;margin-bottom:10px">
              📥 Messages reçus (${recusNew.length + recusOld.length})
              ${totalNonLus ? `<span style="margin-left:8px;padding:2px 8px;background:#C8960C;border-radius:10px;font-size:.65rem;color:#0D1B2A;font-weight:800">${totalNonLus} non lu${totalNonLus>1?'s':''}</span>` : ''}
            </div>
            ${(newCards + oldCards) || `<div style="text-align:center;padding:22px;color:#5A7090;background:#0D1B2A;border-radius:10px;border:1px solid #1E3050;font-size:.8rem">Aucun message reçu pour l'instant.</div>`}`
        }

        // ─── Contenu onglet Envoyés ───────────────────────────────
        let envoyesHTML = ''
        if (tab === 'envoyes') {
          // Messages envoyés (nouvelle table)
          const envCards = envoyes.map(m => _msgCard(m, true)).join('')
          // Messages envoyés via l'ancienne table (messages_etudiants expéditeur = role)
          const { data: oldEnv } = await sb.from('messages_etudiants').select('*')
            .eq('expediteur_role', uRole).order('created_at', {ascending:false})
          const oldEnvCards = (oldEnv||[]).map(m => {
            const dateStr  = _msgDateStr(m.created_at)
            const accuse   = m.accuse_reception
            const accuseAt = accuse && m.accuse_reception_at ? _msgDateStr(m.accuse_reception_at) : ''
            return `<div style="background:#152233;border:1px solid #1A3A2A;border-radius:12px;padding:14px 16px;margin-bottom:8px">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:8px">
                <div style="flex:1">
                  <div style="font-weight:700;color:#90A4AE;font-size:.85rem">${m.sujet||'—'}</div>
                  <div style="font-size:.68rem;color:#5A7090;margin-top:3px">
                    <span style="color:#4AE090">→ ${m.etudiant_nom||'Étudiant #'+(m.etudiant_id||'?')}</span> &nbsp;· ${dateStr}
