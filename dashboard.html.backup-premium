    window._loadMesFormations = async function(etudiantId) {
      const cont = document.getElementById('mesFormationsGrid')
      if (!cont) return
      const {data: inscs} = await sb
        .from('inscriptions_classes')
        .select('classe_id,statut,classes(id,nom,niveau,horaire,formateur_nom,quota_seances,description)')
        .eq('etudiant_id', etudiantId)
        .order('created_at', {ascending: false})

      if (!inscs || !inscs.length) {
        cont.innerHTML = `<div style="color:#5A7090;font-size:.8rem;padding:24px;text-align:center;grid-column:1/-1;background:rgba(21,37,64,0.4);border-radius:12px;border:1px solid rgba(200,150,12,0.1)">
          Aucune formation inscrite. Contactez l'administration.
        </div>`
        return
      }

      const classeIds = inscs.map(i=>i.classe_id).filter(Boolean)
      const {data: presData} = await sb
        .from('presences')
        .select('seance_id,present,seances(classe_id)')
        .eq('etudiant_id', etudiantId)
        .eq('present', 1)

      const presCountMap = {}
      ;(presData||[]).forEach(p => {
        const cid = p.seances?.classe_id
        if (cid) presCountMap[cid] = (presCountMap[cid]||0) + 1
      })

      const today = new Date().toISOString().substring(0,10)
      const upcomingResult = classeIds.length ? await sb
        .from('seances')
        .select('classe_id,date_seance,heure_debut,sujet')
        .in('classe_id', classeIds)
        .gte('date_seance', today)
        .order('date_seance')
        .limit(50)
        : {data:[]}
      const upcomingSeances = upcomingResult.data || []

      const nextSeanceMap = {}
      upcomingSeances.forEach(s => {
        if (!nextSeanceMap[s.classe_id]) nextSeanceMap[s.classe_id] = s
      })

      const colPalette = ['#4A90D9','#C8960C','#4AE090','#9B59B6','#E04A4A','#E8B84B']

      cont.innerHTML = inscs.map((insc, idx) => {
        const cl = insc.classes || {}
        const quota = cl.quota_seances || 24
        const done = presCountMap[insc.classe_id] || 0
        const pct = Math.min(100, Math.round(done/quota*100))
        const col = colPalette[idx % colPalette.length]
        const pctCol = pct >= 100 ? '#4AE090' : pct >= 75 ? '#C8960C' : col
        const next = nextSeanceMap[insc.classe_id]
        const statBadge = insc.statut === 'Actif'
          ? '<span style="font-size:.6rem;background:#1A3A1A;color:#4AE090;padding:1px 6px;border-radius:4px;font-weight:700">✅ Actif</span>'
          : '<span style="font-size:.6rem;background:#2A1A1A;color:#E04A4A;padding:1px 6px;border-radius:4px;font-weight:700">⏸ Suspendu</span>'
        return `<div onclick="navigateTo('mes_seances')"
          style="background:linear-gradient(135deg,#0E1E34,#1A1408);border:1px solid ${col}30;border-radius:14px;
                 padding:16px;cursor:pointer;transition:all .18s;position:relative;overflow:hidden"
          onmouseover="this.style.borderColor='${col}';this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.4)'"
          onmouseout="this.style.borderColor='${col}30';this.style.transform='none';this.style.boxShadow='none'">
          <div style="position:absolute;top:0;left:0;right:0;height:3px;background:${col};opacity:.7;border-radius:14px 14px 0 0"></div>
          <div style="font-weight:800;color:#E2D8C0;font-size:.88rem;margin-bottom:4px;line-height:1.3">${cl.nom||'Formation'}</div>
          <div style="font-size:.7rem;color:${col};font-weight:600;margin-bottom:8px">${cl.niveau||''} ${cl.formateur_nom?'· '+cl.formateur_nom:''}</div>
          ${statBadge}
          <div style="margin:10px 0 6px">
            <div style="display:flex;justify-content:space-between;font-size:.62rem;margin-bottom:4px">
              <span style="color:#8AAAC0">Progression</span>
              <span style="color:${pctCol};font-weight:700">${done}/${quota} séances · ${pct}%</span>
            </div>
            <div style="height:6px;background:#0A1520;border-radius:3px;overflow:hidden">
              <div style="height:100%;width:${pct}%;background:${pctCol};border-radius:3px;transition:width .4s ease"></div>
            </div>
          </div>
          ${next ? `<div style="margin-top:8px;padding:6px 10px;background:rgba(200,150,12,0.08);border:1px solid rgba(200,150,12,0.2);border-radius:7px;font-size:.65rem;color:#C8960C">
            📅 Prochaine : ${new Date(next.date_seance).toLocaleDateString('fr-FR',{weekday:'short',day:'2-digit',month:'short'})} ${next.heure_debut?'à '+next.heure_debut:''}
          </div>` : ''}
          ${cl.horaire ? `<div style="margin-top:6px;font-size:.62rem;color:#5A7090">🕐 ${cl.horaire}</div>` : ''}
        </div>`
      }).join('')
    }

