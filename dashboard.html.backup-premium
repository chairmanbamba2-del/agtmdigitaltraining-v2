    window._aiUpdateUserTier = async function(userId) {
      const sel = document.getElementById(`tier_${userId}`)
      if (!sel) return
      const tier = sel.value
      const claudeTiers = ['essentiel', 'recommande', 'premium']
      // Sauvegarder dans ai_config (supporte tous les tiers dont groq)
      const {error: cfgErr} = await sb.from('ai_config').upsert(
        { cle: `user_${userId}_tier`, valeur: tier, updated_at: new Date().toISOString() },
        { onConflict: 'cle' }
      )
      if (cfgErr) { toast('❌ ' + cfgErr.message, 'err'); return }
      // Sync utilisateurs.ai_tier seulement pour les tiers Claude (contrainte CHECK)
      if (claudeTiers.includes(tier)) {
        await sb.from('utilisateurs').update({ ai_tier: tier }).eq('id', userId).catch(() => {})
      }
      toast('✅ Tier mis à jour → ' + tier, 'ok')
    }

