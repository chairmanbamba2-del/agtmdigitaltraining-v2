    // ── JOURNAL DE CAISSE ────────────────────────────────────────
    async function _finCaisse() {
      const moisStr=new Date().toISOString().substring(0,7)
      const [{data:pais},{data:deps}]=await Promise.all([
        sb.from('paiements').select('id,montant,date_paiement,type_paiement,etudiant_nom,notes').order('date_paiement',{ascending:false}).limit(200),
        sb.from('depenses').select('id,montant,date_depense,categorie,description').order('date_depense',{ascending:false}).limit(200),
      ])

      // Fusionner et trier par date
      const lignes=[
        ...(pais||[]).map(p=>({date:p.date_paiement,type:'entree',libelle:p.etudiant_nom||(p.notes?p.notes.split(' — ')[0]:'Encaissement'),detail:p.type_paiement||'Paiement',montant:Number(p.montant)||0})),
        ...(deps||[]).map(d=>({date:d.date_depense,type:'sortie',libelle:d.description||d.categorie,detail:d.categorie||'Dépense',montant:Number(d.montant)||0})),
      ].sort((a,b)=>a.date<b.date?1:-1)

      const totEntrees=(pais||[]).reduce((s,p)=>s+(Number(p.montant)||0),0)
      const totSorties=(deps||[]).reduce((s,d)=>s+(Number(d.montant)||0),0)
      const solde=totEntrees-totSorties

      // Solde cumulatif (du plus récent au plus ancien)
      let running=solde
      const lignesAvecSolde=lignes.map(l=>{
        const s=running
        running = l.type==='entree' ? running-l.montant : running+l.montant
        return {...l, solde:s}
      })

      // Filtre mois courant par défaut
      const lignesMois=lignesAvecSolde.filter(l=>String(l.date||'').substring(0,7)===moisStr)
      const entreesMois=lignesMois.filter(l=>l.type==='entree').reduce((s,l)=>s+l.montant,0)
      const sortiesMois=lignesMois.filter(l=>l.type==='sortie').reduce((s,l)=>s+l.montant,0)

      setContent(`
        ${finTabBar('caisse')}
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px">
          ${kpi('🏦','Solde caisse actuel',fmtMoney(solde),solde>=0?'#4AE090':'#E04A4A')}
          ${kpi('💰','Entrées ce mois',fmtMoney(entreesMois),'#4AE090')}
          ${kpi('💸','Sorties ce mois',fmtMoney(sortiesMois),'#E04A4A')}
          ${kpi('📊','Solde du mois',fmtMoney(entreesMois-sortiesMois),(entreesMois-sortiesMois)>=0?'#4AE090':'#E04A4A')}
        </div>

        ${wrap(`
          ${card('📒 Journal de Caisse — Toutes opérations',`${lignesAvecSolde.length} ligne(s)`)}
          <table style="width:100%;border-collapse:collapse">
            <thead>${th('Date','Type','Libellé','Détail','Entrée (+)','Sortie (−)','Solde cumulé')}</thead>
            <tbody>
              ${lignesAvecSolde.map(l=>`<tr style="border-top:1px solid #1E3050">
                <td style="padding:9px 14px;font-size:.7rem;color:#5A7090;white-space:nowrap">${fmtDate(l.date)}</td>
                <td style="padding:9px 14px">${l.type==='entree'
                  ? bdg('▲ ENTRÉE','#1A3A1A','#4AE090')
                  : bdg('▼ SORTIE','#2A1A1A','#E04A4A')}</td>
                <td style="padding:9px 14px;font-weight:600;color:#fff;font-size:.82rem">${l.libelle||'—'}</td>
                <td style="padding:9px 14px;font-size:.72rem;color:#90A4AE">${l.detail||'—'}</td>
                <td style="padding:9px 14px;font-weight:700;color:${l.type==='entree'?'#4AE090':'#3A5A3A'}">${l.type==='entree'?'+ '+fmtMoney(l.montant):'—'}</td>
                <td style="padding:9px 14px;font-weight:700;color:${l.type==='sortie'?'#E04A4A':'#3A1A1A'}">${l.type==='sortie'?'− '+fmtMoney(l.montant):'—'}</td>
                <td style="padding:9px 14px;font-weight:800;color:${l.solde>=0?'#4AE090':'#E04A4A'}">${fmtMoney(l.solde)}</td>
              </tr>`).join('')||`<tr><td colspan="7" style="padding:28px;text-align:center;color:#5A7090">Aucune opération</td></tr>`}
            </tbody>
          </table>
        `)}
      `)
    }

