    window._edtSaveSeance = async function() {
      const id=document.getElementById('edtSeanceId').value
      const date_seance=document.getElementById('edtDate').value
      const heure_debut=document.getElementById('edtHeure').value
      const heure_fin=document.getElementById('edtHeureFin').value||null
      const sujet=document.getElementById('edtSujet').value.trim()
      const programme=document.getElementById('edtProgramme')?.value.trim()||null
      const enseignant=document.getElementById('edtFormateur').value.trim()||null
      const lien_meet=document.getElementById('edtLien').value.trim()||null
      const salle=document.getElementById('edtSalle')?.value.trim()||null
      const statut=document.getElementById('edtStatut').value
      const format=document.getElementById('edtFormat')?.value||null
      const chapitre=document.getElementById('edtModule')?.value.trim()||null
      const notes=document.getElementById('edtObjectifs')?.value.trim()||null
      const classeEl=document.getElementById('edtClasse')
      const classe_id=classeEl?.value?Number(classeEl.value):(window._edtClasseId||null)
      if(!date_seance||!sujet){toast('Date et titre du cours sont requis','err');return}

      // ── Détection de conflits ──
      const conflits = await _detectConflits({ date_seance, heure_debut, heure_fin, enseignant, salle, excludeId: id||null })
      if (conflits.length > 0) {
        const msgs = conflits.map(c=>c.msg).join('\n')
        const force = confirm(`⚠️ CONFLIT DÉTECTÉ :\n\n${msgs}\n\nVoulez-vous quand même enregistrer ?`)
        if (!force) return
      }

      const payload={
        date_seance, heure_debut:heure_debut||null, heure_fin,
        sujet, titre:sujet, programme, enseignant, lien_meet, salle, statut,
        classe_id, format: format||null, chapitre: chapitre||null, notes: notes||null
      }
      let err
      if(id) {
        const r=await sb.from('seances').update(payload).eq('id',id)
        err=r.error
      } else {
        const r=await sb.from('seances').insert(payload)
        err=r.error
      }
      if(err){toast('Erreur : '+err.message,'err');return}
      toast(id?'✅ Séance modifiée':'✅ Séance ajoutée')
      document.getElementById('edtForm').style.display='none'
      if(classe_id) await _autoSyncProgramme(classe_id)
      renderPedagogie()
    }

    window._edtDelSeance = async function(id) {
      if(!confirm('Supprimer cette séance ?')) return
      const {data:sdel}=await sb.from('seances').select('classe_id').eq('id',id).single()
      const cidDel=sdel?.classe_id||null
      const {error}=await sb.from('seances').delete().eq('id',id)
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('Séance supprimée')
      if(cidDel) await _autoSyncProgramme(cidDel)
      renderPedagogie()
    }

    // ── Synchronisation automatique programme ← séances ─────────
    // Reconstruit classes.programme à partir de la liste chronologique des séances
    async function _autoSyncProgramme(classeId) {
      if(!classeId) return
      const {data:seq}=await sb.from('seances')
        .select('date_seance,heure_debut,sujet,programme,statut')
        .eq('classe_id',Number(classeId))
        .order('date_seance',{ascending:true})
      if(!seq||!seq.length) return
      const lines=seq.map(s=>{
        const icon=s.statut==='Réalisée'?'✅':s.statut==='Annulée'?'❌':'📅'
        const d=s.date_seance?new Date(s.date_seance+'T00:00:00').toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit'}):'—'
        const h=s.heure_debut?' '+s.heure_debut:''
        const detail=s.programme&&s.programme!==s.sujet?' ('+s.programme+')':''
        return `${icon} ${d}${h} — ${s.sujet||'Cours'}${detail}`
      })
      await sb.from('classes').update({programme:lines.join('\n')}).eq('id',Number(classeId))
    }

    // Régénère le programme d'une classe depuis ses séances (bouton manuel)
    window._syncProgrammeFromSeances = async function(classeId) {
      await _autoSyncProgramme(classeId)
      toast('✅ Programme régénéré depuis les séances')
      renderClasses()
    }

