          .eq('classe_id', cl.id)
          .gte('date_seance', today)
          .order('date_seance')
          .limit(30)
        seances = data||[]
      }

      // 2. Si aucune séance planifiée, générer depuis les jours de la semaine dans l'horaire
      let rows = []
      if (seances.length > 0) {
        rows = seances.map(s => ({
          date: fmtD(s.date_seance),
          creneau: s.heure_debut && s.heure_fin ? `${s.heure_debut} – ${s.heure_fin}` : horaire,
