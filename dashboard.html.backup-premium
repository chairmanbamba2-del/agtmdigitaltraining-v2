    window._applyTheme = function(themeKey) {
      const t = THEMES[themeKey] || THEMES.gold
      // Stocker le thème
      localStorage.setItem('agtm_theme', themeKey)
      // Appliquer la rotation de teinte sur documentElement (sauf thème gold — palette native)
      if (themeKey === 'gold') {
        document.documentElement.style.filter = ''
      } else {
        document.documentElement.style.filter = `hue-rotate(${t.hue}deg)`
      }
      // Mettre à jour la variable CSS d'accent pour les éléments qui l'utilisent directement
      document.documentElement.style.setProperty('--accent', t.accent)
      document.documentElement.style.setProperty('--accent2', t.accent2)
      // Feedback UI
      const msg = document.getElementById('themeApplyMsg')
      if (msg) { msg.textContent = `✅ Thème "${t.label}" appliqué !`; setTimeout(()=>{if(msg)msg.textContent=''},2500) }
    }

