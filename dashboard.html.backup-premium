                </button>
                <span id="secMsg" style="margin-left:12px;font-size:.78rem"></span>
              </div>
            </div>
          </div>

          <!-- Déconnexion -->
          <div style="background:#1A1020;border:1px solid rgba(224,74,74,0.25);border-radius:14px;padding:20px 24px">
            <div style="font-weight:800;color:#E04A4A;font-size:.88rem;margin-bottom:10px">🚪 Déconnexion</div>
