        const msgSujet = `📤 Nouveau devoir soumis — ${devoir.titre || '—'}`
        const msgContenu =
          `📤 UN DEVOIR A ÉTÉ SOUMIS\n\n` +
          `👤 Étudiant : ${devoir.etudiant_nom || '—'}\n` +
          `📝 Titre : ${devoir.titre || '—'}\n` +
          `🏫 Classe : ${devoir.classe_nom || '—'}\n` +
          `👨‍🏫 Formateur désigné : ${devoir.formateur_nom || '—'}\n` +
          `📅 Soumis le : ${new Date().toLocaleDateString('fr-FR')}\n\n` +
          `Merci de prendre en charge la correction dans votre espace pédagogique.\n— AGTM Digital Academy`

        // Notifier l'admin et/ou le formateur désigné
        // On envoie à tous les utilisateurs admin + formateur portant ce nom
