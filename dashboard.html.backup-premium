    // ── CACHE IN-MEMORY (TTL configurable) ───────────────────────
    const _cache = {
      _s: {},
      get(k)          { const e=this._s[k]; if(!e||Date.now()>e.x){delete this._s[k];return null} return e.v },
      set(k,v,ttl=300000) { this._s[k]={v,x:Date.now()+ttl} },
      del(k)          { delete this._s[k] },
      bust(...keys)   { keys.forEach(k=>this.del(k)) },
      clear()         { this._s={} }
    }

    // ── DEBOUNCE ─────────────────────────────────────────────────
    function debounce(fn, ms=200) {
      let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms) }
    }

    // ── SKELETON LOADING ─────────────────────────────────────────
    const _skShimmer = `background:linear-gradient(90deg,#141F30 25%,#1E2E42 50%,#141F30 75%);background-size:200% 100%;animation:shimmer 1.4s ease-in-out infinite;border-radius:6px;`
    function skeletonTable(rows=6, cols=5) {
      return `<div style="padding:16px">${Array(rows).fill(0).map((_,i)=>`
        <div style="display:grid;grid-template-columns:repeat(${cols},1fr);gap:10px;margin-bottom:10px;opacity:${Math.max(0.25,1-i*0.14)}">
          ${Array(cols).fill(0).map((_,j)=>`<div style="height:${j===0?'15':'12'}px;${_skShimmer}"></div>`).join('')}
        </div>`).join('')}</div>`
    }
    function skeletonKpi(n=4) {
