    window._saveFichePaie = async function() {
      const empId=document.getElementById('fpEmp').value
      if(!empId){toast('Sélectionnez un employé','err');return}
      const periode=document.getElementById('fpPeriode').value
      if(!periode){toast('Période requise','err');return}
      const {data:emp}=await sb.from('personnel').select('*').eq('id',empId).single()
      if(!emp){toast('Employé introuvable','err');return}
      const brut=Number(document.getElementById('fpBrut').value)||Number(emp.salaire_base||0)
      const primes=Number(document.getElementById('fpPrimes').value)||0
      const retenues=Number(document.getElementById('fpRet').value)||0
      const cotisations=Number(document.getElementById('fpCot').value)||0
      const hs=Number(document.getElementById('fpHS').value)||0
      const net=brut+primes-retenues-cotisations
      const d=new Date(periode+'-01')
      const moisLabel=d.toLocaleDateString('fr-FR',{month:'long',year:'numeric'})
      const {data:fiche,error}=await sb.from('fiches_paie').insert({
        personnel_id:Number(empId), nom_employe:`${emp.prenom} ${emp.nom}`,
        poste:emp.poste, periode, mois_label:moisLabel,
        salaire_brut:brut, primes, retenues, cotisations,
        heures_sup:hs, net_a_payer:net, statut:'Émise',
      }).select().single()
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('✅ Fiche de paie générée')
      if(fiche) _printFichePaie(fiche.id,fiche)
      renderFinance()
    }

