      // Filter séances belonging to this formateur
      const mySeances=(seancesAll||[]).filter(s=>
        s.enseignant && (
          s.enseignant.trim()===_fName.trim() ||
          _fName.trim().includes(s.enseignant.trim()) ||
          s.enseignant.trim().includes((_fName||'').split(' ').pop()||'')
        )
      )
      const seancesAvenir=mySeances.filter(s=>s.date_seance>=today)
      const _fCin=persoCard?.cin
      const _fPoste=persoCard?.poste||'Formateur'
      
      // Extraire les programmes des séances du formateur (pour les modules)
      const progSeances = mySeances
        .map(s => ({ programme: s.programme }))
        .filter(p => p.programme)

      // Modules uniques (programmes) pour le select - filtrer les noms de classes et sujets non pertinents
      const classNames = (myClasses || []).map(c => c.nom?.toLowerCase().trim()).filter(Boolean)
      
      // Fonction de validation d'un module
      const isValidModule = (prog) => {
        if (!prog || typeof prog !== 'string') return false
        const p = prog.trim()
        if (p.length < 3) return false
        
        // Exclure les noms de classes
        if (classNames.includes(p.toLowerCase())) return false
        
        // Exclure les modèles courants de noms de classes
        const classPatterns = [
          /^english class$/i,
          /^class [A-D]$/i,
          /^groupe [A-D]$/i,
          /^classe [A-D]$/i,
          /^level [1-5]$/i,
          /^niveau [1-5]$/i,
          /^group [A-D]$/i,
          /^beginner$/i,
          /^intermediate$/i,
          /^advanced$/i,
          /^[\d]+$/ // uniquement des chiffres
        ]
        if (classPatterns.some(pattern => pattern.test(p))) return false
        
        // Exclure les entrées de séances (contiennent " — " ou émojis ✅📅)
        if (p.includes(' — ') || p.includes('✅') || p.includes('📅')) return false
        
        // Exclure les chaînes avec motif date/heure (ex: "11/04 17:00")
        const dateTimePattern = /\d{2}\/\d{2} \d{2}:\d{2}/
        if (dateTimePattern.test(p)) return false
        
        return true
      }
      
      // Récupérer les programmes uniques des séances (filtrés)
      const seancesModules = (progSeances || [])
        .map(p => p.programme?.trim())
        .filter(Boolean)
        .filter(isValidModule)
      
      // Récupérer les programmes des classes (filtrés)
