    //  RAPPORT FORM — Navigateur Par Classe / Par Étudiant
    // ══════════════════════════════════════════════════════════════
    async function renderRapportForm() {
      const fmtNom = [profile?.prenom, profile?.nom].filter(Boolean).join(' ')
      setContent('<div style="color:#5A7090;text-align:center;padding:40px">⏳ Chargement des séances…</div>')

      // Stratégie 1 : via le nom exact
      let { data: rawSeances } = await sb.from('seances')
        .select('id,date_seance,sujet,programme,classe_id,pointage_fait,rapport_soumis,statut')
        .eq('enseignant', fmtNom)
        .eq('pointage_fait', true)
        .eq('rapport_soumis', false)
        .order('date_seance', { ascending: false })

      // Stratégie 2 (fallback) : via les classes du formateur si nom ne matche pas
      if (!(rawSeances||[]).length) {
        const {data:mesClasses} = await sb.from('classes').select('id').eq('formateur_id', currentUser?.id)
        const classeIds = (mesClasses||[]).map(c => c.id)
        if (classeIds.length) {
          const {data:byCls} = await sb.from('seances')
            .select('id,date_seance,sujet,programme,classe_id,pointage_fait,rapport_soumis,statut,enseignant')
            .in('classe_id', classeIds)
            .eq('pointage_fait', true)
            .eq('rapport_soumis', false)
            .order('date_seance', { ascending: false })
          rawSeances = byCls || []
        }
      }

      const pSeances = rawSeances || []

      // Grouper par classe (clé = programme)
      const classeMap = {}
      pSeances.forEach(s => {
        const key = s.programme || 'Sans Classe'
        if (!classeMap[key]) classeMap[key] = { nom: key, seances: [] }
        classeMap[key].seances.push(s)
      })
      window._rfClasseData = classeMap

      // Charger étudiants des séances en attente
      const ids = pSeances.map(s => s.id)
      let etudMap = {}
      if (ids.length) {
        const { data: pres } = await sb.from('presences')
          .select('seance_id, etudiants(id,nom,prenom,numero_dossier)')
          .in('seance_id', ids)
        ;(pres||[]).forEach(p => {
          if (!p.etudiants) return
          const e = p.etudiants
          if (!etudMap[e.id]) etudMap[e.id] = { ...e, seanceSet: new Set() }
          etudMap[e.id].seanceSet.add(p.seance_id)
