                  ? `<div style="font-size:.7rem;color:#2A4060;padding:6px 4px">Aucun historique</div>`
                  : sessions.map(_sessItem).join('')}
              </div>
            </div>

            <!-- ZONE CHAT -->
            <div style="flex:1;display:flex;flex-direction:column;min-width:0;min-height:0">

              <!-- Messages -->
              <div id="aiChatBox" style="background:#0B1620;border:1px solid #1E3050;border-radius:14px;padding:20px;flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:14px;margin-bottom:12px">
                ${_renderMsgs(window._aiSession.messages)}
                <div id="aiTypingIndicator" style="display:none">
                  <div style="display:flex;justify-content:flex-start">
                    <div style="padding:10px 16px;border-radius:18px 18px 18px 4px;background:rgba(255,255,255,.05);border:1px solid #1E3050;color:#5A7090;font-size:.88rem">
                      🤖 AGTM AI écrit<span id="aiDots">...</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Sélecteur de moteur IA -->
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;flex-shrink:0;flex-wrap:wrap">
                <span style="font-size:.65rem;color:#3A5070;font-weight:700;letter-spacing:.06em;text-transform:uppercase;flex-shrink:0">Moteur :</span>
                ${[
                  {k:'claude', icon:'🧠', lbl:'Claude', title:'Intelligence complète — outils, mémoire, analyses'},
                  {k:'groq',   icon:'⚡', lbl:'Groq',   title:'Réponse ultra-rapide — LLaMA 3.3 70B'},
                  {k:'turbo',  icon:'🔀', lbl:'Turbo',  title:'Claude analyse + Groq synthétise — vitesse & intelligence'}
                ].map(({k, icon, lbl, title}) => {
                  const active = (window._aiProvider || 'claude') === k
                  return `<button id="aiProviderBtn_${k}" onclick="window._aiSetProvider('${k}')" title="${title}"
                    style="padding:4px 11px;border-radius:8px;font-size:.72rem;font-weight:700;cursor:pointer;transition:all .15s;
                    background:${active?'rgba(74,144,217,.2)':'#0D1B2A'};
                    border:1.5px solid ${active?'#4A90D9':'#1E3050'};
                    color:${active?'#7AAFDF':'#3A5070'}">${icon} ${lbl}</button>`
                }).join('')}
              </div>

              <!-- Zone saisie vocale -->
              <div id="aiVoiceLiveBar" style="display:none;align-items:center;gap:8px;padding:8px 14px;background:rgba(74,144,217,.1);border:1px solid #4A90D9;border-radius:10px;margin-bottom:8px;flex-shrink:0">
                <span style="width:10px;height:10px;border-radius:50%;background:#E04A4A;animation:aiPulse 1s infinite;flex-shrink:0"></span>
                <span id="aiVoiceLiveText" style="font-size:.85rem;color:#7AAFDF;font-style:italic;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">En écoute…</span>
                <span id="aiClarityBadge" style="display:none;font-size:.72rem;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.3px"></span>
              </div>
              <div style="display:flex;gap:8px;align-items:flex-end;flex-shrink:0">
                <!-- Mic button -->
                <button id="aiMicBtn" onclick="window._aiMicToggle()" title="Parler / Dicter"
                  style="padding:0;width:50px;height:50px;border-radius:13px;background:#0D1B2A;border:1.5px solid #1E3050;color:#5A7090;font-size:1.4rem;cursor:pointer;flex-shrink:0;transition:all .2s;display:flex;align-items:center;justify-content:center">🎤</button>
                <!-- Language toggle -->
                <button id="aiLangBtn" onclick="window._aiToggleLang()" title="Langue vocale"
                  style="padding:0;width:50px;height:50px;border-radius:13px;background:#0D1B2A;border:1.5px solid #1E3050;color:#C8D8E8;font-size:1.1rem;cursor:pointer;flex-shrink:0;transition:all .2s;display:flex;align-items:center;justify-content:center"
                  title="${(navigator.language||'fr').startsWith('fr')?'Français':'American English'}">${(navigator.language||'fr').startsWith('fr')?'🇫🇷':'🇺🇸'}</button>
                <!-- Text input -->
                <textarea id="aiMsgInput" placeholder="Tapez votre message ou parlez avec 🎤…"
                  style="flex:1;padding:14px 18px;border-radius:13px;background:#0D1B2A;border:1.5px solid #1E3050;color:#E2D8C0;font-size:.97rem;resize:none;min-height:50px;max-height:160px;outline:none;line-height:1.6;transition:border-color .2s;font-family:inherit"
                  onfocus="this.style.borderColor='#4A90D9'" onblur="this.style.borderColor='#1E3050'"
                  onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();window._aiSendMsg()}"></textarea>
                <!-- TTS toggle + vitesse -->
                <div style="display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0">
                  <button id="aiTTSBtn" onclick="window._aiToggleTTS()" title="Activer/désactiver la lecture vocale des réponses"
                    style="padding:0;width:50px;height:50px;border-radius:13px;background:#0D1B2A;border:1.5px solid #1E3050;color:#5A7090;font-size:1.1rem;cursor:pointer;width:50px;transition:all .2s;display:flex;align-items:center;justify-content:center">🔇</button>
                  <div id="aiTTSRateCtrl" style="display:none;align-items:center;gap:2px;width:50px;justify-content:center">
                    <button onclick="window._aiSetTTSRate(-1)" title="Plus lent"
                      style="padding:0;width:16px;height:16px;border-radius:4px;background:#0D1B2A;border:1px solid #1E3050;color:#7AAFDF;font-size:.65rem;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0">−</button>
                    <span id="aiTTSRateLbl" style="font-size:.58rem;color:#4A90D9;font-weight:700;min-width:22px;text-align:center">×1.0</span>
                    <button onclick="window._aiSetTTSRate(1)" title="Plus vite"
                      style="padding:0;width:16px;height:16px;border-radius:4px;background:#0D1B2A;border:1px solid #1E3050;color:#7AAFDF;font-size:.65rem;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0">+</button>
                  </div>
                </div>
                <!-- Send button -->
                <button onclick="window._aiSendMsg()" id="aiSendBtn"
                  style="padding:14px 22px;border-radius:13px;background:linear-gradient(135deg,#1C3A6A,#2A5080);border:1px solid #4A90D9;color:#C8D8E8;font-weight:700;font-size:.97rem;cursor:pointer;white-space:nowrap;transition:all .2s;flex-shrink:0"
                  onmouseover="this.style.background='linear-gradient(135deg,#2A4A80,#3A60A0)'"
                  onmouseout="this.style.background='linear-gradient(135deg,#1C3A6A,#2A5080)'">➤</button>
              </div>
              <div style="font-size:.73rem;color:#2A4060;margin-top:6px;text-align:center">Shift+Entrée pour aller à la ligne · Entrée pour envoyer · 🎤 pour parler</div>
              <style>@keyframes aiPulse{0%,100%{opacity:1}50%{opacity:.3}}</style>
            </div>
          </div>
        </div>
      `)

      if (window._aiSession.messages.length > 0) {
        const box = document.getElementById('aiChatBox')
        if (box) box.scrollTop = box.scrollHeight
      }
    }

    // Helper escape HTML
    function escHtml(str) {
      return (str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    }

    window._aiQuickSend = function(msg) {
      const inp = document.getElementById('aiMsgInput')
      if (inp) { inp.value = msg; window._aiSendMsg() }
    }

    window._aiNewConv = function() {
      window._aiSession = { session_id: null, messages: [], loading: false, session_created: false }
      renderAIChat()
    }

    window._aiRefreshCtx = async function() {
      window._aiSchoolCtx = null
      window._aiSchoolCtx = await _aiFetchSchoolContext()
      toast('📊 Données école actualisées !', 'ok')
      renderAIChat()
    }

    window._aiLoadSession = async function(sessionId) {
      try {
        const {data:msgs} = await sb.from('ai_conversations')
          .select('role,content,created_at')
          .eq('session_id', sessionId)
          .eq('user_id', currentUser?.id)
          .order('created_at')
          .limit(60)
        window._aiSession = {
          session_id:      sessionId,
          messages:        (msgs||[]).map(m=>({role:m.role,content:m.content})),
          loading:         false,
          session_created: true
        }
      } catch(e) {
        toast('❌ Impossible de charger cette conversation.', 'err')
      }
      renderAIChat()
    }

    window._aiDemandeUpgrade = async function() {
      const tierLabel = { essentiel:'Essentiel → Recommandé', recommande:'Recommandé → Premium' }
      let currentTier = 'essentiel'
      try {
        const {data:u} = await sb.from('utilisateurs').select('ai_tier').eq('id', currentUser?.id).single()
        if (u?.ai_tier) currentTier = u.ai_tier
      } catch(_) {}
      if (currentTier === 'premium') { toast('✅ Vous bénéficiez déjà du tier Premium !'); return }

      const upgrade = tierLabel[currentTier] || 'Upgrade IA'
      const nom = profile?.nom || '', prenom = profile?.prenom || ''
      const msgContent = `📊 Demande d'upgrade IA\n\nL'utilisateur ${prenom} ${nom} souhaite upgrader son Assistant IA : ${upgrade}.\n\nMerci de modifier le tier dans Administration → Paramètres IA → Gestion des utilisateurs.`
      try {
        const {data:admins} = await sb.from('utilisateurs').select('id').eq('role','admin').limit(1)
        const adminId = admins?.[0]?.id
        if (!adminId) { toast('⚠️ Impossible de contacter l\'administration.'); return }
        const {error} = await sb.from('messages').insert({
          expediteur_id: currentUser?.id, destinataire_id: adminId,
          sujet: '⬆ Demande d\'upgrade Assistant IA', contenu: msgContent, lu: false
        })
        if (error) throw error
        toast('✅ Demande envoyée à l\'administration !')
      } catch(e) {
        console.error(e); toast('❌ Erreur lors de l\'envoi de la demande.')
      }
    }

    window._aiSendMsg = async function() {
      const inp = document.getElementById('aiMsgInput')
      const msg = inp?.value?.trim()
      if (!msg || window._aiSession.loading) return

      // Initialiser la session si nouvelle
      if (!window._aiSession.session_id) {
        window._aiSession.session_id = `sess_${currentUser?.id?.substring(0,8)||'u'}_${Date.now()}`
      }

      window._aiSession.messages.push({ role: 'user', content: msg })
      window._aiSession.loading = true
      inp.value = ''

      // Afficher le message utilisateur
      const chatBox = document.getElementById('aiChatBox')
      if (chatBox) {
        const placeholder = chatBox.querySelector('[style*="flex:1"]')
        if (placeholder) placeholder.remove()
        // Badge de prononciation (vocal + TTS actif)
        const _ps = (window._aiLastWasVoice && window._aiLastPronScore !== null && window._aiLastPronScore !== undefined)
          ? window._aiLastPronScore : null
        const _psBadge = _ps !== null
          ? (() => {
              const [icon, tc, bg, bc] = _ps>=85
                ? ['✅','#4AE04A','rgba(74,224,74,.15)','rgba(74,224,74,.3)']
                : _ps>=60
                ? ['⚠','#E0A94A','rgba(224,169,74,.15)','rgba(224,169,74,.3)']
                : ['❌','#E04A4A','rgba(224,74,74,.15)','rgba(224,74,74,.3)']
              return `<div style="margin-top:7px;display:flex;justify-content:flex-end"><span style="font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:20px;background:${bg};color:${tc};border:1px solid ${bc};letter-spacing:.3px">${icon} Prononciation ${_ps}%</span></div>`
            })()
          : ''
        chatBox.insertAdjacentHTML('beforeend', `
          <div style="display:flex;justify-content:flex-end">
            <div style="max-width:80%;padding:14px 18px;border-radius:20px 20px 4px 20px;
              background:linear-gradient(135deg,#1C3A6A,#152850);border:1px solid #2A5080;
              color:#C8D8E8;font-size:1rem;line-height:1.75;white-space:pre-wrap;word-break:break-word">
              ${escHtml(msg)}${_psBadge}
            </div>
          </div>`)
        const ind = document.getElementById('aiTypingIndicator')
        if (ind) { ind.style.display = 'block'; chatBox.appendChild(ind) }
        chatBox.scrollTop = chatBox.scrollHeight
      }

      let dots = 0
      if (window._aiDotsInterval) clearInterval(window._aiDotsInterval)
      window._aiDotsInterval = setInterval(() => {
        const d = document.getElementById('aiDots')
        if (d) { dots = (dots+1)%4; d.textContent = '.'.repeat(dots||1) }
      }, 400)

      try {
        const { data: { session } } = await sb.auth.getSession()
        const token = session?.access_token
        if (!token) throw new Error('Session expirée')

        const userProfile = {
          role:   profile?.role,
          prenom: profile?.prenom,
          nom:    profile?.nom,
          niveau: profile?.niveau || null
        }

        // Contexte école (refresh si besoin)
        if (!window._aiSchoolCtx) {
          window._aiSchoolCtx = await _aiFetchSchoolContext()
        }

        const res = await fetch('/.netlify/functions/ai-chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({
            messages:        window._aiSession.messages.slice(-20),
            session_id:      window._aiSession.session_id,
            user_profile:    userProfile,
            school_context:  window._aiSchoolCtx?.text || '',
            force_provider:  window._aiProvider || 'claude'
          })
        })

        const data = await res.json()
        if (!res.ok) throw new Error(data.error || 'Erreur IA')

        const replyContent = data.reply || ''
        if (replyContent) {
          window._aiSession.messages.push({ role: 'assistant', content: replyContent })
        }

        // Sauvegarder la session (titre = premier message) — async IIFE pour éviter .catch() sur PromiseLike
        if (!window._aiSession.session_created) {
          const title = msg.length > 60 ? msg.substring(0, 60) + '…' : msg
          ;(async () => {
            try {
              const r = await sb.from('ai_chat_sessions').upsert({
                session_id: window._aiSession.session_id,
                user_id:    currentUser?.id,
                title,
                updated_at: new Date().toISOString()
              })
              if (!r.error) window._aiSession.session_created = true
            } catch(_) {}
          })()
        } else {
          ;(async () => {
            try { await sb.from('ai_chat_sessions').update({ updated_at: new Date().toISOString() }).eq('session_id', window._aiSession.session_id) } catch(_) {}
          })()
        }

        // Rafraîchir le marketing si l'IA a fait des modifications
        if (data.marketing_actions && data.marketing_actions.length > 0) {
          window._mktCfg = null  // invalider le cache marketing
        }

        // Effets de bord des actions administratives
        const adminActs = data.admin_actions || []
        if (adminActs.some(a => a.type === 'message_envoye')) {
          // Rafraîchir les badges de messagerie
          _refreshMsgBadges && _refreshMsgBadges()
        }
        if (adminActs.some(a => a.type === 'certificat_genere')) {
          // Invalider le cache certificats si on est sur la section
          window._certCache = null
        }
        // Invalider le contexte école après toute action admin pour le prochain message
        if (adminActs.some(a => ['message_envoye','certificat_genere'].includes(a.type))) {
          window._aiSchoolCtx = null
        }

        clearInterval(window._aiDotsInterval)
        const indicator = document.getElementById('aiTypingIndicator')
        if (indicator) indicator.style.display = 'none'

        const box2 = document.getElementById('aiChatBox')
        if (box2) {
          const tierBadges = {essentiel:'Haiku',recommande:'Sonnet',premium:'Opus'}
          const mu = data.model_used || ''
          const modelBadge = mu === 'groq-llama-3.3-70b'
            ? `<span style="font-size:.58rem;color:#E8B84B;background:#0D1B2A;border:1px solid #2A3010;border-radius:6px;padding:1px 6px;margin-left:4px">⚡ Groq Llama 3.3</span>`
            : mu === 'turbo-claude+groq'
            ? `<span style="font-size:.58rem;color:#BDC3E7;background:#0D1B2A;border:1px solid #2A3050;border-radius:6px;padding:1px 6px;margin-left:4px">🔀 Turbo Claude+Groq</span>`
            : `<span style="font-size:.58rem;color:#5A7090;background:#0D1B2A;border:1px solid #1E3050;border-radius:6px;padding:1px 6px;margin-left:4px">🧠 ${tierBadges[data.tier]||data.tier||'AI'}</span>`
          const engineLabels = { tavily:'🔍 Tavily', brave:'🦁 Brave', wiki:'📖 Wiki' }
          const engines = data.search_engines || (data.used_search ? ['wiki'] : [])
          const searchBadge = engines.length
            ? engines.map(e => `<span style="font-size:.61rem;color:#4AE090;background:rgba(74,224,144,.08);border:1px solid rgba(74,224,144,.25);border-radius:7px;padding:1px 7px;margin-left:4px" title="Requêtes : ${(data.search_queries||[]).join(', ')}">${engineLabels[e]||'🌐 Web'}</span>`).join('')
            : ''
          const mktBadge = (data.marketing_actions && data.marketing_actions.length)
            ? `<span style="font-size:.61rem;color:#E8B84B;background:rgba(232,184,75,.08);border:1px solid rgba(232,184,75,.3);border-radius:7px;padding:1px 7px;margin-left:4px">🎯 Marketing mis à jour</span>`
            : ''

          // Badges actions administratives
          const adminActs = data.admin_actions || []
          const certActions = adminActs.filter(a => a.type === 'certificat_genere')
          const msgActions  = adminActs.filter(a => a.type === 'message_envoye')
          const waActions   = adminActs.filter(a => a.type === 'whatsapp_envoye')
          const certBadge = certActions.length
            ? `<span style="font-size:.61rem;color:#4AE090;background:rgba(74,224,144,.08);border:1px solid rgba(74,224,144,.3);border-radius:7px;padding:1px 7px;margin-left:4px">🎓 Certificat généré · ${certActions.map(c=>c.code).join(', ')}</span>`
            : ''
          const msgBadge = msgActions.length
            ? `<span style="font-size:.61rem;color:#4A90D9;background:rgba(74,144,217,.08);border:1px solid rgba(74,144,217,.3);border-radius:7px;padding:1px 7px;margin-left:4px">💬 Message(s) envoyé(s)</span>`
            : ''
          const waBadge = waActions.length
            ? `<span style="font-size:.61rem;color:#25D366;background:rgba(37,211,102,.08);border:1px solid rgba(37,211,102,.3);border-radius:7px;padding:1px 7px;margin-left:4px" title="${waActions.map(a=>a.destinataire+' '+a.telephone).join(', ')}">📱 WhatsApp envoyé${waActions.length>1?'s ('+waActions.length+')':''}</span>`
            : ''

          // Sources
          const srcLinks = (data.sources || []).filter(u => u && u.startsWith('http'))
          const sourcesBlock = srcLinks.length
            ? `<div style="margin-top:8px;padding-top:8px;border-top:1px solid #1E3050">
                <div style="font-size:.63rem;color:#3A5070;margin-bottom:4px;font-weight:700">SOURCES</div>
                ${srcLinks.map(u => {
                  const label = u.replace(/^https?:\/\//, '').replace(/\/wiki\//, ' — ').substring(0, 60)
                  return `<a href="${u}" target="_blank" rel="noopener" style="display:block;font-size:.63rem;color:#4A90D9;text-decoration:none;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${u}">🔗 ${label}</a>`
                }).join('')}
              </div>`
            : ''

          // Nettoyer les artefacts markdown résiduels
          function _stripMd(t) {
            return t
              .replace(/\*\*\*(.+?)\*\*\*/g, '$1')   // ***bold italic***
              .replace(/\*\*(.+?)\*\*/g,    '$1')    // **bold**
              .replace(/\*(.+?)\*/g,        '$1')    // *italic*
              .replace(/__(.+?)__/g,        '$1')    // __bold__
              .replace(/_([^_\s][^_]*)_/g,  '$1')   // _italic_
              .replace(/`{1,3}([^`]+)`{1,3}/g, '$1') // `code`
              .replace(/^#{1,6}\s+/gm,      '')      // # titres
              .replace(/^[-*•]\s+/gm,       '')      // - listes non numérotées
              .replace(/^\s*>\s*/gm,        '')      // > citations
              .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // [texte](url) → texte
          }
          const cleanReply = _stripMd(replyContent)

          // Rendre le contenu IA avec support images [IMAGE:url|alt]
          const renderedContent = cleanReply.split(/(\[IMAGE:[^\]]+\])/).map(part => {
            const im = part.match(/^\[IMAGE:([^|]+)\|([^\]]*)\]$/)
            if (im) {
              const [, imgUrl, imgAlt] = im
              return `<div style="margin:10px 0;border-radius:10px;overflow:hidden;max-width:100%">
                <img src="${imgUrl}" alt="${escHtml(imgAlt)}" loading="lazy"
                  style="width:100%;max-width:560px;border-radius:10px;display:block"
                  onerror="this.style.display='none'">
                ${imgAlt ? `<div style="font-size:.68rem;color:#5A7090;margin-top:4px;font-style:italic">${escHtml(imgAlt)}</div>` : ''}
              </div>`
            }
            return `<span style="white-space:pre-wrap">${escHtml(part)}</span>`
          }).join('')

          // Stocker le texte pour la réécoute
          if (!window._aiMsgTexts) window._aiMsgTexts = []
          const _msgIdx = window._aiMsgTexts.length
          window._aiMsgTexts.push(cleanReply)

          box2.insertAdjacentHTML('beforeend', `
            <div style="display:flex;justify-content:flex-start;align-items:flex-end;gap:6px">
              <div style="max-width:82%;padding:14px 18px;border-radius:20px 20px 20px 4px;
                background:rgba(255,255,255,.05);border:1px solid #1E3050;
                color:#BDC3E7;font-size:1.05rem;line-height:1.75;word-break:break-word">
                <span style="font-size:.75rem;color:#4A90D9;font-weight:700;display:flex;align-items:center;flex-wrap:wrap;gap:3px;margin-bottom:6px">🤖 AGTM AI${modelBadge}${searchBadge}${mktBadge}${certBadge}${msgBadge}${waBadge}</span>
                ${renderedContent}${sourcesBlock}
              </div>
              <button onclick="window._aiReplay(${_msgIdx})" title="Réécouter ce message"
                style="flex-shrink:0;padding:0;width:32px;height:32px;border-radius:50%;background:#0D1B2A;border:1.5px solid #1E3050;color:#4A90D9;font-size:.95rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;align-self:flex-end;margin-bottom:2px"
                onmouseover="this.style.borderColor='#4A90D9';this.style.background='rgba(74,144,217,.15)'"
                onmouseout="this.style.borderColor='#1E3050';this.style.background='#0D1B2A'">🔊</button>
            </div>`)
          box2.scrollTop = box2.scrollHeight
          // TTS — lire la réponse si activé
          if (window._aiTTSEnabled && typeof window._aiSpeak === 'function') {
            window._aiSpeak(cleanReply)
          }
          // Log vocal si interaction vocale active
          if (window._aiLastWasVoice && typeof window._aiSaveVoiceLog === 'function') {
            window._aiSaveVoiceLog({
              transcription:          window._aiLastVoiceText || '',
