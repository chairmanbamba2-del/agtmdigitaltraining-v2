        // ─── Onglet Nouveau message ───────────────────────────────
        // Construire la liste des destinataires (checkboxes) selon le rôle
        let destCheckHTML = ''
        if (isFormateur) {
          destCheckHTML += `<label style="display:flex;align-items:center;gap:8px;padding:6px 8px;cursor:pointer;border-radius:6px" onmouseover="this.style.background='rgba(200,150,12,.07)'" onmouseout="this.style.background='transparent'">
