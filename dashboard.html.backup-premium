          </div>
          <div style="background:#152233;border:1px solid #1E3050;border-radius:10px;padding:12px 18px;text-align:center">
            <div style="font-size:1.6rem;font-weight:900;color:#4A90D9">${progs.length}</div>
            <div style="font-size:.7rem;color:#5A7090">Programmes</div>
          </div>
          ${lvlOrder.filter(l=>byLevel[l]).map(l=>`
            <div style="background:#152233;border:1px solid ${lvlColors[l]}44;border-radius:10px;padding:12px 18px;text-align:center">
              <div style="font-size:1.6rem;font-weight:900;color:${lvlColors[l]}">${byLevel[l]}</div>
