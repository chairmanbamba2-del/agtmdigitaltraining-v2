    window._apModEvalPick = function(i) {
      const es = window._apES; if(!es||es.answered) return
      es.answered = true
      const q = es.questions[es.current]
      const opts = Array.isArray(q.options) ? q.options : []
      const chosen = opts[i]
      const correct = q.reponse_correcte
      // Normaliser : "A) some text" → "A", "A" → "A" (gère les deux formats)
      const _normL = s => { if(!s) return ''; const m2=(s+'').trim().match(/^([A-Za-z])[).]/); return m2?m2[1].toUpperCase():(s+'').trim().toUpperCase() }
      const ok = chosen && correct && (_normL(chosen) === _normL(correct) || chosen.trim().toLowerCase() === correct.trim().toLowerCase())
      if (ok) es.score++
      else es.errors.push({q:q.question, chosen, correct, expl:q.explication||''})
      opts.forEach((o,j)=>{
        const b=document.getElementById('_evo_'+j); if(!b) return
        b.disabled=true
        if(_normL(o)===_normL(correct)||o.trim().toLowerCase()===correct.trim().toLowerCase()){b.style.borderColor='#4AE090';b.style.background='#1A3A1A';b.style.color='#4AE090'}
        else if(j===i&&!ok){b.style.borderColor='#E04A4A';b.style.background='#2A1A1A';b.style.color='#E04A4A'}
      })
      const wrap=document.getElementById('_evOpts')
      if(wrap) wrap.insertAdjacentHTML('afterend',`
        <div style="margin-top:10px;padding:11px 15px;border-radius:9px;background:${ok?'#1A3A1A':'#2A1A1A'};border:1px solid ${ok?'#4AE090':'#E04A4A'}">
          <div style="font-weight:700;color:${ok?'#4AE090':'#E04A4A'};margin-bottom:3px">${ok?'✅ Correct !':'❌ Incorrect'}</div>
          ${q.explication?`<div style="font-size:.75rem;color:#90A4AE">${q.explication}</div>`:''}
        </div>
        <div style="margin-top:10px;text-align:right">
          <button onclick="window._apModEvalNext()" style="padding:9px 22px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:#4AE090;border:none;color:#0D1B2A">
            ${es.current+1<es.questions.length?'Question suivante →':'📊 Voir mes résultats'}
          </button>
        </div>`)
    }

    window._apModEvalNext = function() {
      const es=window._apES; if(!es) return
      es.current++; es.answered=false; _apModEvalRender()
    }

    async function _apModEvalResults() {
      if(window._apEvalTimer) clearInterval(window._apEvalTimer)
      const es = window._apES; if(!es) return
      const total = es.questions.length
      const pct = Math.round(es.score/total*100)
      const appList = ['Insuffisant','Assez Bien','Bien','Très Bien','Excellent']
      const appr = pct>=90?'Excellent':pct>=75?'Très Bien':pct>=60?'Bien':pct>=50?'Assez Bien':'Insuffisant'
      const score20 = Math.round(es.score/total*20*10)/10

      // Enregistrer dans evaluations (notes) et soumissions_evaluations
      const dateEval = new Date().toISOString().substring(0,10)
      const catLabel = ({grammaire:'Grammaire',vocabulaire:'Vocabulaire',business:'Business English',bepc:'Prépa BEPC',bac:'Prépa BAC',toeic:'Prépa TOEIC'})[es.cat]||'Anglais'
      await Promise.all([
        sb.from('soumissions_evaluations').insert({
          evaluation_titre: es.modTitre,
          etudiant_nom: es.nom, etudiant_email: es.email||null,
          niveau: es.niv||'—', score: score20, score_max: 20,
          nb_questions: total, nb_bonnes: es.score,
          reponses: es.errors,
          module_id: es.modId,
        }),
        sb.from('evaluations').insert({
          etudiant_nom: es.nom,
          type_eval: 'Quiz',
          matiere: catLabel,
          chapitre: es.modTitre,
          note: score20,
          note_max: 20,
          appreciation: appr,
          date_eval: dateEval,
          commentaire: `Évaluation en ligne — ${es.modTitre}`,
          module_id: es.modId,
          categorie: es.cat,
        }),
      ])

      const errHtml = es.errors.length ? `<div style="margin-top:18px;text-align:left">
        <div style="font-size:.75rem;font-weight:700;color:#E04A4A;margin-bottom:8px">❌ Points à revoir :</div>
