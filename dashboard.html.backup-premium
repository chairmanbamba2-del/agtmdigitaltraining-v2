    window._saveFeuille = async function() {
      const date = document.getElementById('fsDate').value
      const sujet = document.getElementById('fsSujet').value.trim()
      if (!date||!sujet) { toast('Date et sujet sont obligatoires','err'); return }
      const hd = document.getElementById('fsHD').value||null
      const hf = document.getElementById('fsHF').value||null
      const classeId = Number(document.getElementById('fsClasse').value)||null
      const module = document.getElementById('fsModule').value.trim()||null
      const obj = document.getElementById('fsObj').value.trim()||null
      const fmtNomSel = document.getElementById('fsFmtNomSel')
      const fmtMatSel = document.getElementById('fsFmtMatSel')
      if (fmtNomSel?.value && fmtMatSel?.value && fmtNomSel.value !== fmtMatSel.value) {
        toast('⚠️ Le matricule ne correspond pas au formateur sélectionné','err'); return
      }
      const fmtNom = fmtNomSel?.selectedOptions[0]?.text?.trim()||null
      const fmtMat = fmtMatSel?.selectedOptions[0]?.text?.trim()||null
      const format = document.getElementById('fsFormat')?.value||'Groupe en ligne'
       const programme = document.getElementById('fsProgramme')?.value||'Général'
       let lienMeet = document.getElementById('fsLienMeet')?.value.trim()||null
       // Générer automatiquement un lien Google Meet aléatoire si cours en ligne et aucun lien fourni
       if (format.includes('ligne') && !lienMeet) {
         const randomId = Math.random().toString(36).substring(2, 10)
         lienMeet = 'https://meet.google.com/' + randomId
         const meetInput = document.getElementById('fsLienMeet')
         if (meetInput) meetInput.value = lienMeet
         toast('🔗 Lien Google Meet généré automatiquement', 'info')
       }

      // Créer la séance — essai complet, puis retry sans colonnes v9 si besoin
      const _baseInsert = {
        date_seance:date, heure_debut:hd, heure_fin:hf,
        sujet, enseignant:fmtNom,
        notes:[module?`Module: ${module}`:'', obj].filter(Boolean).join(' — ')||null,
        statut:'Planifiée', format, programme,
      }
      const _fullInsert = { ..._baseInsert, module:module||null, titre:sujet, classe_id:classeId, lien_meet:lienMeet }

      let seance = null
      {
        const {data:d1, error:e1} = await sb.from('seances').insert(_fullInsert).select().single()
        if (!e1) { seance = d1 }
        else if (e1.message && e1.message.includes('schema cache')) {
          // Colonnes v9 absentes → retry sans elles
          const {data:d2, error:e2} = await sb.from('seances').insert(_baseInsert).select().single()
          if (e2) { toast('Erreur séance : '+e2.message,'err'); return }
          seance = d2
        } else { toast('Erreur séance : '+e1.message,'err'); return }
      }

      // Enregistrer les présences
      const rows = window._fsEtudRows||[]
      if (rows.length && seance?.id) {
        const presRecords = rows.filter(r=>r.id).map(r=>{
          const el = document.querySelector(`[name="fsp_${r._rid}"]:checked`)
          return { seance_id:seance.id, etudiant_id:r.id, present:el?Number(el.value):0 }
        })
        if (presRecords.length) {
          await sb.from('presences').upsert(presRecords,{onConflict:'seance_id,etudiant_id'})
        }
      }

      // Afficher le lien partageable + bouton de pointage
      if (seance?.id) {
        window._fsCurrentSeanceId = seance.id
        const lb = document.getElementById('fsLinkBlock')
        if (lb) {
          const base = window.location.origin + window.location.pathname
          const lien = `${base}?pointage=${seance.id}`
          lb.innerHTML = `
            <div style="font-size:.78rem;font-weight:800;color:#4AE090;margin-bottom:8px">🔗 Lien de Pointage Public — à partager avec les étudiants et le formateur</div>
            <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:10px">
              <input id="fsLinkUrl" type="text" readonly value="${lien}"
                style="flex:1;min-width:0;padding:9px 14px;border-radius:8px;background:#0A1520;border:1px solid #4AE090;color:#4AE090;font-size:.78rem;font-weight:600;cursor:pointer"
                onclick="this.select()"/>
              <button onclick="_copyFsLink()" style="padding:9px 18px;border-radius:8px;font-weight:700;font-size:.78rem;cursor:pointer;background:#1A4A2A;border:1px solid #4AE090;color:#4AE090;white-space:nowrap">📋 Copier</button>
              <button onclick="window.open('${lien}','_blank')" style="padding:9px 18px;border-radius:8px;font-weight:700;font-size:.78rem;cursor:pointer;background:#1A3A1A;border:1px solid #4AE090;color:#4AE090;white-space:nowrap">🔗 Ouvrir</button>
            </div>
            <button onclick="renderPointageInline(${seance.id})"
              style="padding:10px 22px;border-radius:9px;background:#C8960C;border:none;color:#0D1B2A;font-weight:800;font-size:.88rem;cursor:pointer;width:100%;margin-bottom:8px">
              📋 Pointer cette séance maintenant</button>
            <div style="font-size:.7rem;color:#5A7090">⚠️ Ce lien est valide pour toute la durée de la séance. Partagez-le aux apprenants via WhatsApp ou email.</div>
          `
          lb.style.display = 'block'
          lb.scrollIntoView({behavior:'smooth',block:'nearest'})
        }
      }

      toast('✅ Séance créée ! Lien de pointage disponible ci-dessous.')
      // ── Notification automatique aux étudiants et formateur ──
      if (seance) await window._notifySeanceCreated(seance)
    }

