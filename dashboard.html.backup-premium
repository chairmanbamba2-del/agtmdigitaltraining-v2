    window._propagateProgrammeToSeances = async function(classeId) {
      const prog=document.getElementById('ec_pr_'+classeId)?.value.trim()
      if(!prog){toast('Programme vide — rien à propager','err');return}
      if(!confirm('Mettre à jour le champ "programme" de toutes les séances planifiées de cette classe avec ce texte ?')) return
      const {error}=await sb.from('seances').update({programme:prog}).eq('classe_id',Number(classeId)).eq('statut','Planifiée')
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('✅ Programme propagé vers les séances planifiées')
    }

