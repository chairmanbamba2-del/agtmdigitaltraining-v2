                    ${!s.vise_par_direction?`<button onclick="_delSeance(${s.id})" style="padding:2px 8px;border-radius:5px;font-size:.65rem;cursor:pointer;background:#2A1A1A;border:1px solid #E04A4A;color:#E04A4A">🗑️</button>`:`<span style="font-size:.62rem;color:#8E44AD;padding:2px 6px;background:rgba(142,68,173,0.1);border-radius:4px">🔐</span>`}
