    window._fsSetHoraire = function() {
      const v = document.getElementById('fsPlage').value
      if (!v) return
      const [deb, fin] = v.split('–')
      const toTime = s => { const [h,m] = s.replace('h','').split(':'); return (h||'00')+':'+(m||'00') }
      const hd = toTime(deb||'')
      const hf = toTime(fin||'')
      document.getElementById('fsHD').value = hd
      document.getElementById('fsHF').value = hf
      // Calculer durée
      try {
        const [hh1,mm1] = hd.split(':').map(Number)
        const [hh2,mm2] = hf.split(':').map(Number)
        const diff = (hh2*60+mm2) - (hh1*60+mm1)
        if (diff>0) {
          const h = Math.floor(diff/60), m = diff%60
          document.getElementById('fsDuree').value = h>0?(h+'h'+(m>0?m+'min':'')):(m+'min')
        }
      } catch(e){}
    }

    window._fsToggleMeet = function() {
      const fmt = document.getElementById('fsFormat')?.value||''
      const isOnline = fmt.includes('ligne')
      const block = document.getElementById('fsMeetBlock')
      if (block) {
        block.style.display = isOnline ? '' : 'none'
        if (!isOnline) { const inp = document.getElementById('fsLienMeet'); if(inp) inp.value='' }
      }
    }

    window._fsLoadClasse = async function() {
      const classeId = document.getElementById('fsClasse').value
      if (!classeId) { window._fsEtudRows=[]; _fsAddEtudRow(); return }
      document.getElementById('fsEtudMsg').textContent = 'Chargement des étudiants…'

      // Récupérer les étudiants inscrits dans cette classe
      const {data:inscrits} = await sb.from('inscriptions_classes')
        .select('etudiant_id,etudiants(id,nom,prenom,niveau,numero_dossier)')
        .eq('classe_id', classeId).order('id')

      const sel = document.getElementById('fsClasse')
      const opt = sel.selectedOptions[0]
      const fmtNom = opt?.dataset.fmt||''
      if (fmtNom) {
        // Pré-remplir le formateur par correspondance de nom
        const fmt = (window._fsAllFormateurs||[]).find(p=>`${p.prenom||''} ${p.nom||''}`.trim()===fmtNom.trim())
        if (fmt) {
          const ns = document.getElementById('fsFmtNomSel'); if(ns) ns.value = fmt.id
          const ms = document.getElementById('fsFmtMatSel'); if(ms) ms.value = fmt.id
          _fsFmtVerify()
        }
      }
      // Pré-remplir plage horaire si connue
      const hor = opt?.dataset.hor||''
      if (hor) {
        // Chercher la plage correspondante
        const plageEl = document.getElementById('fsPlage')
        for (let o of plageEl.options) { if (o.value && hor.includes(o.value.split('–')[0])) { plageEl.value = o.value; _fsSetHoraire(); break } }
      }

      window._fsEtudRows = (inscrits||[]).map(i=>i.etudiants).filter(Boolean)
      document.getElementById('fsEtudMsg').textContent = `${window._fsEtudRows.length} étudiant(s) chargé(s) depuis la classe.`
      _fsRenderEtudTable()
    }

    window._fsFmtVerify = function() {
      const nomSel = document.getElementById('fsFmtNomSel')
      const matSel = document.getElementById('fsFmtMatSel')
      const st = document.getElementById('fsFmtStatus')
      if (!nomSel||!matSel||!st) return
