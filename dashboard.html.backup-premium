    // ── Charger la feuille de pointage d'une séance ───────────
    window._loadPresenceFeuille = async function() {
      const seanceId=Number(document.getElementById('presSeance').value)
      if(!seanceId){toast('Sélectionnez une séance','err');return}
      const cont=document.getElementById('feuilleContent')
      if(!cont){return}
      cont.innerHTML='<div style="color:#5A7090;padding:14px 0">⏳ Chargement de la feuille…</div>'

      const [{data:seance},{data:etuds},{data:existPres},{data:inscs}]=await Promise.all([
        sb.from('seances').select('*').eq('id',seanceId).single(),
        sb.from('etudiants').select('id,nom,prenom,niveau').order('id').order('nom'),
        sb.from('presences').select('*').eq('seance_id',seanceId),
        sb.from('inscriptions_classes').select('*'),
      ])

      // Si séance liée à une classe, ne montrer que ses étudiants
      let studentsToShow=etuds||[]
      if(seance?.classe_id){
        const classeEtudIds=(inscs||[]).filter(i=>i.classe_id===seance.classe_id).map(i=>i.etudiant_id)
        const filtered=(etuds||[]).filter(e=>classeEtudIds.includes(e.id))
        if(filtered.length>0) studentsToShow=filtered
      }

      const presMap={}
      ;(existPres||[]).forEach(p=>{presMap[p.etudiant_id]=Number(p.present)})
      const nbPointes=Object.keys(presMap).length
      const nbPres=Object.values(presMap).filter(v=>v===1).length

      cont.innerHTML=`
        <div style="background:#0D1B2A;border:1px solid #2A3F58;border-radius:8px;padding:10px 16px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
          <div>
            <span style="font-weight:700;color:#C8960C">${fmtDate(seance?.date_seance)} ${seance?.heure_debut?'· '+seance.heure_debut:''}</span>
            <span style="margin-left:8px;font-size:.82rem;color:#e0e0e0">${seance?.sujet||'—'}</span>
