    window._registerFormateur = async function() {
      const sel    = document.getElementById('fmPersoSel')
      const email  = document.getElementById('fmEmail')?.value.trim()
      const pwd    = document.getElementById('fmPwd')?.value
      const errEl  = document.getElementById('fmErr')
      if (!errEl) return
      errEl.textContent = ''

      if (!sel?.value) { errEl.textContent='Sélectionnez un formateur depuis la liste du personnel RH.'; return }
      const opt = sel.selectedOptions[0]
      const nom    = opt.dataset.nom    || ''
      const prenom = opt.dataset.prenom || ''
      const poste  = opt.dataset.poste  || 'Formateur'
      const personnelId = opt.value

      if (!email)         { errEl.textContent='Email obligatoire.'; return }
      if (!pwd || pwd.length < 6) { errEl.textContent='Mot de passe : minimum 6 caractères.'; return }

      // Créer le compte Supabase Auth
      const { data, error } = await sb.auth.signUp({
        email, password: pwd,
        options: {
          data: { nom, prenom, role:'formateur', poste },
          emailRedirectTo: window.location.origin + '/auth/callback'
        }
      })
      if (error) {
        const isRateLimit = error.status===429 || (error.message||'').toLowerCase().includes('rate limit') || error.code==='over_email_send_rate_limit'
        if (isRateLimit) {
          errEl.innerHTML = `⚠️ <strong>Limite d'envoi d'emails Supabase atteinte.</strong><br/>
            <span style="font-size:.75rem;line-height:1.6">
              Pour désactiver cette limite :<br/>
              <strong>Supabase Dashboard → Authentication → Settings → désactiver "Confirm email"</strong><br/>
              Ou réessayez dans 1 heure.
            </span>`
        } else {
          errEl.textContent = 'Erreur Auth : '+error.message
        }
        return
      }

      // Le trigger on_auth_user_created crée automatiquement la ligne utilisateurs.
      // On force le rôle formateur en cas de décalage.
      if (data.user) {
        await sb.from('utilisateurs').upsert({
          id: data.user.id, email, role:'formateur', nom, prenom
        }, {onConflict:'id'})
      }

      toast('✅ Accès formateur créé pour '+prenom+' '+nom+' — un email de confirmation a été envoyé')
      renderPedagogie()
    }

    window._deleteFormateur = async function(userId, nom) {
      if (!confirm('Supprimer le compte formateur de ' + nom + ' ?\n\nCela supprime l\'accès au dashboard. Les données (rapports, classes) sont conservées.')) return
      // Désassigner les classes liées à ce formateur
      await sb.from('classes').update({ formateur_id: null, formateur_nom: null }).eq('formateur_id', userId)
      // Supprimer de la table utilisateurs
      const { error } = await sb.from('utilisateurs').delete().eq('id', userId)
      if (error) { toast('Erreur : '+error.message,'err'); return }
      toast('✅ Compte formateur supprimé')
      renderPedagogie()
    }

    window._assignClass = async function(formateurId, formateurNom, classeId, sel) {
      if (!classeId) return
      const { error } = await sb.from('classes').update({
        formateur_id: formateurId,
        formateur_nom: formateurNom,
      }).eq('id', Number(classeId))
      if (sel) sel.value = ''
      if (error) { toast('Erreur : '+error.message,'err'); return }
      toast('✅ Classe assignée à '+formateurNom)
      renderPedagogie()
    }

