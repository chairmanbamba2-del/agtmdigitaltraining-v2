    window._waClean = function(numero) {
      let n = String(numero || '').replace(/\s+/g,'').replace(/[^0-9+]/g,'')
      if (!n) return ''
      if (n.startsWith('+')) n = n.slice(1)
      if (n.length >= 8 && n.length <= 10 && !n.startsWith('225') && !n.startsWith('33') && !n.startsWith('1')) {
        n = '225' + n
      }
      return n
    }

