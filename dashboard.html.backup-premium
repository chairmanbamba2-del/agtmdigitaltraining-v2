    window._marquerTous = function(val) {
      document.querySelectorAll(`input[type="radio"][value="${val}"]`).forEach(r=>{
        if(r.name.startsWith('pres_')) r.checked=true
      })
    }

    window._saveAllPresences = async function(seanceId, etudIds) {
      const records=etudIds.map(eid=>{
        const radios=document.querySelectorAll(`input[name="pres_${eid}"]`)
        let val=null
        radios.forEach(r=>{if(r.checked)val=Number(r.value)})
        if(val===null) return null
        // valeur 2 = justifié → on enregistre comme absent (0) côté DB
        return {seance_id:seanceId,etudiant_id:eid,present:val===2?0:val}
      }).filter(Boolean)
      if(!records.length){toast('Cochez au moins un étudiant','err');return}
       const {error}=await sb.from('presences').upsert(records,{onConflict:'seance_id,etudiant_id'})
       if(error){toast('Erreur : '+error.message,'err');return}
       const nbP=records.filter(r=>r.present===1).length
       const nbA=records.filter(r=>r.present===0).length
       
       // Mettre à jour le statut de la séance
       const role = profile?.role || 'formateur'
       const isAdmin = ['admin', 'directeur_pedagogique', 'sous_directeur_pedagogique'].includes(role)
       const newStatut = isAdmin ? 'Réalisée' : 'Pointage soumis'
       const {error: errStatut} = await sb.from('seances')
         .update({ statut: newStatut, pointage_soumis_le: new Date().toISOString() })
         .eq('id', seanceId)
