      const formateurPers = (personnelFmt||[]).find(p=>`${p.prenom||''} ${p.nom||''}`.trim()===formateurNom.trim())
      const formateurMat = formateurPers?.cin||null
      const horaires = classes.map(c=>c.horaire||'—').filter((v,i,a)=>a.indexOf(v)===i).join(' / ') || (e.disponibilites||'—')
      const classesNoms = classes.map(c=>c.nom).join(', ') || '—'

      // Placement test
