            ${evalForSeance.appreciation?`<div style="font-size:.68rem;color:#8AAAC0;margin-top:2px">${evalForSeance.appreciation}</div>`:''}
            ${evalForSeance.commentaire?`<div style="font-size:.68rem;color:#5A7090;margin-top:2px;font-style:italic">${evalForSeance.commentaire}</div>`:''}
          </div>` : ''
