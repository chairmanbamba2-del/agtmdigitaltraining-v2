    window.planCreateSeance = async function() {
      const mode=(window._planState?.mode)||'groupe'
      const fmtId=((document.getElementById('planFmtSel')||{}).value||'').trim()
      const date=((document.getElementById('planDate')||{}).value||'').trim()
      const hdeb=((document.getElementById('planHdeb')||{}).value||'')
      const hfin=((document.getElementById('planHfin')||{}).value||'')
      const sujet=((document.getElementById('planSujet')||{}).value||'').trim()
      const prog=((document.getElementById('planProg')||{}).value||'').trim()
      const res=document.getElementById('planResult')

      if(!fmtId){toast('Sélectionnez un formateur','err');return}
      if(!date){toast('Date requise','err');return}
      if(!sujet){toast('Sujet / thème requis','err');return}

      const fmt=(window._planState?.allFormateurs||[]).find(f=>String(f.id)===String(fmtId))
      const fmtName=fmt?[fmt.prenom,fmt.nom].filter(Boolean).join(' '):(window._planState?.fName||'')

      let classeId=null, chapitreNote=''

      if(mode==='groupe'){
        const selEl=document.getElementById('planClasseSel')
        classeId=selEl?Number(selEl.value)||null:null
        if(!classeId){toast('Sélectionnez une classe','err');return}
      } else {
        const checked=[...document.querySelectorAll('#planEtudList input[type=checkbox]:checked')]
        if(!checked.length){toast('Sélectionnez au moins un étudiant','err');return}
        const names=checked.map(cb=>cb.dataset.etudNom).filter(Boolean)
        chapitreNote='Individuel — '+names.length+' étudiant(s) : '+names.join(', ')
      }

       // Récupérer modalité & lien meet
       const modalite = document.getElementById('planModalite')?.value || 'presentiel'
       const meetLink = document.getElementById('planMeetLink')?.value || null
       // Calculer durée en minutes
       let duree = null
       if (hdeb && hfin) {
         const [h1, m1] = hdeb.split(':').map(Number)
         const [h2, m2] = hfin.split(':').map(Number)
         const totalMin = (h2 * 60 + m2) - (h1 * 60 + m1)
         if (totalMin > 0) duree = totalMin
       }
        const payload={
          date_seance:date,
          heure_debut:hdeb||null,
          heure_fin:hfin||null,
          duree,
          sujet,
          programme:prog||null,
          enseignant:fmtName,
          formateur_id: fmtId ? Number(fmtId) : null,
          statut:'Planifiée',
          format:mode==='groupe'?'Groupe':'Individuel',
          modalite,
          lien_meet: meetLink,
          classe_id:classeId,
          ...(chapitreNote?{chapitre:chapitreNote}:{}),
        }

      const {data:newS,error}=await sb.from('seances').insert(payload).select('id').single()
      if(error||!newS){toast('Erreur : '+(error?.message||'Inconnue'),'err');return}

      const sid=newS.id
      const ptgRel='pointage_form.html?seance_id='+sid
      const ptgAbs=window.location.origin+'/pointage_form?seance_id='+sid

      if(res){
        res.style.display=''
        res.innerHTML=`<div style="background:#0E2A1A;border:1px solid #4AE090;border-radius:10px;padding:16px 18px">
          <div style="font-weight:800;color:#4AE090;font-size:.9rem;margin-bottom:10px">✅ Séance créée — Feuille de pointage générée !</div>
          <div style="font-size:.78rem;color:#8AAAC0;margin-bottom:12px">
            <strong style="color:#E8B84B">${fmtName}</strong> &nbsp;·&nbsp;
            ${new Date(date).toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'})}
            ${hdeb?' à '+hdeb:''} &nbsp;·&nbsp;
            ${bdg(mode==='groupe'?'Groupe':'Individuel',mode==='groupe'?'#1A2D42':'#2A1A0A',mode==='groupe'?'#4A90D9':'#C8960C')}
          </div>
          <div style="font-size:.75rem;color:#5A7090;margin-bottom:10px">
            🔑 ID Séance : <strong style="color:#C8960C;font-family:monospace">${sid}</strong>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <a href="${ptgRel}" target="_blank"
              style="padding:8px 16px;border-radius:8px;background:linear-gradient(135deg,#C8960C,#E8B84B);color:#0D1B2A;font-weight:700;font-size:.8rem;text-decoration:none">
              📋 Ouvrir le Pointage
            </a>
            <button onclick="_planCopyLink('${ptgAbs}')"
              style="padding:8px 14px;border-radius:8px;background:#1A2D42;border:1px solid #4A90D9;color:#6AABF0;font-weight:700;font-size:.8rem;cursor:pointer">
              📋 Copier le lien
            </button>
            <button onclick="planSharePointage(${sid},'${encodeURIComponent(sujet)}')"
              style="padding:8px 14px;border-radius:8px;background:#1A1A08;border:1px solid #E8B84B;color:#E8B84B;font-weight:700;font-size:.8rem;cursor:pointer">
              📤 Partager
            </button>
          </div>
        </div>`
      }
      toast('✅ Séance planifiée — pointage prêt')
      if(classeId) await _autoSyncProgramme(classeId)
    }

