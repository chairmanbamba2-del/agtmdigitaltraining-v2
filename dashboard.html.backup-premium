                          : `<button onclick="window._vizerSeance(${s.id})" style="padding:2px 8px;border-radius:5px;font-size:.65rem;cursor:pointer;background:rgba(142,68,173,0.15);border:1px solid #8E44AD;color:#BDC3E7;font-weight:700">✅ Viser</button>`)
