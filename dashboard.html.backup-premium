      const now = new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})
      const horaire = cl?.horaire || e.disponibilites || '—'
      const fmtD = d => new Date(d+'T00:00:00').toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'})
      const dayNames = ['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi']

      // 1. Chercher les séances planifiées de la classe sur 8 semaines
      let seances = []
