          <button onclick="window._apPlacementNext()" style="padding:9px 22px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A">
            ${ps.current+1<20?'Question suivante →':'📜 Voir mon niveau'}
          </button>
