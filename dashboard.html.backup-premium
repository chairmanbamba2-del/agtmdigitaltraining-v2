    function setContent(html) {
      // Auto-close sec-with-nav shells opened by secNavOpen() (each opens 2 divs)
      const secCount = (html.match(/class="sec-with-nav"/g)||[]).length
      if (secCount > 0) html += '</div></div>'
      const el = document.getElementById('content')
      el.innerHTML = html
      el.classList.remove('fade-in')
      void el.offsetWidth
      el.classList.add('fade-in')
      // Auto-wrap tables for mobile horizontal scrolling
      el.querySelectorAll('table').forEach(t => {
        if (!t.parentElement.classList.contains('tbl-scroll')) {
          const wrap = document.createElement('div')
          wrap.className = 'tbl-scroll'
          t.parentNode.insertBefore(wrap, t)
          wrap.appendChild(t)
        }
      })
      // Make inline 2-col grids responsive on small screens
      el.querySelectorAll('[style*="grid-template-columns"]').forEach(g => {
        g.style.gridTemplateColumns = ''
        g.classList.add('resp-grid-auto')
      })
    }

