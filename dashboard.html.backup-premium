     async function _getPersonnel() {
       let d = _cache.get('personnel_fmts')
       if (!d) {
         const { data } = await sb.from('personnel').select('id,nom,prenom,poste,cin,email,statut')
           .or('poste.eq.Formateur,poste.eq.Enseignant,poste.ilike.%formateur%,poste.ilike.%enseignant%')
           .order('nom')
         d = data||[]; _cache.set('personnel_fmts', d, 600000) // 10 min
       }
       return d
     }
    async function _getClasses() {
      let d = _cache.get('classes_all')
      if (!d) {
        const { data } = await sb.from('classes').select('id,nom,personnel_id,niveau,horaire,formateur_nom,programme,tarif_type').order('nom')
        d = data||[]; _cache.set('classes_all', d, 600000) // 10 min
      }
      return d
    }

    // ── INIT ──────────────────────────────────────────────────────
    async function init() {
      try {
      // 0. Vérifier URL params AVANT la session (accès public sans connexion)
      const _urlParamsInit = new URLSearchParams(window.location.search)
      const _evalParamInit      = _urlParamsInit.get('eval_id')
      const _placementParamInit = _urlParamsInit.get('placement')
      const _testParamInit      = _urlParamsInit.get('test_id')
      const _pointageParamInit  = _urlParamsInit.get('pointage')
      const _marketingParamInit = _urlParamsInit.get('marketing')
      const _clientParamInit    = _urlParamsInit.get('client')
      const _satParamInit       = _urlParamsInit.get('satisfaction')
      const _resetPwdParam      = _urlParamsInit.get('action') === 'reset_password'

      // 1. Session
      let _sessionData
      try {
        _sessionData = await sb.auth.getSession()
      } catch (sessionErr) {
        // Session corrompue (ex: après synchro Supabase/Git → JWT secret changé)
        // Nettoyer le localStorage et rediriger vers la page de connexion
        console.warn('Session invalide, nettoyage localStorage:', sessionErr)
        Object.keys(localStorage).filter(k => k.startsWith('sb-')).forEach(k => localStorage.removeItem(k))
        location.href = 'https://africaglobaltraining.com'
        return
      }
      const { data: { session } } = _sessionData
      if (!session) {
        // Mode public : pointage, évaluation, test de placement, marketing, client ou satisfaction sans connexion
        if (_pointageParamInit || _evalParamInit || _placementParamInit || _testParamInit || _marketingParamInit || _clientParamInit || _satParamInit) {
          currentUser = null
          profile = { role: 'anon', nom: '', prenom: '' }
