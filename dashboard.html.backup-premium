    async function _renderCatalogueEtudiant(etud, niveau, tabBar) {
      // Charger modules depuis l'API + filtre optionnel par niveau étudiant
      const url=niveau?`/api/pedagogy/modules?level=${encodeURIComponent(niveau)}&limit=100`
                      :'/api/pedagogy/modules?limit=100'
      let modules=[], programmes=[]
      try{
        const [mr,pr]=await Promise.all([fetch(url),fetch('/api/pedagogy/programmes')])
        if(mr.ok){const d=await mr.json();modules=d.modules||[]}
        if(pr.ok) programmes=await pr.json()
      }catch(e){}

      const lvlColors={A1:'#4CAF50',A2:'#8BC34A',B1:'#FF9800',B2:'#FF5722',C1:'#9C27B0',C2:'#E91E63'}

      // Regrouper par programme (via category.code et programmes)
      const byCat={}
      modules.forEach(m=>{
        const key=m.category?.name||'Autre'
        if(!byCat[key])byCat[key]=[]
        byCat[key].push(m)
      })

      setContent(tabBar+`
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px">
          <div>
            <span style="font-weight:800;color:#fff;font-size:.95rem">📚 Catalogue des Modules</span>
            ${niveau?`<span style="margin-left:8px;font-size:.72rem;padding:2px 10px;border-radius:10px;
              background:${lvlColors[niveau]||'#1A2D42'};color:#fff;font-weight:700">Niveau ${niveau}</span>`:''}
          </div>
          <span style="font-size:.72rem;color:#5A7090">${modules.length} module${modules.length>1?'s':''} disponible${modules.length>1?'s':''}</span>
        </div>

        ${!modules.length?`<div style="text-align:center;padding:40px;color:#5A7090;background:#0D1B2A;border-radius:10px;border:1px solid #1E3050">
          Aucun module disponible${niveau?' pour le niveau '+niveau:''}.
        </div>`:''}

        ${Object.entries(byCat).map(([catName,mods])=>`
          <div style="margin-bottom:24px">
            <div style="font-size:.75rem;font-weight:800;color:#4A90D9;letter-spacing:.5px;
                        text-transform:uppercase;margin-bottom:10px;padding-bottom:6px;
                        border-bottom:1px solid #1E3050">
              ${catName} <span style="color:#5A7090;font-weight:400">(${mods.length})</span>
            </div>
            <div style="display:grid;gap:10px">
              ${mods.map(m=>{
                const lv=m.level?.code||''
                const lc=lvlColors[lv]||'#4A90D9'
                return `<div style="background:#152233;border:1px solid #1E3050;border-radius:12px;padding:14px 16px">
                  <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">
                    <div style="flex:1">
                      <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px">
                        <span style="font-size:.65rem;padding:2px 8px;border-radius:8px;font-weight:800;
                                     background:${lc}22;color:${lc};border:1px solid ${lc}44">${lv||'?'}</span>
                        <span style="font-weight:700;color:#fff;font-size:.85rem">${m.title}</span>
                      </div>
                      ${m.description?`<div style="font-size:.7rem;color:#5A7090;margin-bottom:6px;line-height:1.4">${m.description.substring(0,120)}${m.description.length>120?'…':''}</div>`:''}
