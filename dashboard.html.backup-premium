    const _GRAM=[
      {id:'gram_a1_m1',titre:'Le Verbe TO BE — Présent',niveau:'A1',duree:20,objectifs:["Conjuguer TO BE à toutes les personnes","Construire phrases affirmatives/négatives/interrogatives","Utiliser les contractions"],contenu:[{type:'intro',texte:"Le verbe TO BE (être) est le verbe le plus important en anglais. Il permet de décrire des personnes, des lieux et des états. Maîtriser TO BE, c'est poser la première pierre de votre anglais."},{type:'tableau',titre:'Conjugaison — TO BE au présent',headers:["Personne","Forme pleine","Contraction","Exemple"],rows:[["I","am","I'm","I'm a student."],["You","are","You're","You're my friend."],["He/She/It","is","He's/She's/It's","She's a doctor."],["We","are","We're","We're from Abidjan."],["They","are","They're","They're very kind."]]},{type:'regle',titre:'Forme Négative',texte:"Ajoutez NOT après le verbe BE.\nI am not (I'm not) · He is not (He isn't) · They are not (They aren't)"},{type:'regle',titre:'Forme Interrogative',texte:"Inversez le sujet et le verbe.\nAm I late? · Is she happy? · Are they students?"},{type:'exemples',titre:'Exemples en contexte',items:[{en:"I am 17 years old.",fr:"J'ai 17 ans."},{en:"She isn't at home right now.",fr:"Elle n'est pas à la maison en ce moment."},{en:"Are you from Côte d'Ivoire?",fr:"Es-tu de Côte d'Ivoire ?"},{en:"We're very excited about the exam.",fr:"Nous sommes très enthousiastes."}]},{type:'conseil',texte:"Astuce AGTM : Mémorisez les contractions dès le début. En anglais naturel, on dit toujours 'I'm' et jamais 'I am' dans la conversation."}],quiz:[{q:"___ a student at AGTM Academy.",opts:["A) I is","B) I am","C) I are","D) Am I"],rep:'B',expl:"'I am' est la seule forme correcte."},{q:"She ___ from Abidjan.",opts:["A) am","B) are","C) is","D) be"],rep:'C',expl:"Avec She/He/It, on utilise toujours IS."},{q:"They ___ not ready for the test.",opts:["A) is","B) am","C) are","D) be"],rep:'C',expl:"Avec They, on utilise ARE."},{q:"___ you a teacher?",opts:["A) Is","B) Am","C) Are","D) Be"],rep:'C',expl:"La question avec YOU utilise ARE."},{q:"We ___ very happy today.",opts:["A) is","B) am","C) are","D) be"],rep:'C',expl:"WE utilise toujours ARE."},{q:"Forme contractée de 'He is not' :",opts:["A) He'sn't","B) He isn't","C) He not is","D) He amn't"],rep:'B',expl:"La contraction correcte est 'He isn't'."},{q:"It ___ a beautiful day.",opts:["A) are","B) am","C) is","D) be"],rep:'C',expl:"IT utilise IS."},{q:"___ I late for class?",opts:["A) Are","B) Is","C) Am","D) Be"],rep:'C',expl:"La question avec I utilise AM."}]},
      {id:'gram_a1_m2',titre:'Le Présent Simple — Actions et habitudes',niveau:'A1',duree:25,objectifs:["Former le présent simple","Employer pour les habitudes et vérités générales","Appliquer la règle du -S à la 3ème personne"],contenu:[{type:'intro',texte:"Le présent simple exprime les habitudes, les routines, les vérités générales et les goûts. C'est le temps de la régularité."},{type:'tableau',titre:'Formation du Présent Simple',headers:["Forme","Règle","Exemple"],rows:[["Affirmative (I/You/We/They)","Verbe base","I study English every day."],["Affirmative (He/She/It)","Verbe + -S / -ES","She studies every evening."],["Négative","do/does not + verbe","He doesn't like coffee."],["Interrogative","Do/Does + sujet + verbe ?","Do you speak French?"]]},{type:'regle',titre:'Règle du -S (3ème personne)',texte:"• Verbes réguliers : + -S → works, plays\n• Finales -ch/-sh/-x/-o : + -ES → watches, goes\n• Finale -y après consonne : → -IES → study → studies\n• Exceptions : have → has · be → is"},{type:'exemples',titre:'Utilisation',items:[{en:"I wake up at 6 a.m. every day.",fr:"Je me lève à 6h tous les jours. (habitude)"},{en:"Water boils at 100°C.",fr:"L'eau bout à 100°C. (vérité générale)"},{en:"She doesn't eat meat.",fr:"Elle ne mange pas de viande."},{en:"Does he play football on weekends?",fr:"Joue-t-il au foot le week-end ?"}]},{type:'marqueurs',titre:'Marqueurs temporels',items:["always (toujours)","usually (d'habitude)","often (souvent)","sometimes (parfois)","rarely (rarement)","never (jamais)","every day/week/year"]}],quiz:[{q:"She ___ to school by bus every day.",opts:["A) go","B) goes","C) going","D) gone"],rep:'B',expl:"3ème personne → go + ES = goes."},{q:"They ___ English very well.",opts:["A) speaks","B) speak","C) speaking","D) spoken"],rep:'B',expl:"Avec THEY, pas de -S."},{q:"He ___ not like spicy food.",opts:["A) do","B) does","C) is","D) are"],rep:'B',expl:"He/She/It → DOES NOT."},{q:"___ you study every evening?",opts:["A) Does","B) Is","C) Do","D) Are"],rep:'C',expl:"Question avec YOU → DO you...?"},{q:"Water ___ at 100 degrees.",opts:["A) boil","B) boils","C) boiling","D) boiled"],rep:'B',expl:"Vérité générale + 3ème personne → boils."},{q:"She ___ her homework (watch → pattern).",opts:["A) watchs","B) watch","C) watches","D) watching"],rep:'C',expl:"watch finit par -CH → + -ES : watches."},{q:"He study → 3ème personne :",opts:["A) studys","B) studies","C) studyes","D) study's"],rep:'B',expl:"study → -Y → -IES : studies."},{q:"___ she speak Arabic?",opts:["A) Do","B) Is","C) Does","D) Are"],rep:'C',expl:"Question avec She → DOES she...?"}]},
      {id:'gram_a1_m3',titre:'Les Articles — A, AN, THE',niveau:'A1',duree:20,objectifs:["Distinguer article indéfini (a/an) et défini (the)","Choisir entre A et AN selon le son initial","Identifier les cas sans article"],contenu:[{type:'intro',texte:"Les articles sont parmi les éléments les plus utilisés en anglais. Bien les maîtriser évite de nombreuses erreurs."},{type:'tableau',titre:'Les trois articles',headers:["Article","Usage","Exemples"],rows:[["A","1 chose indéfinie, consonne initiale","a book, a student, a car"],["AN","1 chose indéfinie, voyelle initiale","an apple, an engineer, an hour"],["THE","Chose définie / déjà mentionnée / unique","the sun, the teacher, the book I gave you"],["∅ (rien)","Noms propres, langues, matières, sports","I speak French. I play football."]]},{type:'regle',titre:'A vs AN — Règle du son',texte:"La règle s'applique au SON, pas à la lettre.\n• AN hour (/aʊər/ → H muet = voyelle)\n• A university (/juː/ → son consonantique)\n• AN honest man (/ɒnɪst/ → H muet)"},{type:'exemples',titre:'Exemples pratiques',items:[{en:"I have a dog and a cat.",fr:"J'ai un chien et un chat. (indéfini, 1ère mention)"},{en:"The dog is very friendly.",fr:"Le chien est très gentil. (déjà mentionné)"},{en:"She is an engineer.",fr:"Elle est ingénieure. (profession, voyelle)"},{en:"I study mathematics.",fr:"J'étudie les mathématiques. (matière → pas d'article)"}]}],quiz:[{q:"She is ___ doctor.",opts:["A) a","B) an","C) the","D) —"],rep:'A',expl:"'doctor' commence par /d/ → consonne → A doctor."},{q:"I saw ___ elephant at the zoo.",opts:["A) a","B) an","C) the","D) —"],rep:'B',expl:"'elephant' → voyelle /ɛ/ → AN elephant."},{q:"___ sun rises in the east.",opts:["A) A","B) An","C) The","D) —"],rep:'C',expl:"Le soleil est unique → THE sun."},{q:"I play ___ football every weekend.",opts:["A) a","B) an","C) the","D) —"],rep:'D',expl:"Avec les sports, pas d'article."},{q:"She gave me ___ book. ___ book was very interesting.",opts:["A) a / The","B) the / A","C) a / A","D) an / An"],rep:'A',expl:"1ère mention → A book. 2ème mention → The book."},{q:"___ honest man always tells the truth.",opts:["A) A","B) An","C) The","D) —"],rep:'B',expl:"'honest' a un H muet → son voyelle → AN honest."},{q:"I speak ___ English very well.",opts:["A) a","B) an","C) the","D) —"],rep:'D',expl:"Les langues s'utilisent sans article."},{q:"He is ___ university student.",opts:["A) a","B) an","C) the","D) —"],rep:'A',expl:"'university' commence par le son /juː/ → consonne → A university."}]},
      {id:'gram_a2_m1',titre:'Le Présent Continu — Actions en cours',niveau:'A2',duree:25,objectifs:["Former le présent continu","Distinguer présent simple et présent continu","Identifier les stative verbs"],contenu:[{type:'intro',texte:"Le présent continu décrit une action qui se déroule EN CE MOMENT ou une situation temporaire. Il s'oppose au présent simple qui exprime l'habitude."},{type:'tableau',titre:'Formation : BE + V-ING',headers:["Forme","Structure","Exemple"],rows:[["Affirmative","sujet + BE + V-ING","She is reading a novel."],["Négative","sujet + BE + NOT + V-ING","They aren't sleeping."],["Interrogative","BE + sujet + V-ING ?","Is he working right now?"]]},{type:'regle',titre:'Orthographe de -ING',texte:"• Règle générale : + -ING → reading, playing\n• Finale -E muet : enlever -E → write → writing\n• Consonne CVC accentuée : doubler → run → running, sit → sitting\n• Exception : open → opening"},{type:'contraste',titre:'Présent Simple vs Présent Continu',headers:["Présent Simple","Présent Continu"],rows:[["I work at AGTM. (habitude)","I'm working late tonight. (maintenant)"],["She lives in Cocody. (permanent)","She's staying at a hotel. (temporaire)"],["He always reads before bed.","He's reading now — don't disturb him."]]},{type:'regle',titre:'Stative Verbs — sans -ING',texte:"Ces verbes expriment un ÉTAT → jamais en -ING :\nknow, understand, believe, want, need, like, love, hate, see, hear, smell, taste, seem, appear, own, have (possession).\n\nEx : I know the answer. ✓ / I am knowing the answer. ✗"}],quiz:[{q:"Listen! The children ___ in the garden.",opts:["A) play","B) plays","C) are playing","D) is playing"],rep:'C',expl:"'Listen!' → action EN CE MOMENT → présent continu. Sujet pluriel → ARE playing."},{q:"She usually ___ to work by bus, but today she ___ her car.",opts:["A) goes / is driving","B) is going / drives","C) goes / drives","D) is going / is driving"],rep:'A',expl:"Usually → habitude. Today → présent continu."},{q:"I ___ what you mean.",opts:["A) am understanding","B) understand","C) is understanding","D) understanding"],rep:'B',expl:"'understand' est un stative verb → jamais en -ING."},{q:"Orthographe correcte de 'swim' en -ING :",opts:["A) swiming","B) swimeing","C) swimming","D) swimms"],rep:'C',expl:"swim = CVC → doubler la consonne : swimming."},{q:"___ you listening to me right now?",opts:["A) Do","B) Does","C) Is","D) Are"],rep:'D',expl:"Présent continu avec YOU → ARE you...?"},{q:"She ___ (write) an email at the moment.",opts:["A) is writting","B) is writing","C) writes","D) written"],rep:'B',expl:"write → enlever -E → writing (un seul T)."},{q:"I ___ coffee — I prefer tea.",opts:["A) am not liking","B) don't like","C) isn't liking","D) not like"],rep:'B',expl:"'like' est un stative verb → présent simple négatif."},{q:"What ___ you ___ this evening?",opts:["A) do / do","B) are / doing","C) is / doing","D) do / doing"],rep:'B',expl:"Plan futur proche → présent continu."}]},
      {id:'gram_a2_m2',titre:'Le Passé Simple — Faits accomplis',niveau:'A2',duree:30,objectifs:["Former le passé simple régulier et irrégulier","Narrer des événements passés terminés","Utiliser les marqueurs temporels du passé"],contenu:[{type:'intro',texte:"Le passé simple (Past Simple) s'utilise pour parler d'actions TERMINÉES dans le passé, avec un moment précis."},{type:'tableau',titre:'Formation',headers:["Type","Affirmatif","Négatif","Interrogatif"],rows:[["Verbes réguliers","V + -ED (worked)","didn't + V base","Did + sujet + V base ?"],["Verbes irréguliers","Forme irrégulière (went)","didn't + V base","Did + sujet + V base ?"]]},{type:'regle',titre:"Règles d'orthographe du -ED",texte:"• Règle générale : + ED → work → worked\n• Finale -E : + D seulement → live → lived\n• Consonne + Y : -Y → -IED → study → studied\n• CVC accentué : doubler → stop → stopped"},{type:'tableau',titre:'20 Verbes Irréguliers Essentiels',headers:["Base","Passé","Traduction"],rows:[["be","was/were","être"],["go","went","aller"],["come","came","venir"],["do","did","faire"],["have","had","avoir"],["take","took","prendre"],["give","gave","donner"],["see","saw","voir"],["say","said","dire"],["know","knew","savoir"],["think","thought","penser"],["make","made","faire"],["get","got","obtenir"],["find","found","trouver"],["tell","told","dire"],["write","wrote","écrire"],["read","read","lire"],["speak","spoke","parler"],["leave","left","partir"],["feel","felt","ressentir"]]},{type:'marqueurs',titre:'Marqueurs du passé simple',items:["yesterday","last week/month/year","ago (3 days ago)","in 2020","when I was young","at that moment","then","after that"]}],quiz:[{q:"She ___ (go) to the market yesterday.",opts:["A) goed","B) goes","C) went","D) gone"],rep:'C',expl:"'go' est irrégulier → passé simple : went."},{q:"I ___ (not study) last night — I was tired.",opts:["A) not studied","B) didn't study","C) didn't studied","D) don't study"],rep:'B',expl:"Négatif au passé simple : didn't + verbe BASE."},{q:"___ you see the game last night?",opts:["A) Do","B) Does","C) Did","D) Were"],rep:'C',expl:"Question au passé simple → DID + sujet + verbe base."},{q:"They ___ in Paris three years ___.",opts:["A) live / before","B) lived / ago","C) were living / ago","D) had lived / before"],rep:'B',expl:"Passé terminé → 'three years AGO'. 'lived' = passé simple."},{q:"Forme correcte de 'stop' au passé :",opts:["A) stoped","B) stopted","C) stopped","D) stopt"],rep:'C',expl:"stop = CVC → doubler le P : stopped."},{q:"She ___ (study) medicine at university.",opts:["A) studyed","B) studied","C) studded","D) studies"],rep:'B',expl:"study → -Y → -IED : studied."},{q:"The meeting ___ at 9 a.m. and ___ at 11.",opts:["A) started / ended","B) start / end","C) was starting / ending","D) has started / ended"],rep:'A',expl:"Deux événements passés terminés → passé simple."},{q:"When ___ you last ___ him?",opts:["A) did / saw","B) did / see","C) do / see","D) have / seen"],rep:'B',expl:"DID + verbe BASE → did you see."}]},
      {id:'gram_a2_m3',titre:'Les Modaux — Can, Must, Should',niveau:'A2',duree:25,objectifs:["Utiliser CAN pour la capacité et la permission","Utiliser MUST pour l'obligation et SHOULD pour le conseil","Former correctement les phrases avec les modaux"],contenu:[{type:'intro',texte:"Les verbes modaux expriment des nuances comme la capacité, l'obligation, la permission ou le conseil. Ils sont invariables et toujours suivis d'un verbe base."},{type:'regle',titre:'Règle fondamentale',texte:"Modal + verbe BASE (sans to, sans -S, sans -ED)\n✓ She can speak three languages.\n✗ She can to speak / She cans speak."},{type:'tableau',titre:'Les modaux essentiels A2',headers:["Modal","Usage principal","Exemple","Négatif"],rows:[["CAN","Capacité / Permission","I can swim very well.","I can't swim."],["COULD","Capacité passée / Demande polie","She could read at age 4.","She couldn't read."],["MUST","Obligation forte (interne)","You must wear a seatbelt.","You mustn't text while driving."],["HAVE TO","Obligation externe (règle)","I have to wear a uniform.","I don't have to work Sundays."],["SHOULD","Conseil / Recommandation","You should study every day.","You shouldn't skip class."],["MAY/MIGHT","Possibilité / Permission formelle","It may rain later.","It might not be ready."]]},{type:'contraste',titre:'MUST vs HAVE TO vs SHOULD',headers:["Modal","Nuance","Exemple"],rows:[["MUST","Obligation personnelle, interne","I must call my mother."],["HAVE TO","Obligation externe, règle imposée","I have to submit my essay by Friday."],["SHOULD","Conseil, pas d'obligation","You should eat more vegetables."],["MUSTN'T","Interdiction absolue","You mustn't use your phone during the exam."],["DON'T HAVE TO","Absence d'obligation","You don't have to come — it's optional."]]}],quiz:[{q:"She ___ play the piano since she was 5.",opts:["A) can","B) could","C) should","D) must"],rep:'B',expl:"Capacité dans le PASSÉ → COULD."},{q:"You ___ smoke in this building. It's forbidden.",opts:["A) mustn't","B) don't have to","C) shouldn't","D) can't"],rep:'A',expl:"Interdiction absolue → MUSTN'T."},{q:"On weekends, employees ___ work. It's their day off.",opts:["A) mustn't","B) don't have to","C) can't","D) shouldn't"],rep:'B',expl:"Absence d'obligation → DON'T HAVE TO."},{q:"I feel sick. I think I ___ see a doctor.",opts:["A) must","B) can","C) should","D) could"],rep:'C',expl:"Conseil → SHOULD."},{q:"Erreur dans : 'She cans speak English.'",opts:["A) Cans → can","B) Speak → spoke","C) Speak → speaks","D) Aucune erreur"],rep:'A',expl:"Les modaux sont invariables : jamais de -S."},{q:"Students ___ wear uniforms at our school. It's the rule.",opts:["A) should","B) can","C) have to","D) might"],rep:'C',expl:"Obligation externe (règle) → HAVE TO."},{q:"___ I borrow your pen, please?",opts:["A) Must","B) Should","C) Can","D) Have to"],rep:'C',expl:"Permission polie → CAN I...?"},{q:"It's cloudy. It ___ rain this afternoon.",opts:["A) must","B) might","C) should","D) have to"],rep:'B',expl:"Possibilité incertaine → MIGHT."}]},
      {id:'gram_b1_m1',titre:'Present Perfect vs Passé Simple',niveau:'B1',duree:35,objectifs:["Distinguer Present Perfect et Past Simple","Identifier les marqueurs temporels de chaque temps","Éviter les erreurs de traduction"],contenu:[{type:'intro',texte:"C'est l'un des points les plus difficiles pour les francophones. En anglais, la distinction entre ces deux temps est fondamentale."},{type:'tableau',titre:'Present Perfect vs Past Simple',headers:["Critère","Present Perfect (have + PP)","Past Simple (V-ed / irrég.)"],rows:[["Lien avec le présent","OUI — résultat visible maintenant","NON — coupé du présent"],["Moment précis","NON spécifié","OUI ou implicite"],["Expérience de vie","OUI (ever, never, before)","NON (moment précis requis)"],["Nouvelles récentes","OUI (just, already, yet)","NON"],["Marqueurs typiques","ever, never, just, already, yet, since, for","yesterday, last week, in 2020, ago"]]},{type:'exemples',titre:'Comparaison directe',items:[{en:"I have visited Paris. (experience — no specific time)",fr:"J'ai visité Paris. (dans ma vie)"},{en:"I visited Paris last summer. (specific time)",fr:"J'ai visité Paris l'été dernier."},{en:"She has just finished her homework.",fr:"Elle vient de finir ses devoirs."},{en:"She finished her homework at 9 p.m.",fr:"Elle a fini ses devoirs à 21h. (moment précis)"}]},{type:'regle',titre:'SINCE vs FOR',texte:"• FOR + durée → I have lived here FOR three years.\n• SINCE + point de départ → I have lived here SINCE 2021."}],quiz:[{q:"I ___ never ___ sushi before. (manger)",opts:["A) have / eaten","B) did / eat","C) have / ate","D) had / eaten"],rep:'A',expl:"Experience de vie avec NEVER → Present Perfect. have + eaten."},{q:"She ___ the new director last Monday.",opts:["A) has met","B) met","C) meets","D) has meet"],rep:'B',expl:"Moment précis 'last Monday' → Past Simple : met."},{q:"They ___ in this city ___ 2018.",opts:["A) live / since","B) have lived / since","C) have lived / for","D) lived / since"],rep:'B',expl:"Situation qui dure + point de départ → Present Perfect + SINCE."},{q:"___ you ever ___ to New York?",opts:["A) Did / go","B) Have / gone","C) Have / been","D) Did / been"],rep:'C',expl:"Expérience de vie avec EVER → Present Perfect."},{q:"He ___ his keys. He can't find them anywhere!",opts:["A) lost","B) has lost","C) loses","D) did lose"],rep:'B',expl:"Résultat présent visible → Present Perfect."},{q:"I ___ this book ___ three weeks.",opts:["A) read / since","B) have read / for","C) have read / since","D) read / for"],rep:'B',expl:"Durée (three weeks = période) → Present Perfect + FOR."},{q:"The president ___ a speech yesterday evening.",opts:["A) has given","B) gives","C) gave","D) has gave"],rep:'C',expl:"Moment précis → Past Simple : gave."},{q:"I ___ already ___ my report — you can check it.",opts:["A) did / finish","B) have / finished","C) had / finished","D) have / finish"],rep:'B',expl:"ALREADY + résultat présent → Present Perfect."}]},
      {id:'gram_b1_m2',titre:'La Voix Passive',niveau:'B1',duree:30,objectifs:["Former la voix passive à tous les temps","Transformer des phrases actives en passives","Comprendre quand utiliser la voix passive"],contenu:[{type:'intro',texte:"La voix passive met en avant le RÉSULTAT de l'action plutôt que l'auteur. Elle est très utilisée en anglais formel, scientifique et journalistique."},{type:'regle',titre:'Formule générale',texte:"SUJET + BE (conjugué) + PARTICIPE PASSÉ (+ by + agent)"},{type:'tableau',titre:'Voix passive aux temps principaux',headers:["Temps","Actif","Passif"],rows:[["Présent simple","They make cocoa in Ghana.","Cocoa is made in Ghana."],["Passé simple","The police arrested the thief.","The thief was arrested."],["Futur (will)","They will build a new bridge.","A new bridge will be built."],["Present Perfect","Scientists have discovered a cure.","A cure has been discovered."],["Modaux","You must submit the form.","The form must be submitted."]]},{type:'regle',titre:"Quand omettre 'by + agent' ?",texte:"On omet l'agent quand :\n1. Il est inconnu → My bike was stolen.\n2. Il est évident → He was arrested.\n3. Il n'est pas important → The report was submitted on time."},{type:'exemples',titre:'Transformation Active → Passive',items:[{en:"Active: Farmers harvest cocoa every year.",fr:"Passif: Cocoa is harvested every year."},{en:"Active: They are building a new school.",fr:"Passif: A new school is being built."},{en:"Active: The government passed a new law.",fr:"Passif: A new law was passed by the government."}]}],quiz:[{q:"English ___ all over the world. (speak)",opts:["A) speaks","B) is spoken","C) is speaking","D) was spoke"],rep:'B',expl:"Présent simple passif : is + spoken."},{q:"The Eiffel Tower ___ in 1889. (build)",opts:["A) was built","B) is built","C) built","D) has been build"],rep:'A',expl:"Passé simple passif : was + built."},{q:"A new hospital ___ next year. (open)",opts:["A) is opened","B) opened","C) will be opened","D) has been opened"],rep:'C',expl:"Futur passif : will be + opened."},{q:"This report ___ submit by tomorrow. (must)",opts:["A) must submitted","B) must be submitted","C) must be submit","D) must submit"],rep:'B',expl:"Modal passif : must be + participe passé."},{q:"Transformer : 'They have cancelled the concert.'",opts:["A) The concert is cancelled.","B) The concert has been cancelled.","C) The concert was cancelled.","D) The concert will be cancelled."],rep:'B',expl:"Present Perfect passif : has been + cancelled."},{q:"My wallet ___ while I was on the bus.",opts:["A) was stolen","B) is stolen","C) stole","D) has stolen"],rep:'A',expl:"Action passée + agent inconnu → passé simple passif."},{q:"The results ___ announced tomorrow morning.",opts:["A) are going to announced","B) will be announced","C) are announced","D) were announced"],rep:'B',expl:"Futur passif : will be + announced."},{q:"The car ___ at the moment. (repair)",opts:["A) is repaired","B) was repaired","C) is being repaired","D) has been repaired"],rep:'C',expl:"Présent continu passif : is being + repaired."}]},
      {id:'gram_b2_m1',titre:'Les Conditionnels — Types 0 à 3 et Mixed',niveau:'B2',duree:40,objectifs:["Maîtriser les quatre types de conditionnels","Utiliser le conditionnel mixte (mixed conditional)","Exprimer des hypothèses avec précision"],contenu:[{type:'intro',texte:"Les conditionnels expriment des hypothèses et leurs conséquences. La maîtrise des 4 types est indispensable pour le BAC et les examens avancés."},{type:'tableau',titre:'Les 4 Types de Conditionnels',headers:["Type","If-clause","Main clause","Usage"],rows:[["Type 0","If + présent simple","Présent simple","Vérité générale / fait scientifique"],["Type 1","If + présent simple","will + base","Situation réelle, probable (futur)"],["Type 2","If + past simple","would + base","Situation imaginaire, peu probable"],["Type 3","If + past perfect","would have + PP","Situation impossible dans le passé"],["Mixed","If + past perfect","would + base","Condition passée → conséquence présente"]]},{type:'exemples',titre:'Exemples commentés',items:[{en:"Type 0: If you heat water to 100°C, it boils.",fr:"Vérité scientifique → présent simple + présent simple."},{en:"Type 1: If it rains tomorrow, we will cancel the trip.",fr:"Situation réelle et probable → présent simple + will."},{en:"Type 2: If I won the lottery, I would travel the world.",fr:"Situation hypothétique → past simple + would."},{en:"Type 3: If I had studied harder, I would have passed.",fr:"Regret / impossibilité → past perfect + would have."},{en:"Mixed: If she had taken the job, she would be rich now.",fr:"Condition passée, conséquence au présent."}]},{type:'conseil',texte:"Astuce AGTM : Pour le BAC, concentrez-vous sur les Types 1, 2 et 3. Le Mixed conditionnel apparaît dans les rédactions C1-C2."}],quiz:[{q:"If she ___ harder, she ___ the exam.",opts:["A) studied / would pass","B) studies / will pass","C) had studied / would have passed","D) studies / passes"],rep:'C',expl:"Regret sur le passé → Type 3 : If + past perfect / would have + PP."},{q:"If water ___ to 0°C, it ___.",opts:["A) freezes / will freeze","B) cools / cooled","C) is cooled / freezes","D) cools / freezes"],rep:'D',expl:"Vérité scientifique → Type 0 : les deux au présent simple."},{q:"If I ___ you, I ___ accept that offer.",opts:["A) am / will","B) were / would","C) had been / would have","D) am / would"],rep:'B',expl:"Conseil hypothétique → Type 2 : If I were you, I would..."},{q:"If you ___ me earlier, I ___ able to help.",opts:["A) told / would be","B) had told / would have been","C) tell / am","D) had told / would be"],rep:'B',expl:"Condition passée, conséquence passée → Type 3."},{q:"If it ___ tomorrow, the match ___ cancelled.",opts:["A) rained / would be","B) rains / will be","C) had rained / would have been","D) rains / is"],rep:'B',expl:"Situation réelle et probable → Type 1."},{q:"If she ___ the job last year, she ___ in Paris now.",opts:["A) took / would be","B) had taken / would be","C) had taken / would have been","D) took / will be"],rep:'B',expl:"Mixed conditional : condition passée → conséquence présente."},{q:"If you ___ the instructions, the machine ___ properly.",opts:["A) follow / works","B) followed / would worked","C) follow / will work","D) had followed / will work"],rep:'A',expl:"Type 0 : vérité générale. Présent simple + présent simple."},{q:"She wishes she ___ more time to study.",opts:["A) has","B) have","C) had","D) would have"],rep:'C',expl:"Wish + past simple exprime un regret présent (équivalent Type 2)."}]},
      {id:'gram_b2_m2',titre:'Le Discours Rapporté — Reported Speech',niveau:'B2',duree:35,objectifs:["Rapporter des paroles et pensées en anglais","Appliquer la concordance des temps","Transformer questions et ordres au discours indirect"],contenu:[{type:'intro',texte:"Le discours rapporté (Reported Speech) permet de retranscrire ce que quelqu'un a dit sans le citer directement."},{type:'tableau',titre:'Concordance des Temps',headers:["Direct Speech","Reported Speech","Exemple"],rows:[["Present Simple","Past Simple",'"I work here." → He said he worked there.'],["Present Continuous","Past Continuous",'"I am studying." → She said she was studying.'],["Past Simple","Past Perfect",'"I went." → He said he had gone.'],["Present Perfect","Past Perfect",'"I have finished." → She said she had finished.'],["Will","Would",'"I will call." → He said he would call.'],["Can","Could",'"I can help." → She said she could help.'],["Must","Had to",'"You must leave." → He said I had to leave.']]},{type:'regle',titre:'Questions Indirectes',texte:"• Questions Yes/No → if/whether : 'Are you ready?' → He asked if I was ready.\n• Questions Wh- → wh + ordre normal : 'Where do you live?' → She asked where I lived.\n• IMPORTANT : pas d'inversion sujet-verbe dans la question indirecte."},{type:'regle',titre:'Ordres et Demandes (Imperatives)',texte:"• Ordres → told + to-infinitif : 'Open the window!' → He told me to open the window.\n• Ordres négatifs → told + not + to-infinitif : 'Don't be late!' → She told me not to be late."},{type:'tableau',titre:'Changements de temps et pronoms',headers:["Direct","Indirect"],rows:[["now","then / at that moment"],["today","that day"],["yesterday","the day before"],["tomorrow","the next day"],["last week","the week before"],["here","there"],["this","that"]]}],quiz:[{q:"'I am tired.' She said that she ___ tired.",opts:["A) is","B) was","C) were","D) has been"],rep:'B',expl:"Present Simple → Past Simple en discours rapporté."},{q:"'I have already eaten.' He told me that he ___ already ___.",opts:["A) had / eaten","B) has / eaten","C) have / eaten","D) had / eat"],rep:'A',expl:"Present Perfect → Past Perfect : had already eaten."},{q:"'Will you come?' She asked me if I ___ come.",opts:["A) will","B) would","C) could","D) should"],rep:'B',expl:"Will → Would en discours rapporté."},{q:"'Where do you live?' He asked me where I ___.",opts:["A) lived","B) did live","C) do live","D) living"],rep:'A',expl:"Question Wh- indirecte : ordre normal, pas d'inversion."},{q:"'Don't touch that!' She told me ___ that.",opts:["A) not touch","B) not to touch","C) to not touch","D) don't touch"],rep:'B',expl:"Ordre négatif indirect : told me NOT TO + infinitif."},{q:"'I can speak four languages.' She said she ___ speak four languages.",opts:["A) can","B) could","C) must","D) might"],rep:'B',expl:"Can → Could en discours rapporté."},{q:"'Come here now!' → He told me to go ___ ___.",opts:["A) here / now","B) there / then","C) here / then","D) there / now"],rep:'B',expl:"here → there, now → then."},{q:"'Are you ready?' She asked me ___ I ___ ready.",opts:["A) if / was","B) that / was","C) if / am","D) whether / am"],rep:'A',expl:"Question Yes/No → if + ordre normal + concordance."}]},
      {id:'gram_c1_m1',titre:'Structures Avancées — Inversions et Emphases',niveau:'C1',duree:40,objectifs:["Maîtriser les inversions stylistiques en anglais formel","Utiliser les structures clivées (cleft sentences)","Employer des structures d'emphase"],contenu:[{type:'intro',texte:"Les structures avancées permettent d'enrichir l'expression écrite et orale au niveau C1-C2. Elles sont fréquentes dans les essais académiques, la presse et la littérature."},{type:'tableau',titre:'Inversions stylistiques',headers:["Structure","Usage","Exemple"],rows:[["Never / Rarely / Seldom + aux + sujet","Emphase sur la rareté","Never have I seen such dedication."],["Not only... but also","Double affirmation","Not only did she pass, but she also got top marks."],["Hardly/Scarcely... when","Séquence immédiate","Hardly had I arrived when it started raining."],["Only + when/after/if + inversion","Restriction","Only when you understand the rules can you break them."],["So/Such... that","Emphase sur le degré","So difficult was the exam that half the students failed."]]},{type:'tableau',titre:'Phrases Clivées (Cleft Sentences)',headers:["Type","Structure","Exemple"],rows:[["It-cleft","It is/was + X + that/who...","It was Issa Bamba who founded AGTM."],["Wh-cleft","What + clause + is/was + X","What I need is more practice."],["All-cleft","All + clause + is/was + to-inf","All I want is to pass this exam."]]},{type:'conseil',texte:"Astuce AGTM : Intégrez 1 ou 2 inversions dans vos essais C1-C2. Cela montre une maîtrise stylistique avancée et impressionne les correcteurs."}],quiz:[{q:"___ have I witnessed such an extraordinary performance.",opts:["A) Never","B) Not","C) Rarely ever","D) Hardly"],rep:'A',expl:"Inversion après Never : Never have I witnessed..."},{q:"Not only ___ the exam, but he also received a scholarship.",opts:["A) he passed","B) did he pass","C) he did pass","D) passed he"],rep:'B',expl:"Not only → inversion : Not only DID he PASS."},{q:"___ I sat down ___ the phone rang.",opts:["A) Hardly / when","B) Never / that","C) Rarely / when","D) Scarcely / than"],rep:'A',expl:"Hardly... when = à peine... que."},{q:"It was ___ who discovered the solution.",opts:["A) her","B) she","C) hers","D) herself"],rep:'B',expl:"Après 'It was + who', on utilise le pronom sujet."},{q:"___ I truly need is more confidence.",opts:["A) That","B) It","C) What","D) Which"],rep:'C',expl:"Wh-cleft : What I need... Emphase sur ce dont on a besoin."},{q:"Reformuler : 'I had barely entered the room before they stood up.'",opts:["A) Barely I had entered...","B) Barely had I entered...","C) I barely had entered...","D) Had barely I entered..."],rep:'B',expl:"Inversion après barely : Barely HAD I entered..."},{q:"So ___ was the problem that no one could solve it.",opts:["A) difficulty","B) difficultly","C) difficult","D) difficile"],rep:'C',expl:"So + adjectif + was + sujet : So difficult was the problem..."},{q:"Only ___ I understand how hard teaching is.",opts:["A) now do","B) now I do","C) I do now","D) I now do"],rep:'A',expl:"Only + now → inversion : Only now DO I understand..."}]},

      // ── PRONOMS ANGLAIS PARTIE 1 (A1) ──────────────────────────────
      {id:'gram_a1_m4',titre:'Les Pronoms en Anglais — Partie 1',niveau:'A1',duree:30,
       objectifs:["Identifier et utiliser les pronoms sujets","Maîtriser les pronoms compléments","Employer correctement les adjectifs possessifs","Distinguer this / that / these / those"],
       contenu:[
        {type:'intro',texte:"Les pronoms sont des mots qui remplacent un nom. Ils évitent les répétitions et rendent la communication plus fluide. Dans cette partie, vous allez découvrir les quatre types essentiels pour les débutants."},
        {type:'tableau',titre:'Pronoms Sujets (Subject Pronouns)',headers:['Personne','Singulier','Pluriel'],rows:[['1ʳᵉ','I (je)','We (nous)'],['2ᵉ','You (tu/vous)','You (vous)'],['3ᵉ masc.','He (il)','—'],['3ᵉ fém.','She (elle)','—'],['3ᵉ neutre','It (il/elle)','They (ils/elles)']]},
        {type:'regle',texte:"Les pronoms sujets se placent AVANT le verbe. Ils indiquent QUI fait l'action. Ex : She reads. / They play. / It rains."},
        {type:'tableau',titre:'Pronoms Compléments (Object Pronouns)',headers:['Sujet','Complément'],rows:[['I','me'],['You','you'],['He','him'],['She','her'],['It','it'],['We','us'],['They','them']]},
        {type:'regle',texte:"Les pronoms compléments se placent APRÈS le verbe ou une préposition. Ex : Call me! / I like him. / She looks at them."},
        {type:'tableau',titre:'Adjectifs Possessifs (Possessive Adjectives)',headers:['Sujet','Adjectif possessif'],rows:[['I','my (mon/ma/mes)'],['You','your (ton/votre)'],['He','his (son — masc.)'],['She','her (son — fém.)'],['It','its (son — neutre)'],['We','our (notre/nos)'],['They','their (leur/leurs)']]},
        {type:'conseil',texte:"⚠️ Attention : l'adjectif possessif se place DEVANT un nom (my book, her car). Ne le confondez pas avec le pronom possessif (mine, hers) qui s'utilise seul."},
        {type:'tableau',titre:'Pronoms Démonstratifs (Demonstrative Pronouns)',headers:['Distance','Singulier','Pluriel'],rows:[['Proche','This (ceci)','These (ceux-ci)'],['Éloigné','That (cela)','Those (ceux-là)']]},
        {type:'exemples',liste:["This is my pen. (Ce stylo est le mien — proche)","That is your car. (C'est ta voiture — loin)","These are my books. (Ce sont mes livres — proches)","Those are her shoes. (Ce sont ses chaussures — loin)"]}
       ],
       quiz:[
        {q:"The cat is hungry. ___ wants food.",opts:["A) He","B) She","C) It","D) They"],rep:'C',expl:"Pour un animal ou une chose non genrée, on utilise 'It'."},
        {q:"The students are late. ___ missed the bus.",opts:["A) He","B) She","C) It","D) They"],rep:'D',expl:"'Students' est pluriel → They."},
        {q:"I called my teacher. ___ helped me a lot.",opts:["A) He","B) She","C) It","D) They"],rep:'B',expl:"'My teacher' est féminin dans le contexte → She."},
        {q:"Please give ___ the report. (to me)",opts:["A) I","B) me","C) my","D) mine"],rep:'B',expl:"Après un verbe, on utilise le pronom complément 'me', pas le sujet 'I'."},
        {q:"I like ___. He is very funny. (my friend Tom)",opts:["A) he","B) his","C) him","D) himself"],rep:'C',expl:"Après 'like' (verbe), on utilise le pronom complément 'him'."},
        {q:"___ is my bag. (pointing to a bag right next to you)",opts:["A) That","B) Those","C) These","D) This"],rep:'D',expl:"Objet proche + singulier → This."},
        {q:"Look at ___ shoes over there! (far, plural)",opts:["A) this","B) that","C) those","D) these"],rep:'C',expl:"Objets éloignés + pluriel → Those."},
        {q:"___ car is very fast. (belonging to us)",opts:["A) Our","B) Ours","C) We","D) Us"],rep:'A',expl:"Devant un nom ('car'), on utilise l'adjectif possessif 'our'."},
        {q:"The dog wagged ___ tail.",opts:["A) his","B) her","C) its","D) their"],rep:'C',expl:"Pour un animal non genré, l'adjectif possessif est 'its'."},
        {q:"She sent ___ an email yesterday. (to them)",opts:["A) they","B) their","C) them","D) themselves"],rep:'C',expl:"Après un verbe, pronom complément pluriel = 'them'."}
       ]},

      // ── PRONOMS ANGLAIS PARTIE 2 (B1) ──────────────────────────────
      {id:'gram_b1_m3',titre:'Les Pronoms en Anglais — Partie 2',niveau:'B1',duree:35,
       objectifs:["Distinguer adjectifs possessifs et pronoms possessifs","Utiliser les pronoms réfléchis correctement","Maîtriser les pronoms relatifs who/which/that/whose","Employer les pronoms interrogatifs et indéfinis"],
       contenu:[
        {type:'intro',texte:"Cette partie couvre les pronoms avancés qui permettent d'exprimer la possession, l'autoréférence, les relations entre propositions et l'indétermination. Indispensables pour atteindre le niveau B1."},
        {type:'tableau',titre:'Pronoms Possessifs (Possessive Pronouns)',headers:['Adjectif possessif','Pronom possessif'],rows:[['my','mine (le mien / la mienne)'],['your','yours (le tien / le vôtre)'],['his','his (le sien — masc.)'],['her','hers (le sien — fém.)'],['its','its (le sien — neutre)'],['our','ours (le nôtre)'],['their','theirs (le leur)']]},
        {type:'regle',texte:"Le pronom possessif REMPLACE un groupe nominal. Il s'utilise SEUL, sans nom après lui. Ex : This is my book → This book is mine. / Is that her coat? No, it's hers."},
        {type:'tableau',titre:'Pronoms Réfléchis (Reflexive Pronouns)',headers:['Sujet','Réfléchi'],rows:[['I','myself'],['You (sg)','yourself'],['He','himself'],['She','herself'],['It','itself'],['We','ourselves'],['You (pl)','yourselves'],['They','themselves']]},
        {type:'regle',texte:"Les pronoms réfléchis s'utilisent quand le sujet et le complément sont la même personne. Ex : She hurt herself. / He taught himself guitar. / We enjoyed ourselves at the party."},
        {type:'conseil',texte:"💡 Intensificateurs : les pronoms réfléchis peuvent aussi renforcer le sujet. Ex : I myself wrote the report (= moi-même). / The president himself attended the meeting."},
        {type:'tableau',titre:'Pronoms Relatifs (Relative Pronouns)',headers:['Pronom','Usage'],rows:[['who','pour les personnes (sujet)'],['whom','pour les personnes (complément, formel)'],['which','pour les choses et les animaux'],['that','pour les personnes et les choses (propositions restrictives)'],['whose','possession (de qui / dont)']]},
        {type:'exemples',liste:["The teacher who taught me English was excellent.","The book which I bought yesterday is fascinating.","The man whose car was stolen called the police.","That is the film that everyone is talking about."]},
        {type:'tableau',titre:'Pronoms Interrogatifs (Interrogative Pronouns)',headers:['Pronom','Usage','Exemple'],rows:[['Who','sujet, personnes','Who called you?'],['Whom','complément, personnes (formel)','Whom did you see?'],['Which','choix limité','Which do you prefer?'],['What','choses, informations','What is your name?'],['Whose','possession','Whose bag is this?']]},
        {type:'tableau',titre:'Pronoms Indéfinis (Indefinite Pronouns)',headers:['Personnes','Choses','Lieux'],rows:[['someone / somebody','something','somewhere'],['everyone / everybody','everything','everywhere'],['no one / nobody','nothing','nowhere'],['anyone / anybody','anything','anywhere']]},
        {type:'regle',texte:"Règle clé des indéfinis : someone/everyone/no one prennent un verbe au singulier. Ex : Everyone IS ready. Nobody HAS arrived. Something IS wrong."}
       ],
       quiz:[
        {q:"This is not your coat. It is ___. (belonging to her)",opts:["A) her","B) hers","C) herself","D) she"],rep:'B',expl:"Seul, sans nom après = pronom possessif. 'hers' = le sien (féminin)."},
        {q:"He cooked the meal ___. (without help from anyone)",opts:["A) him","B) his","C) himself","D) hisself"],rep:'C',expl:"Sujet = complément → pronom réfléchi. 'hisself' n'existe pas en anglais standard."},
        {q:"The woman ___ called is my aunt.",opts:["A) which","B) whose","C) who","D) whom"],rep:'C',expl:"Pour une personne (sujet de la relative) → who."},
        {q:"The car ___ he drives belongs to his father.",opts:["A) who","B) whom","C) whose","D) which"],rep:'D',expl:"Pour une chose → which (ou that). 'who' et 'whom' sont réservés aux personnes."},
        {q:"The student ___ notes I borrowed got an A.",opts:["A) who","B) which","C) whose","D) that"],rep:'C',expl:"Relation de possession → whose."},
        {q:"___ is calling at this hour?",opts:["A) What","B) Which","C) Whose","D) Who"],rep:'D',expl:"On demande l'identité d'une personne → Who."},
        {q:"She looked at ___ in the mirror.",opts:["A) her","B) hers","C) herself","D) she"],rep:'C',expl:"Sujet (she) = complément → pronom réfléchi herself."},
        {q:"___ has arrived yet. The hall is empty.",opts:["A) Someone","B) Anyone","C) Everyone","D) No one"],rep:'D',expl:"Phrase négative avec un sens de 'personne' → No one."},
        {q:"Is this bag yours or ___? (belonging to me)",opts:["A) my","B) me","C) mine","D) myself"],rep:'C',expl:"Pronom possessif utilisé seul (sans nom après) → mine."},
        {q:"___ do you prefer — the red one or the blue one?",opts:["A) What","B) Who","C) Which","D) Whose"],rep:'C',expl:"Choix entre deux options définies → Which (pas What)."}
       ]}
    ]

    const _VOC=[
      {id:'voc_a1_m1',titre:'La Famille et les Relations',niveau:'A1',duree:20,objectifs:["Nommer les membres de la famille en anglais","Décrire les relations familiales","Utiliser les possessifs"],contenu:[{type:'intro',texte:"Parler de sa famille est souvent la première chose qu'on apprend. Ce module vous donne le vocabulaire essentiel pour vous présenter et présenter vos proches."},{type:'lexique',titre:'La Famille Nucléaire',items:[{en:"father / dad",fr:"père / papa"},{en:"mother / mum",fr:"mère / maman"},{en:"brother",fr:"frère"},{en:"sister",fr:"sœur"},{en:"son",fr:"fils"},{en:"daughter",fr:"fille"},{en:"husband",fr:"mari"},{en:"wife",fr:"femme (épouse)"},{en:"parents",fr:"parents"},{en:"children / kids",fr:"enfants"}]},{type:'lexique',titre:'La Famille Étendue',items:[{en:"grandfather / grandpa",fr:"grand-père / papi"},{en:"grandmother / grandma",fr:"grand-mère / mamie"},{en:"uncle",fr:"oncle"},{en:"aunt",fr:"tante"},{en:"cousin",fr:"cousin(e)"},{en:"nephew",fr:"neveu"},{en:"niece",fr:"nièce"},{en:"in-laws",fr:"belle-famille"},{en:"step-father / step-mother",fr:"beau-père / belle-mère"}]},{type:'exemples',titre:'Phrases modèles',items:[{en:"My father is a teacher and my mother is a nurse.",fr:"Mon père est enseignant et ma mère est infirmière."},{en:"I have two brothers and one sister.",fr:"J'ai deux frères et une sœur."},{en:"My grandmother lives with us.",fr:"Ma grand-mère vit avec nous."}]}],quiz:[{q:"Your mother's brother is your ___.",opts:["A) nephew","B) uncle","C) cousin","D) grandfather"],rep:'B',expl:"Le frère de ta mère est ton oncle (uncle)."},{q:"Your brother's daughter is your ___.",opts:["A) cousin","B) niece","C) sister","D) daughter"],rep:'B',expl:"La fille de ton frère est ta nièce (niece)."},{q:"The woman you are married to is your ___.",opts:["A) girlfriend","B) sister","C) wife","D) daughter"],rep:'C',expl:"Ta femme mariée est ta 'wife'."},{q:"Your father's father is your ___.",opts:["A) uncle","B) grandfather","C) father-in-law","D) stepfather"],rep:'B',expl:"Le père de ton père est ton grand-père."},{q:"Comment dit-on 'neveu' en anglais ?",opts:["A) niece","B) nephew","C) cousin","D) uncle"],rep:'B',expl:"Neveu = nephew. Niece = nièce."},{q:"Your parents' parents are your ___.",opts:["A) cousins","B) in-laws","C) grandparents","D) step-parents"],rep:'C',expl:"Les parents de tes parents sont tes grands-parents."}]},
