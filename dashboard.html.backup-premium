                </div>`).join('')}
            </div>
          </div>`).join('')}
      `)
    }

    window._startModuleQuiz=async function(moduleCode){
      setContent(skeletonTable(4,3))
      let data=null
      try{
        const r=await fetch(`/api/pedagogy/quiz/${encodeURIComponent(moduleCode)}`)
        if(r.ok) data=await r.json()
        else if(r.status===404){
          setContent(`<div style="text-align:center;padding:40px;color:#5A7090">
            Aucun quiz disponible pour ce module.
            <br><button onclick="_quizParModule('<div></div>')" style="margin-top:12px;padding:8px 20px;
              background:#1E3050;border:none;border-radius:8px;color:#90A4AE;cursor:pointer;font-size:.82rem">← Retour</button>
          </div>`)
          return
        }
      }catch(e){}
      if(!data||!data.questions?.length){
        setContent(`<div style="text-align:center;padding:40px;color:#5A7090">Quiz introuvable.</div>`)
        return
      }

      // Convertir le format API → format QS compatible avec _qRender
      const qs=data.questions.map(q=>({
        id:              q.id,
        question:        q.question,        // question_text déjà remappé par l'API
        options:         q.options.map(o=>o.text),
        reponse_correcte:q.options.find(o=>o.is_correct)?.text||'',
        explication:     q.explanation||'',
        pilier:          data.module?.title||'Module',
        niveau:          moduleCode.split('-')[1]||'',
      }))

      const modeBar=`<div style="display:flex;gap:0;margin-bottom:20px;border-bottom:2px solid #1E3050">
        <button onclick="window._quizMode='module';renderQuiz()"
          style="padding:9px 18px;font-size:.82rem;font-weight:600;border:none;cursor:pointer;
                 background:transparent;margin-bottom:-2px;color:#5A7090;
                 border-bottom:2px solid transparent">← Modules</button>
        <span style="padding:9px 18px;font-size:.82rem;font-weight:700;
                     color:#C8960C;border-bottom:2px solid #C8960C">
          📝 ${data.module?.title||moduleCode}
        </span>
      </div>`

      QS={questions:qs,current:0,score:0,answered:false,modeBar}
      _qRender()
    }

    function _qRender() {
      const q=QS.questions[QS.current]
      let opts=[]
      try{opts=typeof q.options==='string'?JSON.parse(q.options):(q.options||[])}catch{opts=[]}
      window._qO=opts; window._qR=q.reponse_correcte; window._qE=q.explication||''

      setContent(`${QS.modeBar||''}
         <div class="quiz-container" style="max-width:620px;margin:0 auto">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
            <span style="font-size:.78rem;color:#90A4AE">Question ${QS.current+1} / ${QS.questions.length}</span>
            <span style="font-size:.78rem;font-weight:700;color:#C8960C">Score : ${QS.score} / ${QS.current}</span>
          </div>
          <div style="height:4px;border-radius:2px;background:#1E3050;margin-bottom:18px;overflow:hidden">
            <div style="height:4px;border-radius:2px;background:#C8960C;width:${QS.current/QS.questions.length*100}%;transition:width .4s"></div>
          </div>
          <div style="display:flex;gap:7px;margin-bottom:12px">
            ${bdg(q.pilier,'#1A2D42','#4A90D9')} ${bdg(q.niveau,'#1A2D42','#E8B84B')}
          </div>
          <div style="padding:18px 22px;border-radius:12px;background:#152233;border:1px solid #1E3050;margin-bottom:14px">
            <p style="font-size:.95rem;font-weight:600;color:#fff;margin:0;line-height:1.55">${q.question}</p>
          </div>
          <div id="qOpts" style="display:flex;flex-direction:column;gap:8px">
            ${opts.map((o,i)=>`
              <button id="qo_${i}" onclick="_qPick(${i})"
                style="width:100%;text-align:left;padding:12px 16px;border-radius:9px;font-size:.85rem;font-weight:500;
                       cursor:pointer;background:#0D1B2A;border:1.5px solid #1E3050;color:#e0e0e0;transition:all .15s;
                       display:flex;align-items:center;gap:11px">
                <span style="width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;background:#1E3050;color:#90A4AE;flex-shrink:0">${String.fromCharCode(65+i)}</span>
                ${o}
              </button>
            `).join('')}
          </div>
        </div>
      `)
    }

    window._qPick = function(i) {
      if(QS.answered) return
      QS.answered=true
      const chosen=window._qO[i], correct=window._qR, ok=chosen===correct
      if(ok) QS.score++
      window._qO.forEach((o,j)=>{
        const b=document.getElementById('qo_'+j); if(!b) return
        b.disabled=true
        if(o===correct){b.style.borderColor='#4AE090';b.style.background='#1A3A1A';b.style.color='#4AE090'}
        else if(j===i&&!ok){b.style.borderColor='#E04A4A';b.style.background='#2A1A1A';b.style.color='#E04A4A'}
      })
      const w=document.querySelector('[style*="max-width:620px"]')
      if(w) w.insertAdjacentHTML('beforeend',`
        <div style="margin-top:12px;padding:12px 16px;border-radius:9px;background:${ok?'#1A3A1A':'#2A1A1A'};border:1px solid ${ok?'#4AE090':'#E04A4A'}">
          <div style="font-weight:700;color:${ok?'#4AE090':'#E04A4A'};margin-bottom:3px">${ok?'✅ Correct !':'❌ Incorrect'}</div>
          ${window._qE?`<div style="font-size:.78rem;color:#90A4AE">${window._qE}</div>`:''}
        </div>
        <div style="margin-top:12px;text-align:right">
          <button onclick="_qNext()" style="padding:9px 22px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A">
            ${QS.current+1<QS.questions.length?'Question suivante →':'🏆 Résultats'}
          </button>
        </div>
      `)
    }

    window._qNext = function() {
      QS.current++
      if(QS.current>=QS.questions.length){_qResults();return}
      QS.answered=false
      _qRender()
    }

    function _qResults() {
      const pct=Math.round(QS.score/QS.questions.length*100)
      setContent(`
        <div style="max-width:440px;margin:40px auto;text-align:center">
          <div style="font-size:4rem;margin-bottom:10px">${pct>=80?'🏆':pct>=60?'👍':'📚'}</div>
          <div style="font-size:2.2rem;font-weight:900;color:#C8960C;margin-bottom:6px">${QS.score} / ${QS.questions.length}</div>
          <div style="font-size:1rem;font-weight:600;color:#fff;margin-bottom:4px">${pct}% de bonnes réponses</div>
          <div style="font-size:.82rem;color:#90A4AE;margin-bottom:28px">${pct>=80?'Excellent travail !':pct>=60?'Bon travail, continuez !':'Révisez et réessayez !'}</div>
          <button onclick="renderQuiz()" style="padding:11px 30px;border-radius:10px;font-weight:700;font-size:.88rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A">
            🔄 Recommencer
          </button>
        </div>
      `)
    }

