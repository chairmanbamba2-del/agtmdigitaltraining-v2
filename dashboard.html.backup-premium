      </style></head><body>
      <div>
        <div class="no-print">
          <button onclick="window.print()" style="padding:10px 28px;background:${col};border:none;border-radius:8px;color:#fff;font-weight:700;cursor:pointer;font-size:.9rem">🖨 Imprimer / PDF</button>
          <button id="_dlCertBtn" style="padding:10px 22px;background:#1a1a2e;border:2px solid ${col};border-radius:8px;color:${col};font-weight:700;cursor:pointer;font-size:.9rem">💾 Télécharger (.html)</button>
