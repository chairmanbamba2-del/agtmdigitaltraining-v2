            <input type="text" id="${searchId}" placeholder="Rechercher..." class="sec-nav-search" oninput="const val=this.value.toLowerCase();Array.from(this.parentNode.parentNode.querySelectorAll('.sec-nav-item')).forEach(btn=>{const label=btn.querySelector('.sni-label').textContent.toLowerCase();btn.style.display=label.includes(val)?'flex':'none'})">
          </div>` : ''}
          ${tabs.map(t=>`<button onclick="${switchFn}('${t.id}')" class="sec-nav-item${active===t.id?' sec-active':''}" data-id="${t.id}">
            <span class="sni-icon">${t.icon}</span><span class="sni-label">${t.label}</span>
          </button>`).join('')}
        </nav>
        <div class="sec-body">`
