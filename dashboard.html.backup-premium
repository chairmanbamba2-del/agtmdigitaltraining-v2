    // ── 1. Détection de conflits ─────────────────────────────────
    window._detectConflits = async function({ date_seance, heure_debut, heure_fin, enseignant, salle, excludeId }) {
      if (!date_seance || !heure_debut) return []
      const conflits = []
      // Charger toutes séances du même jour
      const { data: sameDay } = await sb.from('seances')
        .select('id,heure_debut,heure_fin,enseignant,salle,sujet,classe_id')
        .eq('date_seance', date_seance)
        .neq('statut', 'Annulée')
      const others = (sameDay || []).filter(s => String(s.id) !== String(excludeId))

      const toMin = t => { if(!t) return null; const [h,m] = t.split(':').map(Number); return h*60+m }
      const startA = toMin(heure_debut)
      const endA   = toMin(heure_fin) || (startA + 90) // default 90 min
      const overlap = s => {
        const startB = toMin(s.heure_debut)
        const endB   = toMin(s.heure_fin) || (startB + 90)
        return startB !== null && startA < endB && endA > startB
      }

      for (const s of others) {
        if (enseignant && s.enseignant && s.enseignant.trim() === enseignant.trim() && overlap(s)) {
          conflits.push({ type:'formateur', msg:`👨‍🏫 Formateur "${enseignant}" a déjà une séance à ${s.heure_debut} : "${s.sujet}"` })
        }
        if (salle && s.salle && s.salle.trim().toLowerCase() === salle.trim().toLowerCase() && overlap(s)) {
          conflits.push({ type:'salle', msg:`🏫 Salle "${salle}" est déjà occupée à ${s.heure_debut} : "${s.sujet}"` })
        }
      }
      return conflits
    }

    // ── 2. FullCalendar init/refresh ─────────────────────────────
    let _fcInstance = null
    window._initFullCalendar = async function(allSeances, classeMap) {
      const el = document.getElementById('fcCalendar')
      if (!el) return
      if (_fcInstance) { _fcInstance.destroy(); _fcInstance = null }

      // Map events
      const events = (allSeances||[]).map(s => {
        const cl = classeMap?.[s.classe_id] || {}
        const col = s.statut==='Réalisée' ? '#2A7A3A' : s.statut==='Annulée' ? '#7A2A2A' : '#1A4A7A'
        const border = s.statut==='Réalisée' ? '#4AE090' : s.statut==='Annulée' ? '#E04A4A' : '#4A90D9'
        return {
          id: String(s.id),
          title: s.sujet || 'Cours',
          start: s.date_seance + (s.heure_debut ? 'T'+s.heure_debut : ''),
          end:   s.heure_fin ? s.date_seance + 'T' + s.heure_fin : undefined,
          backgroundColor: col,
          borderColor: border,
          textColor: '#fff',
          extendedProps: { seance: s, classe: cl }
        }
      })

      _fcInstance = new FullCalendar.Calendar(el, {
        initialView: 'timeGridWeek',
        locale: 'fr',
        headerToolbar: {
