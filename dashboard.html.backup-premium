    async function _quizParModule(modeBar){
      // Charger la liste des modules depuis l'API pédagogie
      let modules=[]
      try{
        const r=await fetch('/api/pedagogy/modules?limit=100')
        if(r.ok){const d=await r.json();modules=d.modules||[]}
      }catch(e){}

      if(!modules.length){
        setContent(modeBar+`<div style="text-align:center;padding:40px;color:#5A7090">
          Catalogue modules non disponible.<br>
          <button onclick="window._quizMode='libre';renderQuiz()"
            style="margin-top:12px;padding:8px 20px;background:#C8960C;border:none;border-radius:8px;
                   color:#0D1B2A;font-weight:700;cursor:pointer;font-size:.82rem">
            ← Retour Quiz Libre
          </button>
        </div>`)
        return
      }

      // Grouper par niveau
      const lvlOrder=['A1','A2','B1','B2','C1','C2']
