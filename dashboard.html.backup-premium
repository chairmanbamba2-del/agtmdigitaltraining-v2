          const rws = (b.rows||[]).map((r,i)=>`<tr style="background:${i%2===0?'rgba(13,27,42,0.4)':'transparent'}">${r.map(c=>`<td style="padding:8px 14px;font-size:.82rem;color:#D0D8E0;border-bottom:1px solid rgba(255,255,255,0.04)">${c}</td>`).join('')}</tr>`).join('')
