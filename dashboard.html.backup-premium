                const ensNom = s.enseignant||s.formateur_nom||'—'
                const ensMat = fmtMatMap[s.enseignant||'']||fmtMatMap[s.formateur_nom||'']||null
                return `<tr style="border-top:1px solid #1E3050${s.vise_par_direction?';background:rgba(142,68,173,0.06)':''}">
