      if (!confirm('Réinitialiser toutes les permissions aux valeurs par défaut ?')) return
      localStorage.removeItem('agtm_permissions')
      toast('✅ Permissions réinitialisées aux valeurs par défaut')
      buildSidebar()
      renderUtilisateurs()
    }

