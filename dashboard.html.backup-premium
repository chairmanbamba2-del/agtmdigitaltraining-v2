          </select>
          ${(fRole||fActif)?`<button onclick="window._usrFilter={role:'',actif:''};renderUtilisateurs()" style="padding:5px 12px;border-radius:7px;font-size:.72rem;cursor:pointer;background:transparent;border:1px solid #E04A4A;color:#E04A4A;font-weight:700">✕ Réinitialiser</button>`:''}
          <span style="margin-left:auto;font-size:.72rem;color:#5A7090">${filtered.length} résultat(s)</span>
        </div>

        <!-- Liste des utilisateurs -->
        <div style="display:flex;flex-direction:column;gap:10px">
          ${filtered.length ? filtered.map(u=>{
