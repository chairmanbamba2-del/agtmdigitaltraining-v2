        ? (subs||[]).filter(r=>
            (r.etudiant_nom||'').toLowerCase().includes(evalSQ) ||
            (r.evaluation_titre||'').toLowerCase().includes(evalSQ) ||
            (evalMap[r.evaluation_id]?.niveau||'').toLowerCase().includes(evalSQ)
          )
        : (subs||[])

      // KPIs
      const total  = (subs||[]).length
      const moy    = total ? Math.round((subs||[]).reduce((s,r)=>s+(Number(r.score)||0),0)/total*10)/10 : 0
      const reussi = (subs||[]).filter(r=>Number(r.score)>=10).length

