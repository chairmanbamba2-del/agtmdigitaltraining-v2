      border-right: 1px solid rgba(200,150,12,0.13);
      border-radius: 12px 0 0 12px;
      padding: 6px 0;
      position: sticky;
      top: 8px;
      max-height: calc(100vh - 110px);
      overflow-y: auto;
      z-index: 10;
    }
