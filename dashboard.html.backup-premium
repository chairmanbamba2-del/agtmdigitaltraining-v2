    // Voir les présences d'une séance (pour la direction)
    window._voirPresencesSeance = async function(seanceId) {
      const {data:pres} = await sb.from('presences')
        .select('present,justifie,motif_absence,etudiants(id,nom,prenom,numero_dossier)')
        .eq('seance_id', seanceId)
      if (!pres?.length) { toast('Aucune présence enregistrée pour cette séance','err'); return }
      const msg = pres.map(p=>`${p.present?'✅':'❌'} ${p.etudiants?.prenom||''} ${p.etudiants?.nom||''}${p.justifie?' (Justifié)':''}${p.motif_absence?' — '+p.motif_absence:''}`).join('\n')
      alert(`Présences — Séance #${seanceId}\n\n${msg}`)
    }

    // ── Fonctions de visa ─────────────────────────────────────────
    window._vizerSeance = async function(seanceId) {
      const visaPar = `${profile?.prenom||''} ${profile?.nom||''}`.trim() || profile?.email
      const {error} = await sb.from('seances').update({
        vise_par_direction: true,
        visa_par: visaPar,
        visa_par_user_id: currentUser?.id || null,
        visa_at: new Date().toISOString(),
      }).eq('id', seanceId)
      if (error) { toast('Erreur visa : '+error.message,'err'); return }
      toast('✅ Séance visée — modification formateur bloquée')
      const cur = window._navCurrentSectionId
      if (cur==='pedagogie') renderPedagogie()
      else if (cur==='seances') renderSeances()
      else renderDirectionPedagogique()
    }

    window._retirerVisaSeance = async function(seanceId) {
      // Vérifier si la séance est Réalisée (honoraires potentiellement créés)
      const {data:s} = await sb.from('seances').select('statut').eq('id',seanceId).single()
      const wasRealised = s?.statut === 'Réalisée'
      const {error} = await sb.from('seances').update({
        vise_par_direction: false,
        visa_par: null,
        visa_par_user_id: null,
        visa_at: null,
        ...(wasRealised ? {statut:'a_valider_direction'} : {}),
      }).eq('id', seanceId)
      if (error) { toast('Erreur retrait visa : '+error.message,'err'); return }
      // Supprimer les honoraires liés (recalculés lors de la prochaine validation)
      await sb.from('honoraires_formateurs').delete().eq('seance_id', seanceId)
      toast('🔓 Visa retiré — honoraires annulés, formateur peut modifier')
      const cur = window._navCurrentSectionId
      if (cur==='pedagogie') renderPedagogie()
