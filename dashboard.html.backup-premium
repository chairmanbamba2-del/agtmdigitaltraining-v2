    window.addSeance = async function() {
      const date  = document.getElementById('sD').value
      const heure = document.getElementById('sH').value
      const sujet = document.getElementById('sS').value.trim()
      const notes = document.getElementById('sN').value.trim()
      const lienMeet = document.getElementById('sLien')?.value.trim()||null
      const fmtEl = document.getElementById('sFmt')
      const clsEl = document.getElementById('sCls')
      const enseignant = fmtEl?.value || [profile?.prenom, profile?.nom].filter(Boolean).join(' ')
      const classe_id  = clsEl?.value ? Number(clsEl.value) : null
      const classe_nom = clsEl?.selectedOptions?.[0]?.dataset?.nom || null
      const modEl  = document.getElementById('sMod')
      const module_id = modEl?.value || null
      const chapitre  = modEl?.selectedOptions?.[0]?.dataset?.titre || null
      const categorie = modEl?.selectedOptions?.[0]?.dataset?.cat || null
      if (!date || !sujet) { toast('Date et sujet requis','err'); return }
      if (!enseignant)     { toast('Veuillez sélectionner un formateur','err'); return }
      // Vérifier que le formateur est enregistré dans la base
      const {data:fmtCheck} = await sb.from('personnel')
        .select('id,nom,prenom,poste')
        .or(`poste.eq.Formateur,poste.eq.Enseignant`)
        .order('id')
      if (enseignant && !(fmtCheck||[]).some(f => (f.prenom+' '+f.nom).trim() === enseignant.trim() || (f.nom+' '+f.prenom).trim() === enseignant.trim())) {
        toast('⚠️ Ce formateur n\'est pas enregistré dans la base de données. Ajoutez-le d\'abord dans les Ressources Humaines.','err')
        return
      }
      const {data:newSeance, error} = await sb.from('seances').insert({
        date_seance:date, heure_debut:heure, sujet, notes:notes||null,
        enseignant, classe_id, programme:classe_nom,
        module_id, chapitre, categorie,
        lien_meet: lienMeet||null,
        statut:'Planifiée',
      }).select().single()
      if (error) { toast('Erreur : '+error.message,'err'); return }
      // Afficher le lien si renseigné
      if (lienMeet) {
        const lb = document.getElementById('seanceLinkResult')
        const lu = document.getElementById('seanceLinkUrl')
        if (lb && lu) { lu.value = lienMeet; lb.style.display='block'; lb.scrollIntoView({behavior:'smooth',block:'nearest'}) }
      }
      toast('✅ Séance enregistrée')
      // ── Notification automatique aux étudiants et formateur ──
      if (newSeance) await window._notifySeanceCreated(newSeance)
      setTimeout(()=>renderSeances(), lienMeet ? 3000 : 0)
    }

    // ════════════════════════════════════════════════════════════
    //  PRÉSENCES (Formateur) — Liste séances à pointer
    // ════════════════════════════════════════════════════════════
    async function renderPresences() {
      const isAdmin = ['admin','secretaire','directeur_pedagogique','sous_directeur_pedagogique'].includes(profile?.role)
      const fmtNom  = [profile?.prenom, profile?.nom].filter(Boolean).join(' ')

      setContent(skeletonTable(6, 5))

      // Charger les séances sans pointage
      let q = sb.from('seances')
        .select('id,date_seance,heure_debut,sujet,programme,classe_id,enseignant,statut,pointage_fait')
        .eq('pointage_fait', false)
        .not('statut', 'eq', 'Réalisée')
        .order('date_seance', {ascending: true})
        .limit(100)

      if (!isAdmin) q = q.eq('enseignant', fmtNom)

      let {data:rows, error} = await q
      if (error) { setContent(`<div style="color:#E04A4A;padding:24px">Erreur : ${error.message}</div>`); return }

      // Fallback par classe si nom ne matche pas (formateur sans séances par nom)
      if (!isAdmin && !(rows||[]).length) {
        const {data:mesClasses} = await sb.from('classes').select('id').eq('formateur_id', currentUser?.id)
        const classeIds = (mesClasses||[]).map(c => c.id)
        if (classeIds.length) {
          const {data:byCls} = await sb.from('seances')
            .select('id,date_seance,heure_debut,sujet,programme,classe_id,enseignant,statut,pointage_fait')
            .in('classe_id', classeIds)
            .eq('pointage_fait', false)
            .not('statut', 'eq', 'Réalisée')
            .order('date_seance', {ascending: true})
            .limit(100)
          rows = byCls || []
        }
      }

      // Charger aussi les séances déjà pointées (pour voir l'historique)
      let qDone = sb.from('seances')
        .select('id,date_seance,heure_debut,sujet,programme,classe_id,enseignant,statut,pointage_fait')
        .eq('pointage_fait', true)
        .order('date_seance', {ascending: false})
        .limit(50)

      if (!isAdmin) qDone = qDone.eq('enseignant', fmtNom)
      let {data:done} = await qDone

      // Fallback par classe pour l'historique aussi
      if (!isAdmin && !(done||[]).length) {
        const {data:mesClasses} = await sb.from('classes').select('id').eq('formateur_id', currentUser?.id)
        const classeIds = (mesClasses||[]).map(c => c.id)
        if (classeIds.length) {
          const {data:byCls} = await sb.from('seances')
            .select('id,date_seance,heure_debut,sujet,programme,classe_id,enseignant,statut,pointage_fait')
            .in('classe_id', classeIds)
            .eq('pointage_fait', true)
            .order('date_seance', {ascending: false})
            .limit(50)
          done = byCls || []
        }
      }

      const fmtD = d => d ? new Date(d).toLocaleDateString('fr-FR',{weekday:'short',day:'numeric',month:'short',year:'numeric'}) : '—'

      const rowHtml = (list, pointer) => (list||[]).map(s => `
        <tr style="border-top:1px solid #1E3050">
          <td style="padding:9px 14px;color:#E2D8C0;font-weight:600">${fmtD(s.date_seance)}</td>
          <td style="padding:9px 14px;color:#90A4AE;font-size:.75rem">${s.heure_debut||'—'}</td>
          <td style="padding:9px 14px;color:#E2D8C0">${s.sujet||'—'}</td>
          <td style="padding:9px 14px;color:#E8B84B;font-size:.78rem">${s.enseignant||'—'}</td>
          <td style="padding:9px 14px;font-size:.72rem;color:#8AAAC0">${s.programme||'—'}</td>
          <td style="padding:9px 14px">
            ${pointer
              ? `<button onclick="renderPointageInline(${s.id})" style="padding:6px 14px;border-radius:7px;font-size:.75rem;cursor:pointer;background:rgba(200,150,12,0.18);border:1px solid #C8960C;color:#E8B84B;font-weight:700">📋 Pointer</button>`
              : `<span style="font-size:.7rem;color:#4AE090;padding:3px 9px;background:rgba(74,224,144,.08);border-radius:6px;border:1px solid rgba(74,224,144,.2)">✅ Pointage fait</span>`
            }
          </td>
        </tr>`).join('')

      setContent(`
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:22px">
          ${kpi('📋','À pointer',(rows||[]).length,'#C8960C')}
          ${kpi('✅','Déjà pointées',(done||[]).length,'#4AE090')}
        </div>

        ${wrap(`
          ${card('📋 Séances à Pointer',`${(rows||[]).length} séance(s) en attente`)}
          <table style="width:100%;border-collapse:collapse">
            <thead>${th('Date','Heure','Sujet','Formateur','Classe','Action')}</thead>
            <tbody>
              ${rowHtml(rows, true) || '<tr><td colspan="6" style="padding:24px;text-align:center;color:#5A7090">✅ Toutes les séances ont été pointées</td></tr>'}
            </tbody>
          </table>
        `)}

        ${(done||[]).length ? wrap(`
          ${card('✅ Séances Pointées (récentes)',`${(done||[]).length} séance(s)`)}
          <table style="width:100%;border-collapse:collapse">
            <thead>${th('Date','Heure','Sujet','Formateur','Classe','Statut')}</thead>
            <tbody>${rowHtml(done, false)}</tbody>
          </table>
        `) : ''}
      `)
    }

