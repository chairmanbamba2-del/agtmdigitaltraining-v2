              🚪 Se déconnecter
            </button>
          </div>
        </div>
      `)

      window._changePassword = async function() {
        const p1 = document.getElementById('secNewPass')?.value
        const p2 = document.getElementById('secConfPass')?.value
        const msg = document.getElementById('secMsg')
        if (!p1 || p1.length < 8) { if(msg){msg.style.color='#E04A4A';msg.textContent='❌ Minimum 8 caractères.'}; return }
        if (p1 !== p2) { if(msg){msg.style.color='#E04A4A';msg.textContent='❌ Les mots de passe ne correspondent pas.'}; return }
        try {
          const {error} = await sb.auth.updateUser({password: p1})
          if (error) throw error
          if(msg){msg.style.color='#4AE090';msg.textContent='✅ Mot de passe mis à jour !'}
          document.getElementById('secNewPass').value = ''
          document.getElementById('secConfPass').value = ''
          toast('Mot de passe mis à jour avec succès.', 'ok')
        } catch(e) {
          if(msg){msg.style.color='#E04A4A';msg.textContent='❌ ' + (e.message||'Erreur')}
        }
      }
    }

