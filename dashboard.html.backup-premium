    let QS = { questions:[], current:0, score:0, answered:false }

    async function renderQuiz() {
      setContent(skeletonTable(6,4))
      const mode=window._quizMode||'libre'

      // ── Header mode-selector ───────────────────────────────────────────
      const modeBar=`<div style="display:flex;gap:0;margin-bottom:20px;border-bottom:2px solid #1E3050">
        ${[['libre','🎲 Quiz Libre'],['module','📚 Par Module']].map(([id,lbl])=>`
          <button onclick="window._quizMode='${id}';renderQuiz()"
            style="padding:9px 18px;font-size:.82rem;font-weight:600;border:none;cursor:pointer;
                   background:transparent;margin-bottom:-2px;transition:all .2s;
                   border-bottom:${mode===id?'2px solid #C8960C':'2px solid transparent'};
                   color:${mode===id?'#C8960C':'#5A7090'}">${lbl}</button>`).join('')}
      </div>`

