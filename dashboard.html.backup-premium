    window._rhAutoSal = function() {
      const sel = document.getElementById('fpEmp')
      const opt = sel.selectedOptions[0]
      if (!opt || !sel.value) return
      const sal = Number(opt.dataset.sal||0)
      const taux = Number(opt.dataset.taux||0)
      document.getElementById('fpSal').value = sal
      document.getElementById('fpTauxS').value = taux
      _fpRecalc()
      // Si formateur avec taux séance, lancer le comptage auto
      if (taux > 0 && document.getElementById('fpMois').value) {
        _fpAutoSeances()
      }
    }

    window._fpRecalc = function() {
      const sal    = Number(document.getElementById('fpSal')?.value||0)
      const taux   = Number(document.getElementById('fpTauxS')?.value||0)
      const nb     = Number(document.getElementById('fpNbSeances')?.value||0)
      const hs     = Number(document.getElementById('fpHS')?.value||0)
      const th     = Number(document.getElementById('fpTH')?.value||0)
      const pr     = Number(document.getElementById('fpPr')?.value||0)
      const av     = Number(document.getElementById('fpAv')?.value||0)
      const cot    = Number(document.getElementById('fpCot')?.value||0)
      const ret    = Number(document.getElementById('fpRet')?.value||0)
      const adc    = Number(document.getElementById('fpAdc')?.value||0)
      const salSeances = taux * nb
      const net = sal + salSeances + (hs*th) + pr + av - cot - ret - adc
      const fmt = n => Number(n).toLocaleString('fr-FR')
      const salS = document.getElementById('fpSalSeances')
      if (salS) salS.textContent = fmt(salSeances) + ' FCFA'
      const prev = document.getElementById('fpNetPreview')
      if (prev) prev.textContent = fmt(net) + ' FCFA'
      const det = document.getElementById('fpNetDetail')
      if (det) {
        const parts = []
        if (sal > 0)        parts.push(`Fixe : ${fmt(sal)}`)
        if (salSeances > 0) parts.push(`Séances (${nb}×${fmt(taux)}) : ${fmt(salSeances)}`)
        if (hs*th > 0)      parts.push(`H.supp : ${fmt(hs*th)}`)
        if (pr > 0)         parts.push(`Primes : ${fmt(pr)}`)
        if (av > 0)         parts.push(`Avantages : ${fmt(av)}`)
        if (cot+ret+adc > 0) parts.push(`Déductions : -${fmt(cot+ret+adc)}`)
        det.textContent = parts.join(' | ') || '—'
      }
    }

    window._fpAutoSeances = async function() {
      const sel = document.getElementById('fpEmp')
      const moisVal = document.getElementById('fpMois')?.value
      if (!sel.value || !moisVal) { toast('Sélectionnez un employé et un mois','err'); return }
      const opt = sel.selectedOptions[0]
      const nomComplet = opt?.dataset.nom || ''
      if (!nomComplet) return
      // Bornes du mois
      const d = new Date(moisVal)
      const debut = moisVal.substring(0,7) + '-01'
      const finD = new Date(d.getFullYear(), d.getMonth()+1, 0)
      const fin = finD.toISOString().substring(0,10)
      // Chercher par nom du formateur (insensible à la casse) ET statut Réalisée
      const prenom = nomComplet.split(' ')[0] || ''
      const { data: seances } = await sb.from('seances')
        .select('id,date_seance,sujet,statut,enseignant,formateur_nom')
        .eq('statut', 'Réalisée')
        .gte('date_seance', debut)
        .lte('date_seance', fin)
      // Filtrer côté client par nom du formateur
      const nomLower = nomComplet.toLowerCase()
      const seancesFmt = (seances||[]).filter(s => {
        const ens = ((s.enseignant||'')+(s.formateur_nom||'')).toLowerCase()
        return ens.includes(nomLower.split(' ')[0]) || ens.includes(nomLower.split(' ').pop())
      })
      document.getElementById('fpNbSeances').value = seancesFmt.length
      _fpRecalc()
