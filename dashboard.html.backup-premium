    async function renderCertificats() {
      setContent(`<div style="text-align:center;padding:48px;color:#5A7090"><div style="font-size:2rem;margin-bottom:10px">🎓</div><div>Chargement des certificats…</div></div>`)

      // Fetch students with their session counts
      const [{data: etudiants}, {data: seancesData}, {data: classes}] = await Promise.all([
        sb.from('etudiants').select('id,nom,prenom,email,telephone,niveau,statut,formations,quota_seances,date_debut_contrat,date_fin_contrat,numero_dossier').order('nom'),
        sb.from('presences').select('etudiant_id,present').eq('present',1),
        sb.from('classes').select('id,nom,quota_seances'),
      ])

      const presenceMap = {}
      ;(seancesData||[]).forEach(p => {
        if (!presenceMap[p.etudiant_id]) presenceMap[p.etudiant_id] = 0
        presenceMap[p.etudiant_id]++
      })

      const withProgress = (etudiants||[]).map(e => {
        const done = presenceMap[e.id] || 0
        const quota = e.quota_seances || 24
        const pct = Math.min(100, Math.round(done / quota * 100))
        return { ...e, done, quota, pct }
      })

