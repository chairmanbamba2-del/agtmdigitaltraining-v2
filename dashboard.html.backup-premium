    // ── Synchronisation paiement ↔ statut étudiant ─────────────────
    // Vérifie si un étudiant a des échéances en retard → suspend automatiquement
    // Appelée après chaque mise à jour d'échéancier
    async function _syncStatutEtudiantPaiement(etudiantId) {
      if (!etudiantId) return
      const today = new Date().toISOString().substring(0,10)
      // Chercher toutes les échéances non payées dont la date est dépassée
      const {data:retards} = await sb.from('echeances')
        .select('id,date_echeance,statut,plan_id')
        .eq('etudiant_id', etudiantId)
        .neq('statut','Payé')
        .lt('date_echeance', today)
      const hasRetard = (retards||[]).length > 0
      // Mettre à jour le statut de l'étudiant
      const newStatut = hasRetard ? 'Suspendu' : 'Actif'
      const {data:etud} = await sb.from('etudiants').select('statut').eq('id', etudiantId).maybeSingle()
      if (etud && etud.statut !== newStatut && etud.statut !== 'Inactif') {
        await sb.from('etudiants').update({statut: newStatut}).eq('id', etudiantId)
        if (hasRetard) {
          toast('⚠️ Étudiant suspendu automatiquement — échéance(s) en retard')
        }
      }
    }

    window.markEcheancePaid = async function(echId, planId) {
      // 1. Marquer l'échéance comme payée
      const {error}=await sb.from('echeances').update({statut:'Payé'}).eq('id',echId)
      if(error){toast('Erreur : '+error.message,'err');return}

      // 2. Vérifier si toutes les échéances sont payées → solder le plan
      const {data:reste}=await sb.from('echeances').select('id').eq('plan_id',planId).neq('statut','Payé')
      if(!(reste||[]).length) await sb.from('plans_paiement').update({statut:'Soldé'}).eq('id',planId)

      // 3. Récupérer l'étudiant_id du plan pour resynchroniser son statut
      const {data:plan} = await sb.from('plans_paiement').select('etudiant_id').eq('id',planId).maybeSingle()
      if (plan?.etudiant_id) {
        await _syncStatutEtudiantPaiement(plan.etudiant_id)
        // Si toutes les échéances sont payées → réactiver l'étudiant
        if (!(reste||[]).length) {
          await sb.from('etudiants').update({statut:'Actif'}).eq('id', plan.etudiant_id).eq('statut','Suspendu')
          toast('✅ Échéance payée — plan soldé — étudiant réactivé')
        } else {
          toast('✅ Échéance marquée payée')
        }
      } else {
        toast('✅ Échéance marquée payée')
      }
      showEcheancier(planId)
    }

    // ── Réactiver manuellement un étudiant (admin seulement) ────────
    window._reactiverEtudiant = async function(etudiantId, nom) {
      if (!confirm(`Réactiver l'accès de ${nom} ?\n\nCela marque TOUTES les échéances en retard comme payées (paiement reçu hors-plateforme) et rétablit l'accès immédiatement.`)) return
      // 1. Marquer toutes les échéances "En retard" de cet étudiant comme "Payé"
      const {error:eErr} = await sb.from('echeances')
        .update({statut:'Payé'})
        .eq('etudiant_id', etudiantId)
        .eq('statut','En retard')
      if (eErr) { toast('Erreur mise à jour échéances : '+eErr.message,'err'); return }
      // 2. Solder les plans dont toutes les échéances sont payées
      const {data:plans} = await sb.from('plans_paiement').select('id').eq('etudiant_id', etudiantId)
      for (const plan of (plans||[])) {
        const {data:reste} = await sb.from('echeances').select('id').eq('plan_id',plan.id).neq('statut','Payé')
        if (!(reste||[]).length) await sb.from('plans_paiement').update({statut:'Soldé'}).eq('id',plan.id)
      }
      // 3. Réactiver l'étudiant
      const {error} = await sb.from('etudiants').update({statut:'Actif'}).eq('id', etudiantId)
      if (error) { toast('Erreur réactivation : '+error.message,'err'); return }
      toast('✅ '+nom+' réactivé(e) — échéances soldées — accès rétabli')
      finSwitch('echeancier')
    }

    // ── Synchronisation globale de tous les étudiants ───────────────
    window._syncTousEtudiants = async function() {
      const today = new Date().toISOString().substring(0,10)
      toast('⏳ Synchronisation en cours…')
      // 1. Marquer toutes les échéances "En attente" dépassées → "En retard"
      const {data:aMarquer} = await sb.from('echeances').select('id,etudiant_id')
        .eq('statut','En attente').lt('date_echeance', today)
      if ((aMarquer||[]).length) {
        await sb.from('echeances').update({statut:'En retard'}).in('id', aMarquer.map(e=>e.id))
      }
      // 2. Suspendre tous les étudiants avec au moins 1 échéance en retard
      const {data:retardsAll} = await sb.from('echeances').select('etudiant_id')
        .eq('statut','En retard').not('etudiant_id','is',null)
      const idsRetard = [...new Set((retardsAll||[]).map(e=>e.etudiant_id).filter(Boolean))]
      if (idsRetard.length) {
        await sb.from('etudiants').update({statut:'Suspendu'}).in('id', idsRetard)
      }
      const nbSusp = idsRetard.length
      toast(`✅ Synchronisation terminée — ${nbSusp} étudiant(s) suspendu(s)`)
      finSwitch('echeancier')
    }

