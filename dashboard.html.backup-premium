    window._prmExportCSV = async function(type) {
      let data = [], filename = type+'.csv', headers = []
      if (type==='etudiants') {
        const {data:r} = await sb.from('etudiants').select('*').order('created_at',{ascending:false})
        data=r||[]; headers=['id','numero_dossier','nom','prenom','email','telephone','niveau','statut','formations','mode_cours','date_inscription']
      } else if (type==='paiements') {
        const {data:r} = await sb.from('paiements').select('*').order('date_paiement',{ascending:false})
        data=r||[]; headers=['id','etudiant_nom','montant','type_paiement','mode_paiement','date_paiement','statut','notes']
      } else if (type==='depenses') {
        const {data:r} = await sb.from('depenses').select('*').order('date_depense',{ascending:false})
        data=r||[]; headers=['id','categorie','description','montant','date_depense','mode_paiement','justificatif']
      } else if (type==='seances') {
        const {data:r} = await sb.from('seances').select('*').order('date_seance',{ascending:false})
        data=r||[]; headers=['id','date_seance','heure_debut','sujet','enseignant','statut','programme','notes']
      }
      if (!data.length) { toast('Aucune donnée à exporter','err'); return }
      const csv = [headers.join(';'), ...data.map(row=>headers.map(h=>{
        const v = row[h]??''
        return typeof v==='string'&&v.includes(';') ? '"'+v.replace(/"/g,'""')+'"' : v
      }).join(';'))].join('\n')
      const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8'})
      const url  = URL.createObjectURL(blob)
      const a    = document.createElement('a')
      a.href=url; a.download=filename; a.click()
      URL.revokeObjectURL(url)
      toast('✅ Export CSV '+type+' téléchargé')
    }

