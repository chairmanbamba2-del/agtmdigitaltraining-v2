      const montant=Number(document.getElementById('fM').value)
      const date_paiement=document.getElementById('fDp').value
      const type_paiement=document.getElementById('fT').value
      const mode_paiement=document.getElementById('fMo').value
      const module=document.getElementById('fMod').value.trim()||null
      const notes=document.getElementById('fNt').value.trim()||null
      if(!montant||!date_paiement){toast('Montant et date requis','err');return}
      const {error}=await sb.from('paiements').insert({
        etudiant_id,etudiant_nom,montant,date_paiement,
        type_paiement,mode_paiement,statut:'Validé',
        notes: [module,notes].filter(Boolean).join(' — ')||null,
