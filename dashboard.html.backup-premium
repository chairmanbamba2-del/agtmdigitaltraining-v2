<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <title>AGTM Digital Academy — Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,600&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="manifest" href="/manifest.json"/>
  <meta name="theme-color" content="#C8960C"/>
  <link rel="icon" href="/icons/icon.svg" type="image/svg+xml"/>
  <link rel="apple-touch-icon" href="/icons/icon.svg"/>
  <!-- Appliquer le thème sauvegardé immédiatement pour éviter un flash de couleurs -->
  <script>
    ;(function(){
      const HUE={ocean:200,forest:120,ruby:340,violet:270,sunset:25,arctic:180,mono:0}
      const t=localStorage.getItem('agtm_theme')||'gold'
      if(t!=='gold'&&HUE[t]!==undefined){document.documentElement.style.filter='hue-rotate('+HUE[t]+'deg)'}
    })()
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <!-- FullCalendar v6 (free/open-source) -->
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
  <script>
    tailwind.config = {
      theme: { extend: { colors: {
        navy: { DEFAULT:'#0D1B2A', mid:'#152233', light:'#1A2D42', dark:'#080F18', card:'#1E2E42' },
        gold: { DEFAULT:'#C8960C', light:'#E8B84B', dark:'#A07008' },
        sapp: { DEFAULT:'#4A90D9' },
      }}}
    }
  </script>
  <style>
    html { font-size: 16px; }
    * { box-sizing: border-box; }
    /* Taille de texte confortable pour le contenu principal */
    #content { font-size: 0.97rem; }
    #content td, #content th { font-size: 0.92rem; }
    #content select, #content input, #content textarea { font-size: 1rem; }

    /* ── Empêche l'overflow horizontal sur mobile ─────────────── */
    html, body { overflow-x: hidden; max-width: 100%; }
    #app        { max-width: 100vw; overflow-x: hidden; }

    /* ══ DESIGN TOKENS ══════════════════════════════════════════════ */
    :root {
      --accent: #C8960C;
      --accent2: #4A90D9;
      /* Safe Area — iPhone notch / Dynamic Island / barre d'accueil */
      --sat: env(safe-area-inset-top, 0px);
      --sab: env(safe-area-inset-bottom, 0px);
      --sal: env(safe-area-inset-left, 0px);
      --sar: env(safe-area-inset-right, 0px);
      --bg-deep:      #09111E;
      --bg-warm:      #160E04;
      --panel-bg:     linear-gradient(135deg, #152540 0%, #241C08 100%);
      --card-hd:      linear-gradient(90deg, #1C3258 0%, #2C2208 100%);
      --input-bg:     linear-gradient(135deg, #0B1828 0%, #1C1408 100%);
      --border-mix:   rgba(200,150,12,0.22);
      --border-blu:   rgba(74,144,217,0.28);
      --text-main:    #E2D8C0;
      --text-muted:   #A0B0D0;
      --gold:         #C8960C;
      --gold-lt:      #E8B84B;
      --blue:         #4A90D9;
      --green:        #4AE090;
      --red:          #E04A4A;
      --glass:        rgba(255,255,255,0.03);
      --glass-border: rgba(255,255,255,0.07);
      --shadow-gold:  0 8px 32px rgba(200,150,12,0.15);
      --shadow-deep:  0 20px 60px rgba(0,0,0,0.6);
      --radius-lg:    16px;
      --radius-md:    12px;
      --radius-sm:    8px;
      --transition:   all 0.22s cubic-bezier(0.4,0,0.2,1);
      
      /* AGTM Design System tokens */
      --agtm-navy:      #0D2D52;
      --agtm-blue:      #1B4F8A;
      --agtm-gold:      #E8941A;
      --agtm-gold-lt:   #F5B942;
      --agtm-dark:      #080F1A;
      --agtm-card:      #132540;
      --agtm-border:    #1E3A5F;
      --agtm-white:     #FAFAF8;
      --agtm-muted:     #8A9AB5;
      --agtm-success:   #22C55E;
      --agtm-danger:    #EF4444;
      --agtm-warning:   #F59E0B;
      --agtm-info:      #3B82F6;
      --font-serif:  'Cormorant Garamond', Georgia, serif;
      --font-sans:   'DM Sans', system-ui, sans-serif;
      --font-mono:   'Space Mono', 'Courier New', monospace;
      --space-1:  4px;  --space-2:  8px;   --space-3:  12px;
      --space-4:  16px; --space-5:  20px;  --space-6:  24px;
      --space-8:  32px; --space-10: 40px;  --space-12: 48px;
      --space-16: 64px;
      --shadow-sm:  0 1px 3px rgba(0,0,0,0.4);
      --shadow-md:  0 4px 16px rgba(0,0,0,0.5);
      --shadow-lg:  0 8px 40px rgba(0,0,0,0.6);
      --shadow-gold:0 8px 30px rgba(232,148,26,0.3);
      --transition-slow: all 0.4s ease;
      --radius-sm-ds: 2px;
      --radius-md-ds: 4px;
      --radius-lg-ds: 8px;
      --radius-full: 100px;
    }

    body {
      background: linear-gradient(150deg, #09111E 0%, #160E04 40%, #0B1A2E 70%, #160E04 100%);
      background-attachment: fixed;
      /* AGTM Design System body enhancements */
      font-family: var(--font-sans);
      color: var(--agtm-white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    /* Grain texture overlay */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.5;
    }
    /* AGTM Scrollbar */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--agtm-dark); }
    ::-webkit-scrollbar-thumb { background: var(--agtm-card); border-radius: 3px; }

    /* ── Scrollbar ─────────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: linear-gradient(180deg, #C8960C44, #4A90D944); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: linear-gradient(180deg, #C8960C, #4A90D9); }

    /* ── Nav ───────────────────────────────────────────────────── */
    .nav-btn { transition: var(--transition) !important; }
    .nav-btn:hover { background: rgba(200,150,12,0.14) !important; color: #E8B84B !important; transform: translateX(3px); }
    .nav-btn.active { background: linear-gradient(90deg,rgba(200,150,12,0.18),rgba(74,144,217,0.1)) !important; border-left: 3px solid #C8960C; color: #E8B84B !important; }
    #navList .nav-btn { padding: 10px 14px; margin-bottom: 4px; }
    /* Amélioration des états actifs pour sidebar */
    #mainSidebar .nav-btn.active {
      background: rgba(200,150,12,0.25) !important;
      border-left: 3px solid #C8960C !important;
    }
    #mainSidebar .nav-btn:hover {
      background: rgba(200,150,12,0.15) !important;
    }
    /* Assurer un défilement complet */
    #navList {
      padding-bottom: 30px !important;
    }

    /* ── Inputs ────────────────────────────────────────────────── */
    input[type="date"], input[type="time"] { color-scheme: dark; }
    select { color-scheme: dark; }
    select option { background-color: #0D1B2A !important; color: #E2D8C0 !important; }
    input:not([type="checkbox"]):not([type="radio"]):focus,
    select:focus, textarea:focus {
      border-color: var(--gold) !important;
      box-shadow: 0 0 0 3px rgba(200,150,12,0.15) !important;
      outline: none !important;
    }

    /* ── Animations ────────────────────────────────────────────── */
    .fade-in { animation: fadeIn .32s cubic-bezier(0.4,0,0.2,1); }
    @keyframes fadeIn  { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
    @keyframes pulse   { 0%,100%{opacity:.3} 50%{opacity:1} }
    @keyframes slideIn { from { opacity:0; transform:translateX(-16px); } to { opacity:1; transform:none; } }
    @keyframes scaleIn { from { opacity:0; transform:scale(.96); } to { opacity:1; transform:scale(1); } }
    @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
    @keyframes glow    { 0%,100%{box-shadow:0 0 8px rgba(200,150,12,0.3)} 50%{box-shadow:0 0 22px rgba(200,150,12,0.7)} }
    @keyframes ripple  { to { transform:scale(4); opacity:0; } }

    .card-enter { animation: scaleIn .28s cubic-bezier(0.4,0,0.2,1) both; }
    .slide-in   { animation: slideIn .28s cubic-bezier(0.4,0,0.2,1) both; }

    /* ── KPI Cards hover ──────────────────────────────────────── */
    .kpi-card {
      transition: var(--transition);
      cursor: default;
      position: relative;
      overflow: hidden;
      padding: 20px;
    }
    .kpi-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 60%);
      opacity: 0;
      transition: opacity .22s;
    }
    .kpi-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-gold) !important; }
    .kpi-card:hover::before { opacity: 1; }

    /* ── Panels ────────────────────────────────────────────────── */
    .agtm-panel {
      background: var(--panel-bg);
      border: 1px solid var(--border-mix);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: var(--transition);
      box-shadow: var(--shadow-deep);
    }
    .agtm-panel:hover { border-color: rgba(200,150,12,0.35); }
    
    /* Standard card */
    .card {
      background: var(--panel-bg);
      border: 1px solid var(--border-mix);
      border-radius: var(--radius-md);
      padding: 16px;
      box-shadow: var(--shadow-deep);
    }
    .agtm-card-hd {
      background: var(--card-hd);
      padding: 13px 20px;
      border-bottom: 1px solid var(--border-mix);
      display: flex; align-items: center; justify-content: space-between;
    }

    /* ── Tables ────────────────────────────────────────────────── */
    table tbody tr { transition: background .15s; }
    table tbody tr:hover { background: rgba(200,150,12,0.06) !important; }
    
    /* Table improvements */
    table thead th {
      background: linear-gradient(90deg, #1C3258, #2C2208);
      color: #E8B84B;
      font-weight: 700;
      font-size: 0.8rem;
      padding: 10px 14px;
      border-bottom: 2px solid var(--gold);
    }
    table tbody td {
      padding: 10px 14px;
      border-bottom: 1px solid rgba(200,150,12,0.1);
    }

    /* ── FullCalendar Dark Theme ───────────────────────────────── */
    .fc { font-family: 'Segoe UI',system-ui,sans-serif; font-size:.82rem; }
    .fc-theme-standard .fc-scrollgrid { border-color: #1E3050; }
    .fc-theme-standard td, .fc-theme-standard th { border-color: #1E3050; }
    .fc .fc-daygrid-day-number, .fc .fc-col-header-cell-cushion { color: #E2D8C0; text-decoration:none; }
    .fc .fc-toolbar-title { color: #E8B84B; font-size: 1rem; font-weight:800; }
    .fc .fc-button { background:#1A2D42; border-color:#2A3F58; color:#E2D8C0; font-size:.76rem; padding:5px 12px; transition:all .15s; }
    .fc .fc-button:hover { background:#C8960C; border-color:#C8960C; color:#0D1B2A; }
    .fc .fc-button-primary:not(:disabled).fc-button-active { background:#C8960C; border-color:#C8960C; color:#0D1B2A; }
    .fc .fc-daygrid-day.fc-day-today { background: rgba(200,150,12,0.07); }
    .fc .fc-daygrid-day:hover { background: rgba(200,150,12,0.04); cursor:pointer; }
    .fc-event { border-radius:5px !important; padding:2px 5px !important; font-size:.72rem !important; border:none !important; cursor:grab !important; }
    .fc-event:active { cursor:grabbing !important; }
    .fc-event-title { font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .fc-event-conflict { animation: glow 1s ease-in-out 3; box-shadow: 0 0 0 2px #E04A4A; }
    .fc .fc-popover { background:#0E1C2E; border:1px solid rgba(200,150,12,.35); border-radius:10px; box-shadow:0 8px 28px rgba(0,0,0,.7); }
    .fc .fc-popover-title { background:linear-gradient(90deg,#1C3258,#2C2208); color:#E8B84B; }
    .fc .fc-popover-body { color:#E2D8C0; }
    .fc-timegrid-slot-label-cushion { color:#5A7090; font-size:.68rem; }
    .fc-timegrid-event { border-radius:6px !important; }
    .fc-highlight { background:rgba(200,150,12,0.15) !important; }
    .at-risk-badge { animation: pulse 2s ease-in-out infinite; }

    /* ── Buttons ───────────────────────────────────────────────── */
    button { transition: var(--transition) !important; }
    button:active { transform: scale(.97); }
    button:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
    
    /* Button variants */
    .btn-primary {
      background: linear-gradient(135deg, var(--gold), var(--gold-lt)) !important;
      color: #0D1B2A !important;
      font-weight: 700 !important;
      border: 1px solid rgba(200,150,12,0.5) !important;
      padding: 8px 16px !important;
      border-radius: 8px !important;
    }
    .btn-secondary {
      background: rgba(10,20,38,0.7) !important;
      border: 1px solid rgba(74,144,217,0.25) !important;
      color: #4A90D9 !important;
      padding: 6px 12px !important;
      border-radius: 20px !important;
      font-size: 0.7rem !important;
    }
    .btn-secondary:hover {
      background: rgba(10,20,38,0.9) !important;
      border-color: #4A90D9 !important;
    }

    /* Ripple effect */
    .btn-ripple { position:relative; overflow:hidden; }
    .btn-ripple .ripple-wave {
      position:absolute; border-radius:50%;
      background:rgba(255,255,255,0.3);
      width:20px; height:20px;
      animation: ripple .5s linear;
      pointer-events:none;
    }

    /* ── Skeleton loader ───────────────────────────────────────── */
    .skeleton {
      background: linear-gradient(90deg, #152233 25%, #1E3050 50%, #152233 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 6px;
    }

    /* ── Glass morphism panels ─────────────────────────────────── */
    .glass-panel {
      background: rgba(21,37,64,0.45);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
    }

    /* ── Gradient text ─────────────────────────────────────────── */
    .grad-text {
      background: linear-gradient(135deg, #E8B84B, #C8960C, #4A90D9);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Tooltip ────────────────────────────────────────────────── */
    [data-tip] { position: relative; cursor: help; }
    [data-tip]::after {
      content: attr(data-tip);
      position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%);
      background: #0D1B2A; color: #E2D8C0; font-size:.68rem; padding:4px 10px;
      border-radius:6px; white-space:nowrap; pointer-events:none;
      opacity:0; transition:opacity .18s; z-index:1000;
      border:1px solid rgba(200,150,12,0.3);
      box-shadow: 0 4px 14px rgba(0,0,0,.5);
    }
    [data-tip]:hover::after { opacity: 1; }

    /* ── Command Palette (Ctrl+K) ──────────────────────────────── */
    #cmdPalette {
      position: fixed; inset: 0; z-index: 99999;
      background: rgba(4,9,18,.82);
      backdrop-filter: blur(14px);
      display: none; align-items: flex-start; justify-content: center;
      padding-top: 10vh;
    }
    #cmdPalette.open { display: flex; animation: scaleIn .18s ease; }
    #cmdBox {
      width: 100%; max-width: 580px;
      background: linear-gradient(135deg, #0E1C2E, #1A1206);
      border: 1px solid rgba(200,150,12,.4);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 30px 80px rgba(0,0,0,.8), 0 0 0 1px rgba(200,150,12,.1);
    }
    #cmdInput {
      width:100%; padding:18px 20px; background:transparent;
      border:none; border-bottom:1px solid rgba(200,150,12,.2);
      color:#E2D8C0; font-size:1rem; outline:none;
    }
    #cmdInput::placeholder { color:#3A5070; }
    .cmd-item {
      display:flex; align-items:center; gap:12px;
      padding:11px 18px; cursor:pointer;
      transition: background .12s;
    }
    .cmd-item:hover, .cmd-item.selected { background: rgba(200,150,12,0.12); }
    .cmd-item-icon { font-size:1.1rem; width:28px; text-align:center; flex-shrink:0; }
    .cmd-item-label { flex:1; font-size:.88rem; color:#E2D8C0; }
    .cmd-item-shortcut { font-size:.68rem; color:#3A5070; background:#0D1B2A; padding:2px 7px; border-radius:5px; }

    /* ── User Profile Dropdown ─────────────────────────────────── */
    #profileDrop {
      position:absolute; top:calc(100% + 8px); right:0;
      min-width:220px; z-index:9999;
      background: linear-gradient(135deg, #0E1C2E, #1A1206);
      border:1px solid rgba(200,150,12,.35);
      border-radius:14px;
      overflow:hidden;
      box-shadow: 0 16px 48px rgba(0,0,0,.7);
      display:none;
      animation: scaleIn .16s ease;
    }
    #profileDrop.open { display:block; }

    /* ── Mobile Sidebar Overlay ────────────────────────────────── */
    #sidebarOverlay {
      display:none; position:fixed; inset:0; z-index:1400;
       background:rgba(0,0,0,.5); backdrop-filter:blur(4px);
    }
    #sidebarOverlay.open { display:block; }

    /* ── Collapsible Sidebar (Desktop) ────────────────────────── */
    #mainSidebar {
      transition: width .26s cubic-bezier(0.4,0,0.2,1);
    }
    #mainSidebar.collapsed {
      width: 62px !important;
      overflow: hidden !important;
    }
    
    /* Desktop padding for fixed sidebar */
    @media (min-width: 901px) {
      #mainSidebar + div {
        padding-left: 252px;
        transition: padding-left .26s cubic-bezier(0.4,0,0.2,1);
      }
      #mainSidebar.collapsed + div {
        padding-left: 62px;
      }
    }
    #mainSidebar.collapsed .nav-label,
    #mainSidebar.collapsed #sidebarUser,
    #mainSidebar.collapsed .sidebar-footer-links,
    #mainSidebar.collapsed .sidebar-copyright,
    #mainSidebar.collapsed .nav-group-header {
      display: none !important;
    }
    /* Scrollbar sidebar épurée */
    #navList::-webkit-scrollbar { width: 3px; }
    #navList::-webkit-scrollbar-track { background: transparent; }
    #navList::-webkit-scrollbar-thumb { background: rgba(200,150,12,0.25); border-radius: 2px; }
    #navList::-webkit-scrollbar-thumb:hover { background: rgba(200,150,12,0.5); }
    #mainSidebar.collapsed .nav-btn {
      justify-content: center !important;
      padding: 9px 0 !important;
      position: relative !important;
      border-left: none !important;
    }
    #mainSidebar.collapsed .nav-btn span.nav-icon {
      font-size: 1.15rem !important;
    }
    /* En mode collapsed, montrer tous les items même si groupe fermé */
    #mainSidebar.collapsed [id^="nav_grp_"] {
      display: block !important;
      padding-left: 0 !important;
    }
    #mainSidebar.collapsed #sidebarLogoText {
      display: none !important;
    }
    /* Tooltip pour sidebar collapsée */
    #mainSidebar.collapsed .nav-btn::after {
      content: attr(title);
      position: fixed;
      left: 68px;
      background: #0D1B2A;
      color: #E8B84B;
      font-size: .72rem;
      font-weight: 700;
      padding: 5px 12px;
      border-radius: 8px;
      white-space: nowrap;
      pointer-events: none;
      opacity: 0;
      transition: opacity .15s;
      z-index: 9999;
      border: 1px solid rgba(200,150,12,.4);
      box-shadow: 4px 4px 18px rgba(0,0,0,.6);
    }
    #mainSidebar.collapsed .nav-btn:hover::after {
      opacity: 1;
    }
    #hamburgerBtn { display: flex !important; }

    /* ── Tables auto-scrollable ────────────────────────────────── */
    .tbl-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .tbl-scroll table { min-width: max-content; }

    /* ── Grilles auto-responsives (injectées via setContent) ───── */
    .resp-grid-auto {
      display: grid !important;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr)) !important;
      gap: 0.75rem;
    }

    /* ── Pedagogy catalogue — full-screen two-column layout ── */
    .ap-ped-shell {
      display: flex; flex-direction: column;
      height: calc(100vh - 100px);
      margin: -22px;
      overflow: hidden;
    }
    .ap-ped-topbar {
      display: flex; align-items: stretch; flex-shrink: 0;
      border-bottom: 1px solid rgba(200,150,12,0.18);
      background: rgba(8,16,28,0.97);
      padding: 0 18px;
    }
    .ap-ped-body { flex: 1; display: flex; min-height: 0; overflow: hidden; }
    .ap-ped-nav {
      width: 190px; flex-shrink: 0;
      background: rgba(6,13,26,0.7);
      border-right: 1px solid rgba(200,150,12,0.13);
      padding: 6px 0; overflow-y: auto;
    }
    .ap-ped-content { flex: 1; overflow-y: auto; padding: 14px 18px; min-width: 0; }
    @media (max-width: 720px) { .ap-ped-nav { width: 145px; } }
    @media (max-width: 560px) {
      .ap-ped-shell { height: auto; overflow: visible; }
      .ap-ped-body { flex-direction: column; overflow: visible; }
