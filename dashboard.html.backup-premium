                  <div style="display:flex;gap:6px">
                    ${!isSelf?`
                    <button onclick="_toggleUserActif('${u.id}',${isActif})"
                      style="flex:1;padding:6px 10px;border-radius:7px;font-size:.7rem;cursor:pointer;font-weight:700;
                      background:${isActif?'#2A1A1A':'#1A3A1A'};border:1px solid ${isActif?'#E04A4A':'#4AE090'};color:${isActif?'#E04A4A':'#4AE090'}">
                      ${isActif?'🚫 Suspendre':'✅ Réactiver'}
                    </button>
                    <button onclick="_deleteUser('${u.id}','${(u.prenom||'')+' '+(u.nom||'')}')"
                      style="padding:6px 10px;border-radius:7px;font-size:.7rem;cursor:pointer;font-weight:700;background:#2A1A1A;border:1px solid #E04A4A;color:#E04A4A">
                      🗑️
                    </button>` : `<span style="font-size:.68rem;color:#2A4060;padding:6px 0">Votre propre compte — protégé</span>`}
                  </div>
                </div>

              </div>
            </div>`
          }).join('') : `
            <div style="background:#152233;border:1px solid #1E3050;border-radius:12px;padding:36px;text-align:center;color:#5A7090">
              Aucun utilisateur trouvé pour les filtres sélectionnés.
            </div>`}
        </div>

        <!-- Inviter / Créer un utilisateur -->
        <div style="background:#152233;border:1px solid #C8960C;border-radius:12px;overflow:hidden;margin-top:22px">
