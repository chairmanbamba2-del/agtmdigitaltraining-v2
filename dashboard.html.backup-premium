      {id:'bac_m1',titre:"Le BAC Anglais Côte d'Ivoire — Guide Expert",niveau:'B2',categorie:'BAC',duree:40,objectifs:["Maîtriser la structure et les exigences du BAC anglais","Distinguer les attentes selon les séries (A, B, C, D)","Planifier une révision efficace sur 3 mois"],contenu:[{type:'intro',texte:"Le BAC d'anglais en Côte d'Ivoire évalue des compétences avancées. L'objectif d'AGTM : vous amener à 14/20 et plus."},{type:'tableau',titre:'Structure du BAC Anglais (Terminale CI)',headers:["Section","Contenu","Points"],rows:[["Text Comprehension","Texte 20–25 lignes + questions de compréhension, vocabulaire, analyse","8–10 pts"],["Language in Use","Exercices de grammaire avancée (conditionnels, passif, discours rapporté)","4–6 pts"],["Written Expression","Essay argumentatif, lettre formelle ou article de presse 15–20 lignes","6–8 pts"]]},{type:'tableau',titre:'Grammaire Prioritaire BAC',headers:["Point grammatical","Fréquence"],rows:[["Conditionnels (Types 1, 2, 3, Mixed)","Très fréquent"],["Voix passive (tous les temps)","Fréquent"],["Discours rapporté complet","Fréquent"],["Propositions relatives (who, which, whose)","Modéré"],["Modaux avancés (should have, must have)","Modéré"]]},{type:'regle',titre:"Méthode de l'Essay BAC — Structure AGTM",texte:"INTRODUCTION (3-4 lignes) :\n• Contexte général → phrase d'accroche\n• Reformulation du sujet\n• Annonce du plan (In this essay, I will first... then...)\n\nDEVELOPPEMENT — 2 ou 3 paragraphes :\n• Point 1 + argument + exemple concret\n• Point 2 + argument + exemple concret\n\nCONCLUSION (2-3 lignes) :\n• Synthèse des arguments\n• Prise de position personnelle\n• Ouverture (question rhétorique ou projection future)"}],quiz:[{q:"The most frequently tested grammar point at the BAC is:",opts:["A) Articles","B) Conditionals","C) Nouns","D) Prepositions"],rep:'B',expl:"Les conditionnels sont systématiquement testés au BAC."},{q:"An argumentative essay introduction should end with:",opts:["A) your conclusion","B) an example","C) an announcement of the plan (thesis)","D) a grammar exercise"],rep:'C',expl:"L'introduction doit se terminer par l'annonce du plan."},{q:"For the Written Expression at BAC level, the expected length is:",opts:["A) 5 lines","B) 10 lines","C) 15–20 lines","D) 25+ lines"],rep:'C',expl:"L'expression écrite au BAC attend 15–20 lignes bien structurées."},{q:"Which grammar structure uses 'If + Past Perfect / would have + PP'?",opts:["A) Type 1 Conditional","B) Type 2 Conditional","C) Type 3 Conditional","D) Mixed Conditional"],rep:'C',expl:"Type 3 Conditional : If + Past Perfect → would have + Past Participle."},{q:"The conclusion of an essay should include:",opts:["A) new arguments","B) grammar exercises","C) a summary and personal stance","D) vocabulary list"],rep:'C',expl:"La conclusion synthétise les arguments et exprime une position personnelle."}]},
