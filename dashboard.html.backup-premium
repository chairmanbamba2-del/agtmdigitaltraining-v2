        const meetLien=s.lien_meet
        // Find evaluation closest to this séance date (within 7 days, only for past séances)
        const evalForSeance = !avenir ? (mesEvals||[]).find(e => {
          if (!e.date_eval) return false
          const diff = Math.abs(new Date(e.date_eval) - new Date(s.date_seance)) / (1000*60*60*24)
          return diff <= 7
