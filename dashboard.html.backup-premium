    window._delPersonnel = async function(id) {
      if (!confirm('Supprimer définitivement cet employé ? Toutes ses fiches de paie, congés et données RH seront effacés de la base de données. Action irréversible.')) return
      // Suppression en cascade : fiches_paie → conges → personnel
      await sb.from('fiches_paie').delete().eq('personnel_id', id)
      await sb.from('conges').delete().eq('personnel_id', id)
      const {error} = await sb.from('personnel').delete().eq('id', id)
      if (error) { toast('Erreur : ' + error.message, 'err'); return }
      toast('✅ Employé supprimé définitivement')
      renderRH()
    }

