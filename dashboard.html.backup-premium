    window.planCheckConflits = async function() {
      const date = document.getElementById('planDate')?.value
      const hdeb = document.getElementById('planHdeb')?.value
      const hfin = document.getElementById('planHfin')?.value
      const formateurSel = document.getElementById('planFmtSel')?.value
      const alertEl = document.getElementById('planConflitAlert')
      if (!date || !hdeb || !hfin || !formateurSel || !alertEl) return
      // Récupérer le nom du formateur
      const fmtOpt = window._planState?.allFormateurs?.find(f => String(f.id) === String(formateurSel))
      if (!fmtOpt) return
      const fmtName = [fmtOpt.prenom, fmtOpt.nom].filter(Boolean).join(' ')
      // Interroger l'API pour les séances existantes du formateur à cette date
      const { data: existing } = await sb.from('seances')
        .select('id, date_seance, heure_debut, heure_fin, sujet, statut')
        .eq('date_seance', date)
        .eq('enseignant', fmtName)
        .neq('statut', 'Annulée')
        .order('heure_debut')
      let conflits = []
      if (existing && existing.length) {
        const start = hdeb
        const end = hfin
        conflits = existing.filter(s => {
          const sStart = s.heure_debut
          const sEnd = s.heure_fin
          if (!sStart || !sEnd) return false
          // Vérifier chevauchement
          return !(end <= sStart || start >= sEnd)
        })
      }
      if (conflits.length) {
        alertEl.style.display = 'block'
        alertEl.innerHTML = `⚠ Conflit détecté ! Le formateur a déjà ${conflits.length} séance(s) sur ce créneau :<br>
          ${conflits.map(s => `<strong>${s.heure_debut}–${s.heure_fin}</strong> – ${s.sujet || 'Sans sujet'}`).join('<br>')}`
      } else {
        alertEl.style.display = 'none'
      }
    }

    // Initialiser la durée au chargement
    setTimeout(() => {
      if (typeof planUpdateDuree === 'function') planUpdateDuree()
