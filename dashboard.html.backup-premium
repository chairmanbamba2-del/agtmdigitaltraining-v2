              <thead>${th('Étudiant','Niveau','Séances','Présences','Absences','Taux de présence','Alerte')}</thead>
              <tbody>
                ${studentStats.map(e=>{
                  const col=e.taux>=75?'#4AE090':e.taux>=50?'#E8B84B':'#E04A4A'
                  const alerte=e.taux<50?bdg('🚨 Critique','#2A1A00','#E04A4A'):e.taux<75?bdg('⚠️ Insuffisant','#2A1500','#E8B84B'):bdg('✅ Satisfaisant','#1A3A1A','#4AE090')
