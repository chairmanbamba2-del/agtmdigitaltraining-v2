    /**
     * Génère le message de rappel de séance (Admin/Secrétaire)
     */
    window._waMsgSeance = function(nomEtudiant, date, heure, lienPointage) {
      const dateStr = date ? new Date(date).toLocaleDateString('fr-FR',{weekday:'long',day:'2-digit',month:'long',year:'numeric'}) : '—'
      const conditions = 'Les absences non justifiées ne sont pas rattrapables. En cas d\'empêchement, prévenez-nous avant la séance.'
      return `Bonjour ${nomEtudiant} 👋,\n\nVotre séance AGTM Digital Academy est prévue le *${dateStr}* à *${heure || '—'}*.\n\n📋 Conditions :\n${conditions}\n\n✅ Lien de pointage :\n${lienPointage || '[lien non disponible]'}\n\nÀ bientôt !\n— Équipe AGTM Digital Academy`
    }

    /**
     * Génère le message du formateur vers un étudiant
     */
    window._waMsgFormateur = function(nomEtudiant, motif, detail) {
      const base = `Bonjour ${nomEtudiant} 👋,\n\nC'est votre formateur d'anglais AGTM.\n\n`
      const msgs = {
        seance: `Je vous contacte concernant *votre prochaine séance*${detail ? ' du ' + detail : ''}.\nMerci de confirmer votre présence et d'avoir votre matériel prêt.\n\nÀ bientôt ! 🎓`,
        absence: `Je vous contacte concernant *votre absence* lors de la dernière séance${detail ? ' du ' + detail : ''}.\nMerci de nous faire parvenir un justificatif si l'absence est motivée.\nSans justificatif, la séance ne pourra pas être rattrapée.\n\nCordialement. 📋`,
        quiz: `Je vous contacte concernant *le quiz* à compléter${detail ? ' : ' + detail : ''}.\nMerci de vous connecter à votre espace étudiant pour le finaliser avant la prochaine séance.\n\nBonne chance ! 🧠`,
      }
      return base + (msgs[motif] || msgs.seance)
    }

    /**
     * Dialog rappel séance — fetches students from the classe linked to the séance,
     * shows individual WA buttons with pre-filled messages
     */
    window._waRappelSeanceDialog = async function(seanceId, date, heure, sujet) {
      const ptgLink = window.location.origin + window.location.pathname + '?pointage=' + seanceId
      const {data: seance} = await sb.from('seances').select('classe_id,enseignant').eq('id',seanceId).maybeSingle()
      let students = []
      if (seance?.classe_id) {
        const {data: inscs} = await sb.from('inscriptions_classes')
          .select('etudiants(id,nom,prenom,telephone)')
          .eq('classe_id', seance.classe_id).order('id')
        students = (inscs||[]).map(i=>i.etudiants).filter(Boolean)
      }
      if (!students.length) {
        const num = prompt('Numéro WhatsApp du destinataire (ex: +225 07 00 00 00 00) :')
        if (!num) return
        const nom = prompt('Nom de l\'étudiant :') || 'Étudiant'
        const msg = window._waMsgSeance(nom, date, heure, ptgLink)
        window.open('https://wa.me/' + window._waClean(num) + '?text=' + encodeURIComponent(msg), '_blank')
        return
      }
      const modal = document.createElement('div')
      modal.style.cssText = 'position:fixed;inset:0;z-index:99998;background:rgba(4,9,18,.88);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;padding:20px'
      modal.onclick = e => { if(e.target===modal) modal.remove() }
      modal.innerHTML = `
        <div style="background:linear-gradient(135deg,#0E1C2E,#1A1206);border:1px solid rgba(200,150,12,.4);border-radius:18px;width:100%;max-width:520px;overflow:hidden;box-shadow:0 20px 70px rgba(0,0,0,.7)">
          <div style="background:linear-gradient(90deg,#1C3258,#2C2208);border-bottom:2px solid #C8960C;padding:16px 22px;display:flex;align-items:center;justify-content:space-between">
            <div>
              <div style="font-size:.95rem;font-weight:800;color:#E8B84B">📲 Rappel WhatsApp — ${sujet}</div>
              <div style="font-size:.7rem;color:#8AAAC0;margin-top:2px">${date ? new Date(date).toLocaleDateString('fr-FR',{weekday:'long',day:'2-digit',month:'long'}) : ''} ${heure ? 'à '+heure : ''}</div>
            </div>
            <button onclick="this.closest('[style*=fixed]').remove()" style="background:none;border:none;color:#5A7090;font-size:1.2rem;cursor:pointer">✕</button>
          </div>
          <div style="padding:18px;max-height:60vh;overflow-y:auto">
            <div style="font-size:.72rem;color:#8AAAC0;margin-bottom:12px">${students.length} étudiant(s) actif(s) dans cette classe :</div>
            ${students.map(e => {
              const nom = [e.prenom,e.nom].filter(Boolean).join(' ')
              const tel = e.telephone || ''
              const msg = window._waMsgSeance(nom, date, heure, ptgLink)
              return `<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-radius:8px;background:rgba(21,37,64,0.4);border:1px solid rgba(200,150,12,0.12);margin-bottom:8px;gap:10px">
                <div>
                  <div style="font-weight:700;color:#E2D8C0;font-size:.82rem">${nom}</div>
                  <div style="font-size:.65rem;color:#5A7090;margin-top:1px">${tel||'<span style=color:#E04A4A>Pas de numéro</span>'}</div>
                </div>
                ${tel ? window._waBtn(tel, msg, '📲 Envoyer') : '<span style="font-size:.65rem;color:#5A7090">—</span>'}
              </div>`
            }).join('')}
          </div>
          <div style="padding:12px 18px;border-top:1px solid rgba(200,150,12,0.12);font-size:.65rem;color:#3A5070;text-align:center">
            🔒 Les liens s'ouvrent dans WhatsApp Web ou l'app — aucune donnée envoyée à des serveurs tiers
          </div>
        </div>`
      document.body.appendChild(modal)
    }

    /**
     * Contact étudiant par WhatsApp depuis l'espace formateur
     */
    window._waContactEtudiant = async function(nomComplet, motif, detail) {
      const parts = nomComplet.trim().split(' ')
      const prenom = parts[0]
      const nom = parts.slice(1).join(' ')
      let tel = ''
      const {data: etud} = await sb.from('etudiants')
        .select('telephone,prenom,nom')
        .ilike('nom', nom ? '%'+nom+'%' : '%'+prenom+'%')
        .maybeSingle()
      if (etud?.telephone) {
        tel = etud.telephone
      } else {
        tel = prompt('Numéro WhatsApp de ' + nomComplet + ' (ex: +225 07 00 00 00):') || ''
        if (!tel) return
      }
      const msg = window._waMsgFormateur(nomComplet, motif, detail || '')
      const n = window._waClean(tel)
      if (!n) { toast('Numéro invalide','err'); return }
      window.open('https://wa.me/' + n + '?text=' + encodeURIComponent(msg), '_blank')
    }

    // ══ HAMBURGER — Toggle Collapsible (Desktop) / Drawer (Mobile) ══
    window._toggleSidebar = function() {
      const isMobile = window.innerWidth <= 900
      if (isMobile) {
        const sb = document.getElementById('mainSidebar')
        const isOpen = sb?.classList.contains('open')
        if (isOpen) window._closeSidebar()
        else         window._openSidebar()
      } else {
        const sb = document.getElementById('mainSidebar')
        const isCollapsed = sb?.classList.contains('collapsed')
        if (isCollapsed) {
          sb?.classList.remove('collapsed')
          localStorage.setItem('agtm_sidebar_collapsed','0')
        } else {
          sb?.classList.add('collapsed')
          localStorage.setItem('agtm_sidebar_collapsed','1')
        }
      }
    }

    // Restore sidebar state on load
    ;(function() {
      if (localStorage.getItem('agtm_sidebar_collapsed') === '1') {
        const sb = document.getElementById('mainSidebar')
        if (sb && window.innerWidth > 900) sb.classList.add('collapsed')
      }
    })()

    init().catch(err => {
      console.error('❌ init() rejeté:', err)
      document.getElementById('loading').innerHTML = `
        <div style="max-width:480px;text-align:center;padding:32px">
          <div style="font-size:2.5rem;margin-bottom:12px">⚠️</div>
          <div style="font-size:1rem;font-weight:700;color:#E04A4A;margin-bottom:12px">Erreur critique</div>
          <div style="font-size:.82rem;color:#90A4AE;margin-bottom:20px">${err?.message || String(err)}</div>
          <button onclick="location.reload()" style="padding:9px 20px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A">🔄 Réessayer</button>
          <div style="margin-top:12px;font-family:monospace;font-size:.6rem;color:#2A4060;background:#0A1420;padding:8px;border-radius:6px;text-align:left;max-height:80px;overflow-y:auto">${err?.stack ? err.stack.replace(/</g,'&lt;').replace(/>/g,'&gt;') : ''}</div>
        </div>
      `
    })
  </script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').then(reg => {
        reg.addEventListener('updatefound', () => {
          const nw = reg.installing
          nw?.addEventListener('statechange', () => {
            if (nw.state === 'installed' && navigator.serviceWorker.controller) {
              // Nouvelle version disponible — notifier discrètement
              const banner = document.createElement('div')
              banner.style.cssText = 'position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:#C8960C;color:#0D1B2A;padding:10px 20px;border-radius:10px;font-weight:700;font-size:.82rem;z-index:9999;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,.4)'
              banner.textContent = '🔄 Mise à jour disponible — Cliquer pour recharger'
              banner.onclick = () => { nw.postMessage({ type: 'SKIP_WAITING' }); location.reload() }
              document.body.appendChild(banner)
            }
          })
        })
      }).catch(() => {})
    }
  </script>
  <script src="/pedagogy-content.js"></script>

  <!-- ── GOOGLE MEET MODAL (cours en ligne) ──────────── -->
  <div id="_meetModal" style="display:none;position:fixed;inset:0;z-index:99998;background:rgba(0,0,0,.82);backdrop-filter:blur(6px);align-items:center;justify-content:center">
    <div style="background:#0D1B2A;border:2px solid #1a73e8;border-radius:16px;width:min(540px,94vw);overflow:hidden;box-shadow:0 24px 70px rgba(0,0,0,.7)">
      <div style="background:#0A1520;padding:14px 18px;display:flex;align-items:center;gap:12px;border-bottom:1px solid #1A3050">
        <div style="width:36px;height:36px;background:#1a73e8;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0">🎥</div>
        <div style="flex:1;min-width:0">
          <div style="font-weight:800;color:#fff;font-size:.92rem">Cours en ligne — Google Meet</div>
          <div id="_meetModalTitle" style="color:#6AAAE8;font-size:.75rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></div>
        </div>
        <button onclick="window._closeMeetModal()" style="padding:6px 12px;border-radius:8px;background:rgba(224,74,74,.15);border:1.5px solid rgba(224,74,74,.4);color:#E04A4A;font-weight:700;font-size:.8rem;cursor:pointer;flex-shrink:0">✕ Fermer</button>
      </div>
      <div style="padding:26px 22px;display:flex;flex-direction:column;gap:18px;align-items:center">
        <div style="font-size:3.2rem;line-height:1">📹</div>
        <div style="color:#e0e0e0;font-weight:700;font-size:.92rem;text-align:center">Réunion prête — cliquez pour rejoindre</div>
        <div style="color:#8AAAC0;font-size:.76rem;text-align:center;line-height:1.5">Google Meet s'ouvre dans un nouvel onglet.<br>Copiez le lien ci-dessous pour le partager aux apprenants.</div>
        <div style="display:flex;align-items:center;gap:8px;background:#080F18;border:1px solid #1A3050;border-radius:10px;padding:10px 14px;width:100%;box-sizing:border-box">
          <input id="_meetModalLink" readonly value="" style="flex:1;background:transparent;border:none;color:#4A90D9;font-size:.82rem;outline:none;min-width:0;font-weight:600"/>
          <button onclick="window._copyMeetLink()" style="padding:5px 12px;border-radius:7px;background:#1A2D42;border:1px solid #4A90D9;color:#4A90D9;font-size:.72rem;font-weight:700;cursor:pointer;flex-shrink:0;white-space:nowrap">📋 Copier</button>
        </div>
        <button onclick="window._joinMeet()" style="width:100%;padding:15px;border-radius:12px;background:linear-gradient(135deg,#1a73e8 0%,#0d5bb5 100%);border:none;color:#fff;font-weight:800;font-size:.97rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;box-shadow:0 4px 20px rgba(26,115,232,.4)">
          📹 Rejoindre Google Meet
        </button>
        <div style="color:#3A5070;font-size:.68rem;text-align:center">Les apprenants utilisent le même lien pour rejoindre</div>
      </div>
    </div>
  </div>
  <script>
  ;(function(){
    let _meetCurrentUrl = ''

    window._copyMeetLink = function() {
      if (!_meetCurrentUrl) return
      const fallback = () => {
        const tmp = document.createElement('input')
        tmp.value = _meetCurrentUrl; document.body.appendChild(tmp)
        tmp.select(); document.execCommand('copy'); document.body.removeChild(tmp)
      }
      if (navigator.clipboard) navigator.clipboard.writeText(_meetCurrentUrl).catch(fallback)
      else fallback()
      if (typeof toast === 'function') toast('✅ Lien Google Meet copié — à envoyer aux apprenants !')
    }

    window._joinMeet = function() {
      if (_meetCurrentUrl) window.open(_meetCurrentUrl, '_blank', 'noopener')
    }

    window._openJitsiRoom = window._openMeetRoom = function(url, title) {
      if (!url) return
      const modal   = document.getElementById('_meetModal')
      const titleEl = document.getElementById('_meetModalTitle')
      const linkEl  = document.getElementById('_meetModalLink')
      if (!modal) { window.open(url, '_blank', 'noopener'); return }
      _meetCurrentUrl = url
      if (titleEl) titleEl.textContent = title || url
      if (linkEl)  linkEl.value = url
      modal.style.display = 'flex'
      document.body.style.overflow = 'hidden'
      // Ouvre immédiatement Google Meet dans un nouvel onglet
      window.open(url, '_blank', 'noopener')
    }

    window._closeJitsiModal = window._closeMeetModal = function() {
      const modal = document.getElementById('_meetModal')
      if (modal) modal.style.display = 'none'
      document.body.style.overflow = ''
    }

    window._isJitsiLink = function() { return false }

    // Ouvre Google Meet pour créer une nouvelle réunion — l'utilisateur copie le lien généré
     window._fsGenGMeet = window._fsGenJitsi = function() {
       window.open('https://meet.google.com/new', '_blank', 'noopener')
       if (typeof toast === 'function') toast('📋 Copiez le lien Google Meet depuis le nouvel onglet et collez-le dans le champ')
     }
     window._fsGenRandomMeet = function() {
       const meetLink = document.getElementById('fsLienMeet')
       if (!meetLink) return
       // Générer un lien Google Meet aléatoire (simulation)
       const randomId = Math.random().toString(36).substring(2, 10)
       const link = 'https://meet.google.com/' + randomId
       meetLink.value = link
       if (typeof toast === 'function') toast('🔗 Lien Google Meet généré (simulation)', 'info')
     }

    window._edtGenGMeet = window._edtGenJitsi = function() {
      window.open('https://meet.google.com/new', '_blank', 'noopener')
      if (typeof toast === 'function') toast('📋 Copiez le lien Google Meet depuis le nouvel onglet et collez-le dans le champ')
    }

    // Rejoindre le cours côté apprenant : pointe la présence + ouvre Meet
    // Sur tablette/mobile : redirection directe (même onglet) pour éviter le freeze
    // Sur desktop : modal habituel + nouvel onglet
    window._joinMeetWithPointage = async function(url, title, seanceId) {
      if (!url) return
      const isMobile = /Android|iPhone|iPad|iPod|Mobile|Tablet/i.test(navigator.userAgent)

      // Pointer la présence silencieusement avant de quitter
      if (seanceId) {
        try {
          const etudiantId = window._mesSeancesEtud?.id
          if (etudiantId && typeof sb !== 'undefined') {
            await sb.from('presences').upsert(
              { seance_id: Number(seanceId), etudiant_id: etudiantId, present: 1 },
              { onConflict: 'seance_id,etudiant_id' }
            )
            if (typeof toast === 'function') toast('✅ Présence enregistrée — bon cours !')
          }
        } catch(_) {}
      }

      if (isMobile) {
        // Tablette/mobile : redirection directe — pas de freeze, Meet prend tout l'écran
        window.location.href = url
      } else {
        // Desktop : modal + nouvel onglet
        window._openMeetRoom(url, title)
      }
    }
  })()
  </script>
