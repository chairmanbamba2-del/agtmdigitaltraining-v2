      const classeMap={}; (inscsToUse||[]).forEach(i=>{if(i.classes)classeMap[i.classe_id]=i.classes})

      const seanceCard=(s,avenir)=>{
        const pres=presMap[s.id]
        const cl=classeMap[s.classe_id]||{}
