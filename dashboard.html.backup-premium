          '<button onclick="_ptgVerifyEtud()" style="padding:9px 18px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:rgba(14,34,24,.9);border:1px solid #4AE090;color:#4AE090;white-space:nowrap">✅ Pointer</button></div>' +
          '<div id="ptgEtudResult" style="font-size:.78rem;color:#7A9AB0;margin-bottom:8px"></div>' +
          '<div id="ptgEtudList"></div>'

      setContent(
        '<div style="max-width:720px;margin:0 auto">' +
          '<div style="display:flex;align-items:center;gap:10px;margin-bottom:18px">' +
            '<button onclick="renderPresences()" style="padding:6px 14px;border-radius:7px;border:1px solid #2A3F58;background:transparent;color:#8AAAC0;cursor:pointer;font-size:.78rem">← Présences</button>' +
            '<div style="font-size:1rem;font-weight:800;color:#E2D8C0">📋 Feuille de Pointage</div>' +
          '</div>' +
          '<div style="background:linear-gradient(135deg,#152540,#241C08);border:1px solid rgba(200,150,12,.4);border-radius:13px;padding:16px 20px;margin-bottom:18px;display:grid;grid-template-columns:1fr 1fr;gap:10px">' +
            '<div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:#7A9AB0;margin-bottom:3px">Date</div><div style="font-size:.9rem;font-weight:700;color:#E8B84B">' + fmtDate2(seance.date_seance) + '</div></div>' +
            '<div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:#7A9AB0;margin-bottom:3px">Horaire</div><div style="font-size:.88rem;font-weight:700;color:#6AABF0">' + (seance.heure_debut||'—') + (seance.heure_fin?' – '+seance.heure_fin:'') + '</div></div>' +
            '<div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:#7A9AB0;margin-bottom:3px">Sujet</div><div style="font-size:.88rem;font-weight:700;color:#E2D8C0">' + (seance.sujet||'—') + '</div></div>' +
            '<div><div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:#7A9AB0;margin-bottom:3px">Classe</div><div style="font-size:.82rem;font-weight:700;color:#C8960C">' + (seance.programme||'—') + '</div></div>' +
          '</div>' +
          '<div style="background:linear-gradient(135deg,#152540,#241C08);border:1px solid rgba(200,150,12,.18);border-radius:13px;overflow:hidden;margin-bottom:18px">' +
            '<div style="background:linear-gradient(90deg,#1C3258,#2C2208);padding:12px 20px;border-bottom:1px solid rgba(200,150,12,.2);font-size:.88rem;font-weight:700;color:#E8B84B">👨‍🏫 Vérification du Formateur</div>' +
            '<div style="padding:18px">' +
              '<div style="display:flex;gap:10px;margin-bottom:12px">' + inp('ptgMat','text','N° Matricule ou CIN du Formateur') +
                '<button onclick="_ptgVerifyFmt()" style="padding:9px 18px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:rgba(28,50,88,.9);border:1px solid #4A90D9;color:#6AABF0;white-space:nowrap">🔍 Vérifier</button>' +
              '</div>' +
              '<div id="ptgFmtResult"></div>' +
            '</div>' +
          '</div>' +
          '<div style="background:linear-gradient(135deg,#152540,#241C08);border:1px solid rgba(200,150,12,.18);border-radius:13px;overflow:hidden;margin-bottom:18px">' +
            '<div style="background:linear-gradient(90deg,#1C3258,#2C2208);padding:12px 20px;border-bottom:1px solid rgba(200,150,12,.2);font-size:.88rem;font-weight:700;color:#E8B84B">👨‍🎓 Pointage des Étudiants</div>' +
            '<div style="padding:18px">' + etudListHtml + '</div>' +
          '</div>' +
          '<div style="background:linear-gradient(135deg,#0E2A1A,#1A1A08);border:1px solid rgba(74,224,144,.35);border-radius:13px;padding:16px 20px;margin-bottom:18px">' +
            '<div style="font-size:.8rem;color:#8AAAC0;margin-bottom:12px;line-height:1.6">Cliquez sur <strong style="color:#4AE090">Enregistrer le Pointage</strong> une fois la vérification complète.</div>' +
            btn('💾 Enregistrer le Pointage de Séance','_ptgSubmit()') +
          '</div>' +
        '</div>'
      )
    }

    window._ptgTousPresents = function() {
      ;(window._ptgClasseEtuds||[]).forEach(e => {
        const cb = document.getElementById('ptg_'+e.id)
        if (cb) { cb.checked = true; window._ptgToggleMotif(e.id) }
      })
    }

    window._ptgEffacer = function() {
      ;(window._ptgClasseEtuds||[]).forEach(e => {
        const cb = document.getElementById('ptg_'+e.id)
        if (cb) { cb.checked = false; window._ptgToggleMotif(e.id) }
      })
    }

    window._ptgToggleMotif = function(id) {
      const cb = document.getElementById('ptg_'+id)
      const wrap = document.getElementById('ptg_motif_wrap_'+id)
      if (wrap) wrap.style.opacity = cb?.checked ? '0.3' : '1'
      if (cb?.checked) {
        const jEl = document.getElementById('ptg_justif_'+id)
        const mEl = document.getElementById('ptg_motif_'+id)
        if (jEl) jEl.checked = false
        if (mEl) mEl.value = ''
      }
    }

    window._ptgVerifyFmt = async function() {
      const mat = document.getElementById('ptgMat')?.value?.trim()
      if (!mat) { toast('Saisissez le matricule','err'); return }
      const {data:pers} = await sb.from('personnel').select('id,nom,prenom,cin,matricule,poste,statut').ilike('matricule', mat).maybeSingle()
      if (!pers) {
        document.getElementById('ptgFmtResult').innerHTML = `<div style="padding:10px;background:#2A1A1A;border:1px solid #E04A4A;border-radius:8px;color:#E04A4A;font-size:.8rem">❌ Matricule introuvable : <strong>${mat}</strong></div>`
        window._ptgFormateur = null; return
      }
      if (pers.statut !== 'Actif') {
        document.getElementById('ptgFmtResult').innerHTML = `<div style="padding:10px;background:#2A1A1A;border:1px solid #E8B84B;border-radius:8px;color:#E8B84B;font-size:.8rem">⚠️ Compte inactif : <strong>${pers.prenom} ${pers.nom}</strong></div>`
        window._ptgFormateur = null; return
      }
      window._ptgFormateur = pers
      document.getElementById('ptgFmtResult').innerHTML = `<div style="padding:10px;background:#1A3A1A;border:1px solid #4AE090;border-radius:8px;display:flex;align-items:center;gap:10px">
        <span>✅</span><div><div style="font-size:.88rem;font-weight:800;color:#4AE090">${pers.prenom} ${pers.nom}</div>
        <div style="font-size:.7rem;color:#8AAAC0">${pers.poste||'Formateur'} · Actif</div></div></div>`
      toast('✅ Formateur vérifié : '+pers.prenom+' '+pers.nom)
    }

    // Pointage manuel par dossier (pour séances sans classe_id)
    window._ptgManuelEtuds = []
    window._ptgVerifyEtud = async function() {
      const dos = document.getElementById('ptgDos')?.value?.trim()
      if (!dos) { toast('Saisissez un N° dossier','err'); return }
      if ((window._ptgManuelEtuds||[]).find(e=>e.numero_dossier?.toLowerCase()===dos.toLowerCase())) { toast('Déjà dans la liste !','err'); document.getElementById('ptgDos').value=''; return }
      const {data:etud} = await sb.from('etudiants').select('id,nom,prenom,niveau,numero_dossier,statut').ilike('numero_dossier', dos).maybeSingle()
      const res = document.getElementById('ptgEtudResult')
      if (!etud || etud.statut !== 'Actif') {
        res.textContent = `❌ "${dos}" introuvable ou inactif.`; res.style.color='#E04A4A'; return
      }
      window._ptgManuelEtuds.push(etud)
      document.getElementById('ptgDos').value = ''
      res.textContent = `✅ ${etud.prenom} ${etud.nom} ajouté(e).`; res.style.color='#4AE090'
      _ptgRenderManuelList()
      toast(`✅ ${etud.prenom} ${etud.nom} — Niveau ${etud.niveau||'?'}`)
    }

    function _ptgRenderManuelList() {
      const el = document.getElementById('ptgEtudList')
      if (!el) return
      const etuds = window._ptgManuelEtuds || []
      if (!etuds.length) { el.innerHTML = '<div style="font-size:.75rem;color:#5A7090;font-style:italic">Aucun étudiant pointé.</div>'; return }
      el.innerHTML = `<div style="font-size:.72rem;color:#8AAAC0;margin-bottom:8px;font-weight:700">${etuds.length} étudiant(s) présent(s)</div>
        <table style="width:100%;border-collapse:collapse">
          <thead><tr style="background:#0D1B2A"><th style="padding:6px 10px;font-size:.68rem;color:#8AAAC0;text-align:left">N° Dossier</th><th style="padding:6px 10px;font-size:.68rem;color:#8AAAC0;text-align:left">Nom</th><th style="padding:6px 10px;font-size:.68rem;color:#8AAAC0;text-align:center">Niveau</th><th></th></tr></thead>
          <tbody>${etuds.map((e,i)=>`<tr style="border-top:1px solid rgba(200,150,12,.12)">
            <td style="padding:7px 10px;font-size:.78rem;color:#C8960C;font-weight:700">${e.numero_dossier||'—'}</td>
            <td style="padding:7px 10px;font-size:.82rem;color:#E2D8C0;font-weight:600">${e.prenom} ${e.nom}</td>
            <td style="padding:7px 10px;text-align:center"><span style="padding:2px 8px;border-radius:5px;font-size:.7rem;font-weight:700;background:rgba(28,50,88,.7);border:1px solid #4A90D9;color:#6AABF0">${e.niveau||'—'}</span></td>
            <td style="padding:7px 10px"><button onclick="_ptgManuelEtuds.splice(${i},1);_ptgRenderManuelList()" style="padding:2px 8px;border-radius:5px;font-size:.68rem;cursor:pointer;background:#2A1A1A;border:1px solid #E04A4A;color:#E04A4A">✕</button></td>
          </tr>`).join('')}</tbody>
        </table>`
    }

    window._ptgSubmit = async function() {
      if (!window._ptgFormateur) { toast('⚠️ Vérifiez le formateur d\'abord.','err'); return }

      const hasClass = (window._ptgClasseEtuds||[]).length > 0
      let presences = []

      if (hasClass) {
        // Classe pré-chargée : enregistrer présents ET absents
        presences = window._ptgClasseEtuds.map(e => {
          const isPresent = document.getElementById('ptg_'+e.id)?.checked ? 1 : 0
          const justifie  = isPresent ? false : (document.getElementById('ptg_justif_'+e.id)?.checked || false)
          const motif     = isPresent ? null  : (document.getElementById('ptg_motif_'+e.id)?.value?.trim() || null)
          return { seance_id: Number(window._ptgSeanceId), etudiant_id: e.id, present: isPresent, justifie, motif_absence: motif,
                   notes: `Pointage — ${new Date().toLocaleString('fr-FR')}` }
        })
        if (!presences.some(p=>p.present===1)) { toast('⚠️ Cochez au moins un étudiant présent.','err'); return }
      } else {
        // Manuel : seulement les présents ajoutés
        if (!(window._ptgManuelEtuds||[]).length) { toast('⚠️ Ajoutez au moins un étudiant présent.','err'); return }
        presences = window._ptgManuelEtuds.map(e => ({
          seance_id: Number(window._ptgSeanceId), etudiant_id: e.id, present: 1,
          notes: `Pointage — ${new Date().toLocaleString('fr-FR')}`
        }))
      }

      const nbPres = presences.filter(p=>p.present===1).length
      if (!confirm(`Confirmer le pointage ?\n• Formateur : ${window._ptgFormateur.prenom} ${window._ptgFormateur.nom}\n• ${nbPres} présent(s) / ${presences.length} étudiant(s)\n\nÉtape suivante : soumettre le rapport de séance.`)) return

      const {error:se} = await sb.from('seances').update({
        pointage_fait: true,
        enseignant: `${window._ptgFormateur.prenom} ${window._ptgFormateur.nom}`
      }).eq('id', window._ptgSeanceId)
      if (se) { toast('Erreur séance : '+se.message,'err'); return }

      const {error:pe} = await sb.from('presences').upsert(presences, {onConflict:'seance_id,etudiant_id'})
      if (pe) { toast('Erreur présences : '+pe.message,'err'); return }

      _cache.bust('rh_seances')
      if (profile?.role === 'formateur') {
        toast(`✅ Pointage enregistré — ${nbPres} présent(s). Soumettez maintenant le rapport de séance.`)
        window._openRapportSeance(window._ptgSeanceId)
      } else {
        toast(`✅ Pointage enregistré — ${nbPres} présent(s).`)
        renderPresences()
      }
    }

    // ════════════════════════════════════════════════════════════
    //  RAPPORT DE SÉANCE — Formulaire inline obligatoire (formateur)
    // ════════════════════════════════════════════════════════════
    window._openRapportSeance = async function(seanceId) {
      setContent('<div style="color:#5A7090;text-align:center;padding:40px">⏳ Chargement du rapport…</div>')
      const {data:seance} = await sb.from('seances')
        .select('id,date_seance,heure_debut,sujet,enseignant,classe_id,programme,statut,pointage_fait')
        .eq('id', seanceId).maybeSingle()
      if (!seance) { toast('Séance introuvable','err'); renderSeances(); return }

      // Charger les présences déjà enregistrées
      const {data:pres} = await sb.from('presences')
        .select('id,etudiant_id,present,justifie,motif_absence,etudiants(id,nom,prenom,numero_dossier)')
        .eq('seance_id', seanceId)

      const presRows = (pres||[])
      const presents  = presRows.filter(p=>p.present===1||p.present===true)
      const absents   = presRows.filter(p=>!p.present)

      const presHtml = presents.map(p=>`
        <tr style="border-top:1px solid #1E3050">
          <td style="padding:6px 10px;color:#4AE090">✅</td>
          <td style="padding:6px 10px;font-size:.78rem;color:#C8960C">${p.etudiants?.numero_dossier||'—'}</td>
          <td style="padding:6px 10px;font-size:.82rem;color:#E2D8C0">${p.etudiants?.prenom||''} ${p.etudiants?.nom||''}</td>
          <td style="padding:6px 10px"><span style="font-size:.68rem;color:#4AE090">Présent</span></td>
        </tr>`).join('')

      const absHtml = absents.map(p=>`
        <tr style="border-top:1px solid #1E3050">
          <td style="padding:6px 10px;color:#E04A4A">❌</td>
          <td style="padding:6px 10px;font-size:.78rem;color:#C8960C">${p.etudiants?.numero_dossier||'—'}</td>
          <td style="padding:6px 10px;font-size:.82rem;color:#E2D8C0">${p.etudiants?.prenom||''} ${p.etudiants?.nom||''}</td>
          <td style="padding:6px 10px">
            <select id="justif_${p.etudiant_id}" style="font-size:.68rem;padding:2px 7px;border-radius:5px;background:#0D1B2A;border:1px solid #2A3F58;color:#90A4AE">
              <option value="non_justifie">Non Justifié</option>
              <option value="justifie">Justifié</option>
            </select>
          </td>
        </tr>`).join('')

      const fmtD = d => d ? new Date(d).toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) : '—'

      setContent(`
        <div style="max-width:800px;margin:0 auto">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px">
            <button onclick="renderPresences()" style="padding:6px 14px;border-radius:7px;border:1px solid #2A3F58;background:transparent;color:#8AAAC0;cursor:pointer;font-size:.78rem">← Présences</button>
            <div style="font-size:1.05rem;font-weight:800;color:#E8B84B">📝 Rapport de Séance — Obligatoire</div>
          </div>

          <!-- Info séance -->
          <div style="background:linear-gradient(135deg,#152540,#241C08);border:1px solid rgba(200,150,12,.4);border-radius:12px;padding:14px 18px;margin-bottom:18px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
            <div><div style="font-size:.62rem;text-transform:uppercase;color:#5A7090;margin-bottom:2px">Date</div><div style="font-weight:700;color:#E8B84B">${fmtD(seance.date_seance)}</div></div>
            <div><div style="font-size:.62rem;text-transform:uppercase;color:#5A7090;margin-bottom:2px">Sujet</div><div style="font-weight:700;color:#E2D8C0">${seance.sujet||'—'}</div></div>
            <div><div style="font-size:.62rem;text-transform:uppercase;color:#5A7090;margin-bottom:2px">Classe</div><div style="font-weight:700;color:#C8960C">${seance.programme||'—'}</div></div>
          </div>

          <!-- Présences -->
          ${presRows.length ? `
          <div style="background:#152233;border:1px solid #1E3050;border-radius:12px;overflow:hidden;margin-bottom:18px">
            <div style="padding:10px 18px;background:#0D1B2A;font-size:.82rem;font-weight:700;color:#4AE090">
              👥 Récapitulatif des Présences (${presents.length} présent(s) · ${absents.length} absent(s))
            </div>
            <div style="padding:12px 18px">
              <table style="width:100%;border-collapse:collapse">
                <thead><tr style="background:#0D1B2A"><th style="padding:5px 10px;font-size:.68rem;color:#5A7090;text-align:left"></th><th style="padding:5px 10px;font-size:.68rem;color:#5A7090;text-align:left">Dossier</th><th style="padding:5px 10px;font-size:.68rem;color:#5A7090;text-align:left">Nom</th><th style="padding:5px 10px;font-size:.68rem;color:#5A7090;text-align:left">Statut</th></tr></thead>
                <tbody>${presHtml}${absHtml}</tbody>
              </table>
              ${absents.length ? `<div style="font-size:.72rem;color:#C8960C;margin-top:8px">⚠️ Pour les absents, précisez si l'absence est justifiée (certificat médical, etc.) — impact sur le calcul des honoraires.</div>` : ''}
            </div>
          </div>` : `<div style="padding:12px 18px;background:rgba(200,150,12,0.08);border:1px solid rgba(200,150,12,0.3);border-radius:10px;font-size:.8rem;color:#C8960C;margin-bottom:18px">⚠️ Aucun pointage enregistré. Faites d'abord le pointage depuis la section Présences.</div>`}

          <!-- Formulaire rapport -->
          <div style="background:#152233;border:1px solid rgba(200,150,12,0.3);border-radius:12px;overflow:hidden;margin-bottom:18px">
            <div style="padding:12px 18px;background:#0D1B2A;font-size:.88rem;font-weight:800;color:#C8960C">📋 Contenu Pédagogique</div>
            <div style="padding:18px;display:flex;flex-direction:column;gap:14px">
              <div>
                ${lbl('Thème / Module traité *')}
                ${inp('rsTheme','text','Ex: Present Perfect — Usage, Formation, Exercices…')}
              </div>
              <div>
                ${lbl('Objectifs atteints')}
                <textarea id="rsObj" rows="2" placeholder="Ex: Les apprenants savent conjuguer et employer le Present Perfect en contexte professionnel."
                  style="width:100%;padding:8px 12px;border-radius:8px;font-size:.82rem;outline:none;background:#0D1B2A;border:1px solid #2A3F58;color:#fff;resize:vertical;box-sizing:border-box"></textarea>
              </div>
              <div>
                ${lbl('Exercices réalisés')}
                ${inp('rsEx','text','Ex: 3 exercices écrits, 1 jeu de rôle, correction collective…')}
              </div>
              <div>
                ${lbl('Plan de la prochaine séance')}
                ${inp('rsNext','text','Ex: Passive Voice — Introduction et pratique')}
              </div>
              <div>
                ${lbl('Progression générale')}
                <div style="display:flex;gap:8px;margin-top:6px">
                  ${['Bonne','Moyenne','À améliorer'].map(v=>`<button id="rprog_${v.replace(/ /g,'_')}" onclick="window._rsSetProg('${v}')"
                    style="padding:6px 16px;border-radius:8px;font-size:.78rem;cursor:pointer;font-weight:700;
                    background:${v==='Bonne'?'rgba(74,224,144,0.1)':v==='Moyenne'?'rgba(232,184,75,0.1)':'rgba(224,74,74,0.1)'};
                    border:1px solid ${v==='Bonne'?'rgba(74,224,144,0.4)':v==='Moyenne'?'rgba(232,184,75,0.4)':'rgba(224,74,74,0.4)'};
                    color:${v==='Bonne'?'#4AE090':v==='Moyenne'?'#E8B84B':'#E04A4A'}">${v==='Bonne'?'✅':v==='Moyenne'?'⚠️':'🔴'} ${v}</button>`).join('')}
                </div>
              </div>
              <div>
                ${lbl('Observations complémentaires')}
                <textarea id="rsObs" rows="2" placeholder="Difficultés rencontrées, besoins spécifiques d'un apprenant…"
                  style="width:100%;padding:8px 12px;border-radius:8px;font-size:.82rem;outline:none;background:#0D1B2A;border:1px solid #2A3F58;color:#fff;resize:vertical;box-sizing:border-box"></textarea>
              </div>
            </div>
          </div>

          <div style="background:rgba(200,150,12,0.06);border:1px solid rgba(200,150,12,0.25);border-radius:10px;padding:12px 18px;margin-bottom:18px;font-size:.78rem;color:#C8960C">
            📌 En soumettant ce rapport, la séance sera envoyée à la <strong>Direction Pédagogique</strong> pour validation et calcul des honoraires.
          </div>

          <button onclick="window._submitRapportSeance(${seanceId})"
            style="width:100%;padding:13px;border-radius:10px;background:linear-gradient(135deg,rgba(200,150,12,0.25),rgba(200,150,12,0.1));border:1px solid #C8960C;color:#E8B84B;font-weight:800;font-size:.9rem;cursor:pointer">
            📤 Soumettre le Rapport & Envoyer à la Direction
          </button>
        </div>
      `)
      window._rsSeanceId = seanceId
      window._rsSeance   = seance
      window._rsPresRows = presRows
      window._rsProg     = 'Bonne'
      window._rsSetProg('Bonne')
    }

    window._rsSetProg = function(val) {
      window._rsProg = val
      ;['Bonne','Moyenne','À améliorer'].forEach(v=>{
        const btn = document.getElementById('rprog_'+v.replace(/ /g,'_'))
        if (!btn) return
        const isActive = v === val
        btn.style.fontWeight  = isActive ? '900' : '700'
        btn.style.transform   = isActive ? 'scale(1.06)' : 'scale(1)'
        btn.style.boxShadow   = isActive ? '0 0 10px rgba(200,150,12,0.3)' : 'none'
        btn.style.borderWidth = isActive ? '2px' : '1px'
      })
    }

    window._submitRapportSeance = async function(seanceId) {
      const theme = document.getElementById('rsTheme')?.value.trim()
      if (!theme) { toast('Le thème est obligatoire','err'); return }

      const seance   = window._rsSeance
      const presRows = window._rsPresRows || []

      // Récupérer justifications absents
      const absents = presRows.filter(p=>!p.present)
      const justifUpdates = absents.map(p => {
        const sel = document.getElementById(`justif_${p.etudiant_id}`)
        const isJustifie = sel?.value === 'justifie'
        return sb.from('presences').update({justifie: isJustifie}).eq('id', p.id)
      })
      await Promise.all(justifUpdates)

      // Comptages
      const nbPresents = presRows.filter(p=>p.present===1||p.present===true).length
      const nbAbsNJ    = absents.filter(p => {
        const sel = document.getElementById(`justif_${p.etudiant_id}`)
        return !sel || sel.value !== 'justifie'
      }).length
      const nbAbsJ     = absents.length - nbAbsNJ

      // Insérer le rapport
      const {data:rapport, error:re} = await sb.from('rapports_seances').upsert({
        seance_id:         seanceId,
        formateur_id:      currentUser?.id,
        formateur_nom:     seance?.enseignant || [profile?.prenom, profile?.nom].filter(Boolean).join(' '),
        classe_id:         seance?.classe_id || null,
        classe_nom:        seance?.programme || '',
        date_seance:       seance?.date_seance,
        theme,
        objectifs:         document.getElementById('rsObj')?.value.trim() || null,
        exercices:         document.getElementById('rsEx')?.value.trim() || null,
        progression:       window._rsProg || 'Bonne',
        plan_prochaine:    document.getElementById('rsNext')?.value.trim() || null,
        observations:      document.getElementById('rsObs')?.value.trim() || null,
        nb_presents:             nbPresents,
        nb_absents_non_justifies: nbAbsNJ,
        nb_absents_justifies:     nbAbsJ,
      }, {onConflict:'seance_id'}).select().single()
      if (re) { toast('Erreur rapport : '+re.message,'err'); return }

      // Mettre à jour la séance → a_valider_direction
      const {error:se} = await sb.from('seances').update({
        statut:           'a_valider_direction',
        rapport_soumis:   true,
        rapport_seance_id: rapport?.id || null,
      }).eq('id', seanceId)
      if (se) { toast('Erreur mise à jour séance : '+se.message,'err'); return }

      toast('✅ Rapport soumis — séance envoyée à la Direction pour validation.')
      renderSeances()
    }

