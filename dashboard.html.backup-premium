      {id:'biz_b1_m2',titre:'La Correspondance Professionnelle',niveau:'B1',duree:30,objectifs:["Rédiger des emails professionnels en anglais","Maîtriser les formules d'ouverture et de clôture","Utiliser un registre formel adapté"],contenu:[{type:'intro',texte:"L'email professionnel est l'outil de communication n°1 en entreprise. Un anglais professionnel précis et bien structuré est un atout majeur sur le marché du travail."},{type:'tableau',titre:"Structure d'un Email Professionnel AGTM",headers:["Partie","Contenu","Exemple"],rows:[["Salutation","Dear + titre/nom","Dear Mr. Koné, / Dear Sir/Madam,"],["Paragraphe 1","Objet / raison de l'email","I am writing to inquire about..."],["Corps","Détails, demandes, informations","Please find attached... / I would like to..."],["Avant-dernière ligne","Action attendue / prochaine étape","Please do not hesitate to contact me if..."],["Formule de politesse","Closing formula","Yours sincerely, / Kind regards,"],["Signature","Nom + poste + contact","Issa Bamba | Director | AGTM Academy"]]},{type:'lexique',titre:"Phrases d'ouverture",items:[{en:"I am writing to inquire about...",fr:"Je vous écris pour me renseigner sur..."},{en:"I am writing with reference to your email of...",fr:"Je vous écris en référence à votre email du..."},{en:"Further to our meeting/conversation...",fr:"Suite à notre réunion/conversation..."},{en:"I am pleased to inform you that...",fr:"J'ai le plaisir de vous informer que..."}]},{type:'lexique',titre:'Phrases de clôture',items:[{en:"Please do not hesitate to contact me if you have any questions.",fr:"N'hésitez pas à me contacter pour toute question."},{en:"I look forward to hearing from you.",fr:"Dans l'attente de votre réponse."},{en:"Thank you for your prompt attention to this matter.",fr:"Merci de l'attention portée à ce sujet."}]},{type:'tableau',titre:'Formules de politesse finales',headers:["Situation","Formule"],rows:[["Destinataire connu (nom)","Yours sincerely,"],["Destinataire inconnu (Sir/Madam)","Yours faithfully,"],["Semi-formel (collègue)","Kind regards, / Best regards,"],["Informel (familier)","Best wishes, / Regards,"]]}],quiz:[{q:"When you know the recipient's name, the correct closing is:",opts:["A) Yours faithfully","B) Yours sincerely","C) Kind regards","D) Best wishes"],rep:'B',expl:"Si vous connaissez le nom → Yours sincerely. Si non → Yours faithfully."},{q:"The correct opening for an unknown recipient:",opts:["A) Dear Friend,","B) Hello,","C) Dear Sir/Madam,","D) To Whom,"],rep:'C',expl:"Destinataire inconnu → Dear Sir/Madam, (formel)."},{q:"'I am writing to inquire about...' means:",opts:["A) I want to complain about","B) I want to get information about","C) I am confirming","D) I am applying for"],rep:'B',expl:"'Inquire' = se renseigner, demander des informations."},{q:"'I look forward to hearing from you' is used:",opts:["A) At the beginning of the email","B) In the subject line","C) Near the end, before the closing","D) In the signature"],rep:'C',expl:"Cette formule se place en avant-dernière ligne."},{q:"Which is the most formal register for a business email?",opts:["A) Hi John, / Cheers","B) Hello, / Best","C) Dear Mr. Smith, / Yours sincerely","D) Hey, / Take care"],rep:'C',expl:"Registre le plus formel : Dear + nom de famille / Yours sincerely."},{q:"'Please find attached' means:",opts:["A) I need the attachment","B) A document is enclosed with this email","C) Please look for the file","D) The attachment is missing"],rep:'B',expl:"'Please find attached' = vous joignez un document à l'email."}]},
