    window.createPlan = async function() {
      const selEl=document.getElementById('plnE')
      const etudiant_id=Number(selEl.value)
      const etudiant_nom=selEl.selectedOptions[0]?.dataset.nom||''
      const montant_total=Number(document.getElementById('plnM').value)
      const nb=parseInt(document.getElementById('plnN').value)||1
      const dateDebut=document.getElementById('plnD').value
      const type_formation=document.getElementById('plnT').value.trim()
      const notes=document.getElementById('plnNt').value.trim()
      if(!etudiant_id||!montant_total||!dateDebut){toast('Étudiant, montant et date requis','err');return}
      const montant_echeance=Math.round(montant_total/nb*100)/100
      const {data:plan,error:pe}=await sb.from('plans_paiement').insert({
        etudiant_id,etudiant_nom,montant_total,nb_echeances:nb,montant_echeance,
        type_formation:type_formation||null,date_debut:dateDebut,notes:notes||null,
      }).select().single()
      if(pe){toast('Erreur : '+pe.message,'err');return}
      // Créer les lignes d'échéances
      const lignes=[]
      for(let i=0;i<nb;i++){
        const d=new Date(dateDebut)
        d.setMonth(d.getMonth()+i)
        lignes.push({plan_id:plan.id,etudiant_id,num_echeance:i+1,date_echeance:d.toISOString().substring(0,10),montant:montant_echeance})
      }
      const {error:le}=await sb.from('echeances').insert(lignes)
      if(le){toast('Plan créé mais erreur échéances : '+le.message,'err');return}
      toast(`✅ Plan créé — ${nb} échéance(s) de ${fmtMoney(montant_echeance)}`)
      renderFinance()
    }

