    window._submitCandidatureDash = async function() {
      const nom    = document.getElementById('cNom').value.trim().toUpperCase()
      const prenom = document.getElementById('cPren').value.trim()
      const email  = document.getElementById('cEmail').value.trim()
      const tel    = document.getElementById('cTel').value.trim()
      const err    = document.getElementById('cErr')
      const st     = document.getElementById('cUploadStatus')
      err.textContent = ''
      if (!nom||!prenom||!email||!tel) { err.textContent = 'Veuillez remplir les champs obligatoires.'; return }
      const file = document.getElementById('cFichierCV')?.files?.[0] || null
      let cvUrl = null, cvNom = null
      try {
        const up = await _uploadFichier(file, 'candidatures', st)
        cvUrl = up.url; cvNom = up.nom
      } catch(e) { err.textContent = e.message; return }
      const questions = ['Approche A1','Adaptation niveaux','Séance B1','Étudiant en difficulté','Outils numériques','Évaluation progression','Certifications','Motivation AGTM']
      const reponses = {}
      for (let i=1;i<=8;i++) { const v=document.getElementById('cq'+i)?.value.trim(); if(v) reponses[questions[i-1]]=v }
      const {error} = await sb.from('candidatures').insert({
        nom, prenom, email, telephone: tel,
        poste: document.getElementById('cPoste').value,
        niveau_etudes: document.getElementById('cEtudes').value,
        experience_annees: Number(document.getElementById('cExp').value)||0,
        matieres: document.getElementById('cMat').value.trim()||null,
        disponibilites: document.getElementById('cDispo').value.trim()||null,
        motivations: document.getElementById('cMotiv').value.trim()||null,
        reponses, statut: 'Nouveau',
        cv_url: cvUrl, cv_nom: cvNom,
      })
      if (error) { err.textContent = 'Erreur : ' + error.message; return }
      toast('✅ Candidature envoyée !')
      setContent(`<div style="text-align:center;padding:48px 24px;max-width:540px;margin:0 auto">
