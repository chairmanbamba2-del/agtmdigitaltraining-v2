    async function _getEtudProfil(fields) {
      const cols = fields || '*'
      const email = (currentUser?.email || '').trim().toLowerCase()

      // 1. Email exact (insensible à la casse)
      if (email) {
        const {data:e1} = await sb.from('etudiants').select(cols).ilike('email', email).maybeSingle()
        if (e1) return e1
      }
      // 2. Nom + prénom du profil utilisateur
