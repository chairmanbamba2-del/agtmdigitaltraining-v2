      if (!seance) { toast('Séance introuvable','err'); renderPresences(); return }

      // Charger les étudiants inscrits à la classe
      if (seance.classe_id) {
        const {data:inscriptions} = await sb.from('inscriptions_classes')
          .select('etudiant_id, etudiants(id,nom,prenom,niveau,numero_dossier,statut)')
          .eq('classe_id', seance.classe_id)
        window._ptgClasseEtuds = (inscriptions||[])
