    window._apPlacementPick = function(i) {
      const ps=window._apPS; if(!ps||ps.answered) return
      ps.answered=true
      const q=ps.questions[ps.current]
      const chosen=(q.opts||[])[i]
      const correct=(q.opts||[]).find(o=>o.startsWith(q.rep+')'))
      const ok=chosen===correct
      if(ok) ps.score++
      else ps.errors.push({q:q.q,niv:q.niv,chosen,correct})
      ;(q.opts||[]).forEach((o,j)=>{
        const b=document.getElementById('_pto_'+j);if(!b)return
        b.disabled=true
        if(o===correct){b.style.borderColor='#4AE090';b.style.background='#1A3A1A';b.style.color='#4AE090'}
        else if(j===i&&!ok){b.style.borderColor='#E04A4A';b.style.background='#2A1A1A';b.style.color='#E04A4A'}
      })
      const wrap=document.getElementById('_ptOpts')
      if(wrap) wrap.insertAdjacentHTML('afterend',`
        <div style="margin-top:10px;padding:10px 14px;border-radius:8px;background:${ok?'#1A3A1A':'#2A1A1A'};border:1px solid ${ok?'#4AE090':'#E04A4A'}">
