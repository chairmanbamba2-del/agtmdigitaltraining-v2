            cursor:pointer;background:#0D1B2A;border:1.5px solid #1E3050;color:#e0e0e0;transition:all .15s;
            display:flex;align-items:center;gap:11px">
            <span style="width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;background:#1E3050;color:#90A4AE;flex-shrink:0">${String.fromCharCode(65+i)}</span>
            ${o}</button>`).join('')}
        </div>
      </div>`)
    }

    window._apTQPick = function(i) {
      const ts = window._apTS
      if(ts.answered) return
      ts.answered = true
      const q = ts.questions[ts.current]
      const chosen = (q.opts||[])[i]
      const repLetter = (q.rep||'').trim()
      const correct = (q.opts||[]).find(o=>o.startsWith(repLetter+')'))
      const ok = chosen === correct
      if(ok) ts.score++;(q.opts||[]).forEach((o,j)=>{
        const b=document.getElementById('apto_'+j);if(!b)return
        b.disabled=true
        if(o===correct){b.style.borderColor='#4AE090';b.style.background='#1A3A1A';b.style.color='#4AE090'}
        else if(j===i&&!ok){b.style.borderColor='#E04A4A';b.style.background='#2A1A1A';b.style.color='#E04A4A'}
      })
      const wrap=document.getElementById('apTOpts')
      if(wrap) wrap.insertAdjacentHTML('afterend',`
        <div style="margin-top:12px;padding:11px 15px;border-radius:9px;background:${ok?'#1A3A1A':'#2A1A1A'};border:1px solid ${ok?'#4AE090':'#E04A4A'}">
          <div style="font-weight:700;color:${ok?'#4AE090':'#E04A4A'}">${ok?'✅ Correct !':'❌ Incorrect'}</div>
        </div>
        <div style="margin-top:12px;text-align:right">
          <button onclick="window._apTQNext()" style="padding:9px 22px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A">
            ${ts.current+1<ts.questions.length?'Question suivante →':'📊 Voir mes résultats'}
          </button>
        </div>`)
    }

    window._apTQNext = function() {
      window._apTS.current++
      window._apTS.answered = false
      _apTestRunner()
    }

    function _apTestResults() {
      const ts = window._apTS, t = window._apCurTest
      const total = ts.questions.length
      const pct = Math.round(ts.score/total*100)
      const validated = ts.score >= t.seuil_validation
      const col = _NBL[t.niveau_cible]||'#4A90D9'
      const nextLvl = {A1:'A2',A2:'B1',B1:'B2',B2:'C1',C1:'C2'}[t.niveau_cible]
      const isAnon = profile?.role === 'anon'
      const retourRes = isAnon
        ? `<button onclick="location.href='https://africaglobaltraining.com'" style="padding:10px 20px;border:none;cursor:pointer;border-radius:8px 8px 0 0;font-size:.84rem;font-weight:700;background:transparent;color:#90A4AE">← Accueil AGTM</button>`
        : `<button onclick="window._apSetTab('tests')" style="padding:10px 20px;border:none;cursor:pointer;border-radius:8px 8px 0 0;font-size:.84rem;font-weight:700;background:transparent;color:#90A4AE">← Tests de Niveau</button>`
      const tabBar = `<div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid rgba(200,150,12,0.2);padding-bottom:0">
        ${retourRes}
      </div>`
      setContent(tabBar + `<div style="max-width:520px;margin:0 auto;text-align:center">
        <div style="font-size:3.5rem;margin-bottom:14px">${validated?'🏆':'📚'}</div>
        <div style="font-size:2rem;font-weight:900;color:${col};margin-bottom:6px">${ts.score} / ${total}</div>
        <div style="font-size:1rem;font-weight:700;color:#fff;margin-bottom:4px">${pct}% de bonnes réponses</div>
        <div style="margin:14px 0;padding:14px 20px;border-radius:11px;background:${validated?'rgba(74,224,144,0.1)':'rgba(224,74,74,0.1)'};border:1px solid ${validated?'rgba(74,224,144,0.4)':'rgba(224,74,74,0.4)'}">
          <div style="font-size:.95rem;font-weight:700;color:${validated?'#4AE090':'#E04A4A'};margin-bottom:6px">
            ${validated?`✅ Niveau ${t.niveau_cible} validé !`:`❌ Niveau ${t.niveau_cible} non atteint`}
          </div>
          <div style="font-size:.82rem;color:#90A4AE;line-height:1.5">
            ${validated
              ?`Félicitations ! Vous maîtrisez le niveau ${t.niveau_cible}. ${nextLvl?'Nous vous recommandons de passer au niveau '+nextLvl+'.':''}`
              :`Score requis : ${t.seuil_validation}/${total}. Révisez les modules ${t.niveau_cible} avant de retenter le test.`}
