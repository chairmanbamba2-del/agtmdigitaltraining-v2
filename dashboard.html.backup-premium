    window._toggleNotifPanel = function() {
      const panel = document.getElementById('notifPanel')
      if (!panel) return
      window._notifOpen = !window._notifOpen
      panel.style.display = window._notifOpen ? 'block' : 'none'
      if (window._notifOpen) window._loadNotifications()
    }

    window._closeNotifPanel = function() {
      const panel = document.getElementById('notifPanel')
      if (panel) panel.style.display = 'none'
      window._notifOpen = false
    }

