        sb.from('seances').select('*').in('classe_id', classIds).order('date_seance',{ascending:false}).limit(50),
      ])

      setContent(`
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px">
          ${kpi('👥','Mes Classes',(classes||[]).length,'#C8960C')}
          ${kpi('👨‍🎓','Étudiants totaux',(inscs||[]).length,'#4A90D9')}
          ${kpi('📅','Séances totales',(seances||[]).length,'#4AE090')}
        </div>

        ${(classes||[]).map(cl => {
