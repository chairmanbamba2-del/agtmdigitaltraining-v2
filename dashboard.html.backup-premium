          ${!isAnon?`<button onclick="window._apSetTab('catalogue');window._actCat='all';window._actNiv='${t.niveau_cible}'" style="padding:10px 24px;border-radius:9px;font-weight:700;font-size:.85rem;cursor:pointer;background:transparent;border:1px solid ${col};color:${col}">📚 Modules ${t.niveau_cible}</button>`:''}
