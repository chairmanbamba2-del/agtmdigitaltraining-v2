                ${inp('crUrl','url','https://drive.google.com/…')}
                <div style="font-size:.72rem;color:#5A7090;margin-top:4px">Uploadez le fichier sur Google Drive / OneDrive (partage "Tout le monde avec le lien") puis collez le lien ici.</div>
              </div>
              <div>${lbl('Description')}${inp('crDesc','text','Optionnel — résumé du contenu')}</div>
            </div>
            <div style="padding:0 18px 18px">${btn('💾 Enregistrer la ressource','_saveCours()')}</div>
          </div>

          <!-- Affichage par type -->
          ${types.map(type=>{
            const resType=(ressources||[]).filter(r=>r.type===type)
            if(!resType.length && type!=='cours') return ''
            const byNiv={}
            resType.forEach(r=>{ if(!byNiv[r.niveau]) byNiv[r.niveau]=[]; byNiv[r.niveau].push(r) })
            return `
            <div style="background:#152233;border:1px solid #1E3050;border-radius:14px;overflow:hidden;margin-bottom:18px">
              <div style="padding:12px 18px;background:#0D1B2A;display:flex;align-items:center;justify-content:space-between">
                <span style="font-size:.88rem;font-weight:800;color:${typeColors[type]}">${typeLabels[type]}</span>
                <span style="font-size:.72rem;color:#5A7090">${resType.length} ressource(s)</span>
              </div>
              ${resType.length===0?`<div style="padding:18px;font-size:.82rem;color:#5A7090;font-style:italic">Aucune ressource. Ajoutez-en une via le formulaire ci-dessus.</div>`:`
              <div style="padding:16px 18px;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
                ${resType.map(r=>`
                  <div style="background:#0D1B2A;border:1px solid #1E3050;border-radius:10px;padding:14px;position:relative">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px">
                      <span style="padding:2px 9px;border-radius:10px;font-size:.68rem;font-weight:700;background:#1A2D42;color:${typeColors[type]}">${r.niveau||'?'} ${r.ordre?'· N°'+r.ordre:''}</span>
                      <button onclick="_delCours(${r.id})" style="padding:1px 6px;border-radius:4px;font-size:.65rem;cursor:pointer;background:#2A1A1A;border:1px solid #E04A4A;color:#E04A4A">🗑️</button>
                    </div>
                    <div style="font-size:.85rem;font-weight:700;color:#fff;margin-bottom:4px;line-height:1.3">${r.titre||'—'}</div>
                    ${r.description?`<div style="font-size:.75rem;color:#5A7090;margin-bottom:8px">${r.description}</div>`:''}
                    <a href="${r.url}" target="_blank" style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:7px;background:#1A2D42;border:1px solid ${typeColors[type]};color:${typeColors[type]};font-size:.75rem;font-weight:700;text-decoration:none">
                      🔗 Ouvrir le lien
                    </a>
                  </div>`).join('')}
              </div>`}
            </div>`
          }).join('')}
        </div>
      `)
    }
    window._saveCours = async function() {
      const titre=document.getElementById('crTitre').value.trim()
      const url=document.getElementById('crUrl').value.trim()
      const type=document.getElementById('crType').value
      const niveau=document.getElementById('crNiv').value
      const ordre=Number(document.getElementById('crOrdre').value)||null
      const description=document.getElementById('crDesc').value.trim()||null
      if(!titre||!url){toast('Titre et URL sont obligatoires','err');return}
      const {error}=await sb.from('cours_ressources').insert({titre,url,type,niveau,ordre,description})
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('✅ Ressource ajoutée')
      pedaSwitch('cours')
    }
    window._delCours = async function(id) {
      if(!confirm('Supprimer cette ressource ?')) return
      await sb.from('cours_ressources').delete().eq('id',id)
      toast('Ressource supprimée')
      pedaSwitch('cours')
    }

    // ════════════════════════════════════════════════════════════
    //  GESTION DES ACCÈS UTILISATEURS
    // ════════════════════════════════════════════════════════════
    window._usrTab = 'users'
    window._usrFilter = { role: '', actif: '' }

    async function renderUtilisateurs() {
      if (profile?.role !== 'admin') {
        setContent(`<div style="text-align:center;padding:60px;color:#E04A4A;font-weight:700">⛔ Accès réservé à l'administrateur.</div>`)
        return
      }
      setContent(skeletonTable(6,4))
      const {data:users} = await sb.from('utilisateurs').select('id,email,role,nom,prenom,actif,ai_tier,created_at').order('created_at',{ascending:false})
      const all = users || []

      // Rôles disponibles (standard + custom)
      const customRoles = JSON.parse(localStorage.getItem('agtm_custom_roles')||'[]')
