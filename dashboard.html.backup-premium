    // ── SATISFACTIONS APPRENANTS ─────────────────────────────────
    async function _pedaSatisfactions() {
      const [{data:seances},{data:sats},{data:etuds}]=await Promise.all([
        sb.from('seances').select('id,sujet,date_seance,heure_debut').order('date_seance',{ascending:false}).limit(100),
        sb.from('satisfactions').select('*').order('created_at',{ascending:false}).limit(500),
        sb.from('etudiants').select('id,nom,prenom').order('id').order('nom'),
      ])
      const moyenneNote=sats&&sats.length?Math.round((sats||[]).reduce((s,r)=>s+(Number(r.note)||0),0)/sats.length*10)/10:0
      const nbSat5=(sats||[]).filter(r=>Number(r.note)===5).length
      const seanceOpts=(seances||[]).map(s=>`<option value="${s.id}">${fmtDate(s.date_seance)} — ${s.sujet||'Séance'}</option>`).join('')
      const etudOpts=(etuds||[]).map(e=>`<option value="${e.id}">${e.prenom} ${e.nom}</option>`).join('')
      const stars=n=>'⭐'.repeat(n)+'☆'.repeat(5-n)

      setContent(`
        ${pedaTabBar('satisfactions')}
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px">
          ${kpi('⭐','Évaluations reçues',(sats||[]).length,'#C8960C')}
          ${kpi('📊','Note moyenne',moyenneNote+'/5','#4A90D9')}
          ${kpi('🌟','Notes parfaites (5/5)',nbSat5,'#4AE090')}
          ${kpi('📅','Séances évaluées',new Set((sats||[]).map(s=>s.seance_id)).size,'#E8B84B')}
        </div>

        <div style="background:#0D2A1A;border:1px solid #4AE090;border-radius:12px;padding:14px 18px;margin-bottom:16px">
          <div style="font-size:.78rem;font-weight:800;color:#4AE090;margin-bottom:10px">🔗 Liens de satisfaction — à partager avec les apprenants</div>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            ${(seances||[]).slice(0,12).map(s=>{
              const base = window.location.origin + window.location.pathname
              const lien = base + '?satisfaction=' + s.id
              return `<button onclick="window._copyLink('${lien}','✅ Lien satisfaction copié — ${(s.sujet||'Séance').replace(/'/g,"\\'")} !')"
                style="padding:6px 12px;border-radius:7px;font-size:.7rem;font-weight:700;cursor:pointer;background:#1A3A2A;border:1px solid #4AE090;color:#4AE090;white-space:nowrap">
                🔗 ${fmtDate(s.date_seance)} — ${(s.sujet||'Séance').substring(0,20)}</button>`
            }).join('')}
          </div>
        </div>

        <div style="background:#152233;border:1px solid #1E3050;border-radius:12px;overflow:hidden;margin-bottom:22px">
          ${card('➕ Soumettre une évaluation de séance')}
          <div style="padding:18px;display:grid;grid-template-columns:2fr 1fr 2fr;gap:14px">
            <div>${lbl('Séance *')}<select id="satSeance" style="width:100%;padding:8px 12px;border-radius:8px;background:#0D1B2A;border:1px solid #2A3F58;color:#fff;font-size:.82rem;outline:none"><option value="">Choisir une séance…</option>${seanceOpts}</select></div>
            <div>${lbl('Apprenant *')}<select id="satEtud" style="width:100%;padding:8px 12px;border-radius:8px;background:#0D1B2A;border:1px solid #2A3F58;color:#fff;font-size:.82rem;outline:none"><option value="">Choisir…</option>${etudOpts}</select></div>
            <div>${lbl('Note (1 = Insuffisant · 5 = Excellent) *')}<select id="satNote" style="width:100%;padding:8px 12px;border-radius:8px;background:#0D1B2A;border:1px solid #2A3F58;color:#fff;font-size:.82rem;outline:none">
              <option value="">Choisir une note…</option>
              <option value="5">⭐⭐⭐⭐⭐ — Excellent</option>
              <option value="4">⭐⭐⭐⭐☆ — Très bien</option>
              <option value="3">⭐⭐⭐☆☆ — Bien</option>
              <option value="2">⭐⭐☆☆☆ — Passable</option>
              <option value="1">⭐☆☆☆☆ — Insuffisant</option>
            </select></div>
          </div>
          <div style="padding:0 18px 18px;display:grid;grid-template-columns:3fr 1fr;gap:14px">
            <div>${lbl('Commentaire (facultatif)')}${inp('satComment','text','Qu\'avez-vous aimé ? Qu\'est-ce qui peut être amélioré ?')}</div>
