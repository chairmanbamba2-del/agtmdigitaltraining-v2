    async function buildChart(canvasId, months) {
      const since = new Date()
      since.setMonth(since.getMonth() - months + 1)
      since.setDate(1)
      const sinceStr = since.toISOString().substring(0,10)

      const [{ data:paiData },{ data:depData }] = await Promise.all([
        sb.from('paiements').select('montant,date_paiement').gte('date_paiement', sinceStr),
        sb.from('depenses').select('montant,date_depense').gte('date_depense', sinceStr),
      ])

      const labels=[], entrees=[], sorties=[]
      for (let i = months-1; i >= 0; i--) {
        const d = new Date()
        d.setMonth(d.getMonth() - i)
        const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`
        labels.push(d.toLocaleDateString('fr-FR',{month:'short',year:'2-digit'}))
        entrees.push((paiData||[]).filter(p=>String(p.date_paiement||'').substring(0,7)===key)
          .reduce((s,p)=>s+(Number(p.montant)||0),0))
        sorties.push((depData||[]).filter(d=>String(d.date_depense||'').substring(0,7)===key)
          .reduce((s,d)=>s+(Number(d.montant)||0),0))
      }

      const cv = document.getElementById(canvasId)
      if (!cv) return
      if (revenueChart) revenueChart.destroy()
      revenueChart = new Chart(cv, {
        type:'bar',
        data: { labels, datasets:[
          { label:'Encaissements', data:entrees, backgroundColor:'rgba(74,224,144,0.55)', borderColor:'#4AE090', borderWidth:1, borderRadius:4 },
          { label:'Dépenses',      data:sorties, backgroundColor:'rgba(224,74,74,0.55)',  borderColor:'#E04A4A', borderWidth:1, borderRadius:4 },
        ]},
        options: { responsive:true,
          plugins:{ legend:{ labels:{ color:'#90A4AE', font:{size:10} } } },
          scales:{ x:{ticks:{color:'#90A4AE'},grid:{color:'#1E3050'}},
                   y:{ticks:{color:'#90A4AE'},grid:{color:'#1E3050'}} } }
      })
    }

