      const hdr = _apModEvalHeader(window._apCurMod||{niveau:'B1',titre:es.modTitre})
      const tabBar = `<div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:1px solid rgba(200,150,12,0.15)">
