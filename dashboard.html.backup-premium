            <div style="padding:18px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:14px">
              <div>${lbl('Titre de la leçon / ressource *')}${inp('crTitre','text','Ex: Unit 3 — Present Perfect, Business Email Writing…')}</div>
              <div>${lbl('Type *')}${sel('crType',types.map(t=>`<option value="${t}">${typeLabels[t]}</option>`).join(''))}</div>
              <div>${lbl('Niveau *')}${sel('crNiv',niveaux.map(n=>`<option>${n}</option>`).join(''))}</div>
              <div>${lbl('Ordre / N° leçon')}${inp('crOrdre','number','Ex: 1, 2, 3…')}</div>
