      const nom    = (profile?.nom    || '').trim()
      if (prenom && nom) {
        const {data:e3} = await sb.from('etudiants').select(cols)
          .ilike('prenom', prenom).ilike('nom', nom).maybeSingle()
        if (e3) return e3
        // 3. Chercher par nom seul si prénom composé
        const {data:e4} = await sb.from('etudiants').select(cols).ilike('nom', nom).maybeSingle()
        if (e4) return e4
      }
      // 4. Fallback : nom complet dans un seul champ
      const fullSearch = [prenom, nom].filter(Boolean).join(' ')
      if (fullSearch) {
        const {data:all} = await sb.from('etudiants').select(cols)
        const match = (all||[]).find(e => {
          const full = [e.prenom, e.nom].filter(Boolean).join(' ').toLowerCase()
          return full === fullSearch.toLowerCase() || (e.email||'').toLowerCase() === email
        })
        if (match) return match
      }
      return null
    }

