    // ── Badges non-lu messagerie ──────────────────────────────────
    async function _refreshMsgBadges() {
      try {
        const uid = currentUser?.id
        if (!uid) return
        const role = profile?.role
        let count = 0

        if (role === 'admin' || role === 'formateur') {
          // Nouveaux messages dans `messages` (nouvelle table)
          const { count: c1 } = await sb.from('messages')
            .select('id', {count:'exact', head:true})
            .eq('destinataire_user_id', uid).eq('lu', false)
          // Anciens messages (messages_envois_etudiant) non lus
          const destTag = role === 'formateur' ? 'formateur' : 'administration'
          const { count: c2 } = await sb.from('messages_envois_etudiant')
            .select('id', {count:'exact', head:true})
            .eq('destinataire', destTag).eq('lu', false)
          count = (c1||0) + (c2||0)
          _setBadge('badge_messagerie', count)
        } else if (role === 'etudiant') {
          // Étudiant : messages reçus non lus (ancienne + nouvelle table)
          const etud = await _getEtudProfil('id')
          if (etud) {
            const [qOld, qNew] = await Promise.all([
              sb.from('messages_etudiants')
                .select('id', {count:'exact', head:true})
                .eq('etudiant_id', etud.id).eq('lu', false),
              uid ? sb.from('messages')
                .select('id', {count:'exact', head:true})
                .eq('destinataire_user_id', uid).eq('lu', false)
                : Promise.resolve({ count: 0 })
            ])
            count = (qOld.count || 0) + (qNew.count || 0)
          }
          _setBadge('badge_mes_messages', count)
        }
      } catch(_) {}
    }

    function _setBadge(id, count) {
      const el = document.getElementById(id)
      if (!el) return
      if (count > 0) {
        el.textContent = count > 99 ? '99+' : count
        el.style.display = 'inline-block'
      } else {
        el.style.display = 'none'
      }
    }

    // ── NAVIGATE ──────────────────────────────────────────────────
    // ── NAVIGATION HISTORY ──────────────────────────────────────────
    window._navHistory = []
    window._navCurrentSectionId = null

    function _navUpdateBackBtn() {
      const btn = document.getElementById('navBackBtn')
      if (!btn) return
      const h = window._navHistory
      if (h.length > 0) {
        const prev = h[h.length - 1]
        btn.textContent = '← ' + prev.label
        btn.style.display = 'inline-flex'
      } else {
        btn.style.display = 'none'
      }
    }

    // ── Toggle groupe sidebar ──────────────────────────────────────
    window._toggleNavGroup = function(role, gi) {
      const grpEl   = document.getElementById('nav_grp_'+role+'_'+gi)
      const arrowEl = document.getElementById('nav_grp_arrow_'+role+'_'+gi)
      if (!grpEl) return
      // Lire l'état depuis la mémoire de session (pas localStorage)
      if (!window._navGrpState) window._navGrpState = {}
      const stateKey = role+'_'+gi
      const isCurrentlyOpen = window._navGrpState[stateKey] !== false
      // Basculer
      const newOpen = !isCurrentlyOpen
      window._navGrpState[stateKey] = newOpen
      grpEl.style.display = newOpen ? 'block' : 'none'
      if (arrowEl) arrowEl.style.transform = newOpen ? 'rotate(90deg)' : 'rotate(0deg)'
    }

    window._navBack = function() {
      if (!window._navHistory.length) return
      const prev = window._navHistory.pop()
      // Restaurer l'état des onglets de la section précédente
      const t = prev.tabs || {}
      if (t.finance    !== undefined) window._finTab    = t.finance
      if (t.pedagogie  !== undefined) window._pedaTab   = t.pedagogie
      if (t.rh         !== undefined) window._rhTab     = t.rh
      if (t.marketing  !== undefined) window._mktTab    = t.marketing
      if (t.parametres !== undefined) window._prmTab    = t.parametres
      window.navigateTo(prev.section, true) // true = depuis historique
    }

    // Pousse un sous-vue dans l'historique (pour les vues de détail intra-section)
    window._navPushSubView = function(backFn, backLabel) {
      const cur = window._navCurrentSectionId || 'overview'
      window._navHistory.push({
        section: cur,
        label: document.getElementById('pageTitle')?.textContent || cur,
        tabs: {
          finance: window._finTab, pedagogie: window._pedaTab,
          rh: window._rhTab, marketing: window._mktTab, parametres: window._prmTab,
        },
        subViewFn: backFn,
        subLabel: backLabel,
      })
      _navUpdateBackBtn()
    }

    window.navigateTo = function(id, _fromHistory) {
      // ── Empiler l'état courant dans l'historique ────────────────
      if (!_fromHistory) {
        const cur = window._navCurrentSectionId
        if (cur && cur !== id) {
          window._navHistory.push({
            section: cur,
            label: document.getElementById('pageTitle')?.textContent || cur,
            tabs: {
              finance:    window._finTab,
              pedagogie:  window._pedaTab,
              rh:         window._rhTab,
              marketing:  window._mktTab,
              parametres: window._prmTab,
            }
          })
        }
      }
      window._navCurrentSectionId = id

      // Nettoyer les timers actifs au changement de section
      if (window._apEvalTimer)    { clearInterval(window._apEvalTimer);    window._apEvalTimer    = null }
      if (window._apPTimer)       { clearInterval(window._apPTimer);       window._apPTimer       = null }
      if (window._aiDotsInterval) { clearInterval(window._aiDotsInterval); window._aiDotsInterval = null }
      if (window._fcInitTimer)    { clearTimeout(window._fcInitTimer);     window._fcInitTimer    = null }

      // Reset tous les boutons nav (grouped + flat)
      document.querySelectorAll('.nav-btn').forEach(b => {
        b.style.background='transparent'
        b.style.color='#C8D8E8'
        b.style.borderLeftColor='transparent'
        b.style.fontWeight='500'
      })
      // Activer le bouton courant
      const ab = document.getElementById('nav_' + id)
      if (ab) {
        ab.style.background='linear-gradient(90deg,rgba(200,150,12,0.18),rgba(200,150,12,0.06))'
        ab.style.color='#E8B84B'
        ab.style.borderLeftColor='#C8960C'
        ab.style.fontWeight='700'
        // Auto-ouvrir le groupe parent si fermé
        const grp = ab.closest('[id^="nav_grp_"]')
        if (grp && grp.style.display === 'none') {
          const parts = grp.id.replace('nav_grp_','').split('_')
          const gi = parseInt(parts[parts.length-1])
          const roleKey = parts.slice(0,parts.length-1).join('_')
          window._toggleNavGroup(roleKey, gi)
        }
      }

      if (revenueChart) { revenueChart.destroy(); revenueChart = null }

      const allNavItems = Object.values(NAV).flat().filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i)
      let _sp = {}; try { _sp = JSON.parse(localStorage.getItem('agtm_permissions')||'{}') } catch(_) {}
      const _role = profile?.role
      let items
      if (_sp[_role] && _role !== 'admin') {
        items = _sp[_role].map(m=>allNavItems.find(x=>x.id===m)).filter(Boolean)
      } else {
        items = NAV[_role] || []
      }
      const item = items.find(n => n.id === id) ||
                   (_role === 'admin' ? allNavItems.find(n => n.id === id) : null)
      // Titre : respecter la langue active
      const _curLang = localStorage.getItem('agtm_lang') || 'fr'
      const _titleLabel = (_curLang !== 'fr' && item && _LANG[_curLang]?.[item.id])
        ? _LANG[_curLang][item.id]
