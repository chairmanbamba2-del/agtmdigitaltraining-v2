    window.importerInscription = async function(id) {
      const {data:r}=await sb.from('inscriptions_web').select('*').eq('id',id).single()
      if(!r) return
      const num='EIP-'+new Date().getFullYear()+'-'+String(id).padStart(4,'0')
      const {error}=await sb.from('etudiants').insert({
        numero_dossier:num,
        nom:(r.nom||'').toUpperCase(), prenom:r.prenom||'',
        email:r.email||null, telephone:r.telephone||null, whatsapp:r.whatsapp||null,
        adresse:r.adresse||null, niveau:r.niveau||'A1',
        formations:r.formations||null, duree_formation:r.duree||null,
        mode_cours:r.mode_cours||null, disponibilites:r.disponibilites||null,
        mode_paiement:r.mode_paiement||null, source:'Portail web EIP', statut:'Actif',
        notes:`Inscription web EIP — importé le ${new Date().toLocaleDateString('fr-FR')}`,
      })
      if(error){toast('Erreur : '+error.message,'err');return}
      await sb.from('inscriptions_web').update({statut:'importé',imported_at:new Date().toISOString()}).eq('id',id)
      toast(`✅ ${r.prenom} ${r.nom} importé (${num})`)
      renderInscriptionsWeb()
    }

