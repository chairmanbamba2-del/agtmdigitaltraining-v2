    async function _pedaFormateurs() {
      const [{data:formateurs},{data:rapports},{data:classes},{data:personnelActifs}]=await Promise.all([
        sb.from('utilisateurs').select('id,nom,prenom,email,created_at').eq('role','formateur').order('nom'),
        sb.from('rapports_coaching').select('formateur_id,formateur_nom,date_seance').order('date_seance',{ascending:false}).limit(300),
        sb.from('classes').select('*').order('nom'),
        sb.from('personnel').select('id,nom,prenom,email,poste,telephone,taux_seance').or('poste.eq.Formateur,poste.eq.Enseignant').order('id').order('nom'),
      ])
      const allClasses=(classes||[])
      const classesLibres=allClasses.filter(c=>!c.formateur_id)

      // Emails des formateurs actifs dans le personnel RH
      const emailsActifs = new Set((personnelActifs||[]).map(p=>(p.email||'').toLowerCase()).filter(Boolean))

      // Filtrer : garder seulement les formateurs dont l'email est dans le personnel actif
      // (ou ceux sans email dans personnel → comptes legacy conservés)
      const formateursActifs = (formateurs||[]).filter(f => {
        const fe = (f.email||'').toLowerCase()
        if (!fe) return true // pas d'email → garder
        return emailsActifs.has(fe) // garder seulement si email dans personnel actif
