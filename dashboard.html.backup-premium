    window._saveMktContenu = async function() {
      // Collecte tous les champs mktf_*
      const inputs = document.querySelectorAll('[id^="mktf_"]')
      if (!inputs.length) { toast('⚠️ Aucun champ à enregistrer.','err'); return }
      const now = new Date().toISOString()
      const updates = []
      inputs.forEach(el => {
        const cle = el.id.replace('mktf_', '')
        const valeur = (el.tagName === 'SELECT' ? el.value : el.value) || ''
        updates.push({ cle, valeur, updated_by: currentUser?.id || null, updated_at: now })
      })
      try {
        const {error} = await sb.from('marketing_config')
          .upsert(updates, {onConflict:'cle'})
        if (error) throw error
        // Invalider le cache vitrine (si service worker actif)
        window._mktCfg = null
        toast('✅ Contenu marketing enregistré — prise d\'effet immédiate !')
        window._mktTab = 'presentation'
        renderMarketing()
      } catch(e) {
        console.error('saveMktContenu error:', e)
        toast('❌ Erreur lors de la sauvegarde : ' + (e.message||'inconnue'), 'err')
      }
    }

