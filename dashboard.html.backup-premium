          </div>
          <div id="feuilleContent" style="padding:0 18px 4px"></div>
        </div>

        <!-- BILAN PAR ÉTUDIANT -->
        ${studentStats.length ? `
          <div style="background:#152233;border:1px solid #1E3050;border-radius:12px;overflow:hidden;margin-bottom:22px">
            ${card('📊 Bilan de Présence par Étudiant',`${studentStats.length} étudiant(s) suivi(s)`)}
            <div style="padding:10px 18px 8px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
