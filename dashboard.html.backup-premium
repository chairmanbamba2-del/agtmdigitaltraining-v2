          <div style="font-weight:800;color:#4AE090;font-size:.92rem;margin-bottom:12px;display:flex;align-items:center;gap:8px">
            ✅ Séances passées
            <span style="font-size:.72rem;color:#5A7090;font-weight:400">(${seancesPasseesFinal.length} dernières)</span>
          </div>
          ${seancesPasseesFinal.length
            ? seancesPasseesFinal.map(s=>seanceCard(s,false)).join('')
            : `<div style="color:#5A7090;font-size:.82rem;padding:20px;text-align:center;background:#0D1B2A;border-radius:10px;border:1px solid #1E3050">Aucune séance passée enregistrée.</div>`}
        </div>
      `)
