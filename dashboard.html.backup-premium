    }

    // ── ÉVALUATIONS EN LIGNE — RÉSULTATS ─────────────────────────
    async function _apEvalView(headerContent) {
      window._evalSearch = window._evalSearch || ''
      if (headerContent !== undefined) window._apEvalHeader = headerContent
      const hdr = window._apEvalHeader || ''
      setContent(hdr + '<div style="text-align:center;padding:40px;color:#5A7090">Chargement des résultats…</div>')
      const role = profile?.role
      const isAdmin = role==='admin'||role==='formateur'

      // Charger : soumissions + évaluations associées
      let subsQ = sb.from('soumissions_evaluations').select('*')
        .not('evaluation_titre','ilike','Test de Placement%')
        .order('created_at',{ascending:false}).limit(200)
      if (role==='etudiant') {
        // Étudiant : ses propres résultats (par id ou par nom/email si anon)
        const nomEtud = [profile?.prenom, profile?.nom].filter(Boolean).join(' ')
        subsQ = sb.from('soumissions_evaluations').select('*')
          .not('evaluation_titre','ilike','Test de Placement%')
          .or(`etudiant_nom.ilike.%${nomEtud}%`)
          .order('created_at',{ascending:false}).limit(50)
      }
      const [{data:subs},{data:evals}] = await Promise.all([
        subsQ,
        sb.from('evaluations').select('id,titre,chapitre,niveau,module_id,categorie,type').eq('type','QCM').order('created_at',{ascending:false}).limit(100),
      ])

      const evalMap = {}; (evals||[]).forEach(e=>{ evalMap[e.id]=e })

      // Recherche / filtre
