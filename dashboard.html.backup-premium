              <thead>${th('Séance','Apprenant','Note','Commentaire','Date')}</thead>
              <tbody>
                ${(sats||[]).slice(0,50).map(r=>`
                  <tr style="border-top:1px solid #1E3050">
                    <td style="padding:9px 14px;font-size:.78rem;color:#90A4AE">${r.seance_sujet||'—'}</td>
                    <td style="padding:9px 14px;font-weight:700;color:#fff">${r.etudiant_nom||'—'}</td>
                    <td style="padding:9px 14px;color:#C8960C;font-size:1rem">${stars(Number(r.note)||0)}</td>
                    <td style="padding:9px 14px;font-size:.78rem;color:#90A4AE;max-width:300px">${r.commentaire||'—'}</td>
                    <td style="padding:9px 14px;font-size:.72rem;color:#5A7090">${r.created_at?new Date(r.created_at).toLocaleDateString('fr-FR'):'—'}</td>
