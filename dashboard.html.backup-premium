    window._printRapportEtudiant = async function(etudiantId, nomEtud) {
      toast('Génération du rapport…')
      // Calculer début et fin de semaine courante
      const now = new Date()
      const day = now.getDay()
      const diffLun = (day===0?-6:1-day)
      const lundi = new Date(now); lundi.setDate(now.getDate()+diffLun); lundi.setHours(0,0,0,0)
      const dimanche = new Date(lundi); dimanche.setDate(lundi.getDate()+6); dimanche.setHours(23,59,59,999)
      const fmt8 = d => d.toISOString().substring(0,10)

      const [
        {data:etud},
        {data:seancesSem},
        {data:presences},
        {data:evals},
        {data:rapports},
        {data:inscClasses},
      ] = await Promise.all([
        sb.from('etudiants').select('*').eq('id',etudiantId).single(),
        sb.from('seances').select('*').gte('date_seance',fmt8(lundi)).lte('date_seance',fmt8(dimanche)),
        sb.from('presences').select('*,seances(date_seance,sujet,heure_debut,heure_fin)').eq('etudiant_id',etudiantId).gte('created_at',lundi.toISOString()),
        sb.from('evaluations').select('*').eq('etudiant_id',etudiantId).gte('date_eval',fmt8(lundi)).lte('date_eval',fmt8(dimanche)),
        sb.from('rapports_coaching').select('*').eq('etudiant_nom',(nomEtud||'').trim()).gte('date_seance',fmt8(lundi)).lte('date_seance',fmt8(dimanche)).order('date_seance'),
        sb.from('inscriptions_classes').select('classes(nom,horaire,formateur_nom)').eq('etudiant_id',etudiantId).order('id'),
      ])

      // Séances à venir cette semaine (planifiées)
      const seancesAVenir = (seancesSem||[]).filter(s=>s.statut==='Planifiée').sort((a,b)=>new Date(a.date_seance)-new Date(b.date_seance))
      const seancesRealisees = (seancesSem||[]).filter(s=>s.statut==='Réalisée')
      const nbSeances = (seancesSem||[]).length
      const nbReal = seancesRealisees.length
      const nbPres = (presences||[]).filter(p=>p.present===1).length
      const nbAbs = (presences||[]).filter(p=>p.present===0).length
      const classes = (inscClasses||[]).map(ic=>ic.classes).filter(Boolean)
      const formateurNom = classes.length && classes[0].formateur_nom ? classes[0].formateur_nom : '—'
