      `)
    }

    window._saveSatisfaction = async function() {
      const seanceId=Number(document.getElementById('satSeance').value)
      const etudId=Number(document.getElementById('satEtud').value)
      const note=Number(document.getElementById('satNote').value)
      const commentaire=document.getElementById('satComment').value.trim()
      if(!seanceId){toast('Sélectionnez une séance','err');return}
      if(!etudId){toast('Sélectionnez un apprenant','err');return}
      if(!note){toast('Choisissez une note','err');return}
      // Récupérer les infos de la séance et de l'apprenant
      const [{data:seance},{data:etud}]=await Promise.all([
        sb.from('seances').select('sujet,date_seance').eq('id',seanceId).single(),
        sb.from('etudiants').select('nom,prenom').eq('id',etudId).single(),
      ])
      const {error}=await sb.from('satisfactions').insert({
        seance_id:seanceId, etudiant_id:etudId, note,
        commentaire:commentaire||null,
        seance_sujet:seance?.sujet||null,
        etudiant_nom:etud?`${etud.prenom} ${etud.nom}`:null,
      })
      if(error){
        if(error.code==='42P01'){toast('Table satisfactions manquante — exécutez la migration v18','err');return}
