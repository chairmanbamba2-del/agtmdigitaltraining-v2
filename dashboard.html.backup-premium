      const evalSearchBar = `<div style="margin-bottom:16px;display:flex;align-items:center;gap:10px">
        <input type="text" placeholder="🔍 Rechercher par apprenant, évaluation ou niveau…"
          value="${(evalSQ).replace(/"/g,'&quot;')}"
          oninput="window._evalSearch=this.value;_apEvalView()"
          style="flex:1;padding:9px 14px;border-radius:9px;font-size:.82rem;outline:none;background:#0D1B2A;border:1px solid ${evalSQ?'#C8960C':'#2A3F58'};color:#E2D8C0;transition:border .15s"/>
        ${evalSQ?`<button onclick="window._evalSearch='';_apEvalView()" style="padding:7px 14px;border-radius:8px;font-size:.78rem;cursor:pointer;background:#2A1A1A;border:1px solid #E04A4A;color:#E04A4A">✕ Effacer</button>`:''}
      </div>`

      setContent(hdr + `
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px">
          ${kpi('📊','Soumissions reçues',total,'#4A90D9')}
          ${kpi('✅','Résultats ≥ 10/20',reussi,'#4AE090')}
          ${kpi('📈','Moyenne générale',moy+'/20',moy>=10?'#4AE090':'#E04A4A')}
        </div>
