              <div style="font-size:.78rem;color:#B0C4D8;line-height:1.55;white-space:pre-wrap">${m.contenu||''}</div>
              ${accuse && accuseAt ? `<div style="margin-top:8px;font-size:.68rem;color:#4AE090;opacity:.7">👁 Réception accusée le ${accuseAt}</div>` : ''}
              ${m.fichier_url ? `<div style="margin-top:9px"><a href="${m.fichier_url}" target="_blank"
                style="display:inline-flex;align-items:center;gap:5px;padding:5px 12px;background:#0D1B2A;border:1px solid #C8960C;border-radius:6px;color:#C8960C;font-size:.72rem;font-weight:700;text-decoration:none">
                📎 ${m.fichier_nom||'Pièce jointe'}</a></div>` : ''}
            </div>`
          }).join('')

          envoyesHTML = `
            <div style="font-weight:700;color:#4AE090;font-size:.82rem;margin-bottom:10px">📤 Messages envoyés (${envoyes.length + (oldEnv||[]).length})</div>
            ${(envCards + oldEnvCards) || `<div style="text-align:center;padding:22px;color:#5A7090;background:#0D1B2A;border-radius:10px;border:1px solid #1E3050;font-size:.8rem">Aucun message envoyé.</div>`}`
