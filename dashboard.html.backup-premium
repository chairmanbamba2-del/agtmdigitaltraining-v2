    }

    window._apPlacementNext = function() {
      const ps=window._apPS;if(!ps)return
      ps.current++;ps.answered=false;_apPlacementRender()
    }

    async function _apPlacementResults() {
      if(window._apPTimer) clearInterval(window._apPTimer)
      const ps=window._apPS;if(!ps)return
      const isAnon = profile?.role === 'anon'
      const niveau  = _placementLevel(ps.score)
