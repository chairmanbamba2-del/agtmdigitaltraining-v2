        border:1px solid ${ok?'#4AE090':'#E04A4A'};
        box-shadow:0 4px 18px rgba(0,0,0,.4);max-width:300px;`
      t.textContent = msg
      document.getElementById('toastBox').appendChild(t)
      setTimeout(() => t.remove(), 4500)
