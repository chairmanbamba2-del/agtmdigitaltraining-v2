    // ── 3. Progression des cohortes ──────────────────────────────
    window._renderCohortProgress = async function(containerId, classIds) {
      const container = document.getElementById(containerId)
      if (!container) return

      const [{ data: classes }, { data: seances }] = await Promise.all([
        sb.from('classes').select('id,nom,quota_seances,frequence_semaine').in('id', classIds.length ? classIds : [0]),
        sb.from('seances').select('classe_id,statut').in('classe_id', classIds.length ? classIds : [0])
      ])
      if (!classes?.length) { container.innerHTML = '<div style="color:#5A7090;font-size:.78rem;padding:12px">Aucune classe trouvée</div>'; return }

      const html = (classes||[]).map(cl => {
        const clSeances = (seances||[]).filter(s => s.classe_id === cl.id)
        const done = clSeances.filter(s => s.statut === 'Réalisée').length
        const total = cl.quota_seances || 24
        const planned = clSeances.filter(s => s.statut === 'Planifiée').length
        const pct = Math.min(100, Math.round(done / total * 100))
        const col = pct >= 100 ? '#4AE090' : pct >= 75 ? '#C8960C' : pct >= 50 ? '#4A90D9' : '#E8B84B'
        // Estimate current week number (based on frequence_semaine)
        const freq = cl.frequence_semaine || 2
        const weekDone = Math.floor(done / freq)
        const weekTotal = Math.ceil(total / freq)
        return `
          <div class="kpi-card" style="background:linear-gradient(135deg,#0E1E34,#1A1206);border:1px solid rgba(200,150,12,0.2);border-radius:12px;padding:14px 16px;margin-bottom:10px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
              <div>
                <div style="font-weight:800;color:#E8B84B;font-size:.85rem">${cl.nom}</div>
                <div style="font-size:.68rem;color:#5A7090;margin-top:2px">Semaine <strong style="color:#4A90D9">${weekDone}/${weekTotal}</strong> complétée · ${freq}×/semaine</div>
              </div>
              <div style="text-align:right">
                <div style="font-size:1.3rem;font-weight:900;color:${col}">${pct}%</div>
                <div style="font-size:.62rem;color:#5A7090">${done}/${total} séances</div>
              </div>
            </div>
            <div style="height:8px;background:#0D1B2A;border-radius:4px;overflow:hidden;position:relative">
              <div style="height:100%;border-radius:4px;background:linear-gradient(90deg,${col}88,${col});width:${pct}%;transition:width .6s cubic-bezier(.4,0,.2,1)"></div>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:.64rem;color:#3A5070;margin-top:5px">
              <span>✅ ${done} réalisées</span>
              <span>📅 ${planned} planifiées</span>
              <span>📋 ${Math.max(0,total-done)} restantes</span>
            </div>
          </div>`
      }).join('')
      container.innerHTML = html
    }

    // ── 4. Algorithme d'assiduité — Étudiants à risque ──────────
    window._renderEtudiantsARisque = async function(containerId) {
      const container = document.getElementById(containerId)
      if (!container) return
      container.innerHTML = '<div class="skeleton" style="height:60px;margin-bottom:8px"></div><div class="skeleton" style="height:60px"></div>'

      // Get last 10 presences per student
      const [{ data: etuds }, { data: pres }, { data: seances }] = await Promise.all([
        sb.from('etudiants').select('id,nom,prenom,telephone,statut').order('id').order('nom'),
        sb.from('presences').select('etudiant_id,present,seance_id,justifie,motif_absence').order('created_at', {ascending:false}).limit(2000),
        sb.from('seances').select('id,date_seance,sujet').order('date_seance',{ascending:false}).limit(200)
      ])

      const seanceMap = {}
      ;(seances||[]).forEach(s => seanceMap[s.id] = s)

      const atRisk = []
      ;(etuds||[]).forEach(e => {
        const etudPres = (pres||[]).filter(p => p.etudiant_id === e.id)
        // Sort by seance date descending
        const sorted = etudPres
          .map(p => ({ ...p, date: seanceMap[p.seance_id]?.date_seance || '0000-00-00' }))
          .sort((a,b) => b.date.localeCompare(a.date))

        // Check last N presences for consecutive absences
        let consecutive = 0
        let maxConsecutive = 0
        for (const p of sorted) {
          if (!p.present) { consecutive++; maxConsecutive = Math.max(maxConsecutive, consecutive) }
          else { consecutive = 0 }
        }

        const totalPres = etudPres.filter(p=>p.present).length
        const totalAbs  = etudPres.filter(p=>!p.present).length
        const totalAtt  = etudPres.length
        const txAbs = totalAtt > 0 ? Math.round(totalAbs/totalAtt*100) : 0

        // At risk: 2+ consecutive absences OR absence rate > 30%
        if (maxConsecutive >= 2 || (totalAtt >= 4 && txAbs >= 30)) {
          atRisk.push({
            ...e,
            maxConsecutive,
            totalPres,
            totalAbs,
            totalAtt,
            txAbs,
            lastAbsDate: sorted.find(p=>!p.present)?.date || '—',
            reason: maxConsecutive >= 2
              ? `${maxConsecutive} absences consécutives`
              : `Taux d'absence : ${txAbs}%`
          })
        }
      })

      if (!atRisk.length) {
        container.innerHTML = `<div style="padding:16px;text-align:center;color:#4AE090;font-size:.82rem;font-weight:700">
          ✅ Aucun étudiant à risque détecté — Bonne assiduité générale !
        </div>`
        return
      }

      const html = atRisk.map(e => {
        const tel = (e.telephone||'').replace(/[\s\-\(\)\.]/g,'')
        const waNum = tel.startsWith('+') ? tel.slice(1) : tel.startsWith('00') ? tel.slice(2) : '225'+tel
        const msg = encodeURIComponent(
          `Bonjour ${e.prenom} ${e.nom},\n\nNous avons remarqué votre absence lors de vos dernières séances à AGTM Digital Academy.\n\nNous tenons à votre progression et souhaiterions avoir de vos nouvelles. Merci de nous contacter ou de reprendre vos cours dès que possible.\n\nL'équipe AGTM Digital Academy`
        )
        const waLink = `https://wa.me/${waNum}?text=${msg}`
        const urgency = e.maxConsecutive >= 3 ? '#E04A4A' : e.maxConsecutive >= 2 ? '#E8B84B' : '#C8960C'
        return `
          <div style="background:linear-gradient(135deg,#1A0E0E,#0E1820);border:1px solid ${urgency}44;border-left:3px solid ${urgency};border-radius:10px;padding:12px 16px;margin-bottom:8px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
            <div style="width:36px;height:36px;border-radius:50%;background:${urgency}22;border:2px solid ${urgency};display:flex;align-items:center;justify-content:center;font-weight:900;font-size:.8rem;color:${urgency};flex-shrink:0">
              ${(e.prenom[0]||'?').toUpperCase()}
            </div>
            <div style="flex:1;min-width:150px">
              <div style="font-weight:800;color:#fff;font-size:.85rem">${e.prenom} ${e.nom}</div>
              <div style="font-size:.72rem;color:${urgency};font-weight:700;margin-top:2px">⚠️ ${e.reason}</div>
              <div style="font-size:.65rem;color:#5A7090;margin-top:2px">
                ${e.totalPres} présence(s) · ${e.totalAbs} absence(s) · Taux abs. : ${e.txAbs}%
                ${e.lastAbsDate!=='—' ? ' · Dernière absence : '+new Date(e.lastAbsDate+'T00:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'short'}) : ''}
              </div>
            </div>
            <div style="display:flex;gap:6px;flex-shrink:0;flex-wrap:wrap">
              ${tel ? `
                <a href="${waLink}" target="_blank"
                  style="display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:8px;background:#1A3A1A;border:1px solid #25D366;color:#25D366;font-size:.73rem;font-weight:700;text-decoration:none;transition:all .15s"
                  onmouseover="this.style.background='rgba(37,211,102,0.15)'" onmouseout="this.style.background='#1A3A1A'">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  Relancer sur WhatsApp
                </a>` : `<span style="font-size:.7rem;color:#3A5070">Pas de téléphone</span>`}
              <button onclick="navigateTo('etudiants')" style="padding:6px 10px;border-radius:8px;background:#1A2D42;border:1px solid #4A90D9;color:#4A90D9;font-size:.72rem;cursor:pointer;font-weight:700">📋 Dossier</button>
            </div>
          </div>`
      }).join('')
      container.innerHTML = html
    }

