    window._inviteUser = async function() {
      const email  = (document.getElementById('invEmail')?.value||'').trim()
      const prenom = (document.getElementById('invPren')?.value||'').trim()
      const nom    = (document.getElementById('invNom')?.value||'').trim()
      const role   = document.getElementById('invRole')?.value || 'etudiant'
      const pwd    = (document.getElementById('invPwd')?.value||'').trim()
      const pwd2   = (document.getElementById('invPwd2')?.value||'').trim()
      if (!email||!prenom||!nom) { toast('Prénom, nom et email obligatoires','err'); return }
      if (!pwd) { toast('Mot de passe obligatoire','err'); return }
      if (pwd !== pwd2) { toast('Les mots de passe ne correspondent pas','err'); return }
      if (pwd.length < 8) { toast('Mot de passe trop court (min. 8 caractères)','err'); return }
      // Créer via Admin API (accès immédiat, sans confirmation email)
      const resp = await fetch(`${SUPABASE_URL}/auth/v1/admin/users`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_SERVICE_ROLE,
          'Authorization': 'Bearer ' + SUPABASE_SERVICE_ROLE
        },
        body: JSON.stringify({ email, password: pwd, email_confirm: true, user_metadata: { role, nom, prenom } })
      })
      const authData = await resp.json()
      if (!resp.ok) {
        toast('Erreur création compte : ' + (authData.msg || authData.message || `HTTP ${resp.status}`), 'err')
        return
      }
      const uid = authData.id
      if (uid) {
        await sb.from('utilisateurs').upsert({id:uid, email, role, nom, prenom, actif:true},{onConflict:'id'})
      }
      // Vider le formulaire
      ;['invEmail','invPren','invNom','invPwd','invPwd2'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=''})
      toast(`✅ Compte créé — ${prenom} ${nom} (${role}) · Accès immédiat actif`)
      renderUtilisateurs()
    }

