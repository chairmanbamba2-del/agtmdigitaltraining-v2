    async function _pedaSeances() {
      const _isDirPed = ['admin','directeur_pedagogique','sous_directeur_pedagogique'].includes(profile?.role)
      const [{data:seances},{data:etuds},{data:pres},{data:classes},{data:personnelAll}]=await Promise.all([
        sb.from('seances').select('id,date_seance,heure_debut,heure_fin,titre,sujet,enseignant,classe_id,statut,format,programme,notes,module_id,vise_par_direction,visa_par,visa_at').order('date_seance',{ascending:false}).limit(200),
        sb.from('etudiants').select('id').order('id'),
        sb.from('presences').select('seance_id,present,etudiants(id,nom,prenom,numero_dossier)').limit(5000),
        sb.from('classes').select('id,nom,niveau').order('nom'),
        sb.from('personnel').select('id,nom,prenom,cin,poste').or('poste.eq.Formateur,poste.eq.Enseignant').order('id'),
      ])
      const tab='seances'

      // Calculs bilan
      const today = new Date(); today.setHours(0,0,0,0)
      const fmt8 = d => { const dt=new Date(d); return dt.toISOString().substring(0,10) }
      const todayStr = fmt8(today)
      const startWeek = new Date(today); startWeek.setDate(today.getDate()-(today.getDay()===0?6:today.getDay()-1))
      const startMonth = new Date(today.getFullYear(), today.getMonth(), 1)

      const seancesAll = seances||[]
      const sToday  = seancesAll.filter(s => s.date_seance === todayStr)
      const sWeek   = seancesAll.filter(s => new Date(s.date_seance) >= startWeek)
      const sMonth  = seancesAll.filter(s => new Date(s.date_seance) >= startMonth)

      const countReal = arr => arr.filter(s=>s.statut==='Réalisée').length
      const countPlan = arr => arr.filter(s=>s.statut==='Planifiée').length

      // Nombre présences par séance + infos étudiants
      const presMap = {}
      const etudNamesMap = {}
      ;(pres||[]).forEach(p=>{
        if(p.present) presMap[p.seance_id]=(presMap[p.seance_id]||0)+1
        if(p.etudiants) {
          if(!etudNamesMap[p.seance_id]) etudNamesMap[p.seance_id]=[]
          const nd = p.etudiants.numero_dossier||''
          const nom = `${p.etudiants.prenom||''} ${p.etudiants.nom||''}`.trim()
          etudNamesMap[p.seance_id].push(nd ? `${nd} — ${nom}` : nom)
        }
      })
      // Map classe_id -> nom
      const classeMap = {}
      ;(classes||[]).forEach(c=>{ classeMap[c.id]=c.nom })
      // Map nom complet formateur -> matricule
      const fmtMatMap = {}
      ;(personnelAll||[]).forEach(p=>{ fmtMatMap[`${p.prenom||''} ${p.nom||''}`.trim()] = p.cin||null })

      // Format distribution (4 formats)
      const fmtGL = seancesAll.filter(s=>s.format==='Groupe en ligne').length
      const fmtGP = seancesAll.filter(s=>s.format==='Groupe présentiel').length
      const fmtIL = seancesAll.filter(s=>s.format==='Individuel en ligne').length
      const fmtIP = seancesAll.filter(s=>s.format==='Individuel présentiel').length

      // Programme distribution
      const progCounts = {}
      seancesAll.forEach(s=>{const p=s.programme||'Général'; progCounts[p]=(progCounts[p]||0)+1})

      const progBadges = Object.entries(progCounts).map(([p,n])=>
        `<span style="padding:3px 10px;border-radius:8px;font-size:.68rem;font-weight:700;background:#1A2D42;border:1px solid #2A3F58;color:#4A90D9;margin-right:4px">${p}: ${n}</span>`
      ).join('')

      setContent(`
        ${pedaTabBar(tab)}

        <!-- KPIs -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px">
          ${kpi('📅','Total séances',seancesAll.length,'#4A90D9')}
          ${kpi('✅','Réalisées',countReal(seancesAll),'#4AE090')}
          ${kpi('📋','Planifiées',countPlan(seancesAll),'#E8B84B')}
          ${kpi('👨‍🎓','Étudiants actifs',(etuds||[]).length,'#C8960C')}
        </div>

        <!-- Bilan journalier / hebdo / mensuel -->
        <div style="background:#152233;border:1px solid #C8960C;border-radius:12px;overflow:hidden;margin-bottom:22px">
          ${card('📊 Bilan des Séances')}
          <div style="padding:14px 18px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
            <div style="background:#0D1B2A;border-radius:10px;padding:12px 16px;border:1px solid #1E3050">
              <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:#5A7090;margin-bottom:6px;font-weight:700">📅 Aujourd'hui</div>
              <div style="font-size:1.4rem;font-weight:900;color:#E8B84B">${sToday.length}</div>
              <div style="font-size:.72rem;color:#90A4AE;margin-top:4px">
                ${countReal(sToday)} réalisée(s) · ${countPlan(sToday)} planifiée(s)
              </div>
            </div>
            <div style="background:#0D1B2A;border-radius:10px;padding:12px 16px;border:1px solid #1E3050">
              <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:#5A7090;margin-bottom:6px;font-weight:700">📆 Cette semaine</div>
              <div style="font-size:1.4rem;font-weight:900;color:#4A90D9">${sWeek.length}</div>
              <div style="font-size:.72rem;color:#90A4AE;margin-top:4px">
                ${countReal(sWeek)} réalisée(s) · ${countPlan(sWeek)} planifiée(s)
              </div>
            </div>
            <div style="background:#0D1B2A;border-radius:10px;padding:12px 16px;border:1px solid #1E3050">
              <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.06em;color:#5A7090;margin-bottom:6px;font-weight:700">🗓️ Ce mois</div>
              <div style="font-size:1.4rem;font-weight:900;color:#4AE090">${sMonth.length}</div>
              <div style="font-size:.72rem;color:#90A4AE;margin-top:4px">
                ${countReal(sMonth)} réalisée(s) · ${countPlan(sMonth)} planifiée(s)
              </div>
            </div>
          </div>
          <div style="padding:0 18px 16px;display:flex;gap:16px;flex-wrap:wrap">
            <div style="font-size:.75rem;color:#90A4AE;display:flex;flex-wrap:wrap;gap:4px;align-items:center"><strong style="color:#5A7090">Formats :</strong>
              ${fmtGL?`<span style="padding:3px 10px;border-radius:8px;font-size:.68rem;font-weight:700;background:rgba(74,144,217,.15);border:1px solid #4A90D9;color:#6AABF0">Groupe en ligne: ${fmtGL}</span>`:''}
              ${fmtGP?`<span style="padding:3px 10px;border-radius:8px;font-size:.68rem;font-weight:700;background:rgba(74,224,144,.1);border:1px solid #4AE090;color:#4AE090">Groupe présentiel: ${fmtGP}</span>`:''}
              ${fmtIL?`<span style="padding:3px 10px;border-radius:8px;font-size:.68rem;font-weight:700;background:rgba(200,150,12,.12);border:1px solid #C8960C;color:#E8B84B">Individuel en ligne: ${fmtIL}</span>`:''}
              ${fmtIP?`<span style="padding:3px 10px;border-radius:8px;font-size:.68rem;font-weight:700;background:rgba(156,108,200,.12);border:1px solid #9B59B6;color:#C090E8">Individuel présentiel: ${fmtIP}</span>`:''}
              ${(!fmtGL&&!fmtGP&&!fmtIL&&!fmtIP)?`<span style="color:#5A7090;font-style:italic">Aucune donnée</span>`:''}
            </div>
            <div style="font-size:.75rem;color:#90A4AE"><strong style="color:#5A7090">Programmes :</strong> <span style="margin-left:4px">${progBadges}</span></div>
          </div>
        </div>


        <!-- Table séances -->
        ${wrap(`
          ${card('📅 Toutes les Séances',`${seancesAll.length} séance(s)`)}
