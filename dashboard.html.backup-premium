    async function renderClassesFormateur() {
      setContent('<div style="color:#5A7090;text-align:center;padding:40px">Chargement de vos classes…</div>')
      const email = currentUser?.email

      // Récupérer le formateur dans la table personnel (insensible à la casse)
      const {data:perso} = await sb.from('personnel')
        .select('id,nom,prenom')
        .or(`email.eq.${email},email.ilike.${email}`)
        .maybeSingle()
      const personnelId = perso?.id

      // Construire toutes les variantes de nom possibles pour formateur_nom
      const nameSet = new Set()
      if (perso?.prenom && perso?.nom) {
        nameSet.add(`${perso.prenom} ${perso.nom}`)
        nameSet.add(`${perso.nom} ${perso.prenom}`)
      }
      if (profile?.prenom && profile?.nom) {
        nameSet.add(`${profile.prenom} ${profile.nom}`)
        nameSet.add(`${profile.nom} ${profile.prenom}`)
      }
      const nameArr = [...nameSet].filter(Boolean)

      // Récupérer les classes par personnel_id ET/OU formateur_nom (toutes variantes)
      const classQueries = []
      if (personnelId) classQueries.push(sb.from('classes').select('*').eq('personnel_id', personnelId).order('nom'))
      if (nameArr.length)  classQueries.push(sb.from('classes').select('*').in('formateur_nom', nameArr).order('nom'))

      let classes = []
      if (classQueries.length) {
        const results = await Promise.all(classQueries)
        const all = results.flatMap(r => r.data || [])
        const seen = new Set()
        classes = all.filter(c => !seen.has(c.id) && seen.add(c.id))
      }

      if (!classes.length) {
        setContent(`
          <div style="text-align:center;padding:60px 20px;color:#5A7090">
            <div style="font-size:3rem;margin-bottom:16px">👥</div>
