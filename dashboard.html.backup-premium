        {id:'directeur_pedagogique',     label:'Directeur Pédagogique',    icon:'🎓',  col:'#8E44AD', bg:'#1A0D2A'},
        {id:'sous_directeur_pedagogique',label:'Sous-Dir. Pédagogique',    icon:'📐',  col:'#BDC3E7', bg:'#1A1A2D'},
        {id:'formateur',                 label:'Formateur',                icon:'👨‍🏫', col:'#4A90D9', bg:'#1A2D42'},
        {id:'etudiant',                  label:'Étudiant',                 icon:'👨‍🎓', col:'#A090E0', bg:'#1A1A2D'},
