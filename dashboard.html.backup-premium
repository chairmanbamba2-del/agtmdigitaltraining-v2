            const initiales = ((u.prenom||'?')[0]+(u.nom||'?')[0]).toUpperCase()
            const isSelf = u.id === profile?.id
            const roleOpts = rolesAll.map(r=>`<option value="${r.id}" ${u.role===r.id?'selected':''}>${r.icon} ${r.label}</option>`).join('')
            return `
            <div style="background:#152233;border:1px solid ${isActif?'#1E3050':'#3A1A1A'};border-radius:12px;padding:16px 18px;opacity:${isActif?1:.75}">
              <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">

                <!-- Avatar -->
                <div style="width:44px;height:44px;border-radius:50%;background:${isActif?rc.bg:'#2A1A1A'};border:2px solid ${isActif?rc.col:'#E04A4A'};display:flex;align-items:center;justify-content:center;font-weight:900;font-size:.85rem;color:${isActif?rc.col:'#E04A4A'};flex-shrink:0">
                  ${isActif?initiales:'🚫'}
                </div>

                <!-- Infos -->
                <div style="flex:1;min-width:200px">
                  <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px">
                    <span style="font-weight:800;color:#fff;font-size:.92rem">${u.prenom||''} ${u.nom||''}</span>
                    <span style="padding:2px 9px;border-radius:10px;font-size:.65rem;font-weight:800;background:${rc.bg};color:${rc.col}">${rc.icon} ${rc.label}</span>
                    <span style="padding:2px 9px;border-radius:10px;font-size:.65rem;font-weight:700;background:${isActif?'#1A3A1A':'#3A1A1A'};color:${isActif?'#4AE090':'#E04A4A'}">
                      ${isActif?'✅ Actif':'🚫 Suspendu'}
                    </span>
                    ${isSelf?`<span style="padding:2px 8px;border-radius:8px;font-size:.6rem;font-weight:800;background:#1A2D42;color:#4A90D9">👤 Vous</span>`:''}
                  </div>
                  <div style="font-size:.75rem;color:#5A7090">✉️ ${u.email||'—'} &nbsp;·&nbsp; 📅 Inscrit le ${fmtDate(u.created_at)}</div>
                </div>

                <!-- Actions -->
                <div style="display:flex;flex-direction:column;gap:7px;min-width:220px">
                  <!-- Changer le rôle -->
                  <div style="display:flex;gap:6px;align-items:center">
                    <select id="rolesel_${u.id}"
                      style="flex:1;padding:6px 10px;border-radius:7px;font-size:.72rem;background:#0D1B2A;border:1px solid #2A3F58;color:#E0E0E0;outline:none;cursor:pointer">
                      ${roleOpts}
                    </select>
                    <button onclick="_applyRole('${u.id}')" style="padding:6px 12px;border-radius:7px;font-size:.7rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A;font-weight:800;white-space:nowrap">💾 Rôle</button>
                  </div>
                  <!-- Tier IA -->
                  <div style="display:flex;gap:6px;align-items:center">
                    <select id="tiersel_${u.id}"
                      style="flex:1;padding:6px 10px;border-radius:7px;font-size:.72rem;background:#0D1B2A;border:1px solid #2A3058;color:#E0E0E0;outline:none;cursor:pointer">
                      <option value="essentiel" ${(u.ai_tier||'essentiel')==='essentiel'?'selected':''}>🔵 Essentiel (Haiku)</option>
                      <option value="recommande" ${u.ai_tier==='recommande'?'selected':''}>🟡 Recommandé (Sonnet)</option>
                      <option value="premium" ${u.ai_tier==='premium'?'selected':''}>🟣 Premium (Opus)</option>
                    </select>
                    <button onclick="_setUserTier('${u.id}')" style="padding:6px 12px;border-radius:7px;font-size:.7rem;cursor:pointer;background:#5A2888;border:none;color:#fff;font-weight:800;white-space:nowrap">🤖 IA</button>
                  </div>
