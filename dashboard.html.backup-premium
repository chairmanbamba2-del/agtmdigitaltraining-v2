    // ── QUIZ ENGINE ───────────────────────────────────────────────
    function _apQuizPanel(m) {
      if (!window._apQS || window._apQS.modId !== m.id) {
        window._apQS = {modId:m.id, questions:m.quiz||[], current:0, score:0, answered:false, errors:[]}
      }
      return _apQRender()
    }

    function _apQRender() {
      const qs = window._apQS
      if (!qs.questions.length) return `<div style="text-align:center;padding:40px 20px">
        <div style="font-size:2rem;margin-bottom:10px">🧩</div>
        <div style="color:#5A7090;margin-bottom:14px;font-size:.88rem">${qs.noQuiz ? 'Aucun quiz disponible pour ce module.' : 'Aucune question chargée pour ce module.'}</div>
        <button onclick="window._apSetModTab('eval')" style="padding:8px 20px;border-radius:8px;border:none;cursor:pointer;font-weight:700;font-size:.82rem;background:#4AE090;color:#0D1B2A">
          🧪 Faire l'évaluation à la place</button>
      </div>`
      if (qs.current >= qs.questions.length) return _apQResults()
      const q = qs.questions[qs.current]
      return `<div style="max-width:600px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <span style="font-size:.78rem;color:#90A4AE">Question ${qs.current+1} / ${qs.questions.length}</span>
          <span style="font-size:.78rem;font-weight:700;color:#C8960C">Score : ${qs.score} / ${qs.current}</span>
        </div>
        <div style="height:4px;background:#1E3050;border-radius:2px;margin-bottom:18px;overflow:hidden">
          <div style="height:4px;background:#C8960C;border-radius:2px;width:${qs.current/qs.questions.length*100}%;transition:width .4s"></div>
        </div>
        <div style="background:#152233;border:1px solid #1E3050;border-radius:12px;padding:18px 22px;margin-bottom:14px">
          <p style="font-size:.95rem;font-weight:600;color:#fff;margin:0;line-height:1.55">${q.q}</p>
        </div>
        <div id="apOpts" style="display:flex;flex-direction:column;gap:8px">
          ${(q.opts||[]).map((o,i)=>`<button id="apo_${i}" onclick="window._apQPick(${i})"
            style="width:100%;text-align:left;padding:12px 16px;border-radius:9px;font-size:.85rem;font-weight:500;
            cursor:pointer;background:#0D1B2A;border:1.5px solid #1E3050;color:#e0e0e0;transition:all .15s;
            display:flex;align-items:center;gap:11px">
            <span style="width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;background:#1E3050;color:#90A4AE;flex-shrink:0">${String.fromCharCode(65+i)}</span>
            ${o}</button>`).join('')}
        </div>
      </div>`
    }

    window._apQPick = function(i) {
      const qs = window._apQS
      if (qs.answered) return
      qs.answered = true
      const q = qs.questions[qs.current]
      const chosen = (q.opts||[])[i]
      const repLetter = (q.rep||'').trim()
      const correct = (q.opts||[]).find(o=>o.startsWith(repLetter+')'))
      const ok = chosen === correct
      if (ok) qs.score++
      else qs.errors.push({q:q.q, chosen, correct, expl:q.expl||''});
      (q.opts||[]).forEach((o,j)=>{
        const b = document.getElementById('apo_'+j); if(!b) return
        b.disabled = true
        if(o===correct){b.style.borderColor='#4AE090';b.style.background='#1A3A1A';b.style.color='#4AE090'}
        else if(j===i&&!ok){b.style.borderColor='#E04A4A';b.style.background='#2A1A1A';b.style.color='#E04A4A'}
      })
      const wrap = document.getElementById('apOpts')
      if(wrap) wrap.insertAdjacentHTML('afterend',`
        <div style="margin-top:12px;padding:12px 16px;border-radius:9px;background:${ok?'#1A3A1A':'#2A1A1A'};border:1px solid ${ok?'#4AE090':'#E04A4A'}">
          <div style="font-weight:700;color:${ok?'#4AE090':'#E04A4A'};margin-bottom:3px">${ok?'✅ Correct !':'❌ Incorrect'}</div>
          ${q.expl?`<div style="font-size:.78rem;color:#90A4AE;line-height:1.5">${q.expl}</div>`:''}
        </div>
        <div style="margin-top:12px;text-align:right">
          <button onclick="window._apQNext()" style="padding:9px 22px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A">
            ${qs.current+1<qs.questions.length?'Question suivante →':'🏆 Résultats'}
          </button>
        </div>`)
    }

    window._apQNext = function() {
      const qs = window._apQS
      qs.current++
      qs.answered = false
      _apModView()
    }

    function _apQResults() {
      const qs = window._apQS
      const total = qs.questions.length
      const pct = Math.round(qs.score/total*100)
      const errHtml = qs.errors.length ? `<div style="margin-top:20px;text-align:left">
        <div style="font-size:.78rem;font-weight:700;color:#E04A4A;margin-bottom:10px">❌ Points à revoir :</div>
        ${qs.errors.map(e=>`<div style="background:#2A1A1A;border:1px solid rgba(224,74,74,0.3);border-radius:8px;padding:10px 14px;margin-bottom:7px">
          <div style="font-size:.82rem;color:#D0A8A8;margin-bottom:4px">${e.q}</div>
          <div style="font-size:.75rem;color:#90A4AE">${e.expl}</div>
        </div>`).join('')}
      </div>` : ''
      return `<div style="max-width:440px;text-align:center">
        <div style="font-size:3.5rem;margin-bottom:10px">${pct>=80?'🏆':pct>=60?'👍':'📚'}</div>
        <div style="font-size:2rem;font-weight:900;color:#C8960C;margin-bottom:6px">${qs.score} / ${total}</div>
        <div style="font-size:.95rem;font-weight:600;color:#fff;margin-bottom:4px">${pct}% de bonnes réponses</div>
        <div style="font-size:.82rem;color:#90A4AE;margin-bottom:20px">${pct>=80?'Excellent ! Vous maîtrisez ce module.':pct>=60?'Bon travail, continuez !':'Révisez le cours et réessayez !'}</div>
        <button onclick="window._apQS=null;_apModView()" style="padding:10px 28px;border-radius:9px;font-weight:700;font-size:.85rem;cursor:pointer;background:#C8960C;border:none;color:#0D1B2A">🔄 Recommencer le quiz</button>
        ${errHtml}
      </div>`
    }

    // ── ÉVALUATION DE MODULE (onglet Évaluation) ──────────────────
    async function _apModEvalStart(m) {
      const col = _NBL[m.niveau]||'#4A90D9'

      let combined = []

      if (m._isDbMod) {
        // Module DB : charger les questions via l'API pédagogique
        try {
          const resp = await fetch('/api/pedagogy/quiz/' + encodeURIComponent(m.id))
          const data = await resp.json()
          const apiQs = (data.questions || []).map(q => {
            const opts = (q.options || []).map((o, idx) => String.fromCharCode(65+idx) + ') ' + o.text)
            const ci = (q.options || []).findIndex(o => !!o.is_correct)
            return {
              question:         q.question_text,
              options:          opts,
              reponse_correcte: ci >= 0 ? opts[ci] : (opts[0] || ''),
              explication:      q.explanation || '',
              _src:             'api',
            }
          })
          combined = apiQs
        } catch(e) {
          console.error('[eval] Erreur chargement quiz API:', e)
        }
      } else {
        // Module statique : quiz du module + complément quiz_questions
        const {data:dbQs} = await sb.from('quiz_questions').select('*').eq('niveau', m.niveau).limit(40)
        const modQs = (m.quiz||[]).map(q=>({
          question:         q.q,
          options:          q.opts,
          reponse_correcte: (q.opts||[]).find(o=>o.startsWith(q.rep+')'))||q.rep,
          explication:      q.expl||'',
          _src:             'module',
        }))
        const dbMapped = (dbQs||[]).map(q=>({
          question:         q.question,
          options: (() => { try { return Array.isArray(q.options)?q.options:JSON.parse(q.options||'[]') } catch{return []} })(),
          reponse_correcte: q.reponse_correcte||q.reponse||'',
          explication:      q.explication||'',
          _src:             'db',
        })).filter(q=>q.options.length>0)
        combined = [...modQs]
        for (const q of dbMapped) {
          if (combined.length >= 20) break
          combined.push(q)
        }
      }

      const questions = combined.sort(()=>Math.random()-.5).slice(0,20)

      const hdr = _apModEvalHeader(m)
      const dureeSec = (m.duree||20)*60
      // Store pending eval context for when student clicks Start
      window._apPendingEval = { questions, modId:m.id, modTitre:m.titre, cat:_getModCat(m.id), dureeSec }

      setContent(hdr + `<div style="max-width:640px">
        <div style="background:rgba(74,224,144,0.07);border:1px solid rgba(74,224,144,0.3);border-radius:10px;padding:14px 18px;margin-bottom:18px">
          <div style="font-size:.78rem;font-weight:700;color:#4AE090;margin-bottom:6px;text-transform:uppercase">📋 Évaluation — ${m.titre}</div>
          <div style="font-size:.82rem;color:#A0D4B8;line-height:1.6">${questions.length} questions · Durée : ${m.duree} min · Correction automatique · Résultat enregistré dans vos notes</div>
        </div>
        <div style="background:linear-gradient(135deg,#152540,#241C08);border:1px solid rgba(200,150,12,.2);border-radius:13px;overflow:hidden;margin-bottom:16px">
          <div style="background:linear-gradient(90deg,#1C3258,#2C2208);padding:13px 20px;border-bottom:1px solid rgba(200,150,12,.2);font-weight:700;color:#E8B84B;font-size:.88rem">👤 Informations de l'apprenant</div>
          <div style="padding:16px 20px;display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div>${lbl('Prénom *')}${inp('evPren','text','Votre prénom')}</div>
            <div>${lbl('Nom *')}${inp('evNomE','text','Votre nom')}</div>
            <div>${lbl('Email')}${inp('evMailE','email','votre@email.com')}</div>
            <div>${lbl('Classe / Niveau')}<select id="evClsE" style="width:100%;padding:9px 13px;border-radius:8px;font-size:.88rem;background:linear-gradient(135deg,#0B1828,#1C1408);border:1px solid #3A3A28;color:#E2D8C0"><option value="">—</option><option>A1</option><option>A2</option><option>B1</option><option>B2</option><option>C1</option><option>C2</option></select></div>
          </div>
        </div>
        <button onclick="window._apModEvalRun()"
          style="width:100%;padding:13px;border-radius:10px;border:none;cursor:pointer;font-size:.92rem;font-weight:800;background:#4AE090;color:#0D1B2A">
          🚀 Démarrer l'Évaluation (${m.duree} min)</button>
      </div>`)
      // Pre-fill nom if profile known
      const pEl=document.getElementById('evPren'); if(pEl&&profile?.prenom) pEl.value=profile.prenom
      const nEl=document.getElementById('evNomE'); if(nEl&&profile?.nom) nEl.value=profile.nom
    }

    function _apModEvalHeader(m) {
      const col = _NBL[m.niveau]||'#4A90D9'
      return `<div style="background:linear-gradient(90deg,#0E1E34 0%,#1A1408 100%);border-radius:11px;padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
        <button onclick="window._apSetModTab('cours')" style="padding:6px 14px;border-radius:7px;border:1px solid #2A3F58;background:transparent;color:#8AAAC0;cursor:pointer;font-size:.78rem">← Cours</button>
        <span style="padding:2px 11px;border-radius:12px;font-size:.72rem;font-weight:800;background:${col}25;color:${col};border:1px solid ${col}50">${m.niveau}</span>
        <span style="font-weight:700;font-size:.92rem;color:#E8B84B;flex:1">${m.titre} — Évaluation</span>
      </div>`
    }

    window._apModEvalRun = function() {
      const ctx = window._apPendingEval||{}
      const pren = document.getElementById('evPren')?.value.trim()
      const nom  = document.getElementById('evNomE')?.value.trim()
      if (!pren||!nom) { toast('Prénom et nom requis','err'); return }
      const email = document.getElementById('evMailE')?.value.trim()||null
      const niv   = document.getElementById('evClsE')?.value||'—'
      window._apES = {
        questions: ctx.questions||[], modId:ctx.modId, modTitre:ctx.modTitre, cat:ctx.cat,
        nom:`${pren} ${nom}`, email, niv,
        current:0, score:0, answered:false, errors:[],
        timeLeft: ctx.dureeSec||1200,
      }
      _apModEvalRender()
      // Démarrer le timer
      if (window._apEvalTimer) clearInterval(window._apEvalTimer)
      window._apEvalTimer = setInterval(()=>{
        const es = window._apES; if(!es) return
        es.timeLeft--
        const el = document.getElementById('_apEvalTimer')
        if (el) {
          const m=Math.floor(es.timeLeft/60), s=es.timeLeft%60
          el.textContent = `⏱ ${m}:${s.toString().padStart(2,'0')}`
          if (es.timeLeft<=60) el.style.color='#E04A4A'
        }
        if (es.timeLeft<=0) { clearInterval(window._apEvalTimer); _apModEvalResults() }
      }, 1000)
    }

    function _apModEvalRender() {
      const es = window._apES
      if (!es || es.current >= es.questions.length) { _apModEvalResults(); return }
      const q = es.questions[es.current]
      const opts = Array.isArray(q.options) ? q.options : []
      const col = _NBL[window._apCurMod?.niveau]||'#4AE090'
      const m=Math.floor(es.timeLeft/60), s=es.timeLeft%60
      const content = `<div style="max-width:600px">
