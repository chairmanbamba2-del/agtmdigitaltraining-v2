        const [mr,pr]=await Promise.all([
          fetch('/api/pedagogy/modules?limit=100'),
          fetch('/api/pedagogy/programmes'),
        ])
        if(mr.ok){const d=await mr.json();modules=d.modules||[]}
        if(pr.ok) progs=await pr.json()
      }catch(e){}

      // Stats globales
      const byLevel={}
      lvlOrder.forEach(l=>byLevel[l]=0)
