      const byLevel={}
      modules.forEach(m=>{
        const lv=(m.level?.code||'??')
        if(!byLevel[lv])byLevel[lv]=[]
        byLevel[lv].push(m)
      })

      setContent(modeBar+`
        <div style="font-size:.82rem;color:#5A7090;margin-bottom:16px">
          Choisissez un module pour démarrer son quiz
        </div>
        ${lvlOrder.filter(lv=>byLevel[lv]).map(lv=>`
          <div style="margin-bottom:20px">
            <div style="font-size:.75rem;font-weight:800;color:${lvlColors[lv]||'#C8960C'};
                        letter-spacing:1px;margin-bottom:10px;text-transform:uppercase">
              ● Niveau ${lv}
            </div>
            <div style="display:grid;gap:8px">
              ${byLevel[lv].map(m=>`
                <div onclick="_startModuleQuiz('${m.code}')"
                  style="background:#152233;border:1px solid #1E3050;border-radius:10px;
                         padding:12px 16px;display:flex;align-items:center;gap:12px;
                         cursor:pointer;transition:border-color .15s"
                  onmouseover="this.style.borderColor='#C8960C'"
                  onmouseout="this.style.borderColor='#1E3050'">
                  <div style="flex:1">
                    <div style="font-weight:700;color:#fff;font-size:.83rem">${m.title}</div>
                    ${m.category?`<div style="font-size:.7rem;color:#5A7090;margin-top:2px">${m.category.name}</div>`:''}
                  </div>
                  <div style="font-size:.7rem;color:#90A4AE;white-space:nowrap">
