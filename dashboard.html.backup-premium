            <span style="font-size:.64rem;color:#6A8AAA">⏱ ${m.duree}min</span>
            ${quizBadge}
            ${m.video_url?`<span style="font-size:.6rem;color:#4A90D9" title="Vidéo disponible">▶ Vidéo</span>`:''}
          </div>
          <div style="font-size:.84rem;font-weight:700;color:#E2D8C0;margin-bottom:6px;line-height:1.4;flex:1">${fmtTitre}</div>
          ${objPreview.length ? `<div style="margin-bottom:10px">
            ${objPreview.map(o=>`<div style="font-size:.69rem;color:#7A9AAA;display:flex;gap:5px;margin-bottom:3px;line-height:1.3"><span style="color:#4AE090;flex-shrink:0;margin-top:1px">✓</span><span>${o}</span></div>`).join('')}
            ${m.objectifs.length>2?`<div style="font-size:.63rem;color:#4A6080;margin-top:2px">+${m.objectifs.length-2} objectif(s) supplémentaire(s)</div>`:''}
          </div>` : `<div style="font-size:.67rem;color:#3A5070;margin-bottom:10px">${m.categorie||''}</div>`}
          <button onclick="window._apOpenModModal('${m.id}')"
            style="width:100%;padding:8px;border-radius:8px;border:none;cursor:pointer;font-size:.8rem;font-weight:700;
            background:linear-gradient(90deg,${col},${col}CC);color:#0D1B2A;margin-bottom:5px;letter-spacing:.01em">
