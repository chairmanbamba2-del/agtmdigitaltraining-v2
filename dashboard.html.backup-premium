    // EMPLOI DU TEMPS UNIFIÉ — GROUPE + ÉTUDIANT + RÉCAP MODIFIABLE
    // ══════════════════════════════════════════════════════════════
    async function _pedaEdtHebdo() {
      const [{data:classes},{data:inscs},{data:etudiants}]=await Promise.all([
        sb.from('classes').select('*').order('nom'),
        sb.from('inscriptions_classes').select('etudiant_id,classe_id').order('id'),
        sb.from('etudiants').select('id,nom,prenom,niveau,numero_dossier').order('id').order('nom'),
      ])

      // ── Filtres mémorisés ─────────────────────────────────────
      if(!window._edtVue) window._edtVue='groupe'
      if(!window._edtWeekOffset) window._edtWeekOffset=0
      const vue       = window._edtVue
      const selectedId = vue==='groupe' ? (window._edtClasseId||((classes||[])[0]?.id)||null) : null
      if(vue==='groupe') window._edtClasseId = selectedId

      // ── Semaine courante ──────────────────────────────────────
      const base=new Date()
      base.setDate(base.getDate()+(window._edtWeekOffset||0)*7)
      const startOfWeek=new Date(base)
      startOfWeek.setDate(base.getDate()-base.getDay()+1)
      const endOfWeek=new Date(startOfWeek); endOfWeek.setDate(startOfWeek.getDate()+6)
      const sDt=startOfWeek.toISOString().substring(0,10)
      const eDt=endOfWeek.toISOString().substring(0,10)

      // ── Séances pour la grille (semaine active) ───────────────
      let seancesQ=sb.from('seances').select('*').gte('date_seance',sDt).lte('date_seance',eDt).order('heure_debut')
      if(vue==='etudiant' && window._edtEtudiantId) {
        const etudClassIds=(inscs||[]).filter(i=>i.etudiant_id===window._edtEtudiantId).map(i=>i.classe_id)
        if(etudClassIds.length) seancesQ=seancesQ.in('classe_id',etudClassIds)
        else seancesQ=seancesQ.eq('classe_id',-1)
      } else if(selectedId) {
        seancesQ=seancesQ.eq('classe_id',selectedId)
      }
      const {data:seances}=await seancesQ

      // ── Toutes séances pour le tableau récap ──────────────────
      let recapQ=sb.from('seances').select('*').order('date_seance',{ascending:false}).limit(80)
      if(vue==='etudiant' && window._edtEtudiantId) {
        const etudClassIds=(inscs||[]).filter(i=>i.etudiant_id===window._edtEtudiantId).map(i=>i.classe_id)
        if(etudClassIds.length) recapQ=recapQ.in('classe_id',etudClassIds)
        else recapQ=recapQ.eq('classe_id',-1)
      } else if(selectedId) {
        recapQ=recapQ.eq('classe_id',selectedId)
      }
      const {data:recapSeances}=await recapQ

      // ── Maps utiles ───────────────────────────────────────────
      const classeMap={}; (classes||[]).forEach(c=>{classeMap[c.id]=c})
      const etudsByClasse={}
      ;(inscs||[]).forEach(i=>{
        const e=(etudiants||[]).find(e=>e.id===i.etudiant_id)
        if(!e) return
        if(!etudsByClasse[i.classe_id]) etudsByClasse[i.classe_id]=[]
        etudsByClasse[i.classe_id].push(e.prenom+' '+e.nom)
      })
      const classeActuelle=classeMap[selectedId]||null
      const classeOpts=(classes||[]).map(c=>`<option value="${c.id}"${c.id===selectedId?' selected':''}>${c.nom} (${c.niveau||'—'}) ${c.formateur_nom?'· '+c.formateur_nom:''}</option>`).join('')
      const etudOpts=(etudiants||[]).map(e=>`<option value="${e.id}"${e.id===window._edtEtudiantId?' selected':''}>${e.prenom} ${e.nom} (${e.niveau||'—'}) — ${e.numero_dossier||'—'}</option>`).join('')

      // ── Grille hebdomadaire ───────────────────────────────────
      const jours=['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche']
      // Créneaux fixes 07:00 → 22:00 par heure
      const gridH=['07:00','08:00','09:00','10:00','11:00','12:00','13:00','14:00',
                   '15:00','16:00','17:00','18:00','19:00','20:00','21:00','22:00']

      const gridRows=gridH.map(h=>{
        const jourCells=jours.map((j,i)=>{
          const d=new Date(startOfWeek); d.setDate(startOfWeek.getDate()+i)
          const dStr=d.toISOString().substring(0,10)
          const seq=(seances||[]).filter(s=>s.date_seance===dStr&&s.heure_debut===h)
          if(seq.length) return `<td style="padding:4px;vertical-align:top;border:1px solid #1E3050">
            ${seq.map(s=>`
            <div style="background:${s.statut==='Réalisée'?'#1A3A1A':s.statut==='Annulée'?'#2A1A1A':'#1A2D42'};border:1px solid ${s.statut==='Réalisée'?'#4AE090':s.statut==='Annulée'?'#E04A4A':'#4A90D9'};border-radius:6px;padding:5px 7px;font-size:.66rem;margin-bottom:3px">
              <div style="color:#fff;font-weight:700">${s.sujet||'Cours'}</div>
              ${s.enseignant?`<div style="color:#C8960C;font-size:.58rem;margin-top:1px">👨‍🏫 ${s.enseignant}</div>`:''}
              ${s.programme?`<div style="color:#8AAAC0;font-size:.58rem">📋 ${s.programme}</div>`:''}
              ${(etudsByClasse[s.classe_id]||[]).length?`<div style="color:#5A8090;font-size:.57rem;margin-top:1px">👥 ${(etudsByClasse[s.classe_id]||[]).slice(0,3).join(', ')}${(etudsByClasse[s.classe_id]||[]).length>3?' +'+((etudsByClasse[s.classe_id]||[]).length-3):''}</div>`:''}
              ${s.lien_meet?`<div style="color:#4A90D9;font-size:.58rem;margin-top:1px">🔗 Meet</div>`:''}
