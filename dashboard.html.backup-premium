        if (jourNums.length > 0) {
          const base = new Date()
          for (let w=0; w<8; w++) {
            jourNums.forEach(jn => {
              const d = new Date(base)
              const diff = ((jn - d.getDay()) + 7) % 7 + w*7
              if (diff===0 && w===0) return // ne pas répéter aujourd'hui
              d.setDate(d.getDate() + (diff||7+w*7))
