      const rows = tbody.querySelectorAll('tr')
      const formateurEl = document.getElementById('filterFormateur')
      const classeEl = document.getElementById('filterClasse')
      const progressionEl = document.getElementById('filterProgression')
      const dateStartEl = document.getElementById('filterDateStart')
      if (!formateurEl || !classeEl || !progressionEl || !dateStartEl) return
      
      const formateur = formateurEl.value.trim().toLowerCase()
      const classe = classeEl.value.trim().toLowerCase()
      const progression = progressionEl.value.trim()
      const dateStart = dateStartEl.value
      
      rows.forEach(row => {
        const cells = row.querySelectorAll('td')
        if (cells.length < 8) return
        
        const formateurCell = cells[1]?.textContent?.trim().toLowerCase() || ''
        const classeCell = cells[2]?.textContent?.trim().toLowerCase() || ''
        const progressionCell = cells[6]?.textContent?.trim() || ''
        const dateCell = cells[0]?.textContent?.trim() || ''
        
        let show = true
        if (formateur && !formateurCell.includes(formateur)) show = false
        if (classe && !classeCell.includes(classe)) show = false
        if (progression && progressionCell !== progression) show = false
        if (dateStart && dateCell && dateCell !== '-') {
          // dateCell is YYYY-MM-DD, dateStart is YYYY-MM-DD
          if (dateCell < dateStart) show = false
        }
        
        row.style.display = show ? '' : 'none'
      })
    }
    
