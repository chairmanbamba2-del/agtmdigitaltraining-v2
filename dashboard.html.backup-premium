    async function renderEtudiants() {
      setContent(skeletonKpi(3) + skeletonTable(8))
      const cached = _cache.get('etudiants_list')
      if (cached) { window._etud = cached; _showEtud(cached); return }
      const { data } = await sb.from('etudiants')
        .select('id,numero_dossier,nom,prenom,email,telephone,niveau,statut,date_inscription,formations,mode_cours,quota_seances,frequence_semaine,date_fin_contrat')
        .order('date_inscription',{ascending:false})
        .limit(500)
      const rows = data||[]
      window._etud = rows
      _cache.set('etudiants_list', rows, 120000) // 2 min
      _showEtud(rows)
    }

    function _showEtud(rows) {
      setContent(`
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap">
          ${inp('seE','text','🔍  Nom, email, téléphone…','oninput="_fe()" style="width:250px"')}
