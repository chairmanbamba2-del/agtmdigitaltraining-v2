    // ══ COMMAND PALETTE ═══════════════════════════════════════════
    let _cmdItems = []
    let _cmdSel = -1

    window._openCmd = function() {
      const pal = document.getElementById('cmdPalette')
      if (!pal) return
      pal.classList.add('open')
      const inp = document.getElementById('cmdInput')
      if (inp) { inp.value=''; inp.focus(); window._cmdSearch('') }
    }
    window._closeCmd = function() {
      const pal = document.getElementById('cmdPalette')
      if (pal) pal.classList.remove('open')
    }

    // Build command items from nav
    function _buildCmdItems() {
      _cmdItems = []
      const role = profile?.role || 'etudiant'
      const items = window.NAV?.[role] || []
      items.forEach(item => {
        _cmdItems.push({ icon: item.icon||'📄', label: item.label, id: item.id, type:'nav' })
      })
      // Extra actions
      _cmdItems.push({ icon:'🔔', label:'Messagerie', id:'messagerie', type:'nav' })
      _cmdItems.push({ icon:'🚪', label:'Déconnexion', id:'__logout', type:'action' })
    }

    window._cmdSearch = function(q) {
      _buildCmdItems()
      _cmdSel = -1
      const list = document.getElementById('cmdList')
      if (!list) return
      const filtered = q.trim() === '' ? _cmdItems.slice(0,10)
        : _cmdItems.filter(i => i.label.toLowerCase().includes(q.toLowerCase()))
      list.innerHTML = filtered.map((item,idx) => `
        <div class="cmd-item" id="cmd_${idx}" onclick="window._cmdRun('${item.id}','${item.type}')">
          <span class="cmd-item-icon">${item.icon}</span>
          <span class="cmd-item-label">${item.label}</span>
          <span class="cmd-item-shortcut">↵</span>
        </div>`).join('')
      window.__cmdFiltered = filtered
    }

    window._cmdKey = function(e) {
      const filtered = window.__cmdFiltered || []
      if (e.key==='ArrowDown') { _cmdSel=Math.min(_cmdSel+1,filtered.length-1); _cmdHighlight(); e.preventDefault() }
      else if (e.key==='ArrowUp') { _cmdSel=Math.max(_cmdSel-1,0); _cmdHighlight(); e.preventDefault() }
      else if (e.key==='Enter' && _cmdSel>=0 && filtered[_cmdSel]) { window._cmdRun(filtered[_cmdSel].id, filtered[_cmdSel].type); e.preventDefault() }
      else if (e.key==='Escape') { window._closeCmd(); e.preventDefault() }
    }

    function _cmdHighlight() {
      const list = document.getElementById('cmdList')
      if (!list) return
      list.querySelectorAll('.cmd-item').forEach((el,i) => {
        el.classList.toggle('selected', i===_cmdSel)
        if (i===_cmdSel) el.scrollIntoView({block:'nearest'})
      })
    }

    window._cmdRun = function(id, type) {
      window._closeCmd()
      if (type==='action' && id==='__logout') { logout(); return }
      navigateTo(id)
    }

    // Global Ctrl+K shortcut
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey||e.metaKey) && e.key==='k') { e.preventDefault(); window._openCmd() }
      if (e.key==='Escape') { window._closeCmd(); window._closeProfile() }
    })

