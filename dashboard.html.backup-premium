        body{font-family:'Georgia',serif;background:#fff;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px}
        .cert{width:100%;max-width:900px;border:8px double ${col};padding:40px 50px;text-align:center;position:relative}
        .no-print{display:flex;justify-content:center;gap:12px;margin-bottom:20px}
        @media print{.no-print{display:none}}
