              .order('date_seance').order('heure_debut').limit(40),
            sb.from('echeances')
              .select('statut,montant,date_echeance,etudiant_id,etudiants(nom,prenom)')
              .in('statut',['En retard','En attente'])
              .lte('date_echeance', in7Str)
              .order('date_echeance').limit(20),
            sb.from('devoirs')
              .select('id,date_rendu,statut,classe_id,classes(nom)')
              .order('created_at',{ascending:false}).limit(30),
            sb.from('paiements')
              .select('montant,date_paiement')
              .gte('date_paiement', moisDebutStr)
              .order('date_paiement',{ascending:false}).limit(50),
            sb.from('rapports_seances')
              .select('id,date_seance,formateur_nom,classe_nom,nb_presents,nb_absents_non_justifies')
