            'onchange="_fe()"')}
          <span style="font-size:.75rem;color:#5A7090">${rows.length} étudiant(s)</span>
          <div style="flex:1"></div>
          ${btn('➕ Ajouter un étudiant','showAddEtud()')}
        </div>
        ${wrap(`
          <table style="width:100%;border-collapse:collapse">
            <thead>${th('N° Dossier','Nom Complet','Email','Niveau','Quota Séances','Statut','Inscrit le','Actions')}</thead>
            <tbody id="etudBody">${_etudRows(rows)}</tbody>
          </table>
        `)}
      `)
    }

    function _etudRows(rows) {
      if (!rows.length) return `<tr><td colspan="8" style="padding:28px;text-align:center;color:#5A7090">Aucun étudiant</td></tr>`
      return rows.map(e=>`<tr style="border-top:1px solid #1E3050">
        <td style="padding:9px 14px;font-family:monospace;font-size:.72rem;color:#C8960C">${e.numero_dossier}</td>
        <td style="padding:9px 14px;font-weight:600;color:#fff">${e.prenom} ${e.nom}</td>
        <td style="padding:9px 14px;font-size:.78rem;color:#90A4AE">${e.email||'—'}</td>
        <td style="padding:9px 14px">${bdg(e.niveau||'—','#1A2D42','#4A90D9')}</td>
        <td style="padding:9px 14px;font-size:.75rem;color:#C8960C;white-space:nowrap">
          ${e.quota_seances ? `📋 ${e.quota_seances} séances<br><span style="font-size:.65rem;color:#5A7090">${e.frequence_semaine||2}×/sem.</span>` : `<span style="color:#2A4060">—</span>`}
        </td>
        <td style="padding:9px 14px">${bdg(e.statut||'—',e.statut==='Actif'?'#1A3A1A':'#2A1A1A',e.statut==='Actif'?'#4AE090':'#E04A4A')}</td>
        <td style="padding:9px 14px;font-size:.7rem;color:#5A7090">${fmtDate(e.date_inscription)}</td>
        <td style="padding:9px 14px;display:flex;gap:5px;flex-wrap:wrap">
          <button onclick="toggleEtud(${e.id},'${e.statut}')"
            style="padding:3px 9px;border-radius:5px;font-size:.7rem;cursor:pointer;background:#152233;border:1px solid #2A3F58;color:#C8960C">
            ${e.statut==='Actif'?'Désactiver':'Activer'}
          </button>
          <button onclick="showEditEtud(${e.id})"
            style="padding:3px 9px;border-radius:5px;font-size:.7rem;cursor:pointer;background:#1A2D42;border:1px solid #4A90D9;color:#4A90D9">
            ✏️ Modifier
          </button>
          <button onclick="printRecuInscription(${e.id})"
            style="padding:3px 9px;border-radius:5px;font-size:.7rem;cursor:pointer;background:#1A3A1A;border:1px solid #4AE090;color:#4AE090">
            🖨️ Reçu
          </button>
          <button onclick="_envoyerMessageEtud(${e.id},'${(e.prenom+' '+e.nom).replace(/'/g,"\\'")}','${(e.email||'').replace(/'/g,"\\'")}')"
            style="padding:3px 9px;border-radius:5px;font-size:.7rem;cursor:pointer;background:#1A1A3A;border:1px solid #8A60D9;color:#A07AE0">
            💬 Message
          </button>
        </td>
      </tr>`).join('')
    }

    window._fe = debounce(function() {
      const q=(document.getElementById('seE')?.value||'').toLowerCase()
      const s=document.getElementById('seS')?.value||''
      const r=(window._etud||[]).filter(e=>{
        const m=!q||[e.nom,e.prenom,e.email,e.telephone,e.numero_dossier].some(v=>(v||'').toLowerCase().includes(q))
        return m&&(!s||e.statut===s)
      })
      const tbody=document.getElementById('etudBody')
      if(tbody) tbody.innerHTML=_etudRows(r)
    }, 150)

