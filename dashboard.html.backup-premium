    // ── CATALOGUE MODULES (Admin) ────────────────────────────────────
    async function _pedaCatalogue() {
      const lvlColors={A1:'#4CAF50',A2:'#8BC34A',B1:'#FF9800',B2:'#FF5722',C1:'#9C27B0',C2:'#E91E63'}
      const lvlOrder=['A1','A2','B1','B2','C1','C2']
