        const noteHTML = evalForSeance ? `
          <div style="margin-top:8px;padding:8px 12px;background:rgba(200,150,12,.08);border:1px solid rgba(200,150,12,.25);border-radius:8px">
            <div style="font-size:.68rem;color:#C8960C;font-weight:700;margin-bottom:2px">📊 Ma note — ${evalForSeance.type_eval||'Évaluation'}</div>
            <div style="font-size:.9rem;font-weight:900;color:${Math.round((Number(evalForSeance.note)||0)/(Number(evalForSeance.note_max)||20)*100)>=70?'#4AE090':Math.round((Number(evalForSeance.note)||0)/(Number(evalForSeance.note_max)||20)*100)>=50?'#E8B84B':'#E04A4A'}">
