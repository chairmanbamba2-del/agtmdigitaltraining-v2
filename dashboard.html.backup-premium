    async function renderPointageInline(seanceId) {
      window._ptgSeanceId = seanceId
      window._ptgFormateur = null
      window._ptgClasseEtuds = []

      setContent('<div style="color:#5A7090;text-align:center;padding:40px">⏳ Chargement…</div>')
