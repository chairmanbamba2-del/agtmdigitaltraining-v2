      if (!confirm(`⚠️ Supprimer définitivement la candidature de ${nom} ?\n\nCette action est irréversible. Le dossier et le CV seront supprimés de la base de données.`)) return
      if (!confirm(`Confirmez la suppression de "${nom}" — action permanente.`)) return
      // Supprimer le fichier CV du storage si présent
      if (cvUrl) {
        try {
          const path = cvUrl.split('/candidatures/')[1]
          if (path) await sb.storage.from('candidatures').remove([path])
        } catch(_) {}
      }
