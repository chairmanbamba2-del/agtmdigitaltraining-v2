      const text='Feuille de pointage — '+decodeURIComponent(sujetEnc||'Séance AGTM')
      if(navigator.share) navigator.share({title:text,url}).catch(()=>{})
      else window._planCopyLink(url)
    }

    // ── Nouvelles fonctions pour amélioration du formulaire ──
    window.planUpdateDuree = function() {
      const hdeb = document.getElementById('planHdeb')?.value
      const hfin = document.getElementById('planHfin')?.value
      const display = document.getElementById('planDureeDisplay')
      if (!hdeb || !hfin || !display) return
      const [h1, m1] = hdeb.split(':').map(Number)
      const [h2, m2] = hfin.split(':').map(Number)
      const totalMin = (h2 * 60 + m2) - (h1 * 60 + m1)
      if (totalMin <= 0) {
        display.textContent = 'Heure invalide'
        display.style.color = '#E04A4A'
        return
      }
      const heures = Math.floor(totalMin / 60)
      const minutes = totalMin % 60
      let texte = ''
      if (heures > 0) texte += heures + 'h'
      if (minutes > 0) texte += minutes + 'min'
      display.textContent = texte || '0min'
      display.style.color = '#C8960C'
    }

