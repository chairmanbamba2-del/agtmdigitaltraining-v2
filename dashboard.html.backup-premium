        mes_cours:renderMesCours, mes_messages:renderMesMessages,
        mon_edt:renderMonEdt, mes_notes:renderMesNotes, quiz:renderQuiz,
        activites:renderActivitesPedago,
        english_corner:renderEnglishCorner,
        messagerie:renderMessagerie,
        marketing:renderMarketing, parametres:renderParametres,
        espace_client:renderEspaceClient,
        ma_satisfaction:renderMaSatisfaction,
        devoir:renderDevoirForm, rapport_form:renderRapportForm,
        inscription:renderFormulaireInscription, candidature:renderCandidatureForm,
        eval_online:renderEvaluationOnline,
        certificats:renderCertificats,
        mon_profil:renderMonProfil,
        mes_preferences:renderMesPreferences,
        ma_securite:renderMaSecurite,
        dir_ped_dashboard:renderDirectionPedagogique,
        mes_honoraires:renderMesHonoraires,
        mes_evals:renderMesEvalsFormateur,
        ged_direction:renderGEDDirection,
        recherche_direction:renderRechercheDirection,
        ai_chat:renderAIChat,
        ai_admin:renderAIAdmin,
      }
      if (map[id]) map[id]()

      _navUpdateBackBtn()

      // Fermer le sidebar mobile automatiquement après navigation
      if (window.innerWidth <= 900) {
        const sb = document.getElementById('mainSidebar')
        const ov = document.getElementById('sidebarOverlay')
        const cl = document.getElementById('sidebarCloseBtn')
        if (sb) sb.classList.remove('open')
        if (ov) ov.classList.remove('open')
        if (cl) cl.style.display = 'none'
      }

      // Close search results on navigation
      const sr = document.getElementById('searchResults')
      const si = document.getElementById('globalSearchInput')
      if (sr) sr.style.display = 'none'
      if (si) si.value = ''
    }

    // ── Recherche globale ────────────────────────────────────────
    window._globalSearch = function(q) {
      const resultsEl = document.getElementById('searchResults')
      if (!resultsEl) return
      q = (q||'').trim().toLowerCase()
      if (!q) { resultsEl.style.display = 'none'; return }

      const role = profile?.role
      const _sp = JSON.parse(localStorage.getItem('agtm_permissions')||'{}')
      const allNavItems = Object.values(NAV).flat().filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i)
      let items
      if (_sp[role] && role !== 'admin') {
        items = _sp[role].map(m=>allNavItems.find(x=>x.id===m)).filter(Boolean)
      } else {
        items = NAV[role] || []
      }

      const matches = items.filter(item =>
        item.label.toLowerCase().includes(q) || item.id.toLowerCase().includes(q)
      )

      if (!matches.length) {
        resultsEl.innerHTML = `<div style="padding:16px;text-align:center;color:#5A7090;font-size:.8rem">Aucun résultat pour « ${q} »</div>`
        resultsEl.style.display = 'block'
        return
      }

       resultsEl.innerHTML = matches.map(item => `
         <button onclick="navigateTo('${item.id}')" class="dropdown-item" style="border-bottom:1px solid rgba(200,150,12,0.1);">
           <span style="font-size:1rem">${item.icon}</span>
           <span style="font-weight:600">${item.label}</span>
         </button>`).join('')
      resultsEl.style.display = 'block'
    }

    // Close search on outside click
    document.addEventListener('click', function(e) {
      const wrap = document.getElementById('searchBarWrap')
      if (wrap && !wrap.contains(e.target)) {
        const sr = document.getElementById('searchResults')
        if (sr) sr.style.display = 'none'
      }
    })

