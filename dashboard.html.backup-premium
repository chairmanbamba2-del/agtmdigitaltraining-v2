      const phone = inp?.dataset.phone || inp?.value?.trim()
      if (!phone) { if(st) st.innerHTML='<span style="color:#E04A4A">⚠️ Numéro requis</span>'; return }

      let body = { telephone: phone }
      if (sel === 'libre') {
