    window._prmCreateUser = async function() {
      const prenom    = document.getElementById('nuPr')?.value.trim()
      const nom       = document.getElementById('nuNom')?.value.trim()
      const email     = document.getElementById('nuEm')?.value.trim()
      const role      = document.getElementById('nuRole')?.value
      const pwd       = document.getElementById('nuPwd')?.value
      const pwd2      = document.getElementById('nuPwd2')?.value
      const isInstant = document.getElementById('nuModeInstant')?.checked ?? true

      if (!prenom||!nom||!email||!role) { toast('Tous les champs marqués * sont obligatoires','err'); return }
      if (!pwd) { toast('Le mot de passe est obligatoire','err'); return }
      if (pwd !== pwd2) { toast('Les mots de passe ne correspondent pas','err'); return }
      if (pwd.length < 8) { toast('Mot de passe trop court (min. 8 caractères)','err'); return }

      let uid = null

      if (isInstant) {
        // ── MODE ACCÈS IMMÉDIAT : Admin API avec email_confirm:true ──
        if (SUPABASE_SERVICE_ROLE === 'REMPLACER_PAR_SERVICE_ROLE_KEY') {
          toast('⚠️ Clé service_role manquante — ajoutez-la dans le code (SUPABASE_SERVICE_ROLE). Supabase Dashboard → Settings → API.', 'err')
          return
        }
        const resp = await fetch(`${SUPABASE_URL}/auth/v1/admin/users`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_SERVICE_ROLE,
            'Authorization': 'Bearer ' + SUPABASE_SERVICE_ROLE
          },
          body: JSON.stringify({
            email,
            password: pwd,
            email_confirm: true,
            user_metadata: { role, nom, prenom }
          })
        })
        const authData = await resp.json()
        if (!resp.ok) {
          toast('Erreur création compte : ' + (authData.msg || authData.message || `HTTP ${resp.status}`), 'err')
          return
        }
        uid = authData.id
        if (uid) {
          await sb.from('utilisateurs').upsert({id:uid, email, role, nom, prenom, actif:true},{onConflict:'id'})
        }
        toast(`✅ Compte créé — ${prenom} ${nom} · Accès immédiat actif`)
      } else {
        // ── MODE EMAIL CONFIRMATION : signUp standard ──
        const {data:authData, error:authErr} = await sb.auth.signUp({
          email, password: pwd,
          options: {
            data: { role, nom, prenom },
            emailRedirectTo: window.location.origin + '/auth/callback'
          }
        })
        if (authErr) {
          const isRateLimit = authErr.status===429 || (authErr.message||'').toLowerCase().includes('rate limit') || authErr.code==='over_email_send_rate_limit'
          if (isRateLimit) {
            toast('⚠️ Limite d\'emails Supabase atteinte. Réessayez dans 1 heure ou utilisez le mode "Accès immédiat".', 'err')
          } else {
            toast('Erreur Auth : '+authErr.message,'err')
          }
          return
        }
        uid = authData?.user?.id
        if (uid) {
          await sb.from('utilisateurs').upsert({id:uid, email, role, nom, prenom, actif:true},{onConflict:'id'})
        }
        toast(`✅ Compte créé — ${prenom} ${nom} · Email de confirmation envoyé à ${email}`)
      }

      document.getElementById('nuPr').value=''
      document.getElementById('nuNom').value=''
      document.getElementById('nuEm').value=''
      document.getElementById('nuPwd').value=''
      document.getElementById('nuPwd2').value=''
      prmSwitch('users')
    }

