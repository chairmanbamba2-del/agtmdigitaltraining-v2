    async function renderMesSeances() {
      setContent(skeletonTable(6,4))
      const etud = await _getEtudProfil('*')
      if(!etud){setContent('<div style="text-align:center;padding:40px;color:#5A7090">Profil introuvable — contactez l\'administration.</div>');return}
      // Note: inscriptions_classes n'a PAS de colonne statut — ne pas filtrer dessus
      const {data:inscsToUse}=await sb.from('inscriptions_classes')
        .select('classe_id,classes(id,nom,niveau,horaire,formateur_nom)')
        .eq('etudiant_id',etud.id)
      const classeIds=(inscsToUse||[]).map(i=>i.classe_id).filter(Boolean)
      const today=new Date().toISOString().substring(0,10)
      const [{data:seancesAvenir},{data:seancesPassees},{data:presences},{data:mesEvals}]=await Promise.all([
        classeIds.length?sb.from('seances').select('*').in('classe_id',classeIds).gte('date_seance',today).order('date_seance').limit(20):Promise.resolve({data:[]}),
        classeIds.length?sb.from('seances').select('*').in('classe_id',classeIds).lt('date_seance',today).order('date_seance',{ascending:false}).limit(20):Promise.resolve({data:[]}),
        sb.from('presences').select('seance_id,present').eq('etudiant_id',etud.id),
        sb.from('evaluations').select('note,note_max,type_eval,date_eval,commentaire,appreciation').eq('etudiant_id',etud.id).order('date_eval',{ascending:false}),
