    window._corrigerDevoir = async function(id, nom) {
      const note = prompt(`Note pour ${nom} (sur 20) :`)
      if (note === null) return
      const noteVal = parseFloat(note)
      if (isNaN(noteVal)||noteVal<0||noteVal>20) { toast('Note invalide (0-20)','err'); return }
      const commentaire = prompt('Commentaire du formateur (optionnel) :') || null
      const { error } = await sb.from('devoirs').update({
        note: noteVal, statut:'Corrigé', commentaire_formateur: commentaire
      }).eq('id', id)
      if (error) { toast('Erreur : '+error.message,'err'); return }
      toast('✅ Devoir corrigé — Note : '+noteVal+'/20')
      renderPedagogie()
    }

