    window._finTab = 'overview'

    function finTabBar(active) {
      const tabs = [
        {id:'overview',      icon:'📊', label:"Vue d'ensemble"},
        {id:'encaissements', icon:'💰', label:'Encaissements'},
        {id:'depenses',      icon:'💸', label:'Dépenses'},
        {id:'caisse',        icon:'🏦', label:'Journal de caisse'},
        {id:'echeancier',    icon:'📋', label:'Échéancier'},
        {id:'proforma',      icon:'🧾', label:'Factures Proforma'},
        {id:'rapport_pdf',   icon:'📄', label:'Rapport PDF'},
      ]
      return secNavOpen(tabs, active, 'finSwitch', '#4AE090')
    }

    window.finSwitch = function(tab) { if (window._finTab===tab) return; window._finTab=tab; renderFinance() }

    async function renderFinance() {
      setContent(skeletonTable(6,4))
      const tab = window._finTab||'overview'
      if (tab==='overview')      { await _finOverview();      return }
      if (tab==='encaissements') { await _finEncaissements(); return }
      if (tab==='depenses')      { await _finDepenses();      return }
      if (tab==='caisse')        { await _finCaisse();        return }
      if (tab==='echeancier')    { await _finEcheancier();    return }
      if (tab==='proforma')      { await _finProforma();      return }
      // Finance Perso déplacée dans la section dédiée — accessible via nav 🔐 Finance Perso
      if (tab==='rapport_pdf')   { await _finRapportPDF();   return }
    }

