    window._lancerRecherche = async function() {
      const dateMin  = document.getElementById('rchDateMin')?.value  || ''
      const dateMax  = document.getElementById('rchDateMax')?.value  || ''
      const theme    = document.getElementById('rchTheme')?.value.trim()    || ''
      const etudiant = document.getElementById('rchEtudiant')?.value.trim() || ''
      const statut   = document.getElementById('rchStatut')?.value          || ''

      window._rechercheState = { dateMin, dateMax, theme, etudiant, statut }

      const div = document.getElementById('rchResults')
      if (div) div.innerHTML = '<div style="text-align:center;padding:24px;color:#5A7090">⏳ Recherche en cours…</div>'

      // Requête séances
      let q = sb.from('seances')
        .select('id,date_seance,sujet,enseignant,programme,statut,vise_par_direction,visa_par,classe_id,classes(nom),rapports_seances(id,theme,nb_presents,nb_absents_non_justifies,progression)')
        .order('date_seance',{ascending:false})
        .limit(150)

      if (dateMin) q = q.gte('date_seance', dateMin)
      if (dateMax) q = q.lte('date_seance', dateMax)
      if (statut)  q = q.eq('statut', statut)
      if (theme)   q = q.or(`sujet.ilike.%${theme}%,programme.ilike.%${theme}%`)

      const {data:seances, error} = await q

      // Filtrage étudiant côté JS (via présences — pas de colonne directe sur séances)
      let results = seances || []

      if (etudiant) {
        // Chercher les séances où cet étudiant est présent ou dans la classe
        const {data:pEtud} = await sb.from('presences')
          .select('seance_id,etudiants(nom,prenom)')
          .ilike('etudiants.nom', `%${etudiant}%`)
          .limit(500)
        const etudSeanceIds = new Set((pEtud||[]).filter(p=>p.etudiants).map(p=>p.seance_id))
        // Aussi chercher via rapports_seances (formateur_nom) si le thème correspond à étudiant
        results = results.filter(s=> etudSeanceIds.has(s.id) ||
          (s.enseignant||'').toLowerCase().includes(etudiant.toLowerCase())
        )
      }

      // Filtrage thème côté JS aussi sur les rapports liés
      if (theme) {
        results = results.filter(s=>
          (s.sujet||'').toLowerCase().includes(theme.toLowerCase()) ||
          (s.programme||'').toLowerCase().includes(theme.toLowerCase()) ||
          (s.rapports_seances?.theme||'').toLowerCase().includes(theme.toLowerCase())
        )
      }

      if (!results.length) {
        if (div) div.innerHTML = '<div style="text-align:center;padding:36px;color:#5A7090">🔍 Aucun résultat pour ces critères.</div>'
        return
      }

      const statutBadge = s => {
        if (s==='Réalisée')          return bdg('Réalisée','#0A2010','#4AE090')
        if (s==='Annulée')           return bdg('Annulée','#2A0A0A','#E04A4A')
        if (s==='a_valider_direction') return bdg('⏳ Direction','rgba(200,150,12,0.2)','#E8B84B')
        return bdg('Planifiée','rgba(74,144,217,0.15)','#4A90D9')
      }

      const rows = results.map(s=>`
        <tr style="border-top:1px solid #1E3050${s.vise_par_direction?';background:rgba(142,68,173,0.05)':''}">
          <td style="padding:9px 12px;color:#E8B84B;font-size:.78rem;white-space:nowrap">${fmtDate(s.date_seance)}</td>
          <td style="padding:9px 12px">
            <div style="font-size:.82rem;font-weight:600;color:#E2D8C0">${s.sujet||'—'}</div>
            ${s.rapports_seances?.theme?`<div style="font-size:.7rem;color:#C8960C;margin-top:2px">📋 ${s.rapports_seances.theme}</div>`:''}
          </td>
          <td style="padding:9px 12px;font-size:.78rem;color:#8AAAC0">${s.enseignant||'—'}</td>
          <td style="padding:9px 12px;font-size:.78rem;color:#4A90D9">${s.classes?.nom||s.programme||'—'}</td>
          <td style="padding:9px 12px;text-align:center">${statutBadge(s.statut)}</td>
          <td style="padding:9px 12px;text-align:center">
            ${s.rapports_seances ? `<div style="font-size:.7rem;color:#4AE090">✅ ${s.rapports_seances.nb_presents||0} prés.</div><div style="font-size:.7rem;color:#E04A4A">❌ ${s.rapports_seances.nb_absents_non_justifies||0} abs.</div>` : '<span style="color:#5A7090;font-size:.72rem">—</span>'}
          </td>
          <td style="padding:9px 12px;text-align:center">${s.vise_par_direction?`<span style="font-size:.72rem;color:#8E44AD">✅ ${s.visa_par||'Direction'}</span>`:'<span style="color:#5A7090;font-size:.72rem">—</span>'}</td>
        </tr>`).join('')

      if (div) div.innerHTML = `
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <div style="font-size:.85rem;font-weight:700;color:#4A90D9">${results.length} résultat(s) trouvé(s)</div>
          <div style="font-size:.72rem;color:#5A7090">${dateMin} → ${dateMax}</div>
        </div>
        ${wrap(`
          <table style="width:100%;border-collapse:collapse">
            <thead>${th('Date','Sujet / Rapport','Formateur','Classe','Statut','Présences','Visa')}</thead>
            <tbody>${rows}</tbody>
          </table>
        `)}
      `
    }

