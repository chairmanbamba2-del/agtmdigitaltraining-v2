    window._submitEvalOnline = async function() {
      const nom   = document.getElementById('evNom').value.trim()
      const email = document.getElementById('evEmail')?.value.trim()||null
      const ecole = document.getElementById('evEcole')?.value.trim()||null
      const err   = document.getElementById('evErr')
      err.textContent = ''
      if (!nom) { err.textContent = 'Veuillez saisir votre nom.'; return }
      const qs = window._evalQuestions || []
      const reponses = []
      let bonnes = 0
      qs.forEach((q,i)=>{
        const checked = document.querySelector(`input[name=eq${i}]:checked`)
        const textEl  = document.getElementById(`eqa_${i}`)
        const rep = checked ? checked.value : (textEl?.value?.trim()||'')
        const correct = rep.trim().toLowerCase() === (q.reponse_correcte||'').trim().toLowerCase()
        if (correct) bonnes++
        reponses.push({question:q.question, reponse:rep, correcte:q.reponse_correcte, ok:correct, explication:q.explication||''})
      })
      const score = Math.round((bonnes/(qs.length||1))*20*10)/10
      const pct = Math.round(bonnes/(qs.length||1)*100)
      const appr = pct>=90?'Excellent':pct>=75?'Très Bien':pct>=60?'Bien':pct>=50?'Assez Bien':'Insuffisant'
      // Titre stocké en variable globale lors du chargement (plus fiable que la lecture DOM)
      const evalTitre = window._evalTitreCache || document.querySelector('div[style*="font-size:1rem;font-weight:800"]')?.textContent?.trim() || '—'
      // Récupérer l'étudiant lié si l'apprenant est connecté
      const etudiantId = profile?.role==='etudiant' ? (await sb.from('etudiants').select('id').eq('email',currentUser?.email||'').maybeSingle()).data?.id || null : null

      try {
        const [subR, evalR] = await Promise.all([
          sb.from('soumissions_evaluations').insert({
            evaluation_id:    window._evalOnlineId,
            evaluation_titre: evalTitre,
            etudiant_id:      etudiantId,
            etudiant_nom:     nom,
            etudiant_email:   email||null,
            etablissement:    ecole||null,
            score, score_max: 20, nb_questions: qs.length, nb_bonnes: bonnes,
            appreciation: appr, reponses,
            formateur_nom:    window._evalFormateurNom || null,
            formateur_id:     window._evalFormateurId  || null,
          }),
          sb.from('evaluations').insert({
            etudiant_id:  etudiantId,
            etudiant_nom: nom,
            titre:        evalTitre,
            chapitre:     evalTitre,
            type_eval:    'Quiz',
            matiere:      'Anglais',
            note:         score,
            note_max:     20,
            appreciation: appr,
            date_eval:    new Date().toISOString().substring(0,10),
            commentaire:  `Évaluation en ligne — ${evalTitre}`,
          }),
        ])
        if (subR.error)  console.warn('Soumission éval:', subR.error.message)
        if (evalR.error) console.warn('Note éval:', evalR.error.message)
      } catch(dbErr) {
        console.warn('Sauvegarde éval (non bloquant):', dbErr?.message||dbErr)
      }
      const [bg,col,msg] = pct>=70?['#EBF9F1','#1A7A45','Très bon résultat !']:pct>=50?['#FFF8E6','#8A6000','Résultat correct. Continuez vos efforts !']:['#FDEAEA','#8A1A1A','Des bases à renforcer.']
      toast('✅ Évaluation soumise !')
      setContent(`<div style="text-align:center;padding:40px 24px;max-width:540px;margin:0 auto">
        <div style="font-size:3rem;margin-bottom:14px">🏆</div>
        <div style="font-size:1.1rem;font-weight:900;color:#E2D8C0;margin-bottom:14px">Résultats de ${nom}</div>
        <div style="font-size:3rem;font-weight:900;color:#E8B84B;line-height:1">${score} / 20</div>
        <div style="font-size:.9rem;color:#8AAAC0;margin-bottom:12px">${bonnes} bonne(s) réponse(s) sur ${qs.length}</div>
        <div style="background:${bg};color:${col};border-radius:10px;padding:12px 18px;margin-bottom:20px;font-size:.88rem">${msg}</div>
        ${btn('← ' + (profile?.role==='anon' ? 'Accueil AGTM' : 'Retour aux activités'), profile?.role==='anon' ? "location.href='https://africaglobaltraining.com'" : "navigateTo('activites')")}
      </div>`)
    }

