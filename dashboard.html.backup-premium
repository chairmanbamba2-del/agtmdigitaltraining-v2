            </div>`).join('')}
        </div>

        <!-- Filtres par niveau -->
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px">
          <button onclick="_pedaCatFilter('')"
            style="padding:5px 14px;border-radius:8px;font-size:.75rem;font-weight:600;
                   cursor:pointer;border:1px solid #1E3050;
                   background:${!window._pedaCatLvl?'#C8960C':'#152233'};
                   color:${!window._pedaCatLvl?'#0D1B2A':'#90A4AE'}">Tous</button>
          ${lvlOrder.filter(l=>byLevel[l]).map(l=>`
            <button onclick="_pedaCatFilter('${l}')"
              style="padding:5px 14px;border-radius:8px;font-size:.75rem;font-weight:700;
                     cursor:pointer;border:1px solid ${lvlColors[l]}55;
                     background:${window._pedaCatLvl===l?lvlColors[l]:'#152233'};
                     color:${window._pedaCatLvl===l?'#0D1B2A':lvlColors[l]}">${l}</button>`).join('')}
