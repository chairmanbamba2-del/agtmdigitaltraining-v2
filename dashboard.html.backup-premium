    window._aiNewKnowledge = function() {
      const form = document.getElementById('aiKnowledgeForm')
      if (!form) return
      document.getElementById('aiKnowledgeFormTitle').textContent = 'Nouvelle Entrée'
      document.getElementById('knId').value = ''
      document.getElementById('knTitre').value = ''
      document.getElementById('knContenu').value = ''
      document.getElementById('knCat').value = 'pedagogie'
      document.getElementById('knNiveau').value = ''
      document.getElementById('knPriorite').value = '5'
      document.getElementById('knActif').checked = true
      form.style.display = 'block'
      form.scrollIntoView({ behavior:'smooth' })
    }

    window._aiEditKnowledge = async function(id) {
      const {data, error} = await sb.from('ai_knowledge').select('*').eq('id', id).single()
      if (error || !data) { toast('❌ Entrée introuvable', 'err'); return }
      const form = document.getElementById('aiKnowledgeForm')
      if (!form) return
      document.getElementById('aiKnowledgeFormTitle').textContent = 'Modifier l\'Entrée'
      document.getElementById('knId').value = data.id
      document.getElementById('knTitre').value = data.titre || ''
      document.getElementById('knContenu').value = data.contenu || ''
      document.getElementById('knCat').value = data.categorie || 'pedagogie'
      document.getElementById('knNiveau').value = data.niveau || ''
      document.getElementById('knPriorite').value = data.priorite || 5
      document.getElementById('knActif').checked = data.actif !== false
      form.style.display = 'block'
      form.scrollIntoView({ behavior:'smooth' })
    }

    window._aiToggleKnowledge = async function(id, newActif) {
      const {error} = await sb.from('ai_knowledge').update({ actif: newActif }).eq('id', id)
      if (error) { toast('❌ ' + error.message, 'err'); return }
      toast(newActif ? '✅ Entrée activée' : '⏸ Entrée désactivée', 'ok')
      await _aiAdminKnowledge()
    }

    window._aiSaveKnowledge = async function() {
      const id      = document.getElementById('knId')?.value
      const titre   = document.getElementById('knTitre')?.value?.trim()
      const contenu = document.getElementById('knContenu')?.value?.trim()
      const cat     = document.getElementById('knCat')?.value
      const niveau  = document.getElementById('knNiveau')?.value || null
      const prior   = parseInt(document.getElementById('knPriorite')?.value || '5', 10)
      const actif   = document.getElementById('knActif')?.checked !== false

      if (!titre || !contenu) { toast('⚠️ Titre et contenu requis', 'err'); return }

      const payload = { titre, contenu, categorie: cat, niveau, priorite: prior, actif, updated_at: new Date().toISOString() }

      let error
      if (id) {
        ({ error } = await sb.from('ai_knowledge').update(payload).eq('id', id))
      } else {
        ({ error } = await sb.from('ai_knowledge').insert(payload))
      }

      if (error) { toast('❌ ' + error.message, 'err'); return }
      toast('✅ Entrée sauvegardée', 'ok')
      document.getElementById('aiKnowledgeForm').style.display = 'none'
      await _aiAdminKnowledge()
    }

