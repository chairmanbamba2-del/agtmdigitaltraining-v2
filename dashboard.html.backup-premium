              expediteur_nom: senderNom,
              expediteur_role: profile?.role || 'etudiant',
              destinataire_user_id: t.id,
              destinataire_nom: [t.prenom, t.nom].filter(Boolean).join(' '),
              destinataire_role: t.role,
              sujet: msgSujet,
              contenu: msgContenu,
              lu: false,
            })
          }
        }
      } catch (e) {
        console.warn('⚠️ Notification devoir échouée :', e)
      }
    }

    // ════════════════════════════════════════════════════════════
    //  VÉRIFICATION QUOTA SÉANCES — Alerte automatique
    //  Appelée après chaque enregistrement de présence
    // ════════════════════════════════════════════════════════════
    window._checkQuotaAlert = async function(etudiantId) {
      try {
        const {data:etud} = await sb.from('etudiants')
          .select('id,nom,prenom,quota_seances,frequence_semaine')
          .eq('id', etudiantId).maybeSingle()
        if (!etud?.quota_seances) return

        const {count:nbPresents} = await sb.from('presences')
          .select('id',{count:'exact',head:true})
          .eq('etudiant_id', etudiantId).eq('present', 1)

        if (!nbPresents) return

        const quota = etud.quota_seances
        const pct   = Math.round(nbPresents / quota * 100)
        const nom   = `${etud.prenom} ${etud.nom}`.trim()

        // Seuils d'alerte : 75%, 90%, et 100%
        const shouldAlert75  = nbPresents === Math.floor(quota * 0.75)
        const shouldAlert90  = nbPresents === Math.floor(quota * 0.90)
        const shouldAlert100 = nbPresents >= quota

        if (!shouldAlert75 && !shouldAlert90 && !shouldAlert100) return

        let niveau = shouldAlert100 ? '🏆 QUOTA ATTEINT' : shouldAlert90 ? '⚠️ Quota bientôt atteint (90%)' : '📊 Avancement quota (75%)'
        let msgEtud, msgAdmin

        if (shouldAlert100) {
          msgEtud  = `🏆 Félicitations ${etud.prenom} !\n\nVous avez réalisé toutes vos ${quota} séances prévues dans votre contrat de formation AGTM.\n\n👉 Contactez l'administration pour renouveler votre inscription.\n\n— AGTM Digital Academy`
          msgAdmin = `🏆 QUOTA ATTEINT — ${nom}\n\nL'étudiant(e) a réalisé ${nbPresents}/${quota} séances (100%).\n\nAction requise : renouveler le contrat ou ajuster le quota.\n\n— Système AGTM`
        } else if (shouldAlert90) {
          msgEtud  = `⚠️ Bonjour ${etud.prenom},\n\nVous avez réalisé ${nbPresents}/${quota} séances (${pct}%).\nIl vous reste seulement ${quota - nbPresents} séance(s) dans votre contrat.\n\n👉 Pensez à renouveler votre inscription prochainement.\n\n— AGTM Digital Academy`
          msgAdmin = `⚠️ QUOTA À 90% — ${nom}\n\nL'étudiant(e) a réalisé ${nbPresents}/${quota} séances.\nIl reste ${quota - nbPresents} séance(s).\n\n— Système AGTM`
        } else {
          msgEtud  = `📊 Bonjour ${etud.prenom},\n\nVous avez réalisé ${nbPresents}/${quota} séances (${pct}%).\nVous êtes à mi-chemin de votre programme !\n\nContinuez sur cette lancée.\n— AGTM Digital Academy`
          msgAdmin = `📊 QUOTA À 75% — ${nom}\n\nL'étudiant(e) a réalisé ${nbPresents}/${quota} séances.\n\n— Système AGTM`
        }

        const senderNom = 'Système AGTM'

        // Notifier l'étudiant
        await sb.from('messages_etudiants').insert({
          etudiant_id: etudiantId,
          expediteur_nom: senderNom, expediteur_role: 'admin',
          sujet: niveau + ` — ${nom}`,
          contenu: msgEtud, lu: false,
        })

        // Notifier l'admin (tous les utilisateurs admin)
        const {data:admins} = await sb.from('utilisateurs').select('id').eq('role','admin')
        for (const a of (admins||[])) {
          await sb.from('messages').insert({
            expediteur_user_id: null, expediteur_nom: senderNom, expediteur_role: 'system',
            destinataire_user_id: a.id, destinataire_nom: 'Administrateur', destinataire_role: 'admin',
            sujet: niveau + ` — ${nom}`,
            contenu: msgAdmin, lu: false,
          })
        }

        if (shouldAlert100) toast(`🏆 Quota atteint pour ${nom} — notifications envoyées`)
        else if (shouldAlert90) toast(`⚠️ Quota à 90% pour ${nom}`)

      } catch(e) {
        console.warn('⚠️ checkQuotaAlert:', e)
      }
    }

