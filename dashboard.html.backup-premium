                          <button onclick="_toggleAll('${r.id}',false)" style="padding:2px 7px;border-radius:4px;font-size:.58rem;cursor:pointer;background:#2A1A1A;border:1px solid #E04A4A;color:#E04A4A;font-weight:700">Tout ✗</button>
                        </div>
                      </th>`).join('')}
                  </tr>
                </thead>
                <tbody>
                  ${allMods.map((mod,i)=>`
                    <tr style="border-top:1px solid #1E3050;background:${i%2===0?'transparent':'rgba(255,255,255,.02)'}">
                      <td style="padding:9px 16px;font-size:.78rem;color:#E2D8C0;font-weight:600;white-space:nowrap;position:sticky;left:0;background:${i%2===0?'#152233':'#162535'};z-index:1">${mod.icon} ${mod.label}</td>
                      <td style="padding:9px 12px;text-align:center">
                        <span style="color:#C8960C;font-size:1rem" title="Admin : accès universel">★</span>
                      </td>
                      ${editableRoles.map(r=>{
                        const checked = effectivePerms[r.id]?.includes(mod.id)
                        return `<td style="padding:9px 12px;text-align:center">
                          <label style="cursor:pointer;display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:7px;border:1.5px solid ${checked?'#4AE090':'#2A3F58'};background:${checked?'rgba(74,224,144,.15)':'transparent'};transition:all .15s">
                            <input type="checkbox" data-role="${r.id}" data-mod="${mod.id}" ${checked?'checked':''}
                              onchange="_onPermChange(this)"
                              style="width:14px;height:14px;accent-color:#4AE090;cursor:pointer"/>
                          </label>
                        </td>`
                      }).join('')}
                    </tr>`).join('')}
                </tbody>
              </table>
            </div>
          </div>

          <div style="background:#0D1B2A;border:1px solid #1E3050;border-radius:10px;padding:12px 18px;font-size:.73rem;color:#5A7090">
            💡 Les modifications sont appliquées immédiatement après enregistrement et prennent effet à la prochaine connexion des utilisateurs concernés.
            Les rôles personnalisés sont créés dans <strong style="color:#4A90D9">Paramètres → Rôles & Accès</strong>.
          </div>
        `)
        return
      }

      // ── TAB UTILISATEURS ───────────────────────────────────────
      setContent(`
        ${tabBar}

        <!-- KPIs -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px">
          ${kpi('👥','Utilisateurs total',nbTotal,'#4A90D9')}
          ${kpi('✅','Comptes actifs',nbActifs,'#4AE090')}
          ${kpi('🚫','Comptes suspendus',nbSusp,'#E04A4A')}
