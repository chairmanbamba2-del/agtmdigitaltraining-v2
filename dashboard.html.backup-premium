    async function renderMesMessages() {
      setContent(skeletonTable(6,4))
      try {
        const etud = await _getEtudProfil('id,nom,prenom')
        if (!etud) {
          setContent(`<div style="text-align:center;padding:40px;color:#5A7090">
            <div style="font-size:1.5rem;margin-bottom:8px">💬</div>
            <div style="font-weight:700;margin-bottom:6px">Profil étudiant non lié</div>
            <div style="font-size:.78rem">Contactez l'administration pour associer votre compte.</div>
            <div style="font-size:.7rem;color:#3A5070;margin-top:8px">Email : ${currentUser?.email||'—'}</div>
          </div>`)
          return
        }

        const tab      = window._etudMsgTab || 'recus'
        const uid      = currentUser?.id
        const etudId   = etud.id
        const nomEtud  = [etud.prenom, etud.nom].filter(Boolean).join(' ') || ''
        const emailEtud = currentUser?.email || ''

        // ─── Données ────────────────────────────────────────────
        const [r1, r2, r3] = await Promise.all([
          // Reçus ancienne table (admin/formateur → étudiant par etudiant_id)
          sb.from('messages_etudiants').select('*').eq('etudiant_id', etudId).order('created_at', {ascending:false}),
          // Envoyés (étudiant → admin/formateur)
          sb.from('messages_envois_etudiant').select('*').eq('etudiant_id', etudId).order('created_at', {ascending:false}),
          // Reçus nouvelle table (admin → étudiant par user_id UUID)
          uid
            ? sb.from('messages').select('*').eq('destinataire_user_id', uid).order('created_at', {ascending:false})
            : Promise.resolve({ data: [] })
        ])

        const recusOld  = r1.data || []
        const envoyes   = r2.data || []
        const recusNew  = r3.data || []

        // Fusionner les reçus triés par date, en marquant la table source
        const recusTous = [
          ...recusNew.map(m => ({...m, _src: 'messages'})),
          ...recusOld.map(m => ({...m, _src: 'messages_etudiants'}))
        ].sort((a,b) => new Date(b.created_at) - new Date(a.created_at))

        // Marquer comme lus
        const nonLusOld = recusOld.filter(m => !m.lu).length
        const nonLusNew = recusNew.filter(m => !m.lu).length
        const totalNonLus = nonLusOld + nonLusNew
        if (nonLusOld > 0)
          sb.from('messages_etudiants').update({lu:true}).eq('etudiant_id', etudId).eq('lu',false).then(()=>{})
        if (nonLusNew > 0 && uid)
          sb.from('messages').update({lu:true}).eq('destinataire_user_id', uid).eq('lu',false).then(()=>{})

        // ─── Style onglets ───────────────────────────────────────
        const tabStyle = (t) => `padding:8px 18px;border-radius:8px 8px 0 0;border:1px solid;cursor:pointer;font-weight:700;font-size:.78rem;transition:all .15s;${tab===t?'background:#C8960C;border-color:#C8960C;color:#0D1B2A':'background:#0D1B2A;border-color:#2A3F58;color:#90A4AE'}`

        // ─── Onglet Reçus ────────────────────────────────────────
        let recusHTML = ''
        if (tab === 'recus') {
          const cards = recusTous.map(m => {
            const isNew   = !m.lu
            const dateStr = _msgDateStr(m.created_at)
