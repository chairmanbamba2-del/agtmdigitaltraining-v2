    // ── Envoyer un message depuis l'admin ou formateur ────────────
    window._submitMsgAdmin = async function() {
      const uid    = currentUser?.id
      const uNom   = [profile?.prenom, profile?.nom].filter(Boolean).join(' ') || currentUser?.email || 'Admin'
      const uRole  = profile?.role
      // Collect all checked recipients
      const checkedCbs = [...document.querySelectorAll('.dest-cb:checked')]
      const sujet   = document.getElementById('msgaSujet')?.value.trim()
      const contenu = document.getElementById('msgaContenu')?.value.trim()
      const file    = document.getElementById('msgaFichier')?.files?.[0] || null
      const st      = document.getElementById('msgaStatus')
      if (!checkedCbs.length) { if(st) st.innerHTML='<span style="color:#E04A4A">⚠️ Sélectionnez au moins un destinataire.</span>'; return }
      if (!sujet || !contenu) { if(st) st.innerHTML='<span style="color:#E04A4A">⚠️ Sujet et message requis.</span>'; return }
      if(st) st.innerHTML='<span style="color:#5A7090">⏳ Envoi en cours…</span>'
      let fichierUrl = null, fichierNom = null
      try {
        const up = await _uploadFichier(file, 'messages', st)
        if (up.url) { fichierUrl = up.url; fichierNom = up.nom }
      } catch(e) { if(st) st.innerHTML=`<span style="color:#E04A4A">⚠️ ${e.message}</span>`; return }

      let sent = 0, errors = 0
      for (const cb of checkedCbs) {
        const parts = cb.value.split('||')
        const destRole = parts[0]
        const destRef  = parts[1]
        const destNom  = parts[2] || '—'
        try {
          if (destRole === 'etudiant' && !destRef.includes('-')) {
            const { error } = await sb.from('messages_etudiants').insert({
              etudiant_id: Number(destRef), expediteur_role: uRole, expediteur_nom: uNom,
              sujet, contenu, fichier_url: fichierUrl, fichier_nom: fichierNom, lu: false
            })
            if (error) errors++; else sent++
          } else {
            const destUserId = (destRole === 'administration') ? null : destRef
            const { error } = await sb.from('messages').insert({
              expediteur_user_id: uid, expediteur_nom: uNom, expediteur_role: uRole,
              destinataire_user_id: destUserId || null,
              destinataire_nom: destNom, destinataire_role: destRole,
              sujet, contenu, fichier_url: fichierUrl, fichier_nom: fichierNom, lu: false
            })
            if (error) errors++; else sent++
          }
        } catch(e) { errors++ }
      }
      if (errors > 0) {
        if(st) st.innerHTML=`<span style="color:#E8B84B">⚠️ ${sent} envoyé(s), ${errors} erreur(s).</span>`
      } else {
        toast(`✅ Message envoyé à ${sent} destinataire(s) !`)
        window._msgTab = 'envoyes'
        renderMessagerie()
      }
    }

