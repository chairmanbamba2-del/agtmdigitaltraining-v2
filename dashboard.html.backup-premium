    }

    // ── RENDU CONTENU RICHE (depuis pedagogy-content.js) ──────────
    function _apRenderRich(sections) {
      if (!sections || !sections.length) return ''
      const colMap = { rule:'#4A90D9', table:'#C8960C', examples:'#4AE090', tips:'#E8B84B', errors:'#E05050', vocab:'#9B59B6', text:'#8AAAC0' }
      return sections.map(s => {
        const col = colMap[s.type] || '#8AAAC0'
        return `<div style="background:rgba(13,27,42,0.55);border:1px solid ${col}28;border-radius:11px;padding:16px 18px;margin-bottom:14px">
          <div style="font-size:.68rem;color:${col};font-weight:800;letter-spacing:.07em;margin-bottom:12px;text-transform:uppercase">${s.titre}</div>
          ${s.html}
        </div>`
      }).join('')
    }

    // ── MODALE PLEIN ÉCRAN — FOCUS MODE ───────────────────────────
    window._apOpenModModal = function(id) {
      const m = _getActiveMods().find(x=>x.id===id)
      if (!m) return
      window._apCurMod = m
      const col = _NBL[m.niveau] || '#4A90D9'
      const fmtTitre = _fmtTitle(m.titre, m.categorie_code || m.categorie)

      // Supprimer ancienne modale si elle existe
      const old = document.getElementById('_modFocusOverlay')
      if (old) old.remove()

      // Lecteur vidéo — regex étendu (watch, shorts, youtu.be, embed)
      let videoHtml = ''
      if (m.video_url) {
        const url = m.video_url.trim()
        const ytId = (url.match(/(?:youtube\.com\/(?:watch\?(?:.*&)?v=|embed\/|shorts\/|v\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/) || [])[1]
        const viId = (url.match(/vimeo\.com\/(?:video\/)?(\d+)/) || [])[1]
        if (ytId) {
          videoHtml = `<div style="margin-bottom:18px">
            <div style="font-size:.68rem;color:#4A90D9;font-weight:700;margin-bottom:6px">▶ Vidéo du cours</div>
            <div style="width:100%;aspect-ratio:16/9;max-height:260px;border-radius:10px;overflow:hidden;border:1px solid rgba(200,150,12,0.25);background:#000">
              <iframe src="https://www.youtube.com/embed/${ytId}?rel=0&modestbranding=1" frameborder="0"
                allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"
                allowfullscreen style="width:100%;height:100%;border:none"></iframe>
            </div>
          </div>`
        } else if (viId) {
          videoHtml = `<div style="margin-bottom:18px">
            <div style="font-size:.68rem;color:#4A90D9;font-weight:700;margin-bottom:6px">▶ Vidéo du cours</div>
            <div style="width:100%;aspect-ratio:16/9;max-height:260px;border-radius:10px;overflow:hidden;border:1px solid rgba(200,150,12,0.25);background:#000">
              <iframe src="https://player.vimeo.com/video/${viId}" frameborder="0" allowfullscreen
                style="width:100%;height:100%;border:none"></iframe>
            </div>
          </div>`
        } else {
          videoHtml = `<div style="margin-bottom:18px">
            <div style="font-size:.68rem;color:#4A90D9;font-weight:700;margin-bottom:6px">▶ Vidéo du cours</div>
            <video src="${url}" controls style="width:100%;max-height:260px;border-radius:10px;border:1px solid rgba(200,150,12,0.25)"></video>
          </div>`
        }
      }

      // Contenu riche (pedagogy-content.js) ou fallback description/plan
      const _richSecs = (window._AP_LESSON_CONTENT || {})[m.id]
      let introHtml = '', planHtml = ''
      if (_richSecs && _richSecs.length) {
        introHtml = _apRenderRich(_richSecs)
      } else {
        const introText = m.contenu?.length ? m.contenu[0].texte : null
        introHtml = introText
          ? `<div style="border-left:4px solid #C8960C;background:rgba(200,150,12,0.06);border-radius:0 10px 10px 0;padding:14px 18px;margin-bottom:20px;font-size:.9rem;color:#D4C8A0;line-height:1.75">${introText}</div>`
          : `<div style="background:rgba(200,150,12,0.05);border:1px dashed rgba(200,150,12,0.2);border-radius:10px;padding:14px 18px;margin-bottom:20px;font-size:.82rem;color:#5A7080;font-style:italic">
              Contenu détaillé en cours de préparation — les objectifs ci-dessous résument ce module.
            </div>`
        planHtml = m.objectifs?.length ? `<div style="background:rgba(13,27,42,0.6);border:1px solid rgba(200,150,12,0.18);border-radius:11px;padding:16px 18px;margin-bottom:20px">
          <div style="font-size:.7rem;color:#C8960C;font-weight:800;letter-spacing:.06em;margin-bottom:14px;text-transform:uppercase">📋 Plan de la leçon</div>
          ${m.objectifs.map((o,i)=>`<div style="display:flex;align-items:flex-start;gap:11px;margin-bottom:9px;padding:9px 13px;background:rgba(200,150,12,0.06);border-radius:8px;border:1px solid rgba(200,150,12,0.1)">
            <span style="min-width:23px;height:23px;border-radius:50%;background:#C8960C;color:#0D1B2A;display:inline-flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:900;flex-shrink:0;margin-top:1px">${i+1}</span>
            <span style="font-size:.86rem;color:#D4C8A0;line-height:1.55">${o}</span>
          </div>`).join('')}
        </div>` : ''
      }

      // Zone exercices (chargement async après DOM)
      const exercicesHtml = `<div id="_modQuizPreview" style="background:rgba(13,27,42,0.4);border:1px dashed rgba(200,150,12,0.18);border-radius:11px;padding:18px;text-align:center;color:#4A6070;font-size:.82rem">
        ${m._hasQuiz
          ? `<span style="color:#5A7090;font-size:.8rem">⏳ Chargement des exercices d'entraînement…</span>`
          : `<span style="color:#3A5060;font-size:.8rem">Aucun exercice disponible pour ce module.</span>`}
      </div>`

      // Modale HTML
      const overlay = document.createElement('div')
      overlay.id = '_modFocusOverlay'
      overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.92);z-index:99990;display:flex;align-items:flex-start;justify-content:center;overflow-y:auto;padding:24px 16px'
      overlay.onclick = e => { if (e.target === overlay) overlay.remove() }

      overlay.innerHTML = `<div style="background:linear-gradient(160deg,#0B1928 0%,#161008 100%);border:1px solid rgba(200,150,12,0.35);border-radius:16px;max-width:880px;width:100%;overflow:hidden;position:relative;box-shadow:0 24px 80px rgba(0,0,0,0.7);margin:auto">
        <div style="height:4px;background:linear-gradient(90deg,${col},#C8960C,${col}88)"></div>
        <div style="background:linear-gradient(90deg,rgba(13,27,42,0.95),rgba(22,16,8,0.95));padding:18px 22px;display:flex;align-items:flex-start;gap:14px;border-bottom:1px solid rgba(200,150,12,0.15)">
          <div style="flex:1">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap">
              <span style="padding:3px 11px;border-radius:12px;font-size:.7rem;font-weight:800;background:${col}25;color:${col};border:1px solid ${col}55">${m.niveau}</span>
              <span style="font-size:.7rem;color:#6A8AAA">⏱ ${m.duree} min</span>
              ${m.categorie?`<span style="font-size:.68rem;color:#5A7090">${m.categorie_icon||''} ${m.categorie}</span>`:''}
              ${m._hasQuiz?`<span style="font-size:.68rem;color:#C8960C;font-weight:700">🧩 Quiz disponible</span>`:''}
              ${m.video_url?`<span style="font-size:.68rem;color:#4A90D9;font-weight:700">▶ Vidéo</span>`:''}
            </div>
            <h2 style="font-size:1.2rem;font-weight:900;color:#E8D4A0;margin:0;line-height:1.4;letter-spacing:.01em">${fmtTitre}</h2>
          </div>
          <button onclick="document.getElementById('_modFocusOverlay').remove()"
            style="padding:6px 10px;border-radius:8px;border:1px solid rgba(200,150,12,0.3);background:transparent;color:#8AAAC0;cursor:pointer;font-size:1.1rem;flex-shrink:0;line-height:1;transition:all .15s"
            onmouseover="this.style.background='rgba(200,150,12,0.15)';this.style.color='#E8B84B'"
            onmouseout="this.style.background='transparent';this.style.color='#8AAAC0'">✕</button>
        </div>
        <div style="padding:22px 24px">
          ${videoHtml}
          ${introHtml}
          ${planHtml}
          ${exercicesHtml}
        </div>
        <div style="background:rgba(5,12,22,0.8);border-top:1px solid rgba(200,150,12,0.15);padding:14px 22px;display:flex;gap:10px;flex-wrap:wrap;align-items:center">
          ${m._hasQuiz ? `<button onclick="document.getElementById('_modFocusOverlay').remove();window._apOpenMod('${m.id}','quiz')"
            style="padding:9px 22px;border-radius:9px;border:none;cursor:pointer;font-size:.85rem;font-weight:800;background:#C8960C;color:#0D1B2A;letter-spacing:.02em">
            🧩 Lancer le Quiz complet</button>` : ''}
          <button onclick="document.getElementById('_modFocusOverlay').remove();window._apOpenMod('${m.id}','eval')"
            style="padding:9px 22px;border-radius:9px;cursor:pointer;font-size:.85rem;font-weight:700;background:rgba(74,224,144,0.12);border:1px solid rgba(74,224,144,0.4);color:#4AE090">
            🧪 Faire l'Évaluation</button>
          <button onclick="document.getElementById('_modFocusOverlay').remove()"
            style="padding:9px 18px;border-radius:9px;cursor:pointer;font-size:.82rem;background:transparent;border:1px solid #2A3F58;color:#6A8AAA;margin-left:auto">
            ← Retour au catalogue</button>
        </div>
      </div>`
      document.body.appendChild(overlay)

      // Charger les exercices en arrière-plan (quiz comme preview)
      if (m._hasQuiz) {
        fetch('/api/pedagogy/quiz/' + encodeURIComponent(m.id))
          .then(r => r.json())
          .then(data => {
            const qs = data.questions || []
            const el = document.getElementById('_modQuizPreview')
            if (!el) return
            if (!qs.length) {
              el.innerHTML = '<span style="color:#3A5060;font-size:.8rem">Exercices non disponibles.</span>'
              return
            }
            el.style.cssText = 'background:rgba(13,27,42,0.5);border:1px solid rgba(200,150,12,0.15);border-radius:11px;padding:0;overflow:hidden'
            el.innerHTML = `<div style="background:rgba(200,150,12,0.1);padding:11px 18px;border-bottom:1px solid rgba(200,150,12,0.15)">
                <span style="font-size:.7rem;color:#C8960C;font-weight:800;letter-spacing:.06em;text-transform:uppercase">✏️ Exercices d'entraînement — ${qs.length} question(s)</span>
              </div>
              <div style="padding:14px 18px;display:flex;flex-direction:column;gap:12px">
                ${qs.slice(0,4).map((q,qi)=>`<div style="background:rgba(5,14,28,0.6);border:1px solid rgba(255,255,255,0.06);border-radius:9px;padding:12px 15px">
                  <div style="font-size:.84rem;font-weight:600;color:#E0D0A0;margin-bottom:9px;line-height:1.5">Q${qi+1}. ${q.question_text}</div>
                  <div style="display:flex;flex-direction:column;gap:5px">
                    ${(q.options||[]).map((o,oi)=>`<div style="font-size:.78rem;color:#8AA0B4;padding:5px 10px;border-radius:6px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.05)">
                      <span style="color:#5A8098;font-weight:700;margin-right:4px">${String.fromCharCode(65+oi)})</span>${o.text}
                    </div>`).join('')}
                  </div>
                </div>`).join('')}
                ${qs.length>4?`<div style="font-size:.72rem;color:#4A6070;text-align:center;padding:4px">
                  + ${qs.length-4} question(s) supplémentaire(s) — cliquez "Lancer le Quiz" pour tout voir
                </div>`:''}
              </div>`
          })
          .catch(() => {
            const el = document.getElementById('_modQuizPreview')
            if (el) el.innerHTML = '<span style="color:#3A5060;font-size:.8rem;padding:10px;display:block;text-align:center">Exercices non disponibles.</span>'
          })
      }

      // Fermer avec Échap
      const escHandler = e => { if (e.key==='Escape') { overlay.remove(); document.removeEventListener('keydown', escHandler) } }
      document.addEventListener('keydown', escHandler)
    }

    window._apGenEvalLink = async function(modId, modTitre, niveau) {
      toast('Création du lien…')
      // Vérifier si une évaluation existe déjà pour ce module
      const {data:existing} = await sb.from('evaluations').select('id').eq('module_id',modId).eq('type','QCM').maybeSingle()
      let evalId = existing?.id
      if (!evalId) {
        const {data:newEval,error} = await sb.from('evaluations').insert({
          titre:        'Évaluation — ' + modTitre,
          chapitre:     modTitre,
          type:         'QCM',
          type_eval:    'Quiz',
          matiere:      'Anglais',
          module_id:    modId,
          niveau:       niveau || 'B1',
          categorie:    _getModCat(modId),
          note_max:     20,
          date_eval:    new Date().toISOString().substring(0,10),
          instructions: 'Évaluation en ligne du module : ' + modTitre,
        }).select('id').single()
        if (error || !newEval) { toast('Erreur : '+(error?.message||'Impossible de créer l\'évaluation'),'err'); return }
        evalId = newEval.id
      }
      const link = window.location.origin + '/eval/' + evalId
      window._copyLink(link, 'Lien évaluation copié ! ID : '+evalId)
      // Afficher dans une overlay
      const old=document.getElementById('_evalLinkOverlay'); if(old) old.remove()
      const box=document.createElement('div')
      box.id='_evalLinkOverlay'
      box.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);z-index:99990;display:flex;align-items:center;justify-content:center'
      box.innerHTML=`<div style="background:#0D1B2A;border:2px solid rgba(200,150,12,.5);border-radius:14px;padding:28px;max-width:560px;width:90%">
        <div style="font-size:1rem;font-weight:700;color:#E8B84B;margin-bottom:14px">🔗 Lien d'évaluation — ${modTitre}</div>
        <div style="background:#152233;border:1px solid #1E3050;border-radius:8px;padding:12px 16px;margin-bottom:16px;word-break:break-all;font-size:.78rem;color:#4AE090;font-family:monospace">${link}</div>
        <div style="font-size:.75rem;color:#6A8AAA;margin-bottom:16px">Les apprenants accèdent directement à l'évaluation via ce lien — <strong style="color:#4AE090">sans connexion requise</strong>. ID Éval : <strong style="color:#C8960C">${evalId}</strong></div>
        <div style="display:flex;gap:10px;justify-content:flex-end">
          <button onclick="window._copyLink('${link.replace(/'/g,"\\'")}','Lien copié !')" style="padding:9px 20px;border-radius:8px;background:#C8960C;border:none;color:#0D1B2A;font-weight:700;cursor:pointer">📋 Copier</button>
          <button onclick="document.getElementById('_evalLinkOverlay').remove()" style="padding:9px 20px;border-radius:8px;background:transparent;border:1px solid #2A3F58;color:#8AAAC0;cursor:pointer">Fermer</button>
        </div>
      </div>`
      document.body.appendChild(box)
    }

    window._apOpenMod = function(id, tab) {
      const m = _getActiveMods().find(x=>x.id===id)
      if(!m) return
      window._apCurMod = m
      window._apModTab = tab || 'cours'
      window._apQS = null
      window._apES = null
      _apModView()
    }

    // ── MODULE VIEWER ─────────────────────────────────────────────
    function _apModView() {
      const m = window._apCurMod
      const col = _NBL[m.niveau]||'#4A90D9'
      const isAdmin = profile?.role === 'admin'
      const mt = window._apModTab

      const hdr = `<div style="background:linear-gradient(90deg,#0E1E34 0%,#1A1408 100%);border-radius:11px;padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
        <button onclick="_apRender()" style="padding:6px 14px;border-radius:7px;border:1px solid #2A3F58;background:transparent;color:#8AAAC0;cursor:pointer;font-size:.78rem">← Catalogue</button>
        <span style="padding:2px 11px;border-radius:12px;font-size:.72rem;font-weight:800;background:${col}25;color:${col};border:1px solid ${col}50">${m.niveau}</span>
        <span style="font-weight:700;font-size:.95rem;color:#E8B84B;flex:1">${m.titre}</span>
        <span style="font-size:.72rem;color:#6A8AAA">⏱ ${m.duree} min</span>
        ${isAdmin?`<button onclick="window._apPDF('${m.id}')" style="padding:6px 16px;border-radius:7px;border:1px solid #C8960C;background:transparent;color:#C8960C;cursor:pointer;font-size:.78rem;font-weight:700">⬇ PDF</button>`:''}
      </div>`

      const modTabs = `<div style="display:flex;gap:4px;margin-bottom:16px;border-bottom:1px solid rgba(200,150,12,0.15);padding-bottom:0">
        <button onclick="window._apSetModTab('cours')" style="padding:8px 20px;border-radius:7px 7px 0 0;border:none;cursor:pointer;font-size:.82rem;font-weight:700;background:${mt==='cours'?col+'30':'transparent'};color:${mt==='cours'?col:'#90A4AE'};border-bottom:${mt==='cours'?'2px solid '+col:'2px solid transparent'}">📘 Cours</button>
        <button onclick="window._apSetModTab('quiz')" style="padding:8px 20px;border-radius:7px 7px 0 0;border:none;cursor:pointer;font-size:.82rem;font-weight:700;background:${mt==='quiz'?'rgba(200,150,12,0.2)':'transparent'};color:${mt==='quiz'?'#E8B84B':'#90A4AE'};border-bottom:${mt==='quiz'?'2px solid #C8960C':'2px solid transparent'}">🧩 Quiz${m._isDbMod ? (m._hasQuiz ? (window._apQS?.loaded&&window._apQS.questions.length?' ('+window._apQS.questions.length+' q.)':' ✓') : ' —') : ' ('+(m.quiz||[]).length+' q.)'}</button>
        <button onclick="window._apSetModTab('eval')" style="padding:8px 20px;border-radius:7px 7px 0 0;border:none;cursor:pointer;font-size:.82rem;font-weight:700;background:${mt==='eval'?'rgba(74,224,144,0.15)':'transparent'};color:${mt==='eval'?'#4AE090':'#90A4AE'};border-bottom:${mt==='eval'?'2px solid #4AE090':'2px solid transparent'}">🧪 Évaluation</button>
      </div>`

      if (mt === 'eval') {
        setContent(hdr + modTabs + '<div style="text-align:center;padding:40px;color:#5A7090">⏳ Chargement…</div>')
        _apModEvalStart(m)
        return
      }
      // Pour les modules DB, charger le quiz depuis l'API si besoin
      if (mt === 'quiz' && m._isDbMod && !window._apQS?.loaded) {
        // Si on sait déjà qu'il n'y a pas de quiz, inutile de requêter l'API
        if (m._hasQuiz === false) {
          window._apQS = { modId: m.id, questions: [], current: 0, score: 0, answered: false, errors: [], loaded: true, noQuiz: true }
          setContent(hdr + modTabs + _apQuizPanel(m))
          return
        }
        setContent(hdr + modTabs + '<div style="text-align:center;padding:40px;color:#5A7090">⏳ Chargement du quiz…</div>')
        fetch('/api/pedagogy/quiz/' + encodeURIComponent(m.id))
          .then(r => r.json())
          .then(data => {
            const qs = (data.questions || []).map(q => ({
              q:    q.question_text,
              opts: (q.options || []).map((o,i) => String.fromCharCode(65+i) + ') ' + o.text),
              rep:  (()=>{ const ci=(q.options||[]).findIndex(o=>!!o.is_correct); return ci>=0?String.fromCharCode(65+ci):'A'; })(),
              expl: q.explanation || '',
            }))
            window._apQS = { modId: m.id, questions: qs, current: 0, score: 0, answered: false, errors: [], loaded: true }
            _apModView()
          })
          .catch(() => {
            window._apQS = { modId: m.id, questions: [], current: 0, score: 0, answered: false, errors: [], loaded: true, noQuiz: true }
            _apModView()
          })
        return
      }
      const body = mt==='cours' ? _apCoursContent(m) : _apQuizPanel(m)
