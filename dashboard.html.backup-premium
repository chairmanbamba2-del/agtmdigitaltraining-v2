    window._saveInscriptionWeb = async function(id) {
      const prenom = document.getElementById('inscE_prenom')?.value.trim()
      const nom    = document.getElementById('inscE_nom')?.value.trim()
      if (!prenom || !nom) { toast('Prénom et Nom obligatoires', 'err'); return }
      const {error} = await sb.from('inscriptions_web').update({
        prenom, nom,
        telephone:  document.getElementById('inscE_tel')?.value.trim()   || null,
        email:      document.getElementById('inscE_email')?.value.trim() || null,
