    window._apPrintCert = function(nom,niveau,score,pct,date,code) {
      const col={A1:'#27AE60',A2:'#2980B9',B1:'#D4A017',B2:'#E67E22',C1:'#E74C3C',C2:'#8E44AD'}[niveau]||'#2980B9'
