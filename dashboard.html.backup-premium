    window._prmToggleUser = async function(id, currentlyActive) {
      // 1. Mettre à jour le statut dans la table utilisateurs
      const {error} = await sb.from('utilisateurs').update({actif: !currentlyActive}).eq('id',id)
      if (error) { toast('Erreur : '+error.message,'err'); return }

      // 2. Si on désactive : forcer la déconnexion immédiate via l'Admin API Supabase
      //    (invalide tous les refresh tokens actifs de cet utilisateur)
      if (currentlyActive) {
        await fetch(`${SUPABASE_URL}/auth/v1/admin/users/${id}`, {
          method: 'PUT',
          headers: {
            'Content-Type':  'application/json',
            'apikey':        SUPABASE_SERVICE_ROLE,
            'Authorization': 'Bearer ' + SUPABASE_SERVICE_ROLE,
          },
          body: JSON.stringify({ ban_duration: 'none', user_metadata: { suspended: true } })
        }).catch(()=>{})
        // Révoquer toutes les sessions actives
        await fetch(`${SUPABASE_URL}/auth/v1/admin/users/${id}/logout`, {
          method: 'POST',
          headers: {
            'apikey':        SUPABASE_SERVICE_ROLE,
            'Authorization': 'Bearer ' + SUPABASE_SERVICE_ROLE,
          }
        }).catch(()=>{})
        toast('🚫 Utilisateur désactivé — session terminée immédiatement')
      } else {
        // Réactiver : retirer le flag suspended
        await fetch(`${SUPABASE_URL}/auth/v1/admin/users/${id}`, {
          method: 'PUT',
          headers: {
            'Content-Type':  'application/json',
            'apikey':        SUPABASE_SERVICE_ROLE,
            'Authorization': 'Bearer ' + SUPABASE_SERVICE_ROLE,
          },
          body: JSON.stringify({ user_metadata: { suspended: false } })
        }).catch(()=>{})
        toast('✅ Utilisateur réactivé')
      }
      prmSwitch('users')
    }

