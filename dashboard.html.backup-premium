    window._savePermMatrix = function() {
      const perms = {}
      document.querySelectorAll('#permMatrix input[type="checkbox"]').forEach(cb => {
        const r = cb.dataset.role
        const m = cb.dataset.mod
        if (!perms[r]) perms[r] = []
        if (cb.checked) perms[r].push(m)
      })
      localStorage.setItem('agtm_permissions', JSON.stringify(perms))
      toast('✅ Permissions enregistrées — actives à la prochaine connexion')
      // Reconstruire la sidebar immédiatement pour le rôle courant
      buildSidebar()
    }

