    window._saveConge = async function() {
      const sel=document.getElementById('cgEmp')
      const personnel_id=Number(sel.value)
      const opt=sel.selectedOptions[0]
      const nom_employe=opt?.dataset.nom||''
      const poste=opt?.dataset.poste||''
      const type_conge=document.getElementById('cgType').value
      const date_debut=document.getElementById('cgDeb').value
      const date_fin=document.getElementById('cgFin').value
      const motif=document.getElementById('cgMotif').value.trim()||null
      if(!personnel_id){toast('Sélectionnez un employé','err');return}
      if(!date_debut||!date_fin){toast('Dates obligatoires','err');return}
      if(date_fin<date_debut){toast('La date de fin doit être ≥ date de début','err');return}
      const nb_jours=Math.round((new Date(date_fin)-new Date(date_debut))/(1000*60*60*24))+1
      const {error}=await sb.from('conges').insert({personnel_id,nom_employe,poste,type_conge,date_debut,date_fin,nb_jours,motif})
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('✅ Congé enregistré — '+nb_jours+' jour(s)')
      renderRH()
    }

    window._rhCongeStatut = async function(id, statut) {
      const {error}=await sb.from('conges').update({statut}).eq('id',id)
      if(error){toast('Erreur : '+error.message,'err');return}
      toast(statut==='Approuvé'?'✅ Congé approuvé':'❌ Congé refusé')
      renderRH()
    }

    window._delConge = async function(id) {
      if(!confirm('Supprimer cette demande de congé ?')) return
      const {error}=await sb.from('conges').delete().eq('id',id)
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('Congé supprimé')
      renderRH()
    }

