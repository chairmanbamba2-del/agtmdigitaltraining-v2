    window._iTelFmt = function(el) {
      let v = el.value.replace(/[^\d+]/g,'')
      if (v.startsWith('+225') && v.length > 4) {
        const digits = v.substring(4).replace(/\D/g,'')
        v = '+225 ' + digits.replace(/(\d{2})(?=\d)/g,'$1 ').trim()
      }
      el.value = v
    }

    window._iUpdate = function() {
      const nom   = (document.getElementById('iNom')?.value||'').trim()
      const pren  = (document.getElementById('iPren')?.value||'').trim()
      const tel   = (document.getElementById('iTel')?.value||'').trim()
      const niv   = document.getElementById('iNiv')?.value||''
      const form  = document.getElementById('iForm')?.value||''
      const duree = document.getElementById('iDuree')?.value||''
      const mode  = document.getElementById('iMode')?.value||''
      const dispo = (document.getElementById('iDispo')?.value||'').trim()
      const email = (document.getElementById('iEmail')?.value||'').trim()
      const pai   = document.getElementById('iPai')?.value||''
      const src   = document.getElementById('iSource')?.value||''
      const obj   = (document.getElementById('iObj')?.value||'').trim()

      // Indicateurs OK
      const setOk = (id, ok) => {
        const el = document.getElementById(id)
        if (el) { el.style.display = ok ? 'block' : 'none'; el.textContent = ok ? '✅' : '' }
      }
      setOk('iNomOk',  nom.length >= 2)
      setOk('iPrenOk', pren.length >= 2)
      setOk('iTelOk',  tel.length >= 8)

      // Barre de progression
      const required = [nom, pren, tel, niv, form]
      const filled = required.filter(v => v.length > 0).length
      const pct = Math.round(filled / required.length * 100)
      const bar = document.getElementById('iProgress')
      const txt = document.getElementById('iProgressTxt')
      if (bar) bar.style.width = pct + '%'
      if (txt) txt.textContent = filled + ' / ' + required.length + ' champs obligatoires remplis' + (pct===100?' — ✅ Prêt à soumettre !':'')

      // Récapitulatif dynamique
      const lines = []
      if (nom||pren)  lines.push(`<div>👤 <strong style="color:#E2D8C0">${pren} ${nom}</strong></div>`)
      if (tel)        lines.push(`<div>📞 <strong style="color:#E2D8C0">${tel}</strong></div>`)
      if (email)      lines.push(`<div>📧 <span style="color:#4A90D9">${email}</span></div>`)
      if (niv)        lines.push(`<div>🎯 Niveau : <strong style="color:#C8960C">${niv}</strong></div>`)
      if (form)       lines.push(`<div>📚 Formation : <strong style="color:#E8B84B">${form}</strong></div>`)
      if (duree)      lines.push(`<div>⏱️ Durée : ${duree}</div>`)
      if (mode)       lines.push(`<div>🏫 Mode : ${mode}</div>`)
