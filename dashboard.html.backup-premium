    }

    window._apStartPlacement = function() {
      const pren = document.getElementById('plPren')?.value.trim()
      const nom  = document.getElementById('plNomE')?.value.trim()
      if (!pren||!nom) { toast('Prénom et nom requis','err'); return }
      const email = document.getElementById('plMailP')?.value.trim()||null
      const tel   = document.getElementById('plTelP')?.value.trim()||null
      const ecole = document.getElementById('plEcole')?.value.trim()||null
      window._apPS = {
        nom:`${pren} ${nom}`, email, tel, ecole,
        questions: _PLACEMENT_QS,
        current:0, score:0, answered:false, errors:[],
        timeLeft: 15*60,
      }
      _apPlacementRender()
      if (window._apPTimer) clearInterval(window._apPTimer)
      window._apPTimer = setInterval(()=>{
        const ps=window._apPS; if(!ps) return
        ps.timeLeft--
        const el=document.getElementById('_apPTimer')
        if(el){
          const m=Math.floor(ps.timeLeft/60),s=ps.timeLeft%60
          el.textContent=`⏱ ${m}:${s.toString().padStart(2,'0')}`
          if(ps.timeLeft<=120) el.style.color='#E04A4A'
          if(ps.timeLeft<=60)  el.style.fontWeight='900'
        }
        if(ps.timeLeft<=0){ clearInterval(window._apPTimer); _apPlacementResults() }
      },1000)
    }

    function _apPlacementRender() {
      const ps = window._apPS
      if(!ps||ps.current>=ps.questions.length){ _apPlacementResults(); return }
      const q = ps.questions[ps.current]
      const m=Math.floor(ps.timeLeft/60),s=ps.timeLeft%60
