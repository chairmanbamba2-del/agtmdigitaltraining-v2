      #langToggleBtn { display: none !important; }
    }

    /* ▸ Téléphone (≤ 600px) */
    @media (max-width: 600px) {
      html { font-size: 15px; }
      #searchBarWrap { display: none !important; }
      .top-bar { height: 64px !important; }
      #content { padding: 10px !important; padding-bottom: calc(10px + var(--sab)) !important; }
      /* Topbar : juste hamburger + titre + notifications */
      #langToggleBtn { display: none !important; }
      /* Grilles KPI 4→2 colonnes dans le contenu généré */
      .resp-grid-4 { grid-template-columns: repeat(2, 1fr) !important; }
      .resp-grid-3 { grid-template-columns: repeat(2, 1fr) !important; }
      /* Modals pleins-écrans */
      #rdvModal > div { border-radius: 12px; margin: 0; max-height: 95vh; }
      /* IA chat : masquer sidebar historique, plein écran */
      #aiSidebar { display: none !important; }
    }

    /* ▸ Très petit téléphone (≤ 420px) */
    @media (max-width: 420px) {
      html { font-size: 14px; }
      #content { padding: 8px !important; padding-bottom: calc(8px + var(--sab)) !important; }
      /* Sidebar : pleine largeur */
      #mainSidebar { width: 100vw !important; }
      /* Topbar : hauteur réduite */
      #pageTitle { font-size: .82rem !important; }
    }

    /* ── Safe area — topbar + sidebar ───────────────────────────── */
    /* Barre de navigation en haut : compense le notch */
    #app > div > div:last-child > div:first-child {
      padding-top: max(0px, var(--sat));
    }
    /* Sidebar : compense barre d'accueil iPhone en bas */
    #mainSidebar {
      padding-bottom: var(--sab);
    }
    /* Zone de contenu principal : marge droite iPhone landscape */
    #content {
      padding-right: max(22px, calc(22px + var(--sar)));
    }
    
    /* ── Mobile touch improvements ───────────────────────────────── */
    @media (max-width: 600px) {
      button, [role="button"] {
        min-height: 44px;
        min-width: 44px;
      }
      #searchBarWrap {
        display: flex !important;
      }
      .nav-btn {
        padding: 12px 16px !important;
      }
    }

    /* ── Contrôle de hauteur pour les sections dynamiques (quiz, vidéos) ── */
    .sec-body > div:not(.video-container) {
      max-height: calc(100vh - 200px);
      overflow-y: auto;
      overflow-x: hidden;
    }
    
    /* Conteneurs de vidéo - garder une hauteur raisonnable */
    .video-container, iframe:not(.english-corner-iframe), video {
      max-height: 400px;
      width: 100%;
      border-radius: 12px;
    }
    
    /* Sections de quiz - scroll interne */
    .quiz-container, .quiz-section, [id*="quiz"] {
      max-height: calc(100vh - 250px);
      overflow-y: auto;
      overflow-x: hidden;
    }
    
    /* Assurer que le contenu principal ne dépasse pas */
    #content > div {
      max-height: calc(100vh - 180px);
      overflow-y: auto;
      overflow-x: hidden;
    }
    
    /* Garder la navbar et topbar visibles */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: linear-gradient(180deg, #09111E 0%, #160E04 95%);
      padding-top: var(--sat);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(200,150,12,0.2);
    }
    
    /* Assurer que le contenu commence après la topbar */
