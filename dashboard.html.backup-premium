        sb.from('echeances').select('*').order('date_echeance'),
      ])
      window._echs=echs||[]
      const retards=(echs||[]).filter(e=>e.statut==='En attente'&&e.date_echeance<today)
      if(retards.length){
        await sb.from('echeances').update({statut:'En retard'}).in('id',retards.map(e=>e.id))
        retards.forEach(e=>e.statut='En retard')
