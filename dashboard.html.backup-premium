                </select>
              </div>

              <div style="margin-bottom:8px">
                <div style="font-size:.7rem;color:#8AAAC0;margin-bottom:4px">Destinataire</div>
                <input id="waToInput" placeholder="Numéro (+225…) — ou cliquez ↩ Répondre ci-dessous"
                  style="width:100%;padding:8px 12px;border-radius:8px;background:#0D1B2A;border:1px solid #2A3F58;color:#fff;font-size:.8rem;outline:none;box-sizing:border-box"/>
              </div>

              <!-- Champs template -->
              <div id="waTemplateFields">
                <div style="margin-bottom:8px">
                  <div style="font-size:.7rem;color:#8AAAC0;margin-bottom:4px">Nom de l'étudiant</div>
                  <input id="waVar1" placeholder="ex: Jean Koné"
                    style="width:100%;padding:8px 12px;border-radius:8px;background:#0D1B2A;border:1px solid #2A3F58;color:#fff;font-size:.8rem;outline:none;box-sizing:border-box"/>
