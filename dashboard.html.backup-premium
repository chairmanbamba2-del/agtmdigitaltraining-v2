        // 3. Messages envoyés depuis `messages`
        const qEnv = sb.from('messages').select('*')
          .eq('expediteur_user_id', uid).order('created_at', {ascending:false})

        // 4. Pour le formateur : liste de ses étudiants (pour le compose)
        let mesEtudiants = []
        if (isFormateur) {
          const { data: myClasses } = await sb.from('classes').select('id').eq('formateur_id', uid)
          if (myClasses?.length) {
            const classIds = myClasses.map(c => c.id)
            const { data: insc } = await sb.from('inscriptions_classes').select('etudiant_id').in('classe_id', classIds)
            if (insc?.length) {
              const eIds = [...new Set(insc.map(i => i.etudiant_id))]
              const { data: etuds } = await sb.from('etudiants').select('id,nom,prenom,email').in('id', eIds)
              mesEtudiants = etuds || []
            }
          }
        } else {
          // Admin : tous les utilisateurs pour le compose
          const { data: allU } = await sb.from('utilisateurs').select('id,nom,prenom,email,role').order('nom')
          mesEtudiants = allU || []
        }

        // 5. Liste des formateurs (pour compose admin)
        let lesFormateurs = []
        if (!isFormateur) {
          const { data: fmts } = await sb.from('utilisateurs').select('id,nom,prenom,email').eq('role','formateur')
          lesFormateurs = fmts || []
        }

        const [r1, r2, r3] = await Promise.all([qRecus, qOldRecus, qEnv])
        const recusNew  = r1.data || []
        const envoyes   = r3.data || []
        // Pour le formateur : filtrer les anciens messages reçus par ses propres étudiants
        const _mesEtudIds = mesEtudiants.map(e => e.id)
        const recusOld = isFormateur && _mesEtudIds.length
          ? (r2.data || []).filter(m => _mesEtudIds.includes(m.etudiant_id))
          : (r2.data || [])

        // Marquer comme lus (table messages)
        const nonLusNew = recusNew.filter(m => !m.lu)
        if (nonLusNew.length) {
          sb.from('messages').update({lu:true})
            .eq('destinataire_user_id', uid).eq('lu', false).then(()=>{})
        }
        const totalNonLus = nonLusNew.length + recusOld.filter(m => !m.lu).length

        // ─── HTML des onglets ─────────────────────────────────────
        const tabStyle = (t) => `padding:8px 18px;border-radius:8px 8px 0 0;border:1px solid;cursor:pointer;font-weight:700;font-size:.78rem;transition:all .15s;${tab===t?'background:#C8960C;border-color:#C8960C;color:#0D1B2A':'background:#0D1B2A;border-color:#2A3F58;color:#90A4AE'}`

        // ─── Onglet WhatsApp entrant (admin + secrétaire) ────────
        let waHTML = ''
        if (tab === 'whatsapp' && showWaInbox) {
          const { data: waMsgs, error: waErr } = await sb.from('messages_whatsapp')
            .select('*').order('created_at', { ascending: false }).limit(50)
          const msgs = waMsgs || []
          const nonLusWa = msgs.filter(m => !m.lu)
          // Marquer comme lus
          if (nonLusWa.length) sb.from('messages_whatsapp').update({lu:true}).eq('lu',false).then(()=>{})

          const waCards = msgs.map(m => {
            const dateStr = _msgDateStr(m.created_at)
            const isNew   = !m.lu
            const sender  = m.from_name ? `${m.from_name} (${m.from_number})` : m.from_number
            return `<div style="background:${isNew?'#1A2D1A':'#152233'};border:1px solid ${isNew?'#25D366':'#1E3050'};border-radius:12px;padding:14px 16px;margin-bottom:8px">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:8px">
                <div style="flex:1">
                  <div style="display:flex;align-items:center;gap:8px">
                    <span style="font-size:1.1rem">📲</span>
                    <div style="font-weight:700;color:${isNew?'#25D366':'#90A4AE'};font-size:.85rem">${sender}</div>
                    ${isNew ? `<span style="padding:2px 8px;background:#25D366;border-radius:10px;font-size:.6rem;color:#0D1B2A;font-weight:700">Nouveau</span>` : ''}
                  </div>
                  <div style="font-size:.68rem;color:#5A7090;margin-top:3px">${dateStr}</div>
                </div>
              </div>
              <div style="font-size:.82rem;color:#E2D8C0;line-height:1.55;white-space:pre-wrap">${m.body||'<i style="color:#5A7090">— média —</i>'}</div>
              ${m.media_url ? `<div style="margin-top:8px"><a href="${m.media_url}" target="_blank" style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:#0D1B2A;border:1px solid #25D366;border-radius:6px;color:#25D366;font-size:.7rem;font-weight:700;text-decoration:none">📎 Voir le média</a></div>` : ''}
              <div style="margin-top:10px;text-align:right">
                <button data-phone="${m.from_number}" data-name="${(m.from_name||'').replace(/"/g,'&quot;')}"
