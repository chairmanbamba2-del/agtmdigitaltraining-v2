        if(Number(p.present)===1)statsMap[p.etudiant_id].presents++
      })
      const studentStats=(etuds||[]).map(e=>{
        const s=statsMap[e.id]||{total:0,presents:0}
        return {...e,total:s.total,presents:s.presents,absents:s.total-s.presents,
          taux:s.total?Math.round(s.presents/s.total*100):null}
      }).filter(e=>e.total>0).sort((a,b)=>(a.taux||0)-(b.taux||0))

      // ── Séances avec info classe ──────────────────────────────
