    async function renderRechercheDirection() {
      const isDir = ['directeur_pedagogique','sous_directeur_pedagogique','admin'].includes(profile?.role)
      if (!isDir) { setContent('<div style="padding:40px;text-align:center;color:#E04A4A">⛔ Accès réservé.</div>'); return }

      const today = new Date().toISOString().substring(0,10)
      const monthAgo = new Date(Date.now()-30*86400000).toISOString().substring(0,10)

