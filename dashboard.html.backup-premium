    window._saveFichePaie = async function() {
      const sel = document.getElementById('fpEmp')
      const personnel_id = Number(sel.value)
      const opt = sel.selectedOptions[0]
      const nom_employe = opt?.dataset.nom||''
      const poste = opt?.dataset.poste||''
      const moisVal = document.getElementById('fpMois').value
      const sal = parseFloat(document.getElementById('fpSal').value)||0
      const taux_seance = parseFloat(document.getElementById('fpTauxS').value)||0
      const nb_seances = parseInt(document.getElementById('fpNbSeances').value)||0
      const salaire_seances = taux_seance * nb_seances
      const hs = parseFloat(document.getElementById('fpHS').value)||0
      const th = parseFloat(document.getElementById('fpTH').value)||0
      const primes = parseFloat(document.getElementById('fpPr').value)||0
      const avantages = parseFloat(document.getElementById('fpAv').value)||0
      const cotisations = parseFloat(document.getElementById('fpCot').value)||0
      const retenues = parseFloat(document.getElementById('fpRet').value)||0
      const avances = parseFloat(document.getElementById('fpAdc').value)||0
      const notes = document.getElementById('fpNotes').value.trim()||null
      if (!personnel_id) { toast('Sélectionnez un employé','err'); return }
      if (!moisVal) { toast('Sélectionnez un mois','err'); return }
      const net = sal + salaire_seances + (hs*th) + primes + avantages - cotisations - retenues - avances
      const d = new Date(moisVal)
      const mois_label = d.toLocaleDateString('fr-FR',{month:'long',year:'numeric'}).replace(/^./,c=>c.toUpperCase())
      const {data:ficheCreee, error} = await sb.from('fiches_paie').insert({
        personnel_id, nom_employe, poste, periode:moisVal, mois_label,
        salaire_base:sal, nb_seances, taux_seance, salaire_seances,
        heures_sup:hs, taux_h_sup:th, primes, avantages,
        cotisations, retenues, avances, net_a_payer:net, notes,
      }).select().single()
      if (error) { toast('Erreur : '+error.message,'err'); return }

      // ── Synchronisation Finance & Comptabilité ──────────────────
      // Créer automatiquement la charge salariale dans les dépenses (statut : en attente)
      if (ficheCreee) {
        const ref = `FP-${ficheCreee.id}`
        const {data:existing} = await sb.from('depenses').select('id').eq('justificatif',ref).maybeSingle()
        if (!existing) {
          await sb.from('depenses').insert({
            categorie:      'Salaires',
            description:    `Traitement salaire — ${nom_employe} — ${mois_label} [En attente]`,
            montant:        net,
            date_depense:   moisVal,
            mode_paiement:  'Virement bancaire',
            justificatif:   ref,
          })
        }
      }
      // ────────────────────────────────────────────────────────────

      toast('✅ Fiche de paie générée — Net : '+fmtMoney(net)+' · Synchronisée avec Finance')
      renderRH()
    }

    window._rhPayStatut = async function(id, statut, sel) {
      if(!statut) return
      const upd={statut}
      if(statut==='Payé') upd.date_paiement=new Date().toISOString().substring(0,10)
      const {error}=await sb.from('fiches_paie').update(upd).eq('id',id)
      if(sel) sel.value=''
      if(error){toast('Erreur : '+error.message,'err');return}
      // Quand une fiche de paie est marquée "Payé", synchroniser la dépense correspondante
      if (statut==='Payé') {
        const {data:fp}=await sb.from('fiches_paie').select('*').eq('id',id).single()
        if (fp) {
          const ref = `FP-${id}`
          const dateP = fp.date_paiement || fp.periode || new Date().toISOString().substring(0,10)
          const {data:existing}=await sb.from('depenses').select('id').eq('justificatif',ref).maybeSingle()
          if (existing) {
            // Mettre à jour la dépense existante : enlever "[En attente]", mettre la vraie date
            await sb.from('depenses').update({
              description: `Traitement salaire — ${fp.nom_employe||''} — ${fp.mois_label||''}`,
              date_depense: dateP,
            }).eq('justificatif', ref)
          } else {
            // Créer si elle n'existait pas encore (rétrocompatibilité)
            await sb.from('depenses').insert({
              categorie:     'Salaires',
              description:   `Traitement salaire — ${fp.nom_employe||''} — ${fp.mois_label||''}`,
              montant:       Number(fp.net_a_payer)||0,
              date_depense:  dateP,
              mode_paiement: 'Virement bancaire',
              justificatif:  ref,
            })
          }
        }
      }
      toast('Statut mis à jour')
      renderRH()
    }

