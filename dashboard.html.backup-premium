      const getRoleConf = r => rolesAll.find(x=>x.id===r) || {id:r,label:r,icon:'❓',col:'#90A4AE',bg:'#1A2A3A'}

      // KPIs
      const nbTotal = all.length
      const nbActifs = all.filter(u=>u.actif!==false).length
      const nbSusp   = all.filter(u=>u.actif===false).length
      const byRole   = {}
      all.forEach(u=>{ byRole[u.role]=(byRole[u.role]||0)+1 })

      // Filtre
      const fRole = window._usrFilter.role
      const fActif = window._usrFilter.actif
      let filtered = all
      if (fRole)  filtered = filtered.filter(u=>u.role===fRole)
      if (fActif==='actif')   filtered = filtered.filter(u=>u.actif!==false)
      if (fActif==='suspendu') filtered = filtered.filter(u=>u.actif===false)

      // Matrice des permissions
      const allModules = Object.values(NAV).flat().filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i)
      const permMatrix = rolesAll.map(r=>{
        const mods = NAV[r.id] ? NAV[r.id].map(m=>m.id) : []
        return {role:r, mods}
