        planning:renderPlanning, classes:()=>profile?.role==='formateur'?renderClassesFormateur():renderClasses(),
        seances:renderSeances, presences:renderPresences, rapports:renderRapports,
        progression:renderProgression, tests:renderTests,
        investor_dashboard:renderInvestorDashboard,
