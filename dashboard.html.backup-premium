    window.saveQuizQuestion = async function() {
      const question=document.getElementById('qqQ').value.trim()
      const reponse_correcte=document.getElementById('qqR').value.trim()
      if(!question||!reponse_correcte){toast('Question et réponse correcte requises','err');return}
      const optsRaw=document.getElementById('qqO').value.trim()
      const options=optsRaw?optsRaw.split('|').map(s=>s.trim()).filter(Boolean):null
      const {error}=await sb.from('quiz_questions').insert({
        question,reponse_correcte,
        options:options?JSON.stringify(options):null,
        explication:document.getElementById('qqE').value.trim()||null,
        pilier:document.getElementById('qqP').value,
        niveau:document.getElementById('qqN').value,
        created_by:currentUser.id,
      })
      if(error){toast('Erreur : '+error.message,'err');return}
      toast('✅ Question ajoutée à la banque')
