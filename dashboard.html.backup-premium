      {q:"My name ___ Kofi.",opts:["A) am","B) is","C) are","D) be"],rep:"B",niv:"A1",dom:"Grammaire"},
      {q:"The opposite of 'big' is ___.",opts:["A) tall","B) heavy","C) small","D) fast"],rep:"C",niv:"A1",dom:"Vocabulaire"},
      {q:"Read: 'Hello! My name is Ama. I am 16 and I live in Abidjan.' — How old is Ama?",opts:["A) 15","B) 16","C) 17","D) 18"],rep:"B",niv:"A1",dom:"Compréhension"},
      {q:"She ___ coffee every morning.",opts:["A) drink","B) drinks","C) drinking","D) drinked"],rep:"B",niv:"A1",dom:"Grammaire"},
      {q:"They ___ in Paris last summer.",opts:["A) are","B) was","C) were","D) be"],rep:"C",niv:"A2",dom:"Grammaire"},
      {q:"Which word means 'to purchase'?",opts:["A) sell","B) buy","C) lend","D) borrow"],rep:"B",niv:"A2",dom:"Vocabulaire"},
      {q:"Read: 'It was raining heavily, so the match was cancelled.' — Why was the match cancelled?",opts:["A) Nobody came","B) Because of the rain","C) The players were tired","D) It was too late"],rep:"B",niv:"A2",dom:"Compréhension"},
      {q:"She ___ an email right now.",opts:["A) is writing","B) writes","C) wrote","D) has wrote"],rep:"A",niv:"A2",dom:"Grammaire"},
      {q:"English ___ all over the world.",opts:["A) speaks","B) is spoken","C) was spoke","D) has spoken"],rep:"B",niv:"B1",dom:"Grammaire"},
      {q:"'To tackle a problem' means:",opts:["A) To ignore it","B) To create it","C) To address and deal with it","D) To postpone it"],rep:"C",niv:"B1",dom:"Vocabulaire"},
      {q:"Read: 'Despite the heavy rain, the farmers continued working.' — What does 'despite' show?",opts:["A) A reason","B) A consequence","C) A contrast","D) A time period"],rep:"C",niv:"B1",dom:"Compréhension"},
      {q:"She said she ___ tired. (Reported speech)",opts:["A) is","B) was","C) were","D) has been"],rep:"B",niv:"B1",dom:"Grammaire"},
      {q:"My wallet ___. I can't find it anywhere.",opts:["A) is stolen","B) was stolen","C) has been stolen","D) stole"],rep:"C",niv:"B1",dom:"Grammaire"},
      {q:"Read: 'The company launched a product targeting young professionals in urban areas.' — Who is the target?",opts:["A) Elderly people","B) Children","C) Young professionals in cities","D) Rural farmers"],rep:"C",niv:"B1",dom:"Compréhension"},
      {q:"If it rains tomorrow, we ___ cancel the event.",opts:["A) would","B) will","C) shall have","D) might have"],rep:"B",niv:"B1",dom:"Grammaire"},
      {q:"Hardly ___ when the alarm went off.",opts:["A) I had sat down","B) had I sat down","C) I sat down","D) sat I down"],rep:"B",niv:"B2",dom:"Grammaire"},
      {q:"'Outsourcing' means:",opts:["A) Importing goods","B) Moving production to another company","C) Training employees internally","D) Opening a new branch"],rep:"B",niv:"B2",dom:"Vocabulaire"},
      {q:"She suggested that he ___ a lawyer. (Formal subjunctive)",opts:["A) consult","B) consults","C) consulting","D) consulted"],rep:"A",niv:"B2",dom:"Grammaire"},
      {q:"Read: 'The austerity measures, while necessary for fiscal stability, have drawn significant public criticism.' — What is the public's reaction?",opts:["A) They support them","B) They are indifferent","C) They criticise them","D) They celebrate them"],rep:"C",niv:"B2",dom:"Compréhension"},
      {q:"If she had taken that job offer, she ___ in Paris now.",opts:["A) would have been","B) would be","C) will be","D) was"],rep:"B",niv:"B2",dom:"Grammaire"},
    ]

    // Score → Niveau CECRL
    function _placementLevel(score) {
      if (score <= 4)  return 'A1'
      if (score <= 8)  return 'A2'
      if (score <= 12) return 'B1'
      if (score <= 16) return 'B2'
      if (score <= 18) return 'C1'
      return 'C2'
    }

    // Trouve la catégorie d'un module (retourne la clé de _CATS ou le nom de catégorie BDD)
    function _getModCat(id) {
      // Chercher dans les modules BDD d'abord
      if (Array.isArray(window._AP_DB_MODS)) {
        const dbm = window._AP_DB_MODS.find(m => m.id === id)
        if (dbm?.categorie) return dbm.categorie
      }
      for (const [k, v] of Object.entries(_CATS)) {
        if ((v.mods||[]).some(m=>m.id===id)) return k
      }
      return 'grammaire'
    }

    // ── CHARGEMENT MODULES DEPUIS LA BASE DE DONNÉES ──────────────
    window._AP_DB_MODS = undefined // undefined = pas encore tenté ; null = échec ; [] = vide ; [...] = chargé

    // ── Convertit les noms d'icônes Heroicon/Lucide en emoji ─────────
    function _iconEmoji(code) {
      if (!code) return '📘'
      if ([...code].some(c => c.codePointAt(0) > 127)) return code
      const MAP = {
        'spell-check':'✏️','book':'📖','headphones':'🎧','mic':'🎤','mic-2':'🎙️',
        'mail':'📧','users':'👥','layers':'📑','file-text':'📄','file':'📄',
        'edit':'✍️','edit-2':'✍️','edit-3':'✍️','pencil':'✏️','align-left':'📝',
        'book-open':'📖','check-circle':'✅','check':'✅','check-square':'☑️',
        'bookmark':'🔖','repeat':'🔄','briefcase':'💼','award':'🏆',
        'globe':'🌐','globe-2':'🌍','graduation-cap':'🎓','star':'⭐',
        'feather':'✒️','type':'🔤','message-square':'💬','headset':'🎧',
        'volume-2':'🔊','play':'▶️','book-marked':'📖','hash':'📌',
        'list':'📋','layout':'🗂️','cpu':'💻','database':'🗄️',
      }
      return MAP[code] || '📘'
    }

    function _mapDbMod(m) {
      return {
        id:             m.code,
        titre:          m.title,
        niveau:         m.level?.code         || '',
        duree:          m.duration_minutes     || 30,
        categorie:      m.category?.name       || '',
        categorie_code: m.category?.code       || '',
        categorie_icon: _iconEmoji(m.category?.icon),
        objectifs:      m.objectives           || [],
        contenu:        m.description ? [{type:'intro', texte: m.description}] : [],
        quiz:           null,
        video_url:      m.video_url            || null,
        _isDbMod:       true,
        _dbId:          m.id,
        _hasQuiz:       m.has_quiz             || false,
      }
    }

    // ── TITRE : première lettre en majuscule, pas de préfixe redondant ──
    function _fmtTitle(titre) {
      if (!titre) return titre
      return titre.charAt(0).toUpperCase() + titre.slice(1)
    }

    function _getActiveMods() {
      return (Array.isArray(window._AP_DB_MODS) && window._AP_DB_MODS.length)
        ? window._AP_DB_MODS
        : _ALL_MOD
    }

    function _getModuleOptions() {
      const mods = _getActiveMods()
      if (!mods.length) return '<option value="">— Aucun module disponible —</option>'
      const options = mods.map(m => `<option value="${m.titre}">${m.titre}${m.niveau ? ' — Niv. ' + m.niveau : ''}</option>`)
      return '<option value="">— Sélectionner un module —</option>' + options.join('')
    }

    async function _apLoadDbMods() {
      try {
        const r = await fetch('/api/pedagogy/modules?limit=200&page=0')
        const data = await r.json()
        const mods = (data.modules || []).map(_mapDbMod)
        window._AP_DB_MODS = mods.length ? mods : null
      } catch(e) {
        window._AP_DB_MODS = null
      }
    }

    // ── RENDER PRINCIPAL ───────────────────────────────────────────
    function renderActivitesPedago() {
      window._actTab    = window._actTab    || 'catalogue'
      window._actCat    = window._actCat    || 'all'
      window._actNiv    = window._actNiv    || 'all'
      window._actSearch = window._actSearch || ''
      if (window._AP_DB_MODS === undefined) {
        // Première visite : afficher un squelette et charger depuis la BDD
        setContent(`<div style="text-align:center;padding:60px 20px">
          <div style="font-size:2.5rem;margin-bottom:16px">📚</div>
          <div style="color:#8AAAC0;font-size:.9rem;margin-bottom:8px">Chargement du catalogue de modules…</div>
          <div style="width:200px;height:4px;background:#1E3050;border-radius:2px;margin:0 auto;overflow:hidden">
            <div style="height:4px;background:#C8960C;border-radius:2px;width:60%;animation:none;opacity:.7"></div>
          </div>
        </div>`)
        _apLoadDbMods().then(() => _apRender())
      } else {
        _apRender()
      }
    }

    function _apRender() {
      const t = window._actTab
      const tabs = [
        {id:'catalogue',label:'📚 Catalogue'},
        {id:'tests',label:'🎯 Tests & Placement'},
        {id:'evaluations',label:'📝 Évaluations'},
      ]
      const hero = `<div style="background:linear-gradient(135deg,#0E2040 0%,#1A2010 50%,#201408 100%);border:1px solid rgba(200,150,12,0.25);border-radius:14px;padding:18px 24px;margin-bottom:16px;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <div style="font-size:2.5rem">📚</div>
        <div style="flex:1;min-width:200px">
          <div style="font-size:1rem;font-weight:900;color:#E8B84B;margin-bottom:4px">Espace Pédagogique AGTM</div>
          <div style="font-size:.8rem;color:#8AAAC0;line-height:1.5">${_getActiveMods().length} modules · ${window._AP_DB_MODS?.length ? 'Quiz intégrés' : _ALL_MOD.reduce((a,m)=>(a+(m.quiz||[]).length),0)+' questions quiz'} · Tests de niveau A1→C2 · Évaluations avec correction automatique</div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          ${['A1','A2','B1','B2','C1','C2'].map(n=>`<span style="padding:2px 9px;border-radius:12px;font-size:.68rem;font-weight:800;background:${_NBL[n]}20;color:${_NBL[n]};border:1px solid ${_NBL[n]}40">${n} · ${_getActiveMods().filter(m=>m.niveau===n).length}</span>`).join('')}
        </div>
      </div>`
      const tabBar = `<div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid rgba(200,150,12,0.2);padding-bottom:0">
        ${tabs.map(tab=>`<button onclick="window._apSetTab('${tab.id}')"
          style="padding:10px 20px;border:none;cursor:pointer;border-radius:8px 8px 0 0;font-size:.84rem;font-weight:700;
          background:${t===tab.id?'rgba(200,150,12,0.2)':'transparent'};
          color:${t===tab.id?'#E8B84B':'#90A4AE'};
          border-bottom:${t===tab.id?'2px solid #C8960C':'2px solid transparent'}">${tab.label}</button>`).join('')}
      </div>`
      if (t === 'catalogue') { setContent(_apCatalogue(tabs, t)); return }
      else if (t === 'tests') { setContent(hero + tabBar + _apTestsView()); if(['admin','formateur'].includes(profile?.role)) _apLoadPlacementResults() }
      else _apEvalView(hero + tabBar)
    }

    window._apSetTab    = function(t) { window._actTab=t; _apRender() }
    window._apSetCat    = function(c) { window._actCat=c; _apRender() }
    window._apSetNiv    = function(n) { window._actNiv=n; _apRender() }
    window._apSetSearch = function(q) { window._actSearch=q; _apRender() }

    // ── CATALOGUE ─────────────────────────────────────────────────
    function _apCatalogue(tabs, activeTab) {
      const t       = activeTab || window._actTab || 'catalogue'
      const cat     = window._actCat  || 'all'
      const niv     = window._actNiv  || 'all'
      const searchQ = (window._actSearch||'').toLowerCase().trim()
      const allMods = _getActiveMods()
      const usingDb = Array.isArray(window._AP_DB_MODS) && window._AP_DB_MODS.length > 0

      // ── Liste de catégories (nav gauche) ──
      const catList = usingDb
        ? [{id:'all', icon:'📚', label:'Tous les modules', count:allMods.length},
           ...[...new Map(allMods.filter(m=>m.categorie).map(m=>[m.categorie,
             {id:m.categorie, icon:m.categorie_icon||'📘', label:m.categorie,
              count:allMods.filter(x=>x.categorie===m.categorie).length}])).values()]]
        : [{id:'all', icon:'📚', label:'Tous les modules', count:allMods.length},
           ...Object.entries(_CATS).map(([k,v])=>({id:k,icon:v.icon,label:v.label,count:(v.mods||[]).length}))]
      if (usingDb) window._AP_CAT_LIST = catList

      // ── Filtrage modules ──
      let mods = (cat==='all') ? allMods
        : usingDb ? allMods.filter(m => m.categorie === cat)
        : (_CATS[cat]?.mods || allMods)
      if (niv !== 'all') mods = mods.filter(m => m.niveau === niv)
      if (searchQ) mods = mods.filter(m =>
        m.titre.toLowerCase().includes(searchQ) ||
        (m.objectifs||[]).some(o => o.toLowerCase().includes(searchQ)) ||
        (m.categorie||'').toLowerCase().includes(searchQ)
      )

      // ── Boutons onglets (Catalogue / Tests / Évaluations) ──
      const tabBtns = (tabs||[]).map(tab => `<button onclick="window._apSetTab('${tab.id}')"
        style="padding:11px 16px;border:none;cursor:pointer;font-size:.8rem;font-weight:700;white-space:nowrap;
        background:transparent;color:${t===tab.id?'#E8B84B':'#607080'};
        border-bottom:2px solid ${t===tab.id?'#C8960C':'transparent'}">${tab.label}</button>`).join('')

      // ── Items nav gauche (catégories) ──
      const navItems = catList.map((c, ci) => {
        const active = cat === c.id
        const fn = usingDb
          ? `window._apSetCat((window._AP_CAT_LIST||[])[${ci}]?.id||'all')`
          : `window._apSetCat('${c.id.replace(/'/g, "\\'")}')`
        return `<button onclick="${fn}" class="sec-nav-item${active?' sec-active':''}">
          <span class="sni-icon">${c.icon}</span>
          <span class="sni-label">${c.label}</span>
          <span style="margin-left:auto;font-size:.58rem;background:${active?'rgba(200,150,12,0.22)':'rgba(255,255,255,0.04)'};color:${active?'#C8960C':'#4A6080'};padding:1px 5px;border-radius:6px;flex-shrink:0">${c.count}</span>
        </button>`
      }).join('')

      // ── Filtre niveau ──
      const nivFilter = `<div style="display:flex;gap:4px;flex-wrap:wrap;align-items:center;margin-bottom:10px">
        <span style="font-size:.62rem;color:#5A7090;font-weight:700;text-transform:uppercase;letter-spacing:.04em;margin-right:2px">Niveau :</span>
        ${['all','A1','A2','B1','B2','C1','C2'].map(n => {
          const active = niv === n
          const col = n==='all'?'#C8960C':(_NBL[n]||'#C8960C')
          return `<button onclick="window._apSetNiv('${n}')"
            style="padding:3px 10px;border-radius:14px;font-size:.7rem;font-weight:800;cursor:pointer;
            background:${active?col:'rgba(255,255,255,0.05)'};
            color:${active?'#0D1B2A':'#8AAAC0'};border:1px solid ${active?col:'transparent'}">
            ${n==='all'?'Tous':n}
          </button>`
        }).join('')}
        <span style="font-size:.67rem;color:#5A7090;margin-left:auto">${mods.length} module(s)${(niv!=='all'||searchQ)?' — filtré':''}</span>
      </div>`

      // ── Barre de recherche ──
      const searchBar = `<div style="position:relative;margin-bottom:14px">
        <span style="position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:.82rem;pointer-events:none">🔍</span>
        <input type="text" placeholder="Rechercher par titre, objectif…" value="${searchQ.replace(/"/g,'&quot;')}"
          oninput="window._apSetSearch(this.value)"
          style="width:100%;padding:7px 30px 7px 30px;border-radius:8px;font-size:.8rem;outline:none;
          background:#0D1B2A;border:1px solid ${searchQ?'#C8960C':'#2A3F58'};color:#E2D8C0;box-sizing:border-box;transition:border .15s"/>
        ${searchQ?`<button onclick="window._apSetSearch('')" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;color:#E04A4A;cursor:pointer;font-size:.85rem;line-height:1">✕</button>`:''}
      </div>`

      // ── Liste verticale de modules (rangée par catégorie) ──
      let gridContent
      if (!mods.length) {
        gridContent = `<div style="text-align:center;padding:40px 16px;color:#5A7090">
          <div style="font-size:2rem;margin-bottom:10px">🔍</div>
          <div style="font-size:.85rem;margin-bottom:12px">${searchQ?`Aucun résultat pour « ${searchQ} »`:'Aucun module pour cette sélection.'}</div>
          <button onclick="window._actCat='all';window._actNiv='all';window._apSetSearch('')"
            style="padding:7px 16px;border-radius:8px;border:1px solid #C8960C;background:transparent;color:#C8960C;cursor:pointer;font-size:.76rem">
            Réinitialiser les filtres</button>
        </div>`
      } else if (cat === 'all' && !searchQ && niv === 'all') {
        // Vue "Tous" — grouper par catégorie, liste verticale dans chaque groupe
        const byCateg = {}
        mods.forEach(m => {
          const key = m.categorie || 'Autres'
          if (!byCateg[key]) byCateg[key] = {icon:m.categorie_icon||'📘', list:[]}
          byCateg[key].list.push(m)
        })
        gridContent = Object.entries(byCateg).map(([catName,{icon,list:cMods}]) => `
          <div style="margin-bottom:18px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;padding:7px 10px;
              background:linear-gradient(90deg,rgba(200,150,12,0.12),transparent);
              border-left:3px solid #C8960C;border-radius:0 6px 6px 0;cursor:pointer"
              onclick="window._apSetCat('${catName.replace(/'/g,"\\'")}')">
              <span>${icon}</span>
              <span style="font-size:.84rem;font-weight:800;color:#E8B84B">${catName}</span>
              <span style="font-size:.64rem;color:#5A7090;background:rgba(255,255,255,0.05);padding:1px 6px;border-radius:5px">${cMods.length}</span>
              <span style="font-size:.6rem;color:#C8960C;margin-left:auto">Filtrer →</span>
            </div>
            <div style="display:flex;flex-direction:column;gap:2px">
              ${cMods.map(m=>_apModListRow(m)).join('')}
            </div>
          </div>`).join('')
      } else {
        // Vue catégorie sélectionnée — liste verticale simple
        gridContent = `<div style="display:flex;flex-direction:column;gap:2px">
          ${mods.map(m=>_apModListRow(m)).join('')}
        </div>`
      }

      // ── Layout plein écran : barre onglets + nav gauche + contenu droit ──
      return `<div class="ap-ped-shell">
  <div class="ap-ped-topbar">
    <div style="display:flex;align-items:center;gap:8px;padding-right:14px;border-right:1px solid rgba(200,150,12,0.15);margin-right:4px;flex-shrink:0">
      <span style="font-size:1.1rem">📚</span>
      <span style="font-size:.78rem;font-weight:900;color:#E8B84B;white-space:nowrap">Espace Pédagogique</span>
    </div>
    ${tabBtns}
    <div style="margin-left:auto;display:flex;align-items:center;gap:5px;padding-left:8px">
      ${['A1','A2','B1','B2','C1','C2'].map(n=>`<span style="padding:1px 5px;border-radius:8px;font-size:.58rem;font-weight:800;background:${_NBL[n]}18;color:${_NBL[n]};border:1px solid ${_NBL[n]}30">${n}</span>`).join('')}
    </div>
  </div>
  <div class="ap-ped-body">
    <nav class="ap-ped-nav">
      ${navItems}
    </nav>
    <div class="ap-ped-content">
      ${nivFilter}
      ${searchBar}
      ${gridContent}
    </div>
  </div>
</div>`
    }

    window._apSetView = function(v) { window._actView=v; _apRender() }

    function _apModCard(m) {
      const col = _NBL[m.niveau] || '#4A90D9'
      const isAdmin = profile?.role === 'admin'
      const isFmt = ['admin','formateur'].includes(profile?.role)
      const objPreview = (m.objectifs||[]).slice(0,2)
      const fmtTitre = _fmtTitle(m.titre, m.categorie_code || m.categorie)
      const quizBadge = m._isDbMod
        ? (m._hasQuiz ? `<span style="font-size:.6rem;color:#C8960C;font-weight:700" title="Quiz disponible">🧩 Quiz</span>` : '')
        : ((m.quiz||[]).length ? `<span style="font-size:.6rem;color:#C8960C">🧩 ${(m.quiz||[]).length}q</span>` : '')
