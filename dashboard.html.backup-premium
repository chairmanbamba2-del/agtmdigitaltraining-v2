        </div>`).join('')}
      </div>` : ''

      const hdr = _apModEvalHeader(window._apCurMod||{niveau:'B1',titre:es.modTitre})
      setContent(hdr + `<div style="max-width:480px;text-align:center;margin:0 auto">
        <div style="font-size:3rem;margin-bottom:10px">${pct>=80?'🏆':pct>=60?'👍':'📚'}</div>
        <div style="font-size:2rem;font-weight:900;color:#4AE090;margin-bottom:4px">${score20} / 20</div>
        <div style="font-size:.95rem;font-weight:600;color:#fff;margin-bottom:4px">${pct}% · ${appr}</div>
        <div style="font-size:.8rem;color:#90A4AE;margin-bottom:16px">${es.score} bonne(s) / ${total} questions — Résultat enregistré ✅</div>
        <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
          <button onclick="window._apES=null;window._apSetModTab('eval')" style="padding:9px 22px;border-radius:8px;font-weight:700;font-size:.82rem;cursor:pointer;background:#4AE090;border:none;color:#0D1B2A">🔄 Recommencer</button>
